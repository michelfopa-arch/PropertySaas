@using PropertySaaS.Web.Localization
@inject CurrentOrganization CurrentOrganization
@inject NavigationManager NavigationManager

<MudNavMenu Class="material-nav-menu">
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.AutoAwesome">@UiText.Get("Nav_Marketing")</MudNavLink>
    @if (!CurrentOrganization.IsAuthenticated)
    {
        <MudNavLink Href="/sign-up" Icon="@Icons.Material.Filled.PersonAdd">@UiText.Get("Nav_SignUp")</MudNavLink>
        <MudNavLink Href="/sign-in" Icon="@Icons.Material.Filled.Login">@UiText.Get("Nav_SignIn")</MudNavLink>
    }
    <MudNavLink Href="/pricing" Icon="@Icons.Material.Filled.Payments">@UiText.Get("Nav_Pricing")</MudNavLink>

    @if (CurrentOrganization.IsAuthenticated && !CurrentOrganization.HasOrganizationAccess)
    {
        <MudNavLink Href="/onboarding" Icon="@Icons.Material.Filled.AutoAwesome">@UiText.Get("Onboarding_Title")</MudNavLink>
    }

    @if (CurrentOrganization.HasOrganizationAccess && CurrentOrganization.CanAccessWorkspace)
    {
        <MudNavLink Href="/workspace" Icon="@Icons.Material.Filled.AutoAwesome">@UiText.Get("Nav_RuntiraWorkspace")</MudNavLink>
        <MudNavLink Href="/profile" Icon="@Icons.Material.Filled.Group">@UiText.Get("Nav_TeamAccess")</MudNavLink>
        <MudDivider Class="my-2" />
    }

    @if (CurrentOrganization.HasOrganizationAccess && !CurrentOrganization.CanAccessWorkspace)
    {
        <MudNavLink Href="/subscriptions/expired" Icon="@Icons.Material.Filled.WarningAmber">@UiText.Get("Nav_RenewAccess")</MudNavLink>
        <MudNavLink Href="/subscriptions" Icon="@Icons.Material.Filled.Subscriptions">@UiText.Get("Nav_Subscriptions")</MudNavLink>
    }

    @if (CurrentOrganization.IsSuperAdmin)
    {
        <MudNavLink Href="/superadmin/select-organization" Icon="@Icons.Material.Filled.Domain">@UiText.Get("Nav_SuperAdminOrganizations")</MudNavLink>
    }

    @if (CurrentOrganization.IsAuthenticated)
    {
        <MudDivider Class="my-2" />
        <MudNavLink Href="/account" Icon="@Icons.Material.Filled.ManageAccounts">@UiText.Get("Nav_ManageAccount")</MudNavLink>
        <MudNavLink Href="/account/logout" Icon="@Icons.Material.Filled.Logout">@UiText.Get("Nav_SignOut")</MudNavLink>
    }
</MudNavMenu>

