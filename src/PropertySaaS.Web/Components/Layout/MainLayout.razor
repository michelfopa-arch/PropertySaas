@inherits LayoutComponentBase
@inject PropertySaaS.Application.Common.CurrentOrganization CurrentOrganization
@inject RuntiraTenantAccessService TenantAccessService
@inject NavigationManager NavigationManager
@using PropertySaaS.Web.Localization

<MudLayout>
    <MudDrawer Open="true" Elevation="1" Variant="DrawerVariant.Responsive" Class="app-drawer">
        <MudStack Spacing="3" Class="pa-4">
            <MudStack Spacing="0">
                <MudText Typo="Typo.h5" Class="brand-title">Runtira</MudText>
                <MudText Typo="Typo.body2" Class="brand-subtitle">@UiText.Format("Layout_BrandSubtitle", CurrentOrganization.Jurisdiction.ProvinceDisplayName)</MudText>
                @if (CurrentOrganization.HasOrganizationAccess && CurrentOrganization.CanAccessWorkspace)
                {
                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" Class="mt-2">@UiText.Get("Dashboard_PremiumBadge")</MudChip>
                }
            </MudStack>

            <MudPaper Elevation="0" Class="tenant-context pa-4">
                @if (CurrentOrganization.IsAuthenticated)
                {
                    <MudText Typo="Typo.subtitle1" Class="tenant-name">@CurrentOrganization.UserFullName</MudText>
                    <MudText Typo="Typo.body2" Class="tenant-user">@CurrentOrganization.UserEmail</MudText>
                    @if (CurrentOrganization.HasOrganizationAccess)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@CurrentOrganization.OrganizationName</MudText>
                         <MudStack Row="true" Spacing="1" Class="mt-3" Wrap="Wrap.Wrap">
                             <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small">@CurrentOrganization.Role</MudChip>
                             @if (CurrentOrganization.IsDemo)
                             {
                                 <MudChip T="string" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small">@UiText.Get("Layout_DemoBadge")</MudChip>
                             }
                         </MudStack>
                        @if (_organizationOptions.Count > 1 || CurrentOrganization.IsSuperAdmin)
                        {
                            <form method="get" action="/tenants/select" class="mt-3">
                                <MudText Typo="Typo.caption" Class="mb-1 d-block">@UiText.Get("Layout_OrganizationSwitcher")</MudText>
                                <select name="tenantId" class="mud-input-slot mud-input-root mud-input-root-outlined mud-select-input" style="width:100%;padding:12px;border-radius:4px;">
                                    @foreach (var option in _organizationOptions)
                                    {
                                         <option value="@option.OrganizationId" selected="@(option.OrganizationId == CurrentOrganization.OrganizationId)">@option.OrganizationName@(option.IsDemo ? $" [{UiText.Get("Layout_DemoOptionSuffix")}]" : string.Empty) (@option.Role)</option>
                                    }
                                </select>
                                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Text" Color="Color.Primary" Class="mt-2">@UiText.Get("Layout_SwitchOrganization")</MudButton>
                            </form>
                        }
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@UiText.Get("Layout_AccessPendingHelp")</MudText>
                        <MudChip T="string" Color="Color.Secondary" Variant="Variant.Outlined" Size="Size.Small" Class="mt-3">@UiText.Get("Layout_AccessPending")</MudChip>
                    }
                }
                else
                {
                    <MudText Typo="Typo.subtitle1" Class="tenant-name">@UiText.Get("Layout_PublicWorkspace")</MudText>
                    <MudText Typo="Typo.body2" Class="tenant-user">@UiText.Get("Layout_PublicWorkspaceHelp")</MudText>
                    <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small" Class="mt-3">@UiText.Get("Layout_Guest")</MudChip>
                }
            </MudPaper>

            <NavMenu />
        </MudStack>
    </MudDrawer>

    <MudMainContent>
        <MudAppBar Elevation="0" Dense="true" Color="Color.Surface" Class="top-bar">
            <MudStack Spacing="0">
                <MudText Typo="Typo.subtitle1">@UiText.Get("Layout_PortfolioOperations")</MudText>
                <MudText Typo="Typo.caption">@TopBarNarrative</MudText>
            </MudStack>
        </MudAppBar>

        <main class="content-shell">
            @Body
        </main>
    </MudMainContent>
</MudLayout>

@code {
    private List<OrganizationAccessOptionDto> _organizationOptions = new();
    private string TopBarNarrative
    {
        get
        {
            var path = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).ToLowerInvariant();
            if (path.StartsWith("resident-360"))
            {
                return UiText.Get("Layout_TopBarDemo");
            }

            if (path.StartsWith("properties") || path.StartsWith("units") || path.StartsWith("tenants") || path.StartsWith("leases"))
            {
                return UiText.Get("Layout_TopBarPortfolio");
            }

            if (path.StartsWith("leasing") || path.StartsWith("rent-payments"))
            {
                return UiText.Get("Layout_TopBarRevenue");
            }

            if (path.StartsWith("maintenance") || path.StartsWith("vendors") || path.StartsWith("tenant-communications") || path.StartsWith("documents-evidence") || path.StartsWith("dashboard") || path.StartsWith("ai-work-queue"))
            {
                return UiText.Get("Layout_TopBarOperations");
            }

            if (path.StartsWith("compliance") || path.StartsWith("ai-import") || path.StartsWith("profile") || path.StartsWith("subscriptions") || path.StartsWith("superadmin"))
            {
                return UiText.Get("Layout_TopBarCompliance");
            }

            return UiText.Get("Layout_TopBarDefault");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (CurrentOrganization.UserId != Guid.Empty)
        {
            _organizationOptions = await TenantAccessService.GetAccessibleTenantsAsync();
            if (CurrentOrganization.IsSuperAdmin)
            {
                var superAdminOptions = await TenantAccessService.GetAllTenantsForSuperAdminAsync();
                _organizationOptions = superAdminOptions
                    .Select(option => new OrganizationAccessOptionDto
                    {
                        OrganizationId = option.OrganizationId,
                        OrganizationName = option.OrganizationName,
                        IsDemo = option.IsDemo,
                        Role = UiText.Get("Nav_SuperAdmin"),
                        Status = "Active"
                    })
                    .ToList();
            }
        }
    }
}
