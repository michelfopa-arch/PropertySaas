@using PropertySaaS.Web.Localization
@inject NavigationManager NavigationManager

<MudPaper Class="pa-3 marketing-card" Elevation="0">
    <MudStack Spacing="1">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <MudStack Spacing="0">
                <MudText Typo="Typo.subtitle2">@(UsePortfolioJourney ? UiText.Get("Common_PortfolioJourney") : UiText.Get("Common_ResidentJourney"))</MudText>
                <MudText Typo="Typo.caption">@JourneySubtitle</MudText>
            </MudStack>
            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="RestartJourney">@UiText.Get("Common_RestartJourney")</MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="OpenAlternateJourney">@AlternateJourneyLabel</MudButton>
                <MudChip T="string" Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small">@UiText.Format("Common_StepProgress", CurrentStepIndex, Steps.Count)</MudChip>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">@UiText.Get("Common_YouAreHere"): @CurrentStepLabel</MudChip>
            </MudStack>
        </MudStack>
        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
            @foreach (var step in Steps)
            {
                <MudChip T="string"
                         Color="@(step.Key == CurrentStepKey ? Color.Primary : Color.Default)"
                         Variant="@(step.Key == CurrentStepKey ? Variant.Filled : Variant.Outlined)"
                         Size="Size.Small"
                         Class="cursor-pointer"
                         OnClick="() => OpenStep(step.Key)">
                    @step.Label
                </MudChip>
            }
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter]
    public string CurrentStepKey { get; set; } = "dashboard";

    [Parameter]
    public string ResidentRoute { get; set; } = "/resident-360";

    [Parameter]
    public bool UsePortfolioJourney { get; set; }

    [Parameter]
    public string PropertiesRoute { get; set; } = "/properties";

    [Parameter]
    public string PropertyProfileRoute { get; set; } = "/properties";

    private string JourneySubtitle => UsePortfolioJourney
        ? UiText.Get("Common_PortfolioJourneySubtitle")
        : UiText.Get("Common_ResidentJourneySubtitle");

    private string AlternateJourneyLabel => UsePortfolioJourney
        ? UiText.Get("Common_OpenResidentJourney")
        : UiText.Get("Common_OpenPortfolioJourney");

    private int CurrentStepIndex => Math.Max(1, Steps.ToList().FindIndex(x => x.Key == CurrentStepKey) + 1);

    private string CurrentStepLabel => Steps.FirstOrDefault(x => x.Key == CurrentStepKey)?.Label ?? UiText.Get("Nav_Overview");

    private IReadOnlyList<DemoStep> Steps
        => UsePortfolioJourney
            ? new[]
            {
                new DemoStep("dashboard", UiText.Get("Nav_Overview")),
                new DemoStep("properties", UiText.Get("Nav_Properties")),
                new DemoStep("property-profile", UiText.Get("Nav_Properties")),
                new DemoStep("leasing", UiText.Get("Nav_Leasing")),
                new DemoStep("maintenance", UiText.Get("Nav_Maintenance")),
                new DemoStep("evidence", UiText.Get("Nav_DocumentsEvidence"))
            }
            : CurrentStepKey == "ai-work-queue"
            ? new[]
            {
                new DemoStep("ai-work-queue", UiText.Get("Nav_AIWorkQueue")),
                new DemoStep("dashboard", UiText.Get("Nav_Overview")),
                new DemoStep("leasing", UiText.Get("Nav_Leasing")),
                new DemoStep("resident", UiText.Get("Nav_Resident360")),
                new DemoStep("maintenance", UiText.Get("Nav_Maintenance")),
                new DemoStep("evidence", UiText.Get("Nav_DocumentsEvidence"))
            }
            : new[]
            {
                new DemoStep("dashboard", UiText.Get("Nav_Overview")),
                new DemoStep("leasing", UiText.Get("Nav_Leasing")),
                new DemoStep("resident", UiText.Get("Nav_Resident360")),
                new DemoStep("maintenance", UiText.Get("Nav_Maintenance")),
                new DemoStep("evidence", UiText.Get("Nav_DocumentsEvidence"))
            };

    private void OpenStep(string stepKey)
    {
        NavigationManager.NavigateTo(ApplyDemoMode(stepKey switch
        {
            "ai-work-queue" => "/ai-work-queue",
            "dashboard" => "/dashboard",
            "properties" => PropertiesRoute,
            "property-profile" => PropertyProfileRoute,
            "leasing" => "/leasing",
            "resident" => ResidentRoute,
            "maintenance" => "/maintenance",
            "evidence" => "/documents-evidence",
            _ => "/dashboard"
        }));
    }

    private void OpenAlternateJourney()
        => NavigationManager.NavigateTo(ApplyDemoMode(UsePortfolioJourney ? ResidentRoute : PropertiesRoute));

    private void RestartJourney()
        => NavigationManager.NavigateTo(ApplyDemoMode(UsePortfolioJourney ? "/dashboard" : ResidentRoute));

    private bool IsDemoCleanView => DemoModeRouteHelper.IsCleanUri(NavigationManager.Uri);

    private string ApplyDemoMode(string route)
        => DemoModeRouteHelper.Apply(route, IsDemoCleanView);

    private sealed record DemoStep(string Key, string Label);
}