@attribute [Authorize]
@page "/profile"
@inject SaasDataService DataService
@inject CurrentOrganization CurrentOrganization
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@using PropertySaaS.Web.Localization

<PageTitle>@UiText.Get("Profile_PageTitle")</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="px-0">
    <MudStack Spacing="3">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <div>
                <MudText Typo="Typo.h4">@UiText.Get("Profile_Title")</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">@UiText.Get("Profile_Subtitle")</MudText>
            </div>
            <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled">@CurrentOrganization.Jurisdiction.ProvinceDisplayName</MudChip>
        </MudStack>

        @if (_isLoading)
        {
            <MudPaper Class="pa-6 d-flex justify-center profile-settings-shell">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </MudPaper>
        }
        else
        {
            <MudGrid Spacing="3">
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4 profile-settings-shell" Elevation="0">
                        <MudAvatar Size="Size.Large" Class="property-avatar mb-4">@Initials</MudAvatar>
                        <MudText Typo="Typo.h6">@_profile.FullName</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@_profile.Email</MudText>
                        <MudDivider Class="my-3" />
                        <MudStack Spacing="1">
                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary">@_profile.Role</MudChip>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@UiText.Format("Profile_Organization", CurrentOrganization.OrganizationName)</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@UiText.Format("Profile_Market", CurrentOrganization.Jurisdiction.ProvinceDisplayName)</MudText>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="8">
                    <MudStack Spacing="3">
                        <MudPaper Class="pa-4 profile-settings-shell" Elevation="0">
                            <MudText Typo="Typo.h6" GutterBottom="true">@UiText.Get("Profile_Preferences")</MudText>
                            <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">@UiText.Get("Profile_PreferencesHelp")</MudText>

                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-4">
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                                    <MudText Typo="Typo.body2">@UiText.Get("Profile_ManageAccountHelp")</MudText>
                                    <MudButton Href="/account" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">@UiText.Get("Profile_ManageAccount")</MudButton>
                                </MudStack>
                            </MudAlert>

                            <MudForm>
                                <MudGrid Spacing="2">
                                    <MudItem xs="12" sm="6">
                                        <MudSelect T="string" Label="@UiText.Get("Profile_PreferredLanguage")" @bind-Value="_preferredLanguage" Variant="Variant.Outlined" Dense="true">
                                            @foreach (var language in SupportedLanguages)
                                            {
                                                <MudSelectItem T="string" Value="@language.Code">@language.Label</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudTextField T="string" Label="@UiText.Get("Profile_Jurisdiction")" Value="@CurrentOrganization.Jurisdiction.ProvinceDisplayName" Variant="Variant.Outlined" Disabled="true" />
                                    </MudItem>
                                </MudGrid>

                                @if (!string.IsNullOrWhiteSpace(_message))
                                {
                                    <MudAlert Severity="@_messageSeverity" Variant="Variant.Filled" Dense="true" Class="mt-4">@_message</MudAlert>
                                }

                                <MudStack Row="true" Spacing="2" Class="mt-4" Wrap="Wrap.Wrap">
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="_isSaving">
                                        @if (_isSaving)
                                        {
                                            <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Indeterminate="true" Class="mr-2" />
                                        }
                                        @UiText.Get("Profile_Save")
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ReloadAsync" Disabled="_isSaving">@UiText.Get("Profile_Reset")</MudButton>
                                </MudStack>
                            </MudForm>
                        </MudPaper>

                        <MudPaper Class="pa-4 profile-settings-shell" Elevation="0">
                            <MudText Typo="Typo.h6" GutterBottom="true">@UiText.Get("Profile_SupportTitle")</MudText>
                            <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">@UiText.Get("Profile_SupportHelp")</MudText>

                            <MudGrid Spacing="2">
                                <MudItem xs="12">
                                    <MudTextField T="string" Label="@UiText.Get("Profile_SupportSubject")" @bind-Value="_supportSubject" Variant="Variant.Outlined" Dense="true" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField T="string" Label="@UiText.Get("Profile_SupportMessage")" @bind-Value="_supportMessage" Variant="Variant.Outlined" Lines="5" />
                                </MudItem>
                            </MudGrid>

                            @if (!string.IsNullOrWhiteSpace(_supportFeedback))
                            {
                                <MudAlert Severity="@_supportFeedbackSeverity" Variant="Variant.Filled" Dense="true" Class="mt-4">@_supportFeedback</MudAlert>
                            }

                            <MudStack Row="true" Spacing="2" Class="mt-4" Wrap="Wrap.Wrap">
                                <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="SendSupportAlertAsync" Disabled="_isSendingSupport || string.IsNullOrWhiteSpace(_supportSubject) || string.IsNullOrWhiteSpace(_supportMessage)">
                                    @if (_isSendingSupport)
                                    {
                                        <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Indeterminate="true" Class="mr-2" />
                                    }
                                    @UiText.Get("Profile_SupportSend")
                                </MudButton>
                            </MudStack>
                        </MudPaper>
                    </MudStack>
                </MudItem>
            </MudGrid>
        }
    </MudStack>
</MudContainer>

@code {
    private AppUser _profile = new();
    private bool _isLoading = true;
    private bool _isSaving;
    private string _preferredLanguage = string.Empty;
    private string? _message;
    private Severity _messageSeverity = Severity.Success;
    private bool _isSendingSupport;
    private string _supportSubject = string.Empty;
    private string _supportMessage = string.Empty;
    private string? _supportFeedback;
    private Severity _supportFeedbackSeverity = Severity.Success;

    private string Initials => string.Join(string.Empty, (_profile.FullName ?? string.Empty)
        .Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2)
        .Select(part => char.ToUpperInvariant(part[0])));

    private IReadOnlyList<(string Code, string Label)> SupportedLanguages => CurrentOrganization.Jurisdiction.SupportedLanguages
        .Select(code => (code, GetLanguageLabel(code)))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _isLoading = true;
        _message = null;

        var profile = await DataService.GetCurrentUserProfileAsync();
        _profile = profile ?? new AppUser
        {
            Email = CurrentOrganization.UserEmail,
            FullName = CurrentOrganization.UserEmail,
            Role = CurrentOrganization.Role,
            PreferredLanguage = CurrentOrganization.PreferredLanguage
        };

        _preferredLanguage = string.IsNullOrWhiteSpace(_profile.PreferredLanguage)
            ? CurrentOrganization.PreferredLanguage
            : _profile.PreferredLanguage;

        _isLoading = false;
    }

    private async Task SaveAsync()
    {
        _isSaving = true;
        _message = null;

        await DataService.UpdateCurrentUserPreferredLanguageAsync(_preferredLanguage);

        _message = UiText.Get("Profile_SaveSuccess");
        _messageSeverity = Severity.Success;
        _isSaving = false;

        var redirectUri = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var target = string.IsNullOrWhiteSpace(redirectUri) ? "/profile" : $"/{redirectUri}";
        var culture = Uri.EscapeDataString(_preferredLanguage);
        var redirect = Uri.EscapeDataString(target);
        NavigationManager.NavigateTo($"/culture/set?culture={culture}&redirectUri={redirect}", forceLoad: true);
    }

    private async Task SendSupportAlertAsync()
    {
        _isSendingSupport = true;
        _supportFeedback = null;

        try
        {
            var client = HttpClientFactory.CreateClient();
            client.BaseAddress = new Uri(NavigationManager.BaseUri);

            var response = await client.PostAsJsonAsync("notifications/support-alert", new
            {
                Subject = _supportSubject,
                Message = _supportMessage
            });

            if (response.IsSuccessStatusCode)
            {
                _supportFeedback = UiText.Get("Profile_SupportSuccess");
                _supportFeedbackSeverity = Severity.Success;
                _supportSubject = string.Empty;
                _supportMessage = string.Empty;
            }
            else
            {
                _supportFeedback = UiText.Get("Profile_SupportError");
                _supportFeedbackSeverity = Severity.Error;
            }
        }
        catch
        {
            _supportFeedback = UiText.Get("Profile_SupportError");
            _supportFeedbackSeverity = Severity.Error;
        }
        finally
        {
            _isSendingSupport = false;
        }
    }

    private static string GetLanguageLabel(string code) => code switch
    {
        "fr-CA" => "Français (Canada)",
        "en-CA" => "English (Canada)",
        "en-US" => "English (United States)",
        "fr-FR" => "Français (France)",
        _ => code
    };
}
