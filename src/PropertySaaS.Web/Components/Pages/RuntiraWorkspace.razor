@attribute [Authorize]
@page "/workspace"
@inject RuntiraWorkspaceService WorkspaceService
@inject CurrentOrganization CurrentOrganization
@inject NavigationManager NavigationManager
@using PropertySaaS.Web.Localization

<PageTitle>@UiText.Get("RuntiraWorkspace_PageTitle")</PageTitle>

@if (_isLoading)
{
    <MudPaper Class="pa-6 d-flex justify-center">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    </MudPaper>
}
else if (_summary is null)
{
    <MudPaper Class="pa-6 marketing-card" Elevation="0">
        <MudStack Spacing="2">
            <MudText Typo="Typo.h5">@UiText.Get("RuntiraWorkspace_EmptyTitle")</MudText>
            <MudText Typo="Typo.body1">@UiText.Get("RuntiraWorkspace_EmptyBody")</MudText>
            <MudButton Href="/onboarding" Variant="Variant.Filled" Color="Color.Primary">@UiText.Get("RuntiraWorkspace_OpenOnboarding")</MudButton>
        </MudStack>
    </MudPaper>
}
else
{
    <MudContainer MaxWidth="MaxWidth.False" Class="px-0">
        <MudStack Spacing="4">
            <MudPaper Class="hero pa-8" Elevation="0">
                <MudGrid Spacing="4" Class="align-center-grid">
                    <MudItem xs="12" lg="8">
                        <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled">@UiText.Get("RuntiraWorkspace_Badge")</MudChip>
                        <MudText Typo="Typo.h3" Class="mt-4">@UiText.Format("RuntiraWorkspace_Title", _summary.OrganizationName)</MudText>
                        <MudText Typo="Typo.h6" Class="mt-3 hero-copy">@UiText.Get("RuntiraWorkspace_Subtitle")</MudText>
                        <MudStack Row="true" Spacing="2" Class="mt-6" Wrap="Wrap.Wrap">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenAssetPrompt">@UiText.Get("RuntiraWorkspace_CreateAsset")</MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Inherit" OnClick="OpenInvoicePrompt">@UiText.Get("RuntiraWorkspace_CreateInvoice")</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="OpenSupportPrompt">@UiText.Get("RuntiraWorkspace_ClassifyInbox")</MudButton>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" lg="4">
                        <MudPaper Class="pa-4 marketing-panel" Elevation="0">
                            <MudText Typo="Typo.h6">@UiText.Get("RuntiraWorkspace_ContextTitle")</MudText>
                            <MudList T="string" Dense="true" Class="mt-3">
                                <MudListItem T="string">@UiText.Format("RuntiraWorkspace_ContextTenant", _summary.OrganizationSlug)</MudListItem>
                                <MudListItem T="string">@UiText.Format("RuntiraWorkspace_ContextLocale", _summary.DefaultLocale)</MudListItem>
                                <MudListItem T="string">@UiText.Format("RuntiraWorkspace_ContextAssets", _summary.AssetCount, _summary.AssetLimit)</MudListItem>
                                <MudListItem T="string">@UiText.Format("RuntiraWorkspace_ContextAi", _summary.ConversationCount, _summary.MonthlyAiLimit)</MudListItem>
                            </MudList>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6" md="3"><MetricCard Title="@UiText.Get("RuntiraWorkspace_Assets")" Value="@_summary.AssetCount.ToString()" Caption="@UiText.Get("RuntiraWorkspace_AssetsCaption")" Icon="@Icons.Material.Filled.Apartment" /></MudItem>
                <MudItem xs="12" sm="6" md="3"><MetricCard Title="@UiText.Get("RuntiraWorkspace_Conversations")" Value="@_summary.ConversationCount.ToString()" Caption="@UiText.Get("RuntiraWorkspace_ConversationsCaption")" Icon="@Icons.Material.Filled.Forum" /></MudItem>
                <MudItem xs="12" sm="6" md="3"><MetricCard Title="@UiText.Get("RuntiraWorkspace_Workflows")" Value="@_summary.WorkflowTemplateCount.ToString()" Caption="@UiText.Get("RuntiraWorkspace_WorkflowsCaption")" Icon="@Icons.Material.Filled.AutoAwesome" /></MudItem>
                <MudItem xs="12" sm="6" md="3"><MetricCard Title="@UiText.Get("RuntiraWorkspace_Archives")" Value="@_summary.ArchiveCount.ToString()" Caption="@UiText.Get("RuntiraWorkspace_ArchivesCaption")" Icon="@Icons.Material.Filled.Archive" /></MudItem>
            </MudGrid>

            <MudGrid Spacing="3">
                <MudItem xs="12" md="7">
                    <MudPaper Class="pa-4 marketing-card h-100" Elevation="0">
                        <MudText Typo="Typo.h5">@UiText.Get("RuntiraWorkspace_ChatTitle")</MudText>
                        <MudText Typo="Typo.body2" Class="mt-2">@UiText.Get("RuntiraWorkspace_ChatBody")</MudText>

                        <MudPaper Class="pa-4 property-detail-panel mt-4" Elevation="0">
                            <MudText Typo="Typo.subtitle2">@UiText.Get("RuntiraWorkspace_PromptLabel")</MudText>
                            <MudText Typo="Typo.body1" Class="mt-2">@_selectedPrompt</MudText>
                        </MudPaper>

                        @if (_requiredQuestions is not null)
                        {
                            <MudPaper Class="pa-4 property-detail-panel mt-4" Elevation="0">
                                <MudText Typo="Typo.subtitle2">@UiText.Get("RuntiraWorkspace_RequiredQuestionsTitle")</MudText>
                                <MudText Typo="Typo.body2" Class="mt-2">@UiText.Format("RuntiraWorkspace_Jurisdiction", _requiredQuestions.CountryCode, _requiredQuestions.RegionCode)</MudText>
                                <MudText Typo="Typo.body2" Class="mt-2">@_requiredQuestions.RequiredQuestionsJson</MudText>
                            </MudPaper>
                        }
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="5">
                    <MudPaper Class="pa-4 marketing-card h-100" Elevation="0">
                        <MudText Typo="Typo.h5">@UiText.Get("RuntiraWorkspace_ExamplesTitle")</MudText>
                        <MudList T="string" Dense="true" Class="mt-3">
                            <MudListItem T="string">@UiText.Get("RuntiraWorkspace_Example1")</MudListItem>
                            <MudListItem T="string">@UiText.Get("RuntiraWorkspace_Example2")</MudListItem>
                            <MudListItem T="string">@UiText.Get("RuntiraWorkspace_Example3")</MudListItem>
                        </MudList>
                        <MudDivider Class="my-4" />
                        <MudText Typo="Typo.subtitle2">@UiText.Get("RuntiraWorkspace_InboxTitle")</MudText>
                        <MudText Typo="Typo.body2" Class="mt-2">@UiText.Get("RuntiraWorkspace_InboxBody")</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudStack>
    </MudContainer>
}

@code {
    private bool _isLoading = true;
    private RuntiraWorkspaceSummaryDto? _summary;
    private RuntiraQuestionPromptDto? _requiredQuestions;
    private string _selectedPrompt = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (!CurrentOrganization.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/sign-in");
            return;
        }

        if (!CurrentOrganization.HasOrganizationAccess)
        {
            NavigationManager.NavigateTo("/onboarding", forceLoad: true);
            return;
        }

        _summary = await WorkspaceService.GetWorkspaceSummaryAsync();
        await LoadPromptAsync("CreateAsset", UiText.Get("RuntiraWorkspace_DefaultPrompt"));
        _isLoading = false;
    }

    private Task OpenAssetPrompt()
        => LoadPromptAsync("CreateAsset", UiText.Get("RuntiraWorkspace_DefaultPrompt"));

    private Task OpenInvoicePrompt()
        => LoadPromptAsync("CreateInvoice", UiText.Get("RuntiraWorkspace_InvoicePrompt"));

    private Task OpenSupportPrompt()
        => LoadPromptAsync("ClassifySupportEmail", UiText.Get("RuntiraWorkspace_SupportPrompt"));

    private async Task LoadPromptAsync(string intent, string prompt)
    {
        _selectedPrompt = prompt;
        _requiredQuestions = await WorkspaceService.GetRequiredQuestionsAsync(intent);
    }
}
