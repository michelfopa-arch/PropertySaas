                return string.Empty;
            }

            if (_selectedConversation.HasMoveInWorkflow && _selectedConversation.MoveInMissingItemCount > 0)
            {
                return UiText.Get("TenantCommunications_NextActionWorkflowMoveInPending");
            }

            if (_selectedConversation.HasMoveInWorkflow && _selectedConversation.CanCompleteOnboardingHandoff)
            {
                return UiText.Get("TenantCommunications_NextActionWorkflowReadyHandoff");
            }

            if (_selectedConversation.HasActiveTenancy)
