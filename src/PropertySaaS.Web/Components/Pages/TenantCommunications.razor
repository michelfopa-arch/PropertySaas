    private async Task ReloadAsync()
    {
        _conversations = await DataService.GetTenantConversationsAsync();
        _tenants = await DataService.GetTenantsAsync();
        _templates = await DataService.GetTenantMessageTemplatesAsync();
        _selectedInvoiceForCompose = InvoiceId.HasValue
            ? (await DataService.GetInvoicesAsync()).FirstOrDefault(x => x.InvoiceId == InvoiceId.Value)
            : null;
        if (ConversationId.HasValue)
        {
            var queryConversation = _conversations.FirstOrDefault(x => x.TenantConversationId == ConversationId.Value);
            if (queryConversation is not null)
            {
                _selectedConversation = queryConversation;
                _messages = await DataService.GetTenantMessagesAsync(queryConversation.TenantConversationId);
                _selectedMoveInContext = queryConversation.LeaseId.HasValue
                    ? await DataService.GetLeaseMoveInContextAsync(queryConversation.LeaseId.Value)
                    : null;
                await ApplyQueryComposerAsync();
                return;
            }
        }

        if (TenantId.HasValue)
        {
            var tenantConversation = _conversations
                .Where(x => x.TenantId == TenantId.Value)
                .OrderByDescending(x => x.LastContactUtc ?? DateTime.MinValue)
                .FirstOrDefault();
            if (tenantConversation is not null)
            {
                _selectedConversation = tenantConversation;
                _messages = await DataService.GetTenantMessagesAsync(tenantConversation.TenantConversationId);
                _selectedMoveInContext = tenantConversation.LeaseId.HasValue
                    ? await DataService.GetLeaseMoveInContextAsync(tenantConversation.LeaseId.Value)
                    : null;
                await ApplyQueryComposerAsync();
                return;
            }
        }

        if (_selectedConversation is not null)
        {
            _selectedConversation = _conversations.FirstOrDefault(x => x.TenantConversationId == _selectedConversation.TenantConversationId);
            if (_selectedConversation is not null)
            {
                _messages = await DataService.GetTenantMessagesAsync(_selectedConversation.TenantConversationId);
                _selectedMoveInContext = _selectedConversation.LeaseId.HasValue
                    ? await DataService.GetLeaseMoveInContextAsync(_selectedConversation.LeaseId.Value)
                    : null;
            }
            else
            {
                _selectedMoveInContext = null;
            }
        }

        await ApplyQueryComposerAsync();
    }

    private void SetConversationFilter(string filterKey)
        => _selectedConversationFilter = filterKey;

    private int CountConversations(string filterKey)
        => _conversations.Count(x => MatchesConversationFilter(x, filterKey));

    private int GetPriorityScore(TenantConversationSummaryDto conversation)
    {
        var subject = conversation.Subject ?? string.Empty;
        var status = conversation.Status ?? string.Empty;

        if (string.Equals(status, "Awaiting reply", StringComparison.OrdinalIgnoreCase))
        {
            return 5;
        }

        if (subject.Contains("rent", StringComparison.OrdinalIgnoreCase) || subject.Contains("invoice", StringComparison.OrdinalIgnoreCase) || subject.Contains("n4", StringComparison.OrdinalIgnoreCase))
        {
            return 4;
        }

        if (conversation.HasMoveInWorkflow && conversation.MoveInMissingItemCount > 0)
        {
            return 3;
        }

        if (subject.Contains("maintenance", StringComparison.OrdinalIgnoreCase) || subject.Contains("repair", StringComparison.OrdinalIgnoreCase))
        {
            return 2;
        }

        if (conversation.HasActiveTenancy)
        {
            return 1;
        }

        return 0;
    }

    private string GetPriorityLaneLabel(TenantConversationSummaryDto conversation)
        => GetPriorityScore(conversation) switch
        {
            5 => UiText.Get("TenantCommunications_PriorityAwaitingReply"),
            4 => UiText.Get("TenantCommunications_PriorityRent"),
            3 => UiText.Get("TenantCommunications_PriorityMoveIn"),
            2 => UiText.Get("TenantCommunications_PriorityMaintenance"),
            1 => UiText.Get("TenantCommunications_PriorityActive"),
            _ => UiText.Get("TenantCommunications_PriorityStandard")
        };

    private Color GetPriorityLaneColor(TenantConversationSummaryDto conversation)
        => GetPriorityScore(conversation) switch
        {
            5 => Color.Warning,
            4 => Color.Secondary,
            3 => Color.Info,
            2 => Color.Error,
            1 => Color.Success,
            _ => Color.Default
        };

    private bool MatchesSelectedConversationFilter(TenantConversationSummaryDto conversation)
        => MatchesConversationFilter(conversation, _selectedConversationFilter);

    private static bool MatchesConversationFilter(TenantConversationSummaryDto conversation, string filterKey)
    {
        var subject = conversation.Subject ?? string.Empty;
        var status = conversation.Status ?? string.Empty;

        return filterKey switch
        {
            "move-in" => conversation.HasMoveInWorkflow,
            "rent" => subject.Contains("rent", StringComparison.OrdinalIgnoreCase) || subject.Contains("invoice", StringComparison.OrdinalIgnoreCase),
            "maintenance" => subject.Contains("maintenance", StringComparison.OrdinalIgnoreCase) || subject.Contains("repair", StringComparison.OrdinalIgnoreCase),
            "notices" => subject.Contains("notice", StringComparison.OrdinalIgnoreCase) || subject.Contains("n4", StringComparison.OrdinalIgnoreCase) || subject.Contains("n1", StringComparison.OrdinalIgnoreCase),
            "awaiting-reply" => string.Equals(status, "Awaiting reply", StringComparison.OrdinalIgnoreCase),
            _ => true
        };
    }

