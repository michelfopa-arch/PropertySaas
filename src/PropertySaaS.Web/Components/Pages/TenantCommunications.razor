@attribute [Authorize]
@page "/tenant-communications"
@inject SaasDataService DataService
@inject NavigationManager NavigationManager
@inject PropertySaaS.Application.Common.CurrentOrganization CurrentOrganization
@using PropertySaaS.Domain.Entities
@using PropertySaaS.Domain.Enums
@using PropertySaaS.Web.Localization

<PageTitle>@UiText.Get("Nav_TenantCommunications")</PageTitle>

<MudStack Spacing="3">
    <MudStack Spacing="0">
        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" Class="mb-2">@UiText.Get("TenantCommunications_PremiumBadge")</MudChip>
        <MudText Typo="Typo.h4">@UiText.Get("TenantCommunications_Title")</MudText>
        <MudText Typo="Typo.body2">@UiText.Get("TenantCommunications_Subtitle")</MudText>
    </MudStack>

    <DemoJourneyBanner CurrentStepKey="resident" ResidentRoute="@Resident360Route" />

    <MudPaper Class="pa-3 marketing-card" Elevation="0">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.subtitle2">@UiText.Get("Common_RecommendedNextStop")</MudText>
            <MudButton Variant="Variant.Text" Color="@RecommendedNextStopColor" OnClick="OpenRecommendedNextStopAsync">@RecommendedNextStopLabel</MudButton>
        </MudStack>
    </MudPaper>

    @if (!IsDemoCleanView)
    {
        <MudGrid Spacing="3">
            <MudItem xs="12" md="4"><MetricCard Title="@UiText.Get("TenantCommunications_OpenConversations")" Value="@_conversations.Count.ToString()" Caption="@UiText.Get("TenantCommunications_OpenConversationsCaption")" Icon="@Icons.Material.Filled.MarkEmailUnread" /></MudItem>
            <MudItem xs="12" md="4"><MetricCard Title="@UiText.Get("TenantCommunications_AiDrafts")" Value="@_messages.Count(x => x.IsAISuggested).ToString()" Caption="@UiText.Get("TenantCommunications_AiDraftsCaption")" Icon="@Icons.Material.Filled.AutoAwesome" /></MudItem>
            <MudItem xs="12" md="4"><MetricCard Title="@UiText.Get("TenantCommunications_AwaitingReply")" Value="@_conversations.Count(x => string.Equals(x.Status, "Awaiting reply", StringComparison.OrdinalIgnoreCase)).ToString()" Caption="@UiText.Get("TenantCommunications_AwaitingReplyCaption")" Icon="@Icons.Material.Filled.ScheduleSend" /></MudItem>
        </MudGrid>
    }

    <MudPaper Class="pa-4 property-detail-panel" Elevation="0">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.subtitle2">@UiText.Get("TenantCommunications_QueueSummaryTitle")</MudText>
            <MudChip T="string" Variant="@(string.Equals(_selectedConversationFilter, "all", StringComparison.OrdinalIgnoreCase) ? Variant.Filled : Variant.Outlined)" Color="Color.Default" OnClick='() => SetConversationFilter("all")'>@UiText.Get("TenantCommunications_FilterAll")</MudChip>
        </MudStack>
        <MudGrid Spacing="2" Class="mt-2">
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-3 property-mini-stat" Elevation="0">
                    <MudText Typo="Typo.overline">@UiText.Get("TenantCommunications_QueueAwaitingReply")</MudText>
                    <MudChip T="string" Variant="@(string.Equals(_selectedConversationFilter, "awaiting-reply", StringComparison.OrdinalIgnoreCase) ? Variant.Filled : Variant.Outlined)" Color="Color.Warning" Class="mt-2" OnClick='() => SetConversationFilter("awaiting-reply")'>@AwaitingReplyCount</MudChip>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-3 property-mini-stat" Elevation="0">
                    <MudText Typo="Typo.overline">@UiText.Get("TenantCommunications_QueueRentAtRisk")</MudText>
                    <MudChip T="string" Variant="@(string.Equals(_selectedConversationFilter, "rent", StringComparison.OrdinalIgnoreCase) ? Variant.Filled : Variant.Outlined)" Color="Color.Secondary" Class="mt-2" OnClick='() => SetConversationFilter("rent")'>@RentAtRiskCount</MudChip>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-3 property-mini-stat" Elevation="0">
                    <MudText Typo="Typo.overline">@UiText.Get("TenantCommunications_QueueMoveInBlocked")</MudText>
                    <MudChip T="string" Variant="@(string.Equals(_selectedConversationFilter, "move-in", StringComparison.OrdinalIgnoreCase) ? Variant.Filled : Variant.Outlined)" Color="Color.Info" Class="mt-2" OnClick='() => SetConversationFilter("move-in")'>@MoveInBlockedCount</MudChip>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-3 property-mini-stat" Elevation="0">
                    <MudText Typo="Typo.overline">@UiText.Get("TenantCommunications_QueueMaintenanceActive")</MudText>
                    <MudChip T="string" Variant="@(string.Equals(_selectedConversationFilter, "maintenance", StringComparison.OrdinalIgnoreCase) ? Variant.Filled : Variant.Outlined)" Color="Color.Error" Class="mt-2" OnClick='() => SetConversationFilter("maintenance")'>@MaintenanceActiveCount</MudChip>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (!IsDemoCleanView)
    {
        <MudExpansionPanels Class="marketing-card mb-4" Elevation="0">
            <MudExpansionPanel Text="@UiText.Get("TenantCommunications_WorkflowTitle")">
                <MudList T="string" Dense="true">
                    <MudListItem T="string">@UiText.Get("TenantCommunications_Workflow1")</MudListItem>
                    <MudListItem T="string">@UiText.Get("TenantCommunications_Workflow2")</MudListItem>
                    <MudListItem T="string">@UiText.Get("TenantCommunications_Workflow3")</MudListItem>
                </MudList>
            </MudExpansionPanel>
        </MudExpansionPanels>
    }

    <MudExpansionPanels Class="marketing-card mb-4" Elevation="0">
        <MudExpansionPanel Text="@UiText.Get("TenantCommunications_DemoStoryTitle")">
            <MudText Typo="Typo.body2">@UiText.Get("TenantCommunications_DemoStoryBody")</MudText>
            <MudList T="string" Dense="true" Class="mt-3">
                <MudListItem T="string">@UiText.Get("TenantCommunications_DemoStoryStep1")</MudListItem>
                <MudListItem T="string">@UiText.Get("TenantCommunications_DemoStoryStep2")</MudListItem>
                <MudListItem T="string">@UiText.Get("TenantCommunications_DemoStoryStep3")</MudListItem>
            </MudList>
            <MudStack Row="true" Spacing="1" Class="mt-3" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="OpenResident360Async">@UiText.Get("TenantCommunications_OpenResident360")</MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="OpenRentFollowUpAsync">@UiText.Get("TenantCommunications_OpenCollections")</MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Warning" OnClick="OpenMaintenanceWorkspaceAsync">@UiText.Get("TenantCommunications_OpenMaintenance")</MudButton>
            </MudStack>
        </MudExpansionPanel>
    </MudExpansionPanels>

    <MudPaper Class="pa-2 table-wrap properties-table-shell" Elevation="0">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="pa-3">
            <MudStack Spacing="1" Class="w-100">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                    <MudText Typo="Typo.h6">@UiText.Get("TenantCommunications_ConversationsTitle")</MudText>
                    @if (CurrentOrganization.CanManageData)
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateConversationPanel">@UiText.Get("TenantCommunications_AddConversation")</MudButton>
                    }
                </MudStack>
                @if (!IsDemoCleanView)
                {
                    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                        @foreach (var filter in ConversationFilters)
                        {
                            <MudChip T="string"
                                     Variant="@(string.Equals(_selectedConversationFilter, filter.Key, StringComparison.OrdinalIgnoreCase) ? Variant.Filled : Variant.Outlined)"
                                     Color="@filter.Color"
                                     OnClick="() => SetConversationFilter(filter.Key)">
                                @filter.Label (@CountConversations(filter.Key))
                            </MudChip>
                        }
                    </MudStack>
                }
            </MudStack>
        </MudStack>
        <MudTable Items="FilteredConversations" Dense="true" Hover="true" Breakpoint="Breakpoint.Md">
            <HeaderContent>
                <MudTh>@UiText.Get("TenantCommunications_Tenant")</MudTh>
                <MudTh>@UiText.Get("TenantCommunications_Subject")</MudTh>
                <MudTh>@UiText.Get("TenantCommunications_Channel")</MudTh>
                <MudTh>@UiText.Get("TenantCommunications_Status")</MudTh>
                <MudTh>@UiText.Get("TenantCommunications_LastContact")</MudTh>
                <MudTh>@UiText.Get("TenantCommunications_LastMessage")</MudTh>
                <MudTh>@UiText.Get("TenantCommunications_Priority")</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="@UiText.Get("TenantCommunications_Tenant")">@context.TenantName</MudTd>
                <MudTd DataLabel="@UiText.Get("TenantCommunications_Subject")">@context.Subject</MudTd>
                <MudTd DataLabel="@UiText.Get("TenantCommunications_Channel")">@context.Channel</MudTd>
                <MudTd DataLabel="@UiText.Get("TenantCommunications_Status")">@context.Status</MudTd>
                <MudTd DataLabel="@UiText.Get("TenantCommunications_LastContact")">@context.LastContactUtc?.ToLocalTime().ToString("g")</MudTd>
                <MudTd DataLabel="@UiText.Get("TenantCommunications_LastMessage")">@context.LastMessagePreview</MudTd>
                <MudTd DataLabel="@UiText.Get("TenantCommunications_Priority")">
                    <MudChip T="string" Variant="Variant.Outlined" Color="@GetPriorityLaneColor(context)">@GetPriorityLaneLabel(context)</MudChip>
                </MudTd>
                <MudTd>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" OnClick="() => SelectConversation(context)">@UiText.Get("TenantCommunications_ViewThread")</MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>

    @if (_selectedConversation is not null)
    {
        <MudPaper Class="pa-4 marketing-card" Elevation="0">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6">@_selectedConversation.Subject</MudText>
                    <MudText Typo="Typo.body2">@_selectedConversation.TenantName · @_selectedConversation.Channel</MudText>
                </MudStack>
                @if (CurrentOrganization.CanManageData)
                {
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.AddComment" OnClick="OpenCreateMessagePanel">@UiText.Get("TenantCommunications_AddMessage")</MudButton>
                }
            </MudStack>

            <MudPaper Class="pa-3 property-detail-panel mt-3" Elevation="0">
                <MudText Typo="Typo.subtitle2">@UiText.Get("TenantCommunications_NextActionTitle")</MudText>
                <MudGrid Spacing="2" Class="mt-2">
                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-3 property-mini-stat" Elevation="0">
                            <MudText Typo="Typo.overline">@UiText.Get("TenantCommunications_NextActionThreadStatus")</MudText>
                            <MudChip T="string" Variant="Variant.Outlined" Color="@ThreadStatusColor" Class="mt-2">@_selectedConversation.Status</MudChip>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-3 property-mini-stat" Elevation="0">
                            <MudText Typo="Typo.overline">@UiText.Get("TenantCommunications_NextActionWorkflow")</MudText>
                            <MudChip T="string" Variant="Variant.Outlined" Color="@WorkflowStatusColor" Class="mt-2">@WorkflowStatusLabel</MudChip>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-3 property-mini-stat" Elevation="0">
                            <MudText Typo="Typo.overline">@UiText.Get("TenantCommunications_NextActionCta")</MudText>
                            <MudButton Class="mt-2" Variant="Variant.Text" Color="@NextActionColor" OnClick="NextThreadAction">@NextActionLabel</MudButton>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
                <MudText Typo="Typo.body2" Class="mt-3">@NextActionMessage</MudText>
            </MudPaper>

            @if (_selectedConversation.HasMoveInWorkflow)
            {
                <MudPaper Class="pa-3 property-detail-panel mt-3" Elevation="0">
                    <MudText Typo="Typo.subtitle2">@UiText.Get("TenantCommunications_MoveInTitle")</MudText>
                    @if (_selectedConversation.MoveInMissingItemCount == 0)
                    {
                        <MudText Typo="Typo.body2" Class="mt-2">@UiText.Get("TenantCommunications_MoveInReady")</MudText>
                        @if (_selectedConversation.LeaseId.HasValue && _selectedConversation.CanCompleteOnboardingHandoff && CurrentOrganization.CanManageData)
                        {
                            <MudButton Class="mt-2" Variant="Variant.Filled" Size="Size.Small" Color="Color.Success" OnClick='() => CompleteOnboardingHandoffAsync(_selectedConversation.LeaseId.Value)'>@UiText.Get("TenantCommunications_MoveInCompleteHandoff")</MudButton>
                        }
                        @if (_selectedConversation.HasActiveTenancy)
                        {
                            <MudStack Row="true" Spacing="1" Class="mt-2" Wrap="Wrap.Wrap">
                                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary" OnClick="OpenRentFollowUp">@UiText.Get("TenantCommunications_MoveInOpenRent")</MudButton>
                                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Secondary" OnClick="OpenTenantProfile">@UiText.Get("TenantCommunications_MoveInOpenTenantProfile")</MudButton>
                                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Tertiary" OnClick="OpenResident360">@UiText.Get("Nav_Resident360")</MudButton>
                                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Info" OnClick="OpenLeaseProfile">@UiText.Get("TenantCommunications_MoveInOpenLease")</MudButton>
                                @if (CurrentOrganization.CanManageData)
                                {
                                    <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Default" OnClick="PreparePostMoveInMessageAsync">@UiText.Get("TenantCommunications_MoveInPostMoveInDraft")</MudButton>
                                }
                            </MudStack>
                        }
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Class="mt-2">@UiText.Get("TenantCommunications_MoveInMissing")</MudText>
                        <MudList T="string" Dense="true" Class="mt-2">
                            @foreach (var item in _selectedConversation.MoveInMissingItems)
                            {
                                <MudListItem T="string">
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="w-100" Wrap="Wrap.Wrap">
                                        <MudText Typo="Typo.body2">@item</MudText>
                                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                            @if (_selectedConversation.LeaseId.HasValue && _selectedConversation.MoveInActionableItems.Contains(item) && CurrentOrganization.CanManageData)
                                            {
                                                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Success" OnClick='() => CompleteMoveInActionAsync(_selectedConversation.LeaseId.Value, item)'>@UiText.Get("TenantCommunications_MoveInMarkReceived")</MudButton>
                                            }
                                            @if (_selectedConversation.LeaseId.HasValue && _selectedConversation.MoveInDocumentActions.TryGetValue(item, out var documentType))
                                            {
                                                @if (CurrentOrganization.CanManageData)
                                                {
                                                    <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Secondary" OnClick='() => AddMoveInDocumentAsync(_selectedConversation.LeaseId.Value, documentType)'>@UiText.Get("TenantCommunications_MoveInAddDocument")</MudButton>
                                                }
                                                @if (IsInternalTemplateDocument(documentType))
                                                {
                                                    <MudButton Href="@GetInternalTemplateUrl(_selectedConversation.LeaseId.Value, documentType)" Target="_blank" Variant="Variant.Text" Size="Size.Small" Color="Color.Default">@UiText.Get("TenantCommunications_MoveInOpenTemplate")</MudButton>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(GetOfficialDocumentUrl(documentType)))
                                                {
                                                    <MudButton Href="@GetOfficialDocumentUrl(documentType)" Target="_blank" Variant="Variant.Text" Size="Size.Small" Color="Color.Primary">@UiText.Get("TenantCommunications_MoveInOpenOfficial")</MudButton>
                                                }
                                            }
                                        </MudStack>
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudPaper>
            }

            <MudList T="string" Dense="true" Class="mt-3">
                @foreach (var message in _messages)
                {
                    <MudListItem T="string">@message.SentUtc.ToLocalTime().ToString("g") - @(message.IsIncoming ? UiText.Get("TenantCommunications_Incoming") : UiText.Get("TenantCommunications_Outgoing")) - @message.Body (@FormatDeliverySummary(message))</MudListItem>
                }
            </MudList>

            @if (!IsDemoCleanView && !string.IsNullOrWhiteSpace(_selectedConversation.MoveInNextDraftBody))
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3 mb-0">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.subtitle2">@(_selectedConversation.MoveInMissingItemCount == 0 ? UiText.Get("TenantCommunications_MoveInReadyToSend") : UiText.Get("TenantCommunications_MoveInUseRecommendedDraft"))</MudText>
                            <MudText Typo="Typo.body2">@_selectedConversation.MoveInNextDraftBody</MudText>
                        </MudStack>
                        @if (CurrentOrganization.CanManageData)
                        {
                            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary" OnClick="UseRecommendedMoveInDraftAsync">@UiText.Get("TenantCommunications_MoveInUseRecommendedDraft")</MudButton>
                        }
                    </MudStack>
                </MudAlert>
            }
        </MudPaper>
    }

    @if (_isConversationPanelOpen)
    {
        <div class="property-form-backdrop" @onclick="CloseConversationPanel">
            <MudPaper Class="pa-5 property-form-drawer" Elevation="0" @onclick:stopPropagation="true">
                <MudStack Spacing="3">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h5">@UiText.Get("TenantCommunications_AddConversation")</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="CloseConversationPanel" />
                    </MudStack>
                    <EditForm Model="_newConversation" OnValidSubmit="SaveConversationAsync">
                        <MudGrid Spacing="2">
                            <MudItem xs="12" md="6">
                                <MudSelect T="Guid?" Label="@UiText.Get("TenantCommunications_Tenant")" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="FormTenantId">
                                    <MudSelectItem T="Guid?" Value="@((Guid?)null)">@UiText.Get("TenantCommunications_SelectTenant")</MudSelectItem>
                                    @foreach (var tenant in _tenants)
                                    {
                                        <MudSelectItem T="Guid?" Value="@((Guid?)tenant.Id)">@tenant.FullName</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="ConversationChannel" Label="@UiText.Get("TenantCommunications_Channel")" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="_newConversation.Channel">
                                    @foreach (var channel in Enum.GetValues<ConversationChannel>())
                                    {
                                        <MudSelectItem T="ConversationChannel" Value="@channel">@channel</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12"><MudTextField Label="@UiText.Get("TenantCommunications_Subject")" Variant="Variant.Outlined" @bind-Value="_newConversation.Subject" /></MudItem>
                        </MudGrid>
                        <MudStack Row="true" Spacing="2" Class="mt-4" Justify="Justify.FlexEnd">
                            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CloseConversationPanel">@UiText.Get("Common_Cancel")</MudButton>
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">@UiText.Get("Common_Create")</MudButton>
                        </MudStack>
                    </EditForm>
                </MudStack>
            </MudPaper>
        </div>
    }

    @if (_isMessagePanelOpen)
    {
        <div class="property-form-backdrop" @onclick="CloseMessagePanel">
            <MudPaper Class="pa-5 property-form-drawer" Elevation="0" @onclick:stopPropagation="true">
                <MudStack Spacing="3">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h5">@UiText.Get("TenantCommunications_AddMessage")</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="CloseMessagePanel" />
                    </MudStack>
                    <EditForm Model="_newMessage" OnValidSubmit="SaveMessageAsync">
                        <MudGrid Spacing="2">
                            @if (_selectedConversation is not null)
                            {
                                <MudItem xs="12">
                                    <MudTextField Label="@UiText.Get("TenantCommunications_Subject")" Variant="Variant.Outlined" Value="@_selectedConversation.Subject" ReadOnly="true" />
                                </MudItem>
                            }
                            <MudItem xs="12">
                                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">@UiText.Get("TenantCommunications_DraftLanguage"): @DraftLanguageLabel</MudChip>
                            </MudItem>
                            <MudItem xs="12">
                                <MudSelect T="string" Label="@UiText.Get("TenantCommunications_Template")" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="_selectedTemplateKey">
                                    <MudSelectItem T="string" Value="@string.Empty">@UiText.Get("TenantCommunications_TemplateNone")</MudSelectItem>
                                    @foreach (var template in _templates)
                                    {
                                        <MudSelectItem T="string" Value="@template.Key">@template.Title</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            @if (!string.IsNullOrWhiteSpace(_selectedTemplateKey))
                            {
                                <MudItem xs="12">
                                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small" OnClick="ApplySelectedTemplate">@UiText.Get("TenantCommunications_ApplyTemplate")</MudButton>
                                </MudItem>
                            }
                            <MudItem xs="12"><MudTextField Label="@UiText.Get("TenantCommunications_MessageBody")" Variant="Variant.Outlined" Lines="5" @bind-Value="_newMessage.Body" /></MudItem>
                            <MudItem xs="12" md="6"><MudTextField Label="@UiText.Get("TenantCommunications_DeliveryMethod")" Variant="Variant.Outlined" @bind-Value="_newMessage.DeliveryMethod" /></MudItem>
                            <MudItem xs="12" md="6"><MudDatePicker Label="@UiText.Get("TenantCommunications_DeliveredUtc")" Variant="Variant.Outlined" @bind-Date="_deliveryDate" Editable="true" /></MudItem>
                            <MudItem xs="12"><MudTextField Label="@UiText.Get("TenantCommunications_DeliveryProof")" Variant="Variant.Outlined" Lines="2" @bind-Value="_newMessage.DeliveryProof" /></MudItem>
                            <MudItem xs="12" md="6"><MudSwitch T="bool" Label="@UiText.Get("TenantCommunications_IsIncoming")" @bind-Value="_newMessage.IsIncoming" /></MudItem>
                            <MudItem xs="12" md="6"><MudSwitch T="bool" Label="@UiText.Get("TenantCommunications_IsAiDraft")" @bind-Value="_newMessage.IsAISuggested" /></MudItem>
                        </MudGrid>
                        <MudStack Row="true" Spacing="2" Class="mt-4" Justify="Justify.FlexEnd">
                            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CloseMessagePanel">@UiText.Get("Common_Cancel")</MudButton>
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">@UiText.Get("Common_Create")</MudButton>
                        </MudStack>
                    </EditForm>
                </MudStack>
            </MudPaper>
        </div>
    }
</MudStack>

@code {
    [SupplyParameterFromQuery] public Guid? ConversationId { get; set; }
    [SupplyParameterFromQuery] public Guid? TenantId { get; set; }
    [SupplyParameterFromQuery] public string? Compose { get; set; }
    [SupplyParameterFromQuery] public Guid? InvoiceId { get; set; }
