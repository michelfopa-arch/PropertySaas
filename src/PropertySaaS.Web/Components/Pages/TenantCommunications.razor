    private Task UseRecommendedMoveInDraftAsync()
    {
        if (_selectedConversation is null || string.IsNullOrWhiteSpace(_selectedConversation.MoveInNextDraftBody))
        {
            return Task.CompletedTask;
        }

        OpenCreateMessagePanel();
        _newMessage.Body = _selectedConversation.MoveInNextDraftBody;
        _newMessage.IsAISuggested = true;
        return Task.CompletedTask;
    }

    private Task ApplyQueryComposerAsync()
    {
        if (_composeHandled || _selectedConversation is null || string.IsNullOrWhiteSpace(Compose))
        {
            return Task.CompletedTask;
        }

        if (string.Equals(Compose, "rent-reminder", StringComparison.OrdinalIgnoreCase))
        {
            OpenCreateMessagePanel();
            var unitLabel = string.IsNullOrWhiteSpace(_selectedConversation.UnitLabel)
                ? UiText.Get("TenantCommunications_UnitFallback")
                : _selectedConversation.UnitLabel;
            var invoiceSummary = _selectedInvoiceForCompose is null
                ? string.Empty
                : string.Equals(CurrentOrganization.PreferredLanguage, "fr-CA", StringComparison.OrdinalIgnoreCase)
                    || string.Equals(CurrentOrganization.PreferredLanguage, "fr", StringComparison.OrdinalIgnoreCase)
                        ? $" La facture {_selectedInvoiceForCompose.Number} de {_selectedInvoiceForCompose.Balance:C} arrive à échéance le {_selectedInvoiceForCompose.DueDate}."
                        : $" Invoice {_selectedInvoiceForCompose.Number} for {_selectedInvoiceForCompose.Balance:C} is due on {_selectedInvoiceForCompose.DueDate}.";
            _newMessage.Body = string.Equals(CurrentOrganization.PreferredLanguage, "fr-CA", StringComparison.OrdinalIgnoreCase)
                || string.Equals(CurrentOrganization.PreferredLanguage, "fr", StringComparison.OrdinalIgnoreCase)
                ? $"Bonjour {_selectedConversation.TenantName}, ceci est un rappel amical concernant le solde de loyer actuel pour {unitLabel}.{invoiceSummary} Merci de confirmer votre date prévue de paiement et de nous indiquer si vous souhaitez discuter des prochaines étapes."
                : $"Hello {_selectedConversation.TenantName}, this is a friendly reminder regarding the current rent balance for {unitLabel}.{invoiceSummary} Please confirm your expected payment date and let us know if you need to discuss the next steps.";
            _newMessage.IsAISuggested = true;
            _selectedTemplateKey = "rent-reminder";
            _composeHandled = true;
        }
        else if (string.Equals(Compose, "maintenance-entry", StringComparison.OrdinalIgnoreCase))
        {
            OpenCreateMessagePanel();
            var unitLabel = string.IsNullOrWhiteSpace(_selectedConversation.UnitLabel)
                ? UiText.Get("TenantCommunications_UnitFallback")
                : _selectedConversation.UnitLabel;
            _newMessage.Body = IsFrenchDraftLanguage
                ? $"Bonjour {_selectedConversation.TenantName}, nous coordonnons actuellement l’accès à {unitLabel} concernant « {_selectedConversation.Subject} ». Merci de confirmer vos disponibilités et toute instruction utile pour finaliser l’intervention."
                : $"Hello {_selectedConversation.TenantName}, we are currently coordinating access to {unitLabel} regarding '{_selectedConversation.Subject}'. Please confirm your availability and any helpful access instructions so we can finalize the service visit.";
            _newMessage.IsAISuggested = true;
            _selectedTemplateKey = "maintenance-entry";
            _composeHandled = true;
        }
        else if (string.Equals(Compose, "notice-delivery", StringComparison.OrdinalIgnoreCase))
        {
            OpenCreateMessagePanel();
            var unitLabel = string.IsNullOrWhiteSpace(_selectedConversation.UnitLabel)
                ? UiText.Get("TenantCommunications_UnitFallback")
                : _selectedConversation.UnitLabel;
            _newMessage.Body = IsFrenchDraftLanguage
                ? $"Bonjour {_selectedConversation.TenantName}, ce message confirme la remise de l’avis lié à {unitLabel}. Merci de répondre pour confirmer la réception et de conserver ce fil pour vos dossiers."
                : $"Hello {_selectedConversation.TenantName}, this message confirms delivery of the related notice for {unitLabel}. Please reply to confirm receipt and keep this thread for your records.";
            _newMessage.IsAISuggested = true;
            _selectedTemplateKey = "notice-delivery";
            _composeHandled = true;
        }
        else if (string.Equals(Compose, "n4-prep", StringComparison.OrdinalIgnoreCase))
        {
            OpenCreateMessagePanel();
            var unitLabel = string.IsNullOrWhiteSpace(_selectedConversation.UnitLabel)
                ? UiText.Get("TenantCommunications_UnitFallback")
                : _selectedConversation.UnitLabel;
            var invoiceSummary = _selectedInvoiceForCompose is null
                ? string.Empty
                : IsFrenchDraftLanguage
                    ? $" Le solde actuel lié à la facture {_selectedInvoiceForCompose.Number} est de {_selectedInvoiceForCompose.Balance:C} et l’échéance était le {_selectedInvoiceForCompose.DueDate}."
                    : $" The current balance tied to invoice {_selectedInvoiceForCompose.Number} is {_selectedInvoiceForCompose.Balance:C} and the due date was {_selectedInvoiceForCompose.DueDate}.";
            _newMessage.Body = IsFrenchDraftLanguage
                ? $"Bonjour {_selectedConversation.TenantName}, nous faisons un suivi du loyer impayé pour {unitLabel}.{invoiceSummary} Merci de nous répondre rapidement afin de confirmer votre calendrier de paiement avant toute étape formelle de type N4."
                : $"Hello {_selectedConversation.TenantName}, we are following up on the outstanding rent for {unitLabel}.{invoiceSummary} Please reply promptly to confirm your payment timing before any formal N4 notice steps are reviewed.";
            _newMessage.IsAISuggested = true;
            _selectedTemplateKey = "n4-prep";
            _composeHandled = true;
        }

        return Task.CompletedTask;
    }

    private void ApplyMoveInComposerDefaults()
    {
        if (_selectedConversation is null || !_selectedConversation.HasMoveInWorkflow)
        {
            return;
        }

        _newMessage.DeliveryProof = BuildMoveInDeliveryProof();
    }

    private string BuildMoveInDeliveryProof()
    {
        if (_selectedConversation is null)
        {
            return string.Empty;
        }

        var unitLabel = string.IsNullOrWhiteSpace(_selectedConversation.UnitLabel)
            ? UiText.Get("TenantCommunications_UnitFallback")
            : _selectedConversation.UnitLabel;

        return $"Move-in follow-up prepared for {_selectedConversation.TenantName} regarding {unitLabel} in thread '{_selectedConversation.Subject}'.";
    }

    private void CloseMessagePanel() => _isMessagePanelOpen = false;

    private void ApplySelectedTemplate()
    {
        if (_selectedConversation is null)
        {
            return;
        }

        var template = _templates.FirstOrDefault(x => x.Key == _selectedTemplateKey);
        if (template is null)
        {
            return;
        }

        var nextStepDate = DateOnly.FromDateTime(DateTime.Today.AddDays(3)).ToString("yyyy-MM-dd");
        _newMessage.Body = template.BodyTemplate
            .Replace("{{tenantName}}", _selectedConversation.TenantName, StringComparison.Ordinal)
            .Replace("{{unitLabel}}", string.IsNullOrWhiteSpace(_selectedConversation.UnitLabel) ? UiText.Get("TenantCommunications_UnitFallback") : _selectedConversation.UnitLabel, StringComparison.Ordinal)
            .Replace("{{subject}}", _selectedConversation.Subject, StringComparison.Ordinal)
            .Replace("{{nextStepDate}}", nextStepDate, StringComparison.Ordinal);
        _newMessage.IsAISuggested = true;
    }

    private async Task SaveMessageAsync()
    {
        if (_newMessage.TenantConversationId == Guid.Empty || string.IsNullOrWhiteSpace(_newMessage.Body))
        {
            return;
        }

        _newMessage.SentBy = _newMessage.IsIncoming ? UiText.Get("TenantCommunications_Tenant") : CurrentOrganization.UserEmail;
        _newMessage.DeliveredUtc = _deliveryDate;
        await DataService.AddTenantMessageAsync(_newMessage);
        await ReloadAsync();
        CloseMessagePanel();
    }

    private async Task CompleteMoveInActionAsync(Guid leaseId, string actionKey)
    {
        var updated = await DataService.CompleteLeaseMoveInActionAsync(leaseId, actionKey);
        if (!updated)
        {
            return;
        }

        await ReloadAsync();
    }

    private async Task AddMoveInDocumentAsync(Guid leaseId, string documentType)
    {
        var added = await DataService.AddLeaseMoveInDocumentAsync(
            leaseId,
            documentType,
            $"{GetMoveInDocumentTypeLabel(documentType)} - {_selectedConversation?.TenantName}.pdf",
            $"Added from tenant communications thread for {_selectedConversation?.Subject}.");
        if (!added)
        {
            return;
        }

        await ReloadAsync();
    }

    private string GetMoveInDocumentTypeLabel(string documentType)
        => documentType switch
        {
            "SignedLease" => UiText.Get("Leases_MoveInDocumentTypeSignedLease"),
            "InsuranceProof" => UiText.Get("Leases_MoveInDocumentTypeInsuranceProof"),
            "GovernmentId" => UiText.Get("Leases_MoveInDocumentTypeGovernmentId"),
            "IncomeProof" => UiText.Get("Leases_MoveInDocumentTypeIncomeProof"),
            "DepositReceipt" => UiText.Get("Leases_MoveInDocumentTypeDepositReceipt"),
            _ => documentType
        };

    private static bool IsInternalTemplateDocument(string documentType)
        => documentType is "DepositReceipt" or "IncomeProof" or "GovernmentId";

    private string GetInternalTemplateUrl(Guid leaseId, string documentType)
    {
        var propertyName = Uri.EscapeDataString(_selectedMoveInContext?.PropertyName ?? string.Empty);
        var unitLabel = Uri.EscapeDataString(_selectedMoveInContext?.UnitLabel ?? string.Empty);
        var tenantName = Uri.EscapeDataString(_selectedMoveInContext?.TenantName ?? string.Empty);
        return $"/docs/move-in/{documentType}?propertyName={propertyName}&unitLabel={unitLabel}&tenantName={tenantName}";
    }

    private string GetOfficialDocumentUrl(string documentType)
        => documentType switch
        {
            "SignedLease" when string.Equals(CurrentOrganization.Province, "ON", StringComparison.OrdinalIgnoreCase)
                => string.Equals(CurrentOrganization.PreferredLanguage, "fr-CA", StringComparison.OrdinalIgnoreCase)
                    ? "/docs/ontario-standard-lease"
                    : "/docs/ontario-standard-lease",
            "InsuranceProof" when string.Equals(CurrentOrganization.Province, "ON", StringComparison.OrdinalIgnoreCase)
                => "https://www.fsrao.ca/consumers/property-and-casualty-insurance",
            _ => string.Empty
        };

    private static string FormatDeliverySummary(TenantMessageSummaryDto message)
    {
        var delivered = message.DeliveredUtc.HasValue ? message.DeliveredUtc.Value.ToLocalTime().ToString("g") : "not marked delivered";
        var method = string.IsNullOrWhiteSpace(message.DeliveryMethod) ? "logged" : message.DeliveryMethod;
        var proof = string.IsNullOrWhiteSpace(message.DeliveryProof) ? string.Empty : $"; {message.DeliveryProof}";
        return $"{method}, {delivered}{proof}";
    }
}
