            ? Color.Default
            : _selectedConversation.HasMoveInWorkflow && _selectedConversation.MoveInMissingItemCount > 0
                ? Color.Warning
                : _selectedConversation.HasMoveInWorkflow && _selectedConversation.CanCompleteOnboardingHandoff
                    ? Color.Success
                    : _selectedConversation.HasActiveTenancy
                        ? Color.Primary
                        : Color.Info;

    private Func<Task> NextThreadAction
        => _selectedConversation is not null && _selectedConversation.HasMoveInWorkflow && _selectedConversation.MoveInMissingItemCount > 0 && !string.IsNullOrWhiteSpace(_selectedConversation.MoveInNextDraftBody)
            ? UseRecommendedMoveInDraftAsync
            : _selectedConversation is not null && _selectedConversation.HasMoveInWorkflow && _selectedConversation.CanCompleteOnboardingHandoff && _selectedConversation.LeaseId.HasValue
                ? () => CompleteOnboardingHandoffAsync(_selectedConversation.LeaseId.Value)
                : _selectedConversation is not null && _selectedConversation.Subject.Contains("maintenance", StringComparison.OrdinalIgnoreCase)
                    ? OpenMaintenanceEntryDraftAsync
                    : _selectedConversation is not null && (_selectedConversation.Subject.Contains("rent", StringComparison.OrdinalIgnoreCase) || _selectedConversation.Subject.Contains("invoice", StringComparison.OrdinalIgnoreCase))
                        ? OpenRentReminderDraftAsync
                        : _selectedConversation is not null && _selectedConversation.HasActiveTenancy
                            ? OpenResident360Async
                            : OpenCreateMessagePanelAsync;

