    private void OpenCreateMessagePanel()
    {
        if (_selectedConversation is null)
        {
            return;
        }

        _newMessage = new TenantMessage
        {
            TenantConversationId = _selectedConversation.TenantConversationId,
            SentBy = CurrentOrganization.UserEmail,
