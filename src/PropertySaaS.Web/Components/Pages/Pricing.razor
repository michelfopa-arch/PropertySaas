@page "/pricing"
@using PropertySaaS.Web.Localization

<PageTitle>@UiText.Get("Pricing_PageTitle")</PageTitle>

<MudStack Spacing="3">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h4">@UiText.Get("Pricing_Title")</MudText>
        <MudText Typo="Typo.body1">@UiText.Get("Pricing_Intro")</MudText>
    </MudStack>

    <MudPaper Class="pa-4 marketing-card" Elevation="0">
        <MudText Typo="Typo.h6">@UiText.Get("Pricing_TrialOfferTitle")</MudText>
        <MudText Typo="Typo.body1">@UiText.Get("Pricing_TrialOfferBody")</MudText>
    </MudPaper>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 pricing-card h-100" Elevation="0">
                <MudText Typo="Typo.h5">@UiText.Get("Pricing_StarterPlan")</MudText>
                <MudText Typo="Typo.h3" Class="mt-2">$49</MudText>
                <MudText Typo="Typo.body2">@UiText.Get("Pricing_PerMonth")</MudText>
                <MudText Typo="Typo.body2" Class="mt-2">@UiText.Get("Pricing_StarterTagline")</MudText>
                <MudList T="string" Dense="true" Class="mt-3">
                    <MudListItem T="string">@UiText.Get("Pricing_Starter1")</MudListItem>
                    <MudListItem T="string">@UiText.Get("Pricing_Starter2")</MudListItem>
                    <MudListItem T="string">@UiText.Get("Pricing_Starter3")</MudListItem>
                    <MudListItem T="string">@UiText.Get("Pricing_Starter4")</MudListItem>
                    <MudListItem T="string">@UiText.Get("Pricing_Starter5")</MudListItem>
                </MudList>
                <MudButton Href="/sign-up" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">@UiText.Get("Pricing_StartTrialCta")</MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 pricing-card pricing-card-featured h-100" Elevation="0">
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Class="mb-3">@UiText.Get("Pricing_GrowthPopular")</MudChip>
                <MudText Typo="Typo.h5">@UiText.Get("Pricing_GrowthPlan")</MudText>
                <MudText Typo="Typo.h3" Class="mt-2">$129</MudText>
                <MudText Typo="Typo.body2">@UiText.Get("Pricing_PerMonth")</MudText>
                <MudText Typo="Typo.body2" Class="mt-2">@UiText.Get("Pricing_GrowthTagline")</MudText>
                <MudList T="string" Dense="true" Class="mt-3">
                    <MudListItem T="string">@UiText.Get("Pricing_Growth1")</MudListItem>
                    <MudListItem T="string">@UiText.Get("Pricing_Growth2")</MudListItem>
                    <MudListItem T="string">@UiText.Get("Pricing_Growth3")</MudListItem>
                    <MudListItem T="string">@UiText.Get("Pricing_Growth4")</MudListItem>
                    <MudListItem T="string">@UiText.Get("Pricing_Growth5")</MudListItem>
                    <MudListItem T="string">@UiText.Get("Pricing_Growth6")</MudListItem>
                </MudList>
                <MudButton Href="/sign-up" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">@UiText.Get("Pricing_StartTrialCta")</MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 pricing-card h-100" Elevation="0">
                <MudText Typo="Typo.h5">@UiText.Get("Pricing_ProPlan")</MudText>
                <MudText Typo="Typo.h3" Class="mt-2">$249</MudText>
                <MudText Typo="Typo.body2">@UiText.Get("Pricing_PerMonth")</MudText>
                <MudText Typo="Typo.body2" Class="mt-2">@UiText.Get("Pricing_ProTagline")</MudText>
                <MudList T="string" Dense="true" Class="mt-3">
                    <MudListItem T="string">@UiText.Get("Pricing_Pro1")</MudListItem>
                    <MudListItem T="string">@UiText.Get("Pricing_Pro2")</MudListItem>
                    <MudListItem T="string">@UiText.Get("Pricing_Pro3")</MudListItem>
                    <MudListItem T="string">@UiText.Get("Pricing_Pro4")</MudListItem>
                    <MudListItem T="string">@UiText.Get("Pricing_Pro5")</MudListItem>
                    <MudListItem T="string">@UiText.Get("Pricing_Pro6")</MudListItem>
                </MudList>
                <MudButton Href="/sign-up" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">@UiText.Get("Pricing_ContactSalesCta")</MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4 marketing-card h-100" Elevation="0">
                <MudText Typo="Typo.h6">@UiText.Get("Pricing_ImprovementsTitle")</MudText>
                <MudList T="string" Dense="true" Class="mt-3">
                    <MudListItem T="string">@UiText.Get("Pricing_Improvements1")</MudListItem>
                    <MudListItem T="string">@UiText.Get("Pricing_Improvements2")</MudListItem>
                    <MudListItem T="string">@UiText.Get("Pricing_Improvements3")</MudListItem>
                    <MudListItem T="string">@UiText.Get("Pricing_Improvements4")</MudListItem>
                </MudList>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4 marketing-card h-100" Elevation="0">
                <MudText Typo="Typo.h6">@UiText.Get("Pricing_PromiseTitle")</MudText>
                <MudText Typo="Typo.body1">@UiText.Get("Pricing_PromiseBody")</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>
