@attribute [Authorize]
@page "/units"
@inject SaasDataService DataService
@inject PropertySaaS.Application.Common.CurrentOrganization CurrentOrganization
@inject IStringLocalizer<SharedResource> Localizer
@using PropertySaaS.Web.Localization

<PageTitle>@Localizer["Units_Title"]</PageTitle>

<MudStack Spacing="3">
    <MudStack Spacing="0">
        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" Class="mb-2">@UiText.Get("Units_PremiumBadge")</MudChip>
        <MudText Typo="Typo.h4">@Localizer["Units_Title"]</MudText>
        <MudText Typo="Typo.body2">@Localizer["Units_Subtitle"]</MudText>
    </MudStack>

    @if (!IsDemoCleanView)
    {
        <MudGrid Spacing="2" Class="align-center-grid">
            <MudItem xs="12" lg="4">
                <MudTextField T="string"
                              Label="@Localizer["Units_SearchLabel"]"
                              Variant="Variant.Outlined"
                              Immediate="true"
                              @bind-Value="_searchText"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Placeholder="@Localizer["Units_SearchPlaceholder"]" />
            </MudItem>
            <MudItem xs="12" sm="4" lg="2">
                <MudSelect T="string" Label="@Localizer["Units_FilterProperty"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="_selectedPropertyFilter">
                    <MudSelectItem T="string" Value="@string.Empty">@Localizer["Units_FilterAllProperties"]</MudSelectItem>
                    @foreach (var property in _properties)
                    {
                        <MudSelectItem T="string" Value="@property.Name">@property.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4" lg="2">
                <MudSelect T="string" Label="@Localizer["Units_FilterStatus"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="_selectedOccupancyFilter">
                    <MudSelectItem T="string" Value="@string.Empty">@Localizer["Units_FilterAllStatuses"]</MudSelectItem>
                    <MudSelectItem T="string" Value='@Localizer["Units_Occupied"].Value'>@Localizer["Units_Occupied"]</MudSelectItem>
                    <MudSelectItem T="string" Value='@Localizer["Units_Vacant"].Value'>@Localizer["Units_Vacant"]</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4" lg="2">
                <MudSelect T="string" Label="@Localizer["Units_FilterBedrooms"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="_selectedBedroomFilter">
                    <MudSelectItem T="string" Value="@string.Empty">@Localizer["Units_FilterAllLayouts"]</MudSelectItem>
                    @foreach (var option in BedroomOptions)
                    {
                        <MudSelectItem T="string" Value="@option">@option @Localizer["Units_BedroomAbbreviation"]</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" lg="2">
                <MudStack Row="true" Spacing="1" Class="properties-toolbar-actions">
                    @if (HasActiveFilters)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true" StartIcon="@Icons.Material.Filled.FilterAltOff" OnClick="ClearFilters">@Localizer["Common_Reset"]</MudButton>
                    }
                    @if (CurrentOrganization.CanManageData)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreatePanel">@Localizer["Units_AddUnit"]</MudButton>
                    }
                </MudStack>
            </MudItem>
        </MudGrid>
    }

    <MudGrid Spacing="2">
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["Units_StatShown"]</MudText><MudText Typo="Typo.h6">@FilteredUnits.Count()</MudText></MudPaper></MudItem>
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["Units_StatVacant"]</MudText><MudText Typo="Typo.h6">@FilteredUnits.Count(x => !x.IsOccupied)</MudText></MudPaper></MudItem>
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["Units_StatMonthlyRent"]</MudText><MudText Typo="Typo.h6">@FilteredUnits.Sum(x => x.MonthlyRent).ToString("C")</MudText></MudPaper></MudItem>
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["Units_StatPropertiesCovered"]</MudText><MudText Typo="Typo.h6">@FilteredUnits.Select(x => x.PropertyId).Distinct().Count()</MudText></MudPaper></MudItem>
    </MudGrid>

    <MudExpansionPanels>
        <MudExpansionPanel Text="@Localizer["Common_BulkImport"]">
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.h6">@Localizer["Common_QuickCsvImport"]</MudText>
                <MudText Typo="Typo.body2" Class="mb-2">@Localizer["Units_CsvFormatHint"]</MudText>
                <MudTextField Lines="5" Variant="Variant.Outlined" @bind-Value="_csvInput" FullWidth="true" />
                @if (CurrentOrganization.CanManageData)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" Class="mt-3" OnClick="ImportCsvAsync">@Localizer["Common_ImportCsvText"]</MudButton>
                }
                @if (!string.IsNullOrWhiteSpace(_importResult))
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3 mb-0">@_importResult</MudAlert>
                }
            </MudPaper>
        </MudExpansionPanel>
    </MudExpansionPanels>

    <MudPaper Class="pa-2 table-wrap properties-table-shell">
        <MudTable Items="FilteredUnits.ToList()" Dense="true" Hover="true" Breakpoint="Breakpoint.Md" RowsPerPage="10">
            <HeaderContent>
                <MudTh>@Localizer["Units_ColumnUnit"]</MudTh>
                <MudTh>@Localizer["Units_ColumnProperty"]</MudTh>
                <MudTh>@Localizer["Units_ColumnLayout"]</MudTh>
                <MudTh>@Localizer["Units_ColumnRent"]</MudTh>
                <MudTh>@Localizer["Units_ColumnStatus"]</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="@Localizer["Units_ColumnUnit"]">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2">@context.UnitNumber</MudText>
                        <MudText Typo="Typo.caption" Class="property-address">@GetUnitSummary(context)</MudText>
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="@Localizer["Units_ColumnProperty"]"><MudButton Href="@GetPropertyRoute(context.PropertyId)" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small">@GetPropertyName(context.PropertyId)</MudButton></MudTd>
                <MudTd DataLabel="@Localizer["Units_ColumnLayout"]">@GetLayoutLabel(context.Bedrooms, context.Bathrooms)</MudTd>
                <MudTd DataLabel="@Localizer["Units_ColumnRent"]">@context.MonthlyRent.ToString("C")</MudTd>
                <MudTd DataLabel="@Localizer["Units_ColumnStatus"]"><MudChip T="string" Variant="Variant.Filled" Color="@(context.IsOccupied ? Color.Success : Color.Warning)">@GetOccupancyLabel(context)</MudChip></MudTd>
                <MudTd DataLabel="@Localizer["Units_ColumnActions"]">
                    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                        <MudButton Href="@GetPropertyRoute(context.PropertyId)" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small">@Localizer["Common_PropertyProfile"]</MudButton>
                        @if (CurrentOrganization.CanManageData)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small" OnClick="() => OpenEditPanel(context)">@Localizer["Common_Edit"]</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteAsync(context.Id)">@Localizer["Common_Delete"]</MudButton>
                        }
                    </MudStack>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudStack Class="pa-6 properties-empty-state" Spacing="1" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.MeetingRoom" Size="Size.Large" Color="Color.Default" />
                    <MudText Typo="Typo.subtitle1">@Localizer["Units_NoRecordsTitle"]</MudText>
                    <MudText Typo="Typo.body2">@Localizer["Units_NoRecordsSubtitle"]</MudText>
                    @if (HasActiveFilters)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ClearFilters">@Localizer["Common_ResetFilters"]</MudButton>
                    }
                </MudStack>
            </NoRecordsContent>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>

    @if (_isFormPanelOpen)
    {
        <div class="property-form-backdrop" @onclick="CloseFormPanel">
            <MudPaper Class="pa-5 property-form-drawer" Elevation="0" @onclick:stopPropagation="true">
                <MudStack Spacing="3">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h5">@(_isCreateMode ? Localizer["Units_DrawerAddTitle"] : Localizer["Units_DrawerEditTitle"])</MudText>
                            <MudText Typo="Typo.body2">@Localizer["Units_DrawerSubtitle"]</MudText>
                        </MudStack>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="CloseFormPanel" />
                    </MudStack>

                    <EditForm Model="ActiveUnit" OnValidSubmit="SaveFormAsync">
                        <MudGrid Spacing="2">
                            <MudItem xs="12" md="6"><MudTextField Label="@Localizer["Units_FormUnitNumber"]" Variant="Variant.Outlined" @bind-Value="ActiveUnit.UnitNumber" /></MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="Guid?" Label="@Localizer["Units_ColumnProperty"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="FormPropertyId">
                                    <MudSelectItem T="Guid?" Value="@((Guid?)null)">@Localizer["Units_FormSelectProperty"]</MudSelectItem>
                                    @foreach (var property in _properties)
                                    {
                                        <MudSelectItem T="Guid?" Value="@((Guid?)property.Id)">@property.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="4"><MudNumericField T="int" Label="@Localizer["Units_FilterBedrooms"]" Variant="Variant.Outlined" @bind-Value="ActiveUnit.Bedrooms" /></MudItem>
                            <MudItem xs="12" md="4"><MudNumericField T="int" Label="@Localizer["Units_FormBathrooms"]" Variant="Variant.Outlined" @bind-Value="ActiveUnit.Bathrooms" /></MudItem>
                            <MudItem xs="12" md="4"><MudNumericField T="decimal" Label="@Localizer["Units_StatMonthlyRent"]" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentText="$" @bind-Value="ActiveUnit.MonthlyRent" /></MudItem>
                            <MudItem xs="12"><MudSwitch T="bool" Color="Color.Primary" Label="@Localizer["Units_FormMarkedOccupied"]" @bind-Value="ActiveUnit.IsOccupied" /></MudItem>
                            <MudItem xs="12"><MudPaper Class="pa-3 property-detail-panel" Elevation="0"><MudText Typo="Typo.subtitle2">@Localizer["Units_FormExecutionNote"]</MudText><MudText Typo="Typo.body2">@GetFormGuidance()</MudText></MudPaper></MudItem>
                        </MudGrid>

                        <MudStack Row="true" Spacing="2" Class="mt-4" Justify="Justify.FlexEnd">
                            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CloseFormPanel">@Localizer["Common_Cancel"]</MudButton>
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">@(_isCreateMode ? Localizer["Units_Create"] : Localizer["Common_SaveChanges"])</MudButton>
                        </MudStack>
                    </EditForm>
                </MudStack>
            </MudPaper>
        </div>
    }
</MudStack>

@code {
    [SupplyParameterFromQuery(Name = "demo")] public string? DemoMode { get; set; }

    private List<Unit> _items = new();
    private List<Property> _properties = new();
    private Unit _newUnit = new();
    private Unit _editUnit = new();
    private string _csvInput = string.Empty;
    private string? _importResult;
    private string _searchText = string.Empty;
    private string _selectedPropertyFilter = string.Empty;
    private string _selectedOccupancyFilter = string.Empty;
    private string _selectedBedroomFilter = string.Empty;
    private bool _isFormPanelOpen;
    private bool _isCreateMode = true;
    private bool IsDemoCleanView => DemoModeRouteHelper.IsClean(DemoMode);

    private bool HasActiveFilters => !string.IsNullOrWhiteSpace(_searchText) || !string.IsNullOrWhiteSpace(_selectedPropertyFilter) || !string.IsNullOrWhiteSpace(_selectedOccupancyFilter) || !string.IsNullOrWhiteSpace(_selectedBedroomFilter);
    private Unit ActiveUnit => _isCreateMode ? _newUnit : _editUnit;
    private IEnumerable<string> BedroomOptions => _items.Select(x => x.Bedrooms.ToString()).Distinct().OrderBy(x => int.Parse(x));

    private Guid? FormPropertyId
    {
        get => ActiveUnit.PropertyId == Guid.Empty ? null : ActiveUnit.PropertyId;
        set => ActiveUnit.PropertyId = value ?? Guid.Empty;
    }

    private string WithDemoMode(string route)
        => DemoModeRouteHelper.Apply(route, IsDemoCleanView);

    private IEnumerable<Unit> FilteredUnits => _items
        .Where(unit => string.IsNullOrWhiteSpace(_searchText)
            || unit.UnitNumber.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || GetPropertyName(unit.PropertyId).Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || GetUnitSummary(unit).Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || GetOccupancyLabel(unit).Contains(_searchText, StringComparison.OrdinalIgnoreCase))
        .Where(unit => string.IsNullOrWhiteSpace(_selectedPropertyFilter) || string.Equals(GetPropertyName(unit.PropertyId), _selectedPropertyFilter, StringComparison.OrdinalIgnoreCase))
        .Where(unit => string.IsNullOrWhiteSpace(_selectedOccupancyFilter) || string.Equals(GetOccupancyLabel(unit), _selectedOccupancyFilter, StringComparison.OrdinalIgnoreCase))
        .Where(unit => string.IsNullOrWhiteSpace(_selectedBedroomFilter) || string.Equals(unit.Bedrooms.ToString(), _selectedBedroomFilter, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _items = await DataService.GetUnitsAsync();
        _properties = await DataService.GetPropertiesAsync();
    }

    private void OpenCreatePanel()
    {
        _isCreateMode = true;
        _newUnit = new Unit();
        _isFormPanelOpen = true;
    }

    private void OpenEditPanel(Unit unit)
    {
        _isCreateMode = false;
        _editUnit = new Unit
        {
            Id = unit.Id,
            PropertyId = unit.PropertyId,
            UnitNumber = unit.UnitNumber,
            Bedrooms = unit.Bedrooms,
            Bathrooms = unit.Bathrooms,
            MonthlyRent = unit.MonthlyRent,
            IsOccupied = unit.IsOccupied
        };
        _isFormPanelOpen = true;
    }

    private void CloseFormPanel()
    {
        _isFormPanelOpen = false;
        _isCreateMode = true;
    }

    private async Task SaveFormAsync()
    {
        if (ActiveUnit.PropertyId == Guid.Empty)
        {
            return;
        }

        if (_isCreateMode)
        {
            await DataService.AddUnitAsync(_newUnit);
            _newUnit = new Unit();
        }
        else
        {
            await DataService.UpdateUnitAsync(_editUnit);
            _editUnit = new Unit();
        }

        await ReloadAsync();
        CloseFormPanel();
    }

    private async Task DeleteAsync(Guid id)
    {
        await DataService.DeleteUnitAsync(id);
        await ReloadAsync();
    }

    private void ClearFilters()
    {
        _searchText = string.Empty;
        _selectedPropertyFilter = string.Empty;
        _selectedOccupancyFilter = string.Empty;
        _selectedBedroomFilter = string.Empty;
    }

    private async Task ImportCsvAsync()
    {
        var imported = 0;
        var skipped = 0;
        var lines = _csvInput.Split(new[] { "\r\n", "\n" }, StringSplitOptions.RemoveEmptyEntries);
        foreach (var line in lines)
        {
            var parts = line.Split(',');
            if (parts.Length < 5)
            {
                skipped++;
                continue;
            }

            var propertyName = parts[0].Trim();
            var unitNumber = parts[1].Trim();
            var property = _properties.FirstOrDefault(x => string.Equals(x.Name, propertyName, StringComparison.OrdinalIgnoreCase));
            if (property is null || string.IsNullOrWhiteSpace(unitNumber) || !int.TryParse(parts[2], out var beds) || !int.TryParse(parts[3], out var baths) || !decimal.TryParse(parts[4], out var rent))
            {
                skipped++;
                continue;
            }

            if (_items.Any(x => x.PropertyId == property.Id && string.Equals(x.UnitNumber, unitNumber, StringComparison.OrdinalIgnoreCase)))
            {
                skipped++;
                continue;
            }

            await DataService.AddUnitAsync(new Unit
            {
                PropertyId = property.Id,
                UnitNumber = unitNumber,
                Bedrooms = beds,
                Bathrooms = baths,
                MonthlyRent = rent
            });
            imported++;
        }

        _csvInput = string.Empty;
        await ReloadAsync();
        _importResult = string.Format(Localizer["Units_ImportResult"].Value, imported, skipped);
    }

    private string GetPropertyName(Guid propertyId)
        => _properties.FirstOrDefault(x => x.Id == propertyId)?.Name ?? Localizer["Units_UnknownProperty"].Value;

    private string GetPropertyRoute(Guid propertyId)
        => WithDemoMode($"/properties/{propertyId}");

    private string GetLayoutLabel(int bedrooms, int bathrooms)
        => $"{bedrooms} {Localizer["Units_BedroomAbbreviation"].Value} / {bathrooms} {Localizer["Units_BathroomAbbreviation"].Value}";

    private string GetUnitSummary(Unit unit)
        => $"{GetLayoutLabel(unit.Bedrooms, unit.Bathrooms)} • {GetOccupancyLabel(unit)}";

    private string GetOccupancyLabel(Unit unit)
        => unit.IsOccupied ? Localizer["Units_Occupied"].Value : Localizer["Units_Vacant"].Value;

    private string GetFormGuidance()
    {
        if (ActiveUnit.PropertyId == Guid.Empty)
        {
            return Localizer["Units_GuidanceSelectProperty"].Value;
        }

        return ActiveUnit.IsOccupied
            ? Localizer["Units_GuidanceOccupied"].Value
            : Localizer["Units_GuidanceVacant"].Value;
    }
}
