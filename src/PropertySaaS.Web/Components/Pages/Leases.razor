@attribute [Authorize]
@page "/leases"
@inject SaasDataService DataService
@inject NavigationManager NavigationManager
@inject PropertySaaS.Application.Common.CurrentOrganization CurrentOrganization
@inject IStringLocalizer<SharedResource> Localizer
@using PropertySaaS.Domain.Enums
@using PropertySaaS.Application.Features
@using PropertySaaS.Web.Localization

<PageTitle>@Localizer["Leases_Title"]</PageTitle>

<MudStack Spacing="3">
    <MudStack Spacing="0">
        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" Class="mb-2">@UiText.Get("Leases_PremiumBadge")</MudChip>
        <MudText Typo="Typo.h4">@Localizer["Leases_Title"]</MudText>
        <MudText Typo="Typo.body2">@Localizer["Leases_Subtitle"]</MudText>
    </MudStack>

    <DemoJourneyBanner CurrentStepKey="resident" ResidentRoute="@Resident360Route" />

    <MudGrid Spacing="2" Class="align-center-grid">
        <MudItem xs="12" lg="4">
            <MudTextField T="string"
                          Label="@Localizer["Leases_SearchLabel"]"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          @bind-Value="_searchText"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Placeholder="@Localizer["Leases_SearchPlaceholder"]" />
        </MudItem>
        <MudItem xs="12" sm="4" lg="2">
            <MudSelect T="string" Label="@Localizer["Leases_FilterStatus"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="_selectedStatusFilter">
                <MudSelectItem T="string" Value="@string.Empty">@Localizer["Leases_FilterAllStatuses"]</MudSelectItem>
                @foreach (var option in StatusOptions)
                {
                    <MudSelectItem T="string" Value="@option.ToString()">@GetLeaseStatusLabel(option)</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="4" lg="2">
            <MudSelect T="string" Label="@Localizer["Leases_FilterJurisdictionLease"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="_selectedOntarioFilter">
                <MudSelectItem T="string" Value="@string.Empty">@Localizer["Leases_FilterAll"]</MudSelectItem>
                <MudSelectItem T="string" Value='@Localizer["Leases_OntarioSigned"].Value'>@Localizer["Leases_OntarioSigned"]</MudSelectItem>
                <MudSelectItem T="string" Value='@Localizer["Leases_OntarioMissing"].Value'>@Localizer["Leases_OntarioMissing"]</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="4" lg="2">
            <MudSelect T="string" Label="@Localizer["Leases_FilterNoticeWorkflow"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="_selectedWorkflowFilter">
                <MudSelectItem T="string" Value="@string.Empty">@Localizer["Leases_FilterAll"]</MudSelectItem>
                <MudSelectItem T="string" Value='@Localizer["Leases_WorkflowScheduled"].Value'>@Localizer["Leases_WorkflowScheduled"]</MudSelectItem>
                <MudSelectItem T="string" Value='@Localizer["Leases_WorkflowNotScheduled"].Value'>@Localizer["Leases_WorkflowNotScheduled"]</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" lg="2">
            <MudStack Row="true" Spacing="1" Class="properties-toolbar-actions">
                @if (HasActiveFilters)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true" StartIcon="@Icons.Material.Filled.FilterAltOff" OnClick="ClearFilters">@Localizer["Common_Reset"]</MudButton>
                }
                @if (CurrentOrganization.CanManageData)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreatePanel">@Localizer["Leases_AddLease"]</MudButton>
                }
            </MudStack>
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="2">
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["Leases_StatShown"]</MudText><MudText Typo="Typo.h6">@FilteredLeases.Count()</MudText></MudPaper></MudItem>
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["Leases_StatActiveRent"]</MudText><MudText Typo="Typo.h6">@FilteredLeases.Sum(x => x.MonthlyRent).ToString("C")</MudText></MudPaper></MudItem>
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["Leases_StatJurisdictionMissing"]</MudText><MudText Typo="Typo.h6">@FilteredLeases.Count(x => !x.StandardOntarioLeaseSigned)</MudText></MudPaper></MudItem>
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["Leases_StatNoticeScheduled"]</MudText><MudText Typo="Typo.h6">@FilteredLeases.Count(x => x.N1IncreaseNoticeScheduled)</MudText></MudPaper></MudItem>
    </MudGrid>

    <MudPaper Class="pa-4 property-detail-panel" Elevation="0">
        <MudText Typo="Typo.h6">@UiText.Get("Leases_InsightTitle")</MudText>
        <MudGrid Spacing="2" Class="mt-2">
            <MudItem xs="12" md="4"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@UiText.Get("Leases_InsightUrgency")</MudText><MudChip T="string" Variant="Variant.Outlined" Color="@InsightColor" Class="mt-2">@InsightUrgencyLabel</MudChip></MudPaper></MudItem>
            <MudItem xs="12" md="4"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@UiText.Get("Leases_InsightFocus")</MudText><MudChip T="string" Variant="Variant.Outlined" Color="@InsightColor" Class="mt-2">@InsightFocusLabel</MudChip></MudPaper></MudItem>
            <MudItem xs="12" md="4"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@UiText.Get("Leases_InsightNextAction")</MudText><MudButton Class="mt-2" Variant="Variant.Text" Color="@InsightColor" OnClick="OpenInsightNextActionAsync">@InsightActionLabel</MudButton></MudPaper></MudItem>
        </MudGrid>
        <MudText Typo="Typo.body2" Class="mt-3">@InsightMessage</MudText>
    </MudPaper>

    <MudPaper Class="pa-4 marketing-card" Elevation="0">
        <MudText Typo="Typo.h6">@UiText.Get("Leases_MoveInTitle")</MudText>
        @if (PriorityMoveInLease is null)
        {
            <MudText Typo="Typo.body2" Class="mt-2">@UiText.Get("Leases_MoveInEmpty")</MudText>
        }
        else
        {
            <MudText Typo="Typo.subtitle2" Class="mt-2">@GetTenantLabel(PriorityMoveInLease.TenantId) - @GetUnitLabel(PriorityMoveInLease.UnitId)</MudText>
            <MudText Typo="Typo.body2">@(PriorityMoveInLease.StandardOntarioLeaseSigned ? UiText.Get("Leases_MoveInStatusReady") : UiText.Get("Leases_MoveInStatusDraft"))</MudText>
            <MudList T="string" Dense="true" Class="mt-3">
                <MudListItem T="string">@UiText.Get("Leases_MoveInChecklist1")</MudListItem>
                <MudListItem T="string">@UiText.Get("Leases_MoveInChecklist2")</MudListItem>
                <MudListItem T="string">@UiText.Get("Leases_MoveInChecklist3")</MudListItem>
                <MudListItem T="string">@UiText.Get("Leases_MoveInChecklist4")</MudListItem>
            </MudList>
            <MudStack Row="true" Spacing="1" Class="mt-3" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick='() => OpenLeaseConversationAsync(PriorityMoveInLease.Id)'>@UiText.Get("Leases_MoveInOpenCommunication")</MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick='() => OpenLeaseMoveInOutreachDraftAsync(PriorityMoveInLease.Id)'>@UiText.Get("Leases_MoveInOpenOutreachDraft")</MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Default" OnClick='() => OpenLeaseNoticeDeliveryDraftAsync(PriorityMoveInLease.Id)'>@UiText.Get("Leases_MoveInOpenNoticeDeliveryDraft")</MudButton>
                @if (!PriorityMoveInLease.StandardOntarioLeaseSigned)
                {
                    <MudButton Variant="Variant.Text" Color="Color.Warning" OnClick='() => CompleteMoveInStepAsync(PriorityMoveInLease.Id, true, false)'>@UiText.Get("Leases_MoveInMarkSigned")</MudButton>
                }
                @if (PriorityMoveInLease.Status == LeaseStatus.Draft)
                {
                    <MudButton Variant="Variant.Text" Color="Color.Success" OnClick='() => CompleteMoveInStepAsync(PriorityMoveInLease.Id, true, true)'>@UiText.Get("Leases_MoveInMarkActive")</MudButton>
                }
            </MudStack>

            <MudDivider Class="my-3" />
            <MudText Typo="Typo.subtitle2">@UiText.Get("Leases_MoveInPackageTitle")</MudText>
            <MudGrid Spacing="2" Class="mt-1">
                <MudItem xs="12" md="4"><MudSwitch T="bool" Color="Color.Primary" Label="@UiText.Get("Leases_MoveInDeposit")" @bind-Value="_moveInDepositReceived" /></MudItem>
                <MudItem xs="12" md="4"><MudSwitch T="bool" Color="Color.Primary" Label="@UiText.Get("Leases_MoveInInsurance")" @bind-Value="_moveInInsuranceReceived" /></MudItem>
                <MudItem xs="12" md="4"><MudSwitch T="bool" Color="Color.Primary" Label="@UiText.Get("Leases_MoveInChecklist")" @bind-Value="_moveInChecklistCompleted" /></MudItem>
                <MudItem xs="12"><MudTextField Label="@UiText.Get("Leases_MoveInNotes")" Variant="Variant.Outlined" Lines="3" @bind-Value="_moveInNotes" /></MudItem>
            </MudGrid>
            <MudButton Class="mt-3" Variant="Variant.Filled" Color="Color.Primary" OnClick='() => SaveMoveInPackageAsync(PriorityMoveInLease.Id)'>@UiText.Get("Leases_MoveInSave")</MudButton>

            <MudDivider Class="my-3" />
            <MudText Typo="Typo.subtitle2">@UiText.Get("Leases_MoveInRequirementsTitle")</MudText>
            <MudText Typo="Typo.body2" Class="mt-2">@UiText.Get("Leases_MoveInAutoloadHint")</MudText>
            @if (string.Equals(CurrentOrganization.Province, "ON", StringComparison.OrdinalIgnoreCase))
            {
                <MudStack Row="true" Spacing="1" Class="mt-2" Wrap="Wrap.Wrap">
                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">@UiText.Get("Leases_MoveInOfficialOntarioDocs")</MudChip>
                    <MudButton Href="/docs/ontario-standard-lease" Target="_blank" Variant="Variant.Text" Color="Color.Primary">@UiText.Get("Leases_MoveInOfficialLease")</MudButton>
                    <MudButton Href="/docs/n1-template" Target="_blank" Variant="Variant.Text" Color="Color.Default">@UiText.Get("Leases_MoveInOfficialN1")</MudButton>
                    <MudButton Href="/docs/n4-template" Target="_blank" Variant="Variant.Text" Color="Color.Default">@UiText.Get("Leases_MoveInOfficialN4")</MudButton>
                </MudStack>
            }
            <MudGrid Spacing="2" Class="mt-2">
                @foreach (var requirement in _leaseMoveInRequirements)
                {
                    <MudItem xs="12" md="6">
                        <MudPaper Class="pa-3 property-detail-panel" Elevation="0">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.subtitle2">@requirement.Label</MudText>
                                <MudChip T="string" Variant="Variant.Outlined" Color="@(requirement.IsCompleted ? Color.Success : Color.Warning)">@requirement.StatusLabel</MudChip>
                            </MudStack>
                            <MudText Typo="Typo.caption" Class="mt-1">@requirement.Guidance</MudText>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>

            <MudDivider Class="my-3" />
            <MudText Typo="Typo.subtitle2">@UiText.Get("Leases_MoveInDocumentsTitle")</MudText>
            @if (!_leaseMoveInDocuments.Any())
            {
                <MudText Typo="Typo.body2" Class="mt-2">@UiText.Get("Leases_MoveInDocumentsEmpty")</MudText>
            }
            else
            {
                <MudList T="LeaseMoveInDocumentDto" Dense="true" Class="mt-2">
                    @foreach (var document in _leaseMoveInDocuments)
                    {
                        <MudListItem T="LeaseMoveInDocumentDto" Value="document">
                            <MudText Typo="Typo.subtitle2">@document.FileName</MudText>
                            <MudText Typo="Typo.caption">@GetMoveInDocumentTypeLabel(document.DocumentType)</MudText>
                            <MudText Typo="Typo.caption">@document.Caption</MudText>
                            <MudStack Row="true" Spacing="2">
                                @if (!string.IsNullOrWhiteSpace(document.OfficialUrl))
                                {
                                    <MudLink Href="@document.OfficialUrl" Target="_blank" Typo="Typo.caption">@UiText.Get("Leases_MoveInDocumentOfficialSource")</MudLink>
                                }
                                @if (PriorityMoveInLease is not null && IsInternalTemplateDocument(document.DocumentType))
                                {
                                    <MudLink Href="@GetInternalTemplateUrl(PriorityMoveInLease.Id, document.DocumentType)" Target="_blank" Typo="Typo.caption">@UiText.Get("Leases_MoveInDocumentInternalTemplate")</MudLink>
                                }
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            }

            <MudGrid Spacing="2" Class="mt-1">
                <MudItem xs="12" md="3">
                    <MudSelect T="string" Label="@UiText.Get("Leases_MoveInDocumentType")" Variant="Variant.Outlined" @bind-Value="_newMoveInDocumentType">
                        @foreach (var option in MoveInDocumentTypeOptions)
                        {
                            <MudSelectItem T="string" Value="@option">@GetMoveInDocumentTypeLabel(option)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4"><MudTextField Label="@UiText.Get("Leases_MoveInDocumentsName")" Variant="Variant.Outlined" @bind-Value="_newMoveInDocumentName" /></MudItem>
                <MudItem xs="12" md="3"><MudTextField Label="@UiText.Get("Leases_MoveInDocumentsCaption")" Variant="Variant.Outlined" @bind-Value="_newMoveInDocumentCaption" /></MudItem>
                <MudItem xs="12" md="2" Class="d-flex align-end"><MudButton Variant="Variant.Outlined" Color="Color.Secondary" FullWidth="true" OnClick='() => AddMoveInDocumentAsync(PriorityMoveInLease.Id)'>@UiText.Get("Leases_MoveInDocumentsAdd")</MudButton></MudItem>
            </MudGrid>
            @if (_activationBlocked)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-3 mb-0">@UiText.Get("Leases_MoveInActivationBlocked")</MudAlert>
            }
        }
    </MudPaper>

    <MudExpansionPanels>
        <MudExpansionPanel Text="@Localizer["Common_BulkImport"]">
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.h6">@Localizer["Common_QuickCsvImport"]</MudText>
                <MudText Typo="Typo.body2" Class="mb-2">@Localizer["Leases_CsvFormatHint"]</MudText>
                <MudTextField Lines="5" Variant="Variant.Outlined" @bind-Value="_csvInput" FullWidth="true" />
                @if (CurrentOrganization.CanManageData)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" Class="mt-3" OnClick="ImportCsvAsync">@Localizer["Common_ImportCsvText"]</MudButton>
                }
                @if (!string.IsNullOrWhiteSpace(_importResult))
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3 mb-0">@_importResult</MudAlert>
                }
            </MudPaper>
        </MudExpansionPanel>
    </MudExpansionPanels>

    <MudPaper Class="pa-2 table-wrap properties-table-shell">
        <MudTable Items="FilteredLeases.ToList()" Dense="true" Hover="true" Breakpoint="Breakpoint.Md" RowsPerPage="10">
            <HeaderContent>
                <MudTh>@Localizer["Leases_ColumnUnit"]</MudTh>
                <MudTh>@Localizer["Leases_ColumnTenant"]</MudTh>
                <MudTh>@Localizer["Leases_ColumnTerm"]</MudTh>
                <MudTh>@Localizer["Leases_ColumnRent"]</MudTh>
                <MudTh>@Localizer["Leases_ColumnStatus"]</MudTh>
                <MudTh>@Localizer["Leases_ColumnJurisdiction"]</MudTh>
                <MudTh>@Localizer["Leases_ColumnNotice"]</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="@Localizer["Leases_ColumnUnit"]">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2">@GetUnitLabel(context.UnitId)</MudText>
                        <MudText Typo="Typo.caption" Class="property-address">@GetPropertyLabelForLease(context)</MudText>
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="@Localizer["Leases_ColumnTenant"]">@GetTenantLabel(context.TenantId)</MudTd>
                <MudTd DataLabel="@Localizer["Leases_ColumnTerm"]">@GetTermLabel(context)</MudTd>
                <MudTd DataLabel="@Localizer["Leases_ColumnRent"]">@context.MonthlyRent.ToString("C")</MudTd>
                <MudTd DataLabel="@Localizer["Leases_ColumnStatus"]"><MudChip T="string" Variant="Variant.Filled" Color="@GetStatusColor(context.Status)">@GetLeaseStatusLabel(context.Status)</MudChip></MudTd>
                <MudTd DataLabel="@Localizer["Leases_ColumnJurisdiction"]"><MudChip T="string" Variant="Variant.Outlined" Color="@(context.StandardOntarioLeaseSigned ? Color.Success : Color.Warning)">@GetOntarioLabel(context)</MudChip></MudTd>
                <MudTd DataLabel="@Localizer["Leases_ColumnNotice"]">@GetWorkflowLabel(context)</MudTd>
                <MudTd DataLabel="@Localizer["Leases_ColumnActions"]">
                    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                        <MudButton Href="@GetPropertyHref(context)" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small">@Localizer["Common_PropertyProfile"]</MudButton>
                        @if (CurrentOrganization.CanManageData)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small" OnClick="() => OpenEditPanel(context)">@Localizer["Common_Edit"]</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteAsync(context.Id)">@Localizer["Common_Delete"]</MudButton>
                        }
                    </MudStack>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudStack Class="pa-6 properties-empty-state" Spacing="1" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" Color="Color.Default" />
                    <MudText Typo="Typo.subtitle1">@Localizer["Leases_NoRecordsTitle"]</MudText>
                    <MudText Typo="Typo.body2">@Localizer["Leases_NoRecordsSubtitle"]</MudText>
                    @if (HasActiveFilters)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ClearFilters">@Localizer["Common_ResetFilters"]</MudButton>
                    }
                </MudStack>
            </NoRecordsContent>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>

    @if (_isFormPanelOpen)
    {
        <div class="property-form-backdrop" @onclick="CloseFormPanel">
            <MudPaper Class="pa-5 property-form-drawer" Elevation="0" @onclick:stopPropagation="true">
                <MudStack Spacing="3">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h5">@(_isCreateMode ? Localizer["Leases_AddLease"] : Localizer["Leases_DrawerEditTitle"])</MudText>
                            <MudText Typo="Typo.body2">@Localizer["Leases_DrawerSubtitle"]</MudText>
                        </MudStack>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="CloseFormPanel" />
                    </MudStack>

                    <EditForm Model="ActiveLease" OnValidSubmit="SaveFormAsync">
                        <MudGrid Spacing="2">
                            <MudItem xs="12" md="6">
                                <MudSelect T="Guid?" Label="@Localizer["Leases_ColumnUnit"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="FormUnitId">
                                    <MudSelectItem T="Guid?" Value="@((Guid?)null)">@Localizer["Leases_FormSelectUnit"]</MudSelectItem>
                                    @foreach (var unit in _units)
                                    {
                                        <MudSelectItem T="Guid?" Value="@((Guid?)unit.Id)">@GetUnitDisplay(unit)</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="Guid?" Label="@Localizer["Leases_ColumnTenant"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="FormTenantId">
                                    <MudSelectItem T="Guid?" Value="@((Guid?)null)">@Localizer["Leases_FormSelectTenant"]</MudSelectItem>
                                    @foreach (var tenant in _tenants)
                                    {
                                        <MudSelectItem T="Guid?" Value="@((Guid?)tenant.Id)">@tenant.FullName</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="4"><MudDatePicker Label="@Localizer["Leases_FormStartDate"]" Variant="Variant.Outlined" @bind-Date="_formStartDate" Editable="true" /></MudItem>
                            <MudItem xs="12" md="4"><MudDatePicker Label="@Localizer["Leases_FormEndDate"]" Variant="Variant.Outlined" @bind-Date="_formEndDate" Editable="true" /></MudItem>
                            <MudItem xs="12" md="4"><MudNumericField T="decimal" Label="@Localizer["Leases_FormMonthlyRent"]" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentText="$" @bind-Value="ActiveLease.MonthlyRent" /></MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="LeaseStatus" Label="@Localizer["Leases_FilterStatus"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="ActiveLease.Status">
                                    @foreach (var status in Enum.GetValues<LeaseStatus>())
                                    {
                                        <MudSelectItem T="LeaseStatus" Value="@status">@GetLeaseStatusLabel(status)</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="3"><MudSwitch T="bool" Color="Color.Primary" Label="@Localizer["Leases_FormJurisdictionLeaseSigned"]" @bind-Value="ActiveLease.StandardOntarioLeaseSigned" /></MudItem>
                            <MudItem xs="12" md="3"><MudSwitch T="bool" Color="Color.Primary" Label="@Localizer["Leases_StatNoticeScheduled"]" @bind-Value="ActiveLease.N1IncreaseNoticeScheduled" /></MudItem>
                            <MudItem xs="12"><MudPaper Class="pa-3 property-detail-panel" Elevation="0"><MudText Typo="Typo.subtitle2">@Localizer["Leases_FormExecutionNote"]</MudText><MudText Typo="Typo.body2">@GetLeaseGuidance()</MudText></MudPaper></MudItem>
                        </MudGrid>

                        <MudStack Row="true" Spacing="2" Class="mt-4" Justify="Justify.FlexEnd">
                            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CloseFormPanel">@Localizer["Common_Cancel"]</MudButton>
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">@(_isCreateMode ? Localizer["Leases_Create"] : Localizer["Common_SaveChanges"])</MudButton>
                        </MudStack>
                    </EditForm>
                </MudStack>
            </MudPaper>
        </div>
    }
</MudStack>

@code {
    [SupplyParameterFromQuery] public Guid? TenantId { get; set; }

    private List<Lease> _items = new();
    private List<Unit> _units = new();
    private List<Tenant> _tenants = new();
    private List<Property> _properties = new();
    private Lease _newLease = new() { Status = LeaseStatus.Active, StandardOntarioLeaseSigned = true };
    private Lease _editLease = new() { Status = LeaseStatus.Active, StandardOntarioLeaseSigned = true };
    private DateTime? _formStartDate = DateTime.Today;
    private DateTime? _formEndDate = DateTime.Today.AddYears(1);
    private string _csvInput = string.Empty;
    private string? _importResult;
    private string _searchText = string.Empty;
    private string _selectedStatusFilter = string.Empty;
    private string _selectedOntarioFilter = string.Empty;
    private string _selectedWorkflowFilter = string.Empty;
    private bool _isFormPanelOpen;
    private bool _isCreateMode = true;
    private bool _moveInDepositReceived;
    private bool _moveInInsuranceReceived;
    private bool _moveInChecklistCompleted;
    private string _moveInNotes = string.Empty;
    private List<LeaseMoveInDocumentDto> _leaseMoveInDocuments = new();
    private List<LeaseMoveInRequirementDto> _leaseMoveInRequirements = new();
    private LeaseMoveInContextDto? _leaseMoveInContext;
    private bool _activationBlocked;
    private string _newMoveInDocumentType = "SignedLease";
    private string _newMoveInDocumentName = string.Empty;
    private string _newMoveInDocumentCaption = string.Empty;

    private Lease? SelectedLease => TenantId.HasValue
        ? _items
            .Where(x => x.TenantId == TenantId.Value)
            .OrderByDescending(x => x.Status == LeaseStatus.Active || x.Status == LeaseStatus.EndingSoon)
            .ThenByDescending(x => x.StartDate)
            .FirstOrDefault()
        : null;

    private string Resident360Route => SelectedLease is not null ? $"/resident-360?tenantId={SelectedLease.TenantId}" : "/resident-360";

    private bool HasActiveFilters => !string.IsNullOrWhiteSpace(_searchText) || !string.IsNullOrWhiteSpace(_selectedStatusFilter) || !string.IsNullOrWhiteSpace(_selectedOntarioFilter) || !string.IsNullOrWhiteSpace(_selectedWorkflowFilter);
    private Lease ActiveLease => _isCreateMode ? _newLease : _editLease;
    private IEnumerable<LeaseStatus> StatusOptions => Enum.GetValues<LeaseStatus>();
    private IEnumerable<string> MoveInDocumentTypeOptions => new[] { "SignedLease", "InsuranceProof", "GovernmentId", "IncomeProof", "DepositReceipt" };
    private Lease? PriorityMoveInLease => SelectedLease ?? _items.FirstOrDefault(x => x.Status == LeaseStatus.Draft) ?? _items.FirstOrDefault(x => !x.StandardOntarioLeaseSigned);
    private Lease? PriorityNoticeLease => FilteredLeases.FirstOrDefault(x => x.N1IncreaseNoticeScheduled);
    private string InsightUrgencyLabel
        => PriorityMoveInLease is not null && (PriorityMoveInLease.Status == LeaseStatus.Draft || !PriorityMoveInLease.StandardOntarioLeaseSigned)
            ? UiText.Get("Leases_InsightUrgencyHigh")
            : FilteredLeases.Any(x => !x.StandardOntarioLeaseSigned) || PriorityNoticeLease is not null
                ? UiText.Get("Leases_InsightUrgencyMedium")
                : UiText.Get("Leases_InsightUrgencyStable");

    private string InsightFocusLabel
        => PriorityMoveInLease is not null && PriorityMoveInLease.Status == LeaseStatus.Draft
            ? UiText.Get("Leases_InsightFocusMoveIn")
            : FilteredLeases.Any(x => !x.StandardOntarioLeaseSigned)
                ? UiText.Get("Leases_InsightFocusJurisdiction")
                : PriorityNoticeLease is not null
                    ? UiText.Get("Leases_InsightFocusNoticeWorkflow")
                    : UiText.Get("Leases_InsightFocusStable");

    private string InsightMessage
        => PriorityMoveInLease is not null && PriorityMoveInLease.Status == LeaseStatus.Draft
            ? UiText.Get("Leases_InsightMessageMoveIn")
            : FilteredLeases.Any(x => !x.StandardOntarioLeaseSigned)
                ? UiText.Get("Leases_InsightMessageJurisdiction")
                : PriorityNoticeLease is not null
                    ? UiText.Get("Leases_InsightMessageNoticeWorkflow")
                    : UiText.Get("Leases_InsightMessageStable");

    private string InsightActionLabel
        => PriorityMoveInLease is not null && PriorityMoveInLease.Status == LeaseStatus.Draft
            ? UiText.Get("Leases_InsightOpenMoveIn")
            : FilteredLeases.Any(x => !x.StandardOntarioLeaseSigned)
                ? UiText.Get("Leases_InsightOpenJurisdiction")
                : PriorityNoticeLease is not null
                    ? UiText.Get("Leases_InsightOpenNotice")
                    : UiText.Get("Leases_InsightOpenStable");

    private Color InsightColor
        => PriorityMoveInLease is not null && PriorityMoveInLease.Status == LeaseStatus.Draft
            ? Color.Warning
            : FilteredLeases.Any(x => !x.StandardOntarioLeaseSigned)
                ? Color.Info
                : PriorityNoticeLease is not null
                    ? Color.Secondary
                    : Color.Success;

    private Guid? FormUnitId
    {
        get => ActiveLease.UnitId == Guid.Empty ? null : ActiveLease.UnitId;
        set => ActiveLease.UnitId = value ?? Guid.Empty;
    }

    private Guid? FormTenantId
    {
        get => ActiveLease.TenantId == Guid.Empty ? null : ActiveLease.TenantId;
        set => ActiveLease.TenantId = value ?? Guid.Empty;
    }

    private IEnumerable<Lease> FilteredLeases => _items
        .Where(lease => string.IsNullOrWhiteSpace(_searchText)
            || GetUnitLabel(lease.UnitId).Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || GetTenantLabel(lease.TenantId).Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || lease.Status.ToString().Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || GetOntarioLabel(lease).Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || GetWorkflowLabel(lease).Contains(_searchText, StringComparison.OrdinalIgnoreCase))
        .Where(lease => string.IsNullOrWhiteSpace(_selectedStatusFilter) || string.Equals(lease.Status.ToString(), _selectedStatusFilter, StringComparison.OrdinalIgnoreCase))
        .Where(lease => string.IsNullOrWhiteSpace(_selectedOntarioFilter) || string.Equals(GetOntarioLabel(lease), _selectedOntarioFilter, StringComparison.OrdinalIgnoreCase))
        .Where(lease => string.IsNullOrWhiteSpace(_selectedWorkflowFilter) || string.Equals(GetWorkflowLabel(lease), _selectedWorkflowFilter, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
        if (SelectedLease is not null)
        {
            _selectedStatusFilter = SelectedLease.Status.ToString();
        }
    }

    private async Task ReloadAsync()
    {
        _items = await DataService.GetLeasesAsync();
        _units = await DataService.GetUnitsAsync();
        _tenants = await DataService.GetTenantsAsync();
        _properties = await DataService.GetPropertiesAsync();
        _leaseMoveInDocuments = PriorityMoveInLease is null ? new List<LeaseMoveInDocumentDto>() : await DataService.GetLeaseMoveInDocumentsAsync(PriorityMoveInLease.Id);
        _leaseMoveInRequirements = PriorityMoveInLease is null ? new List<LeaseMoveInRequirementDto>() : await DataService.GetLeaseMoveInRequirementsAsync(PriorityMoveInLease.Id);
        _leaseMoveInContext = PriorityMoveInLease is null ? null : await DataService.GetLeaseMoveInContextAsync(PriorityMoveInLease.Id);
        SyncMoveInPackage();
    }

    private void OpenCreatePanel()
    {
        _isCreateMode = true;
        _newLease = new Lease { Status = LeaseStatus.Active, StandardOntarioLeaseSigned = true };
        _formStartDate = DateTime.Today;
        _formEndDate = DateTime.Today.AddYears(1);
        _isFormPanelOpen = true;
    }

    private void OpenEditPanel(Lease lease)
    {
        _isCreateMode = false;
        _editLease = new Lease
        {
            Id = lease.Id,
            UnitId = lease.UnitId,
            TenantId = lease.TenantId,
            StartDate = lease.StartDate,
            EndDate = lease.EndDate,
            MonthlyRent = lease.MonthlyRent,
            Status = lease.Status,
            StandardOntarioLeaseSigned = lease.StandardOntarioLeaseSigned,
            N1IncreaseNoticeScheduled = lease.N1IncreaseNoticeScheduled
        };
        _formStartDate = lease.StartDate.ToDateTime(TimeOnly.MinValue);
        _formEndDate = lease.EndDate.ToDateTime(TimeOnly.MinValue);
        _isFormPanelOpen = true;
    }

    private void CloseFormPanel()
    {
        _isFormPanelOpen = false;
        _isCreateMode = true;
    }

    private async Task SaveFormAsync()
    {
        if (ActiveLease.UnitId == Guid.Empty || ActiveLease.TenantId == Guid.Empty)
        {
            return;
        }

        ActiveLease.StartDate = DateOnly.FromDateTime(_formStartDate ?? DateTime.Today);
        ActiveLease.EndDate = DateOnly.FromDateTime(_formEndDate ?? DateTime.Today.AddYears(1));

        if (ActiveLease.EndDate < ActiveLease.StartDate)
        {
            return;
        }

        if (_isCreateMode)
        {
            await DataService.AddLeaseAsync(_newLease);
            _newLease = new Lease { Status = LeaseStatus.Active, StandardOntarioLeaseSigned = true };
        }
        else
        {
            await DataService.UpdateLeaseAsync(_editLease);
            _editLease = new Lease { Status = LeaseStatus.Active, StandardOntarioLeaseSigned = true };
        }

        await ReloadAsync();
        CloseFormPanel();
    }

    private async Task DeleteAsync(Guid id)
    {
        await DataService.DeleteLeaseAsync(id);
        await ReloadAsync();
    }

    private async Task AddMoveInDocumentAsync(Guid leaseId)
    {
        var added = await DataService.AddLeaseMoveInDocumentAsync(leaseId, _newMoveInDocumentType, _newMoveInDocumentName, _newMoveInDocumentCaption);
        if (!added)
        {
            return;
        }

        _newMoveInDocumentType = "SignedLease";
        _newMoveInDocumentName = string.Empty;
        _newMoveInDocumentCaption = string.Empty;
        await ReloadAsync();
    }

    private async Task OpenLeaseConversationAsync(Guid leaseId)
    {
        var conversationId = await DataService.EnsureLeaseConversationAsync(leaseId);
        NavigationManager.NavigateTo(conversationId.HasValue
            ? $"/tenant-communications?conversationId={conversationId.Value}"
            : "/tenant-communications");
    }

    private async Task OpenLeaseMoveInOutreachDraftAsync(Guid leaseId)
    {
        var conversationId = await DataService.EnsureLeaseMoveInOutreachDraftAsync(leaseId);
        NavigationManager.NavigateTo(conversationId.HasValue
            ? $"/tenant-communications?conversationId={conversationId.Value}"
            : "/tenant-communications");
    }

    private async Task OpenLeaseNoticeDeliveryDraftAsync(Guid leaseId)
    {
        var conversationId = await DataService.EnsureLeaseConversationAsync(leaseId);
        NavigationManager.NavigateTo(conversationId.HasValue
            ? $"/tenant-communications?conversationId={conversationId.Value}&compose=notice-delivery"
            : "/tenant-communications");
    }

    private async Task OpenInsightNextActionAsync()
    {
        if (PriorityMoveInLease is not null && PriorityMoveInLease.Status == LeaseStatus.Draft)
        {
            await OpenLeaseConversationAsync(PriorityMoveInLease.Id);
            return;
        }

        if (FilteredLeases.Any(x => !x.StandardOntarioLeaseSigned))
        {
            _selectedOntarioFilter = Localizer["Leases_OntarioMissing"].Value;
            return;
        }

        if (PriorityNoticeLease is not null)
        {
            await OpenLeaseNoticeDeliveryDraftAsync(PriorityNoticeLease.Id);
            return;
        }

        NavigationManager.NavigateTo("/leases");
    }

    private async Task CompleteMoveInStepAsync(Guid leaseId, bool markSigned, bool activateLease)
    {
        _activationBlocked = false;
        var updated = await DataService.CompleteLeaseMoveInStepAsync(leaseId, markSigned, activateLease);
        if (!updated)
        {
            if (activateLease)
            {
                _activationBlocked = true;
            }
            return;
        }

        await ReloadAsync();
    }

    private async Task SaveMoveInPackageAsync(Guid leaseId)
    {
        var updated = await DataService.UpdateLeaseMoveInPackageAsync(leaseId, _moveInDepositReceived, _moveInInsuranceReceived, _moveInChecklistCompleted, _moveInNotes);
        if (!updated)
        {
            return;
        }

        await ReloadAsync();
    }

    private void ClearFilters()
    {
        _searchText = string.Empty;
        _selectedStatusFilter = string.Empty;
        _selectedOntarioFilter = string.Empty;
        _selectedWorkflowFilter = string.Empty;
    }

    private async Task ImportCsvAsync()
    {
        var imported = 0;
        var skipped = 0;
        var lines = _csvInput.Split(new[] { "\r\n", "\n" }, StringSplitOptions.RemoveEmptyEntries);
        foreach (var line in lines)
        {
            var parts = line.Split(',');
            if (parts.Length < 5)
            {
                skipped++;
                continue;
            }

            var unitNumber = parts[0].Trim();
            var tenantEmail = parts[1].Trim();
            var unit = _units.FirstOrDefault(x => string.Equals(x.UnitNumber, unitNumber, StringComparison.OrdinalIgnoreCase));
            var tenant = _tenants.FirstOrDefault(x => string.Equals(x.Email, tenantEmail, StringComparison.OrdinalIgnoreCase));
            if (unit is null || tenant is null || !DateOnly.TryParse(parts[2], out var start) || !DateOnly.TryParse(parts[3], out var end) || !decimal.TryParse(parts[4], out var rent) || end < start)
            {
                skipped++;
                continue;
            }

            if (_items.Any(x => x.UnitId == unit.Id && x.TenantId == tenant.Id && x.StartDate == start))
            {
                skipped++;
                continue;
            }

            await DataService.AddLeaseAsync(new Lease
            {
                UnitId = unit.Id,
                TenantId = tenant.Id,
                StartDate = start,
                EndDate = end,
                MonthlyRent = rent,
                Status = LeaseStatus.Active,
                StandardOntarioLeaseSigned = true
            });
            imported++;
        }

        _csvInput = string.Empty;
        await ReloadAsync();
        _importResult = string.Format(Localizer["Leases_ImportResult"].Value, imported, skipped);
    }

    private string GetUnitLabel(Guid unitId)
        => _units.FirstOrDefault(x => x.Id == unitId)?.UnitNumber ?? Localizer["Leases_UnknownUnit"].Value;

    private string GetTenantLabel(Guid tenantId)
        => _tenants.FirstOrDefault(x => x.Id == tenantId)?.FullName ?? Localizer["Leases_UnknownTenant"].Value;

    private string GetPropertyLabelForLease(Lease lease)
    {
        var unit = _units.FirstOrDefault(x => x.Id == lease.UnitId);
        return unit is null ? Localizer["Leases_UnknownProperty"].Value : GetPropertyName(unit.PropertyId);
    }

    private string GetPropertyHref(Lease lease)
    {
        var unit = _units.FirstOrDefault(x => x.Id == lease.UnitId);
        return unit is null ? "/properties" : $"/properties/{unit.PropertyId}";
    }

    private string GetPropertyName(Guid propertyId)
        => _properties.FirstOrDefault(x => x.Id == propertyId)?.Name ?? Localizer["Leases_UnknownProperty"].Value;

    private string GetUnitDisplay(Unit unit)
        => $"{unit.UnitNumber} · {GetPropertyName(unit.PropertyId)}";

    private string GetOntarioLabel(Lease lease)
        => lease.StandardOntarioLeaseSigned ? Localizer["Leases_OntarioSigned"].Value : Localizer["Leases_OntarioMissing"].Value;

    private string GetWorkflowLabel(Lease lease)
        => lease.N1IncreaseNoticeScheduled ? Localizer["Leases_WorkflowScheduled"].Value : Localizer["Leases_WorkflowNotScheduled"].Value;

    private static string GetTermLabel(Lease lease)
        => $"{lease.StartDate} - {lease.EndDate}";

    private string GetLeaseStatusLabel(LeaseStatus status)
        => status switch
        {
            LeaseStatus.Active => Localizer["Leases_StatusActive"].Value,
            LeaseStatus.EndingSoon => Localizer["Leases_StatusEndingSoon"].Value,
            LeaseStatus.Expired => Localizer["Leases_StatusExpired"].Value,
            LeaseStatus.Terminated => Localizer["Leases_StatusTerminated"].Value,
            _ => status.ToString()
        };

    private static Color GetStatusColor(LeaseStatus status)
        => status switch
        {
            LeaseStatus.Active => Color.Success,
            LeaseStatus.EndingSoon => Color.Warning,
            LeaseStatus.Expired => Color.Error,
            LeaseStatus.Terminated => Color.Error,
            _ => Color.Info
        };

    private string GetLeaseGuidance()
    {
        if (ActiveLease.UnitId == Guid.Empty || ActiveLease.TenantId == Guid.Empty)
        {
            return Localizer["Leases_GuidanceLinkUnitAndTenant"].Value;
        }

        if (!ActiveLease.StandardOntarioLeaseSigned)
        {
            return Localizer["Leases_GuidanceMissingJurisdictionLease"].Value;
        }

        return ActiveLease.N1IncreaseNoticeScheduled
            ? Localizer["Leases_GuidanceScheduled"].Value
            : Localizer["Leases_GuidanceReady"].Value;
    }

    private void SyncMoveInPackage()
    {
        if (PriorityMoveInLease is null)
        {
            _moveInDepositReceived = false;
            _moveInInsuranceReceived = false;
            _moveInChecklistCompleted = false;
            _moveInNotes = string.Empty;
            _leaseMoveInDocuments = new();
            _leaseMoveInRequirements = new();
            _leaseMoveInContext = null;
            _activationBlocked = false;
            return;
        }

        _moveInDepositReceived = PriorityMoveInLease.DepositReceived;
        _moveInInsuranceReceived = PriorityMoveInLease.InsuranceProofReceived;
        _moveInChecklistCompleted = PriorityMoveInLease.MoveInChecklistCompleted;
        _moveInNotes = PriorityMoveInLease.MoveInNotes;
    }

    private string GetMoveInDocumentTypeLabel(string documentType)
        => documentType switch
        {
            "SignedLease" => UiText.Get("Leases_MoveInDocumentTypeSignedLease"),
            "InsuranceProof" => UiText.Get("Leases_MoveInDocumentTypeInsuranceProof"),
            "GovernmentId" => UiText.Get("Leases_MoveInDocumentTypeGovernmentId"),
            "IncomeProof" => UiText.Get("Leases_MoveInDocumentTypeIncomeProof"),
            "DepositReceipt" => UiText.Get("Leases_MoveInDocumentTypeDepositReceipt"),
            _ => documentType
        };

    private bool IsInternalTemplateDocument(string documentType)
        => documentType is "DepositReceipt" or "IncomeProof" or "GovernmentId";

    private string GetInternalTemplateUrl(Guid leaseId, string documentType)
    {
        var propertyName = Uri.EscapeDataString(_leaseMoveInContext?.PropertyName ?? string.Empty);
        var unitLabel = Uri.EscapeDataString(_leaseMoveInContext?.UnitLabel ?? string.Empty);
        var tenantName = Uri.EscapeDataString(_leaseMoveInContext?.TenantName ?? string.Empty);
        return $"/docs/move-in/{documentType}?propertyName={propertyName}&unitLabel={unitLabel}&tenantName={tenantName}";
    }
}

