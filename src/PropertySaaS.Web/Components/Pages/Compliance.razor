@attribute [Authorize]
@page "/compliance"
@inject SaasDataService DataService

<PageTitle>Compliance</PageTitle>

<MudStack Spacing="3">
    <MudText Typo="Typo.h4">Ontario RTA compliance reminders</MudText>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-2">
                <MudTable Items="_items" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        <MudTh>Reminder</MudTh>
                        <MudTh>Notice</MudTh>
                        <MudTh>Due</MudTh>
                        <MudTh>Reference</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Reminder">@context.Title</MudTd>
                        <MudTd DataLabel="Notice"><MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info">@context.NoticeType</MudChip></MudTd>
                        <MudTd DataLabel="Due">@context.DueDate</MudTd>
                        <MudTd DataLabel="Reference">@context.Reference</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Ontario templates</MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string" Href="/docs/ontario-standard-lease">Ontario Standard Lease Package</MudListItem>
                    <MudListItem T="string" Href="/docs/n4-template">N4 Non-payment Notice</MudListItem>
                    <MudListItem T="string" Href="/docs/n1-template">N1 Rent Increase Notice</MudListItem>
                </MudList>
            </MudPaper>

            <MudPaper Class="pa-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Operational checklist</MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string">Review 90-day rent increase workflows</MudListItem>
                    <MudListItem T="string">Track latest Ontario lease form version</MudListItem>
                    <MudListItem T="string">Retain audit trail for notices and service dates</MudListItem>
                </MudList>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    private List<ComplianceReminder> _items = new();
    protected override async Task OnInitializedAsync() => _items = await DataService.GetComplianceAsync();
}
