@attribute [Authorize]
@page "/compliance"
@inject SaasDataService DataService
@inject NavigationManager NavigationManager
@inject PropertySaaS.Application.Common.CurrentOrganization CurrentOrganization
@inject IStringLocalizer<SharedResource> Localizer
@using PropertySaaS.Web.Localization

<PageTitle>@Localizer["Compliance_Title"]</PageTitle>

<MudStack Spacing="3">
    <MudStack Spacing="0">
        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" Class="mb-2">@UiText.Get("Compliance_PremiumBadge")</MudChip>
        <MudText Typo="Typo.h4">@string.Format(Localizer["Compliance_PageHeading"].Value, CurrentOrganization.Jurisdiction.ProvinceDisplayName)</MudText>
        <MudText Typo="Typo.body2">@string.Format(Localizer["Compliance_PageSubtitle"].Value, CurrentOrganization.Jurisdiction.ProvinceDisplayName)</MudText>
    </MudStack>

    <MudGrid Spacing="2" Class="align-center-grid">
        <MudItem xs="12" lg="4">
            <MudTextField T="string"
                          Label="@Localizer["Compliance_SearchLabel"]"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          @bind-Value="_searchText"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Placeholder="@Localizer["Compliance_SearchPlaceholder"]" />
        </MudItem>
        <MudItem xs="12" sm="4" lg="2">
            <MudSelect T="string" Label="@Localizer["Compliance_FilterNotice"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="_selectedNoticeFilter">
                <MudSelectItem T="string" Value="@string.Empty">@Localizer["Compliance_FilterAllNotices"]</MudSelectItem>
                @foreach (var option in NoticeOptions)
                {
                    <MudSelectItem T="string" Value="@option">@option</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="4" lg="2">
            <MudSelect T="string" Label="@Localizer["Compliance_FilterState"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="_selectedStateFilter">
                <MudSelectItem T="string" Value="@string.Empty">@Localizer["Compliance_FilterAllStates"]</MudSelectItem>
                <MudSelectItem T="string" Value='@Localizer["Compliance_StateOpen"].Value'>@Localizer["Compliance_StateOpen"]</MudSelectItem>
                <MudSelectItem T="string" Value='@Localizer["Compliance_StateCompleted"].Value'>@Localizer["Compliance_StateCompleted"]</MudSelectItem>
                <MudSelectItem T="string" Value='@Localizer["Compliance_StateDueSoon"].Value'>@Localizer["Compliance_StateDueSoon"]</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="4" lg="2">
            <MudStack Row="true" Spacing="1" Class="properties-toolbar-actions">
                @if (HasActiveFilters)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true" StartIcon="@Icons.Material.Filled.FilterAltOff" OnClick="ClearFilters">@Localizer["Common_Reset"]</MudButton>
                }
            </MudStack>
        </MudItem>
        <MudItem xs="12" lg="2">
            <MudButton Href="/docs/jurisdiction/lease-package" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Description">@Localizer["Compliance_OpenTemplates"]</MudButton>
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="2">
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["Compliance_StatShown"]</MudText><MudText Typo="Typo.h6">@FilteredItems.Count()</MudText></MudPaper></MudItem>
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["Compliance_StatDueSoon"]</MudText><MudText Typo="Typo.h6">@FilteredItems.Count(x => !x.IsCompleted && x.DueDate <= DateOnly.FromDateTime(DateTime.Today.AddDays(14)))</MudText></MudPaper></MudItem>
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["Compliance_StatCompleted"]</MudText><MudText Typo="Typo.h6">@FilteredItems.Count(x => x.IsCompleted)</MudText></MudPaper></MudItem>
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["Compliance_StatNoticeTypes"]</MudText><MudText Typo="Typo.h6">@FilteredItems.Select(x => x.NoticeType).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).Count()</MudText></MudPaper></MudItem>
    </MudGrid>

    <MudPaper Class="pa-4 property-detail-panel" Elevation="0">
        <MudText Typo="Typo.h6">@UiText.Get("Compliance_InsightTitle")</MudText>
        <MudGrid Spacing="2" Class="mt-2">
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-3 property-mini-stat" Elevation="0">
                    <MudText Typo="Typo.overline">@UiText.Get("Compliance_InsightUrgency")</MudText>
                    <MudChip T="string" Variant="Variant.Outlined" Color="@InsightColor" Class="mt-2">@InsightUrgencyLabel</MudChip>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-3 property-mini-stat" Elevation="0">
                    <MudText Typo="Typo.overline">@UiText.Get("Compliance_InsightFocus")</MudText>
                    <MudChip T="string" Variant="Variant.Outlined" Color="@InsightColor" Class="mt-2">@InsightFocusLabel</MudChip>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-3 property-mini-stat" Elevation="0">
                    <MudText Typo="Typo.overline">@UiText.Get("Compliance_InsightNextAction")</MudText>
                    <MudButton Class="mt-2" Variant="Variant.Text" Color="@InsightColor" OnClick="OpenInsightNextActionAsync">@InsightActionLabel</MudButton>
                </MudPaper>
            </MudItem>
        </MudGrid>
        <MudText Typo="Typo.body2" Class="mt-3">@InsightMessage</MudText>
    </MudPaper>

    <MudPaper Class="pa-2 table-wrap properties-table-shell">
        <MudTable Items="FilteredItems.ToList()" Dense="true" Hover="true" Breakpoint="Breakpoint.Md" RowsPerPage="10">
            <HeaderContent>
                <MudTh>@Localizer["Compliance_ColumnReminder"]</MudTh>
                <MudTh>@Localizer["Compliance_ColumnNotice"]</MudTh>
                <MudTh>@Localizer["Compliance_ColumnDue"]</MudTh>
                <MudTh>@Localizer["Compliance_ColumnState"]</MudTh>
                <MudTh>@Localizer["Compliance_ColumnReference"]</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="@Localizer["Compliance_ColumnReminder"]">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2">@context.Title</MudText>
                        <MudText Typo="Typo.caption" Class="property-address">@GetReminderNarrative(context)</MudText>
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="@Localizer["Compliance_ColumnNotice"]"><MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">@context.NoticeType</MudChip></MudTd>
                <MudTd DataLabel="@Localizer["Compliance_ColumnDue"]">@context.DueDate</MudTd>
                <MudTd DataLabel="@Localizer["Compliance_ColumnState"]"><MudChip T="string" Variant="Variant.Filled" Color="@GetStateColor(context)">@GetStateLabel(context)</MudChip></MudTd>
                <MudTd DataLabel="@Localizer["Compliance_ColumnReference"]">@context.Reference</MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudStack Class="pa-6 properties-empty-state" Spacing="1" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Gavel" Size="Size.Large" Color="Color.Default" />
                    <MudText Typo="Typo.subtitle1">@Localizer["Compliance_NoRecordsTitle"]</MudText>
                    <MudText Typo="Typo.body2">@string.Format(Localizer["Compliance_NoRecordsSubtitle"].Value, CurrentOrganization.Jurisdiction.ProvinceDisplayName)</MudText>
                    @if (HasActiveFilters)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ClearFilters">@Localizer["Common_ResetFilters"]</MudButton>
                    }
                </MudStack>
            </NoRecordsContent>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>

    <MudGrid Spacing="2">
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4 property-detail-panel h-100" Elevation="0">
                <MudText Typo="Typo.h6" GutterBottom="true">@string.Format(Localizer["Compliance_TemplatesTitle"].Value, CurrentOrganization.Jurisdiction.ProvinceDisplayName)</MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string" Href="/docs/jurisdiction/lease-package">@CurrentOrganization.Jurisdiction.LeasePackageLabel</MudListItem>
                    @foreach (var template in CurrentOrganization.Jurisdiction.DocumentTemplates.Where(x => x.Key != "lease-package"))
                    {
                        <MudListItem T="string" Href="@($"/docs/jurisdiction/{template.Key}")">@template.Value</MudListItem>
                    }
                </MudList>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4 property-detail-panel h-100" Elevation="0">
                <MudText Typo="Typo.h6" GutterBottom="true">@Localizer["Compliance_OperationalChecklist"]</MudText>
                <MudList T="string" Dense="true">
                    @foreach (var item in CurrentOrganization.Jurisdiction.ComplianceChecklist)
                    {
                        <MudListItem T="string">@item</MudListItem>
                    }
                </MudList>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    private List<ComplianceReminder> _items = new();
    private string _searchText = string.Empty;
    private string _selectedNoticeFilter = string.Empty;
    private string _selectedStateFilter = string.Empty;

    private bool HasActiveFilters => !string.IsNullOrWhiteSpace(_searchText) || !string.IsNullOrWhiteSpace(_selectedNoticeFilter) || !string.IsNullOrWhiteSpace(_selectedStateFilter);
    private IEnumerable<string> NoticeOptions => _items.Select(x => x.NoticeType).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(x => x);
    private int DueSoonCount => FilteredItems.Count(x => !x.IsCompleted && x.DueDate <= DateOnly.FromDateTime(DateTime.Today.AddDays(14)));
    private int OpenCount => FilteredItems.Count(x => !x.IsCompleted);
    private string InsightUrgencyLabel
        => DueSoonCount > 0
            ? UiText.Get("Compliance_InsightUrgencyHigh")
            : OpenCount > 0
                ? UiText.Get("Compliance_InsightUrgencyMedium")
                : UiText.Get("Compliance_InsightUrgencyStable");

    private string InsightFocusLabel
        => DueSoonCount > 0
            ? UiText.Get("Compliance_InsightFocusDueSoon")
            : OpenCount > 0
                ? UiText.Get("Compliance_InsightFocusOpen")
                : UiText.Get("Compliance_InsightFocusStable");

    private string InsightMessage
        => DueSoonCount > 0
            ? UiText.Get("Compliance_InsightMessageDueSoon")
            : OpenCount > 0
                ? UiText.Get("Compliance_InsightMessageOpen")
                : UiText.Get("Compliance_InsightMessageStable");

    private string InsightActionLabel
        => DueSoonCount > 0
            ? UiText.Get("Compliance_InsightOpenDueSoon")
            : OpenCount > 0
                ? UiText.Get("Compliance_InsightOpenOpenWork")
                : UiText.Get("Compliance_InsightOpenTemplates");

    private Color InsightColor
        => DueSoonCount > 0
            ? Color.Warning
            : OpenCount > 0
                ? Color.Info
                : Color.Success;

    private IEnumerable<ComplianceReminder> FilteredItems => _items
        .Where(item => string.IsNullOrWhiteSpace(_searchText)
            || item.Title.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || item.NoticeType.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || item.Reference.Contains(_searchText, StringComparison.OrdinalIgnoreCase))
        .Where(item => string.IsNullOrWhiteSpace(_selectedNoticeFilter) || string.Equals(item.NoticeType, _selectedNoticeFilter, StringComparison.OrdinalIgnoreCase))
        .Where(item => string.IsNullOrWhiteSpace(_selectedStateFilter) || string.Equals(GetStateLabel(item), _selectedStateFilter, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
        => _items = (await DataService.GetComplianceAsync())
            .Where(x => string.Equals(x.Province, CurrentOrganization.Province, StringComparison.OrdinalIgnoreCase))
            .ToList();

    private void ClearFilters()
    {
        _searchText = string.Empty;
        _selectedNoticeFilter = string.Empty;
        _selectedStateFilter = string.Empty;
    }

    private Task OpenInsightNextActionAsync()
    {
        if (DueSoonCount > 0)
        {
            _selectedStateFilter = Localizer["Compliance_StateDueSoon"].Value;
            return Task.CompletedTask;
        }

        if (OpenCount > 0)
        {
            _selectedStateFilter = Localizer["Compliance_StateOpen"].Value;
            return Task.CompletedTask;
        }

        NavigationManager.NavigateTo("/docs/jurisdiction/lease-package");
        return Task.CompletedTask;
    }

    private string GetStateLabel(ComplianceReminder reminder)
    {
        if (reminder.IsCompleted)
        {
            return Localizer["Compliance_StateCompleted"].Value;
        }

        if (reminder.DueDate <= DateOnly.FromDateTime(DateTime.Today.AddDays(14)))
        {
            return Localizer["Compliance_StateDueSoon"].Value;
        }

        return Localizer["Compliance_StateOpen"].Value;
    }

    private static Color GetStateColor(ComplianceReminder reminder)
    {
        if (reminder.IsCompleted)
        {
            return Color.Success;
        }

        if (reminder.DueDate <= DateOnly.FromDateTime(DateTime.Today.AddDays(14)))
        {
            return Color.Warning;
        }

        return Color.Info;
    }

    private string GetReminderNarrative(ComplianceReminder reminder)
        => reminder.IsCompleted
            ? Localizer["Compliance_NarrativeCompleted"].Value
            : reminder.DueDate <= DateOnly.FromDateTime(DateTime.Today.AddDays(14))
                ? Localizer["Compliance_NarrativeDueSoon"].Value
                : Localizer["Compliance_NarrativeOpen"].Value;
}
