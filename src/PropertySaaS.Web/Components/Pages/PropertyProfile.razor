@attribute [Authorize]
@page "/properties/{PropertyId:guid}"
@inject SaasDataService DataService
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@Localizer["PropertyProfile_PageTitle"]</PageTitle>

@if (_property is null)
{
    <MudAlert Severity="Severity.Warning">@Localizer["PropertyProfile_NotFound"]</MudAlert>
}
else
{
    var occupiedCount = _units.Count(x => x.IsOccupied);
    var vacantCount = _units.Count - occupiedCount;
    var monthlyRent = _units.Sum(x => x.MonthlyRent);
    var readinessScore = GetMarketingReadinessScore(_property, _units, occupiedCount, monthlyRent);
    var performanceLabel = GetPerformanceLabel(_property, _units, occupiedCount, monthlyRent);
    var performanceColor = GetPerformanceColor(_property, _units, occupiedCount, monthlyRent);

    <MudStack Spacing="3">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudAvatar Size="Size.Large" Class="property-avatar">
                    <MudIcon Icon="@Icons.Material.Filled.Apartment" />
                </MudAvatar>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h4">@_property.Name</MudText>
                    <MudText Typo="Typo.body1" Class="property-address">@FormatAddress(_property)</MudText>
                </MudStack>
            </MudStack>

            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudChip T="string" Variant="Variant.Filled" Color="@performanceColor">@performanceLabel</MudChip>
                <MudButton Href="/properties" Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.ArrowBack">@Localizer["PropertyProfile_BackToProperties"]</MudButton>
            </MudStack>
        </MudStack>

        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
            <MudChip T="string" Variant="Variant.Filled" Color="Color.Dark">@LocalizePropertyType(_property.PropertyType)</MudChip>
            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary">@_property.City</MudChip>
            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">@GetPostalCodeOrFallback(_property)</MudChip>
            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Secondary">@string.Format(Localizer["PropertyProfile_UnitsCount"].Value, _units.Count)</MudChip>
            <MudChip T="string" Variant="Variant.Filled" Color="Color.Success">@string.Format(Localizer["PropertyProfile_OccupiedCount"].Value, occupiedCount)</MudChip>
            <MudChip T="string" Variant="Variant.Filled" Color="Color.Warning">@string.Format(Localizer["PropertyProfile_VacantCount"].Value, vacantCount)</MudChip>
        </MudStack>

        <MudGrid Spacing="2">
            <MudItem xs="12" md="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["PropertyProfile_StatRevenueTarget"]</MudText><MudText Typo="Typo.h6">@_property.MonthlyRevenueTarget.ToString("C")</MudText></MudPaper></MudItem>
            <MudItem xs="12" md="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["PropertyProfile_StatActualRentRoll"]</MudText><MudText Typo="Typo.h6">@monthlyRent.ToString("C")</MudText></MudPaper></MudItem>
            <MudItem xs="12" md="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["PropertyProfile_StatOccupancy"]</MudText><MudText Typo="Typo.h6">@GetOccupancyLabel(_units.Count, occupiedCount)</MudText></MudPaper></MudItem>
            <MudItem xs="12" md="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["PropertyProfile_StatLeasingReadiness"]</MudText><MudText Typo="Typo.h6">@readinessScore/100</MudText></MudPaper></MudItem>
        </MudGrid>

        <MudTabs Rounded="true" PanelClass="pa-4">
            <MudTabPanel Text="@Localizer["PropertyProfile_TabOverview"]">
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="4"><MudPaper Class="pa-4 property-detail-panel h-100" Elevation="0"><MudText Typo="Typo.subtitle2">@Localizer["PropertyProfile_IdealRenterProfile"]</MudText><MudText Typo="Typo.body2">@GetIdealRenterProfile(_property)</MudText></MudPaper></MudItem>
                    <MudItem xs="12" md="4"><MudPaper Class="pa-4 property-detail-panel h-100" Elevation="0"><MudText Typo="Typo.subtitle2">@Localizer["PropertyProfile_SuggestedListingHeadline"]</MudText><MudText Typo="Typo.body2">@GetSuggestedHeadline(_property)</MudText></MudPaper></MudItem>
                    <MudItem xs="12" md="4"><MudPaper Class="pa-4 property-detail-panel h-100" Elevation="0"><MudText Typo="Typo.subtitle2">@Localizer["PropertyProfile_AssetStage"]</MudText><MudChip T="string" Variant="Variant.Filled" Color="@GetAssetStageColor(_units, vacantCount, readinessScore)">@LocalizeAssetStage(GetAssetStage(_units, vacantCount, readinessScore))</MudChip><MudText Typo="Typo.body2" Class="mt-2">@GetAssetStageNarrative(_units, vacantCount, readinessScore)</MudText></MudPaper></MudItem>
                    <MudItem xs="12"><MudPaper Class="pa-4 property-score-panel" Elevation="0"><MudText Typo="Typo.h6">@Localizer["PropertyProfile_LeasingReadinessScore"]</MudText><MudText Typo="Typo.body2" Class="property-note">@GetReadinessSummary(readinessScore)</MudText><MudProgressLinear Class="mt-3" Rounded="true" Size="Size.Large" Color="@GetReadinessColor(readinessScore)" Value="@readinessScore" /></MudPaper></MudItem>
                </MudGrid>
            </MudTabPanel>
            <MudTabPanel Text="@Localizer["Units_Title"]">
                @if (_units.Count == 0)
                {
                    <MudAlert Severity="Severity.Info">@Localizer["PropertyProfile_NoUnitsYet"]</MudAlert>
                }
                else
                {
                    <MudTable Items="_units" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Class="property-units-table">
                        <HeaderContent>
                            <MudTh>@Localizer["Units_ColumnUnit"]</MudTh>
                            <MudTh>@Localizer["Units_ColumnLayout"]</MudTh>
                            <MudTh>@Localizer["Units_ColumnRent"]</MudTh>
                            <MudTh>@Localizer["Units_ColumnStatus"]</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="@Localizer["Units_ColumnUnit"]">@context.UnitNumber</MudTd>
                            <MudTd DataLabel="@Localizer["Units_ColumnLayout"]">@($"{context.Bedrooms} {Localizer["Units_BedroomAbbreviation"]} / {context.Bathrooms} {Localizer["Units_BathroomAbbreviation"]}")</MudTd>
                            <MudTd DataLabel="@Localizer["Units_ColumnRent"]">@context.MonthlyRent.ToString("C")</MudTd>
                            <MudTd DataLabel="@Localizer["Units_ColumnStatus"]"><MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@(context.IsOccupied ? Color.Success : Color.Warning)">@(context.IsOccupied ? Localizer["Units_Occupied"] : Localizer["Units_Vacant"])</MudChip></MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudTabPanel>
            <MudTabPanel Text="@Localizer["Leases_Title"]">
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="6"><MudPaper Class="pa-4 property-detail-panel h-100" Elevation="0"><MudText Typo="Typo.subtitle2">@Localizer["PropertyProfile_LeasingPlaybook"]</MudText><MudText Typo="Typo.body2">@GetTextOrFallback(_property.LeasingNotes, Localizer["PropertyProfile_LeasingPlaybookFallback"].Value)</MudText></MudPaper></MudItem>
                    <MudItem xs="12" md="6"><MudPaper Class="pa-4 property-detail-panel h-100" Elevation="0"><MudText Typo="Typo.subtitle2">@Localizer["PropertyProfile_PricingPosture"]</MudText><MudText Typo="Typo.body2">@GetPricingPosture(_property, monthlyRent, vacantCount)</MudText></MudPaper></MudItem>
                    <MudItem xs="12"><MudPaper Class="pa-4 property-detail-panel" Elevation="0"><MudText Typo="Typo.subtitle2">@Localizer["PropertyProfile_RecommendedActions"]</MudText><MudList T="string" Dense="true">@foreach (var action in GetRecommendedActions(_property, _units, vacantCount, readinessScore, monthlyRent)) { <MudListItem T="string">@action</MudListItem> }</MudList></MudPaper></MudItem>
                    <MudItem xs="12">
                        <MudPaper Class="pa-4 property-detail-panel" Elevation="0">
                            <MudText Typo="Typo.subtitle2">@Localizer["PropertyProfile_LiveLeases"]</MudText>
                            @if (_leases.Count == 0)
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">@Localizer["PropertyProfile_NoLeasesLinked"]</MudAlert>
                            }
                            else
                            {
                                <MudTable Items="_leases" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Class="mt-2">
                                    <HeaderContent>
                                        <MudTh>@Localizer["Leases_ColumnUnit"]</MudTh>
                                        <MudTh>@Localizer["Leases_FormStartDate"]</MudTh>
                                        <MudTh>@Localizer["Leases_FormEndDate"]</MudTh>
                                        <MudTh>@Localizer["Leases_ColumnRent"]</MudTh>
                                        <MudTh>@Localizer["Leases_ColumnStatus"]</MudTh>
                                        <MudTh>@Localizer["PropertyProfile_OntarioLease"]</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="@Localizer["Leases_ColumnUnit"]">@GetUnitLabel(context.UnitId)</MudTd>
                                        <MudTd DataLabel="@Localizer["Leases_FormStartDate"]">@context.StartDate</MudTd>
                                        <MudTd DataLabel="@Localizer["Leases_FormEndDate"]">@context.EndDate</MudTd>
                                        <MudTd DataLabel="@Localizer["Leases_ColumnRent"]">@context.MonthlyRent.ToString("C")</MudTd>
                                        <MudTd DataLabel="@Localizer["Leases_ColumnStatus"]">@context.Status</MudTd>
                                        <MudTd DataLabel="@Localizer["PropertyProfile_OntarioLease"]">@(context.StandardOntarioLeaseSigned ? Localizer["Leases_OntarioSigned"] : Localizer["Leases_OntarioMissing"])</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
            <MudTabPanel Text="@Localizer["PropertyProfile_TabOps"]">
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="6"><MudPaper Class="pa-4 property-detail-panel h-100" Elevation="0"><MudText Typo="Typo.subtitle2">@Localizer["PropertyProfile_OperationalNotes"]</MudText><MudText Typo="Typo.body2">@GetTextOrFallback(_property.OperationalNotes, Localizer["PropertyProfile_OperationalNotesFallback"].Value)</MudText></MudPaper></MudItem>
                    <MudItem xs="12" md="6"><MudPaper Class="pa-4 property-detail-panel h-100" Elevation="0"><MudText Typo="Typo.subtitle2">@Localizer["PropertyProfile_OperationsFocus"]</MudText><MudText Typo="Typo.body2">@GetOperationsFocus(_property, vacantCount)</MudText></MudPaper></MudItem>
                    <MudItem xs="12"><MudPaper Class="pa-4 property-detail-panel" Elevation="0"><MudText Typo="Typo.subtitle2">@Localizer["Properties_FormAmenities"]</MudText><MudText Typo="Typo.body2">@GetTextOrFallback(_property.AmenitySummary, Localizer["PropertyProfile_AmenitiesFallback"].Value)</MudText></MudPaper></MudItem>
                    <MudItem xs="12">
                        <MudPaper Class="pa-4 property-detail-panel" Elevation="0">
                            <MudText Typo="Typo.subtitle2">@Localizer["PropertyProfile_MaintenancePipeline"]</MudText>
                            @if (_maintenance.Count == 0)
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">@Localizer["PropertyProfile_NoMaintenanceLinked"]</MudAlert>
                            }
                            else
                            {
                                <MudTable Items="_maintenance" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Class="mt-2">
                                    <HeaderContent>
                                        <MudTh>@Localizer["Compliance_ColumnReminder"]</MudTh>
                                        <MudTh>@Localizer["Maintenance_ColumnPriority"]</MudTh>
                                        <MudTh>@Localizer["Maintenance_ColumnStatus"]</MudTh>
                                        <MudTh>@Localizer["Maintenance_ColumnVendor"]</MudTh>
                                        <MudTh>@Localizer["Maintenance_ColumnRequested"]</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="@Localizer["Compliance_ColumnReminder"]">@context.Title</MudTd>
                                        <MudTd DataLabel="@Localizer["Maintenance_ColumnPriority"]">@context.Priority</MudTd>
                                        <MudTd DataLabel="@Localizer["Maintenance_ColumnStatus"]">@context.Status</MudTd>
                                        <MudTd DataLabel="@Localizer["Maintenance_ColumnVendor"]">@context.VendorName</MudTd>
                                        <MudTd DataLabel="@Localizer["Maintenance_ColumnRequested"]">@context.RequestedDate</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
            <MudTabPanel Text="@Localizer["Compliance_Title"]">
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="6">
                        <MudPaper Class="pa-4 property-detail-panel h-100" Elevation="0">
                            <MudText Typo="Typo.subtitle2">@Localizer["PropertyProfile_ComplianceReminder"]</MudText>
                            <MudText Typo="Typo.body2">@Localizer["PropertyProfile_ComplianceReminderBody"]</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudPaper Class="pa-4 property-detail-panel h-100" Elevation="0">
                            <MudText Typo="Typo.subtitle2">@Localizer["PropertyProfile_ExecutionChecklist"]</MudText>
                            <MudList T="string" Dense="true">
                                <MudListItem T="string">@Localizer["PropertyProfile_ChecklistItem1"]</MudListItem>
                                <MudListItem T="string">@Localizer["PropertyProfile_ChecklistItem2"]</MudListItem>
                                <MudListItem T="string">@Localizer["PropertyProfile_ChecklistItem3"]</MudListItem>
                            </MudList>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12">
                        <MudPaper Class="pa-4 property-detail-panel" Elevation="0">
                            <MudText Typo="Typo.subtitle2">@Localizer["PropertyProfile_UpcomingOntarioReminders"]</MudText>
                            @if (_compliance.Count == 0)
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">@Localizer["PropertyProfile_NoComplianceReminders"]</MudAlert>
                            }
                            else
                            {
                                <MudTable Items="_compliance" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Class="mt-2">
                                    <HeaderContent>
                                        <MudTh>@Localizer["Compliance_ColumnReminder"]</MudTh>
                                        <MudTh>@Localizer["Compliance_ColumnNotice"]</MudTh>
                                        <MudTh>@Localizer["Compliance_ColumnDue"]</MudTh>
                                        <MudTh>@Localizer["Compliance_ColumnReference"]</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="@Localizer["Compliance_ColumnReminder"]">@context.Title</MudTd>
                                        <MudTd DataLabel="@Localizer["Compliance_ColumnNotice"]"><MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info">@context.NoticeType</MudChip></MudTd>
                                        <MudTd DataLabel="@Localizer["Compliance_ColumnDue"]">@context.DueDate</MudTd>
                                        <MudTd DataLabel="@Localizer["Compliance_ColumnReference"]">@context.Reference</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
        </MudTabs>
    </MudStack>
}

@code {
    [Parameter] public Guid PropertyId { get; set; }

    private Property? _property;
    private List<Unit> _units = new();
    private List<Lease> _leases = new();
    private List<MaintenanceRequest> _maintenance = new();
    private List<ComplianceReminder> _compliance = new();

    protected override async Task OnParametersSetAsync()
    {
        var properties = await DataService.GetPropertiesAsync();
        _property = properties.FirstOrDefault(x => x.Id == PropertyId);

        _units = (await DataService.GetUnitsAsync())
            .Where(x => x.PropertyId == PropertyId)
            .OrderBy(x => x.UnitNumber)
            .ToList();

        var unitIds = _units.Select(x => x.Id).ToHashSet();
        _leases = (await DataService.GetLeasesAsync())
            .Where(x => unitIds.Contains(x.UnitId))
            .OrderByDescending(x => x.StartDate)
            .ToList();

        _maintenance = (await DataService.GetMaintenanceAsync())
            .Where(x => x.PropertyId == PropertyId || (x.UnitId.HasValue && unitIds.Contains(x.UnitId.Value)))
            .OrderByDescending(x => x.RequestedDate)
            .ToList();

        _compliance = (await DataService.GetComplianceAsync())
            .OrderBy(x => x.DueDate)
            .ToList();
    }

    private static string FormatAddress(Property property)
    {
        var parts = new[] { property.AddressLine1, property.City, property.Province, property.PostalCode }.Where(x => !string.IsNullOrWhiteSpace(x));
        return string.Join(", ", parts);
    }

    private string GetOccupancyLabel(int totalUnits, int occupiedUnits)
        => totalUnits == 0 ? Localizer["Properties_NoUnits"] : $"{Math.Round((decimal)occupiedUnits / totalUnits * 100, 0)}%";

    private static int GetMarketingReadinessScore(Property property, List<Unit> propertyUnits, int occupiedCount, decimal monthlyRent)
    {
        var score = 0;
        if (!string.IsNullOrWhiteSpace(property.PropertyType)) score += 10;
        if (!string.IsNullOrWhiteSpace(property.PostalCode)) score += 10;
        if (!string.IsNullOrWhiteSpace(property.AmenitySummary)) score += 20;
        if (!string.IsNullOrWhiteSpace(property.NeighborhoodNotes)) score += 15;
        if (!string.IsNullOrWhiteSpace(property.LeasingNotes)) score += 20;
        if (!string.IsNullOrWhiteSpace(property.OperationalNotes)) score += 10;
        if (propertyUnits.Count > 0) score += 10;
        if (occupiedCount > 0 || monthlyRent > 0) score += 5;
        return Math.Min(score, 100);
    }

    private string GetPerformanceLabel(Property property, List<Unit> propertyUnits, int occupiedCount, decimal monthlyRent)
    {
        if (propertyUnits.Count == 0) return Localizer["PropertyProfile_Performance_SetupNeeded"];
        if (occupiedCount == propertyUnits.Count && monthlyRent >= property.MonthlyRevenueTarget) return Localizer["PropertyProfile_Performance_Performing"];
        if (occupiedCount == 0) return Localizer["PropertyProfile_Performance_NeedsLeasing"];
        return Localizer["PropertyProfile_Performance_Watchlist"];
    }

    private static Color GetPerformanceColor(Property property, List<Unit> propertyUnits, int occupiedCount, decimal monthlyRent)
    {
        if (propertyUnits.Count == 0) return Color.Info;
        if (occupiedCount == propertyUnits.Count && monthlyRent >= property.MonthlyRevenueTarget) return Color.Success;
        if (occupiedCount == 0) return Color.Error;
        return Color.Warning;
    }

    private static Color GetReadinessColor(int score)
        => score >= 80 ? Color.Success : score >= 55 ? Color.Warning : Color.Error;

    private string GetReadinessSummary(int score)
        => score >= 80 ? Localizer["PropertyProfile_ReadinessSummary_High"]
            : score >= 55 ? Localizer["PropertyProfile_ReadinessSummary_Mid"]
            : Localizer["PropertyProfile_ReadinessSummary_Low"];

    private string GetIdealRenterProfile(Property property)
    {
        if (property.PropertyType.Contains("student", StringComparison.OrdinalIgnoreCase)) return Localizer["PropertyProfile_IdealRenterProfile_Student"];
        if (property.PropertyType.Contains("single-family", StringComparison.OrdinalIgnoreCase) || property.PropertyType.Contains("townhome", StringComparison.OrdinalIgnoreCase)) return Localizer["PropertyProfile_IdealRenterProfile_Family"];
        return Localizer["PropertyProfile_IdealRenterProfile_Default"];
    }

    private string GetSuggestedHeadline(Property property)
    {
        var city = string.IsNullOrWhiteSpace(property.City) ? "Toronto" : property.City;
        if (property.PropertyType.Contains("student", StringComparison.OrdinalIgnoreCase)) return string.Format(Localizer["PropertyProfile_Headline_Student"].Value, city);
        if (property.PropertyType.Contains("single-family", StringComparison.OrdinalIgnoreCase) || property.PropertyType.Contains("townhome", StringComparison.OrdinalIgnoreCase)) return string.Format(Localizer["PropertyProfile_Headline_Family"].Value, city);
        if (property.PropertyType.Contains("luxury", StringComparison.OrdinalIgnoreCase) || property.PropertyType.Contains("waterfront", StringComparison.OrdinalIgnoreCase) || property.PropertyType.Contains("executive", StringComparison.OrdinalIgnoreCase)) return string.Format(Localizer["PropertyProfile_Headline_Premium"].Value, property.PropertyType.ToLowerInvariant(), city);
        return string.Format(Localizer["PropertyProfile_Headline_Default"].Value, property.PropertyType.ToLowerInvariant(), city);
    }

    private static string GetAssetStage(List<Unit> propertyUnits, int vacantCount, int readinessScore)
    {
        if (propertyUnits.Count == 0) return "Setup";
        if (vacantCount > 0) return "Lease-up";
        if (readinessScore < 80) return "Stabilize playbook";
        return "Stabilized";
    }

    private static Color GetAssetStageColor(List<Unit> propertyUnits, int vacantCount, int readinessScore)
    {
        var stage = GetAssetStage(propertyUnits, vacantCount, readinessScore);
        return stage switch
        {
            "Setup" => Color.Info,
            "Lease-up" => Color.Warning,
            "Stabilize playbook" => Color.Secondary,
            _ => Color.Success
        };
    }

    private string GetAssetStageNarrative(List<Unit> propertyUnits, int vacantCount, int readinessScore)
    {
        var stage = GetAssetStage(propertyUnits, vacantCount, readinessScore);
        return stage switch
        {
            "Setup" => Localizer["PropertyProfile_AssetStageNarrative_Setup"],
            "Lease-up" => Localizer["PropertyProfile_AssetStageNarrative_LeaseUp"],
            "Stabilize playbook" => Localizer["PropertyProfile_AssetStageNarrative_StabilizePlaybook"],
            _ => Localizer["PropertyProfile_AssetStageNarrative_Stabilized"]
        };
    }

    private string GetPricingPosture(Property property, decimal monthlyRent, int vacantCount)
    {
        if (vacantCount > 0) return string.Format(Localizer["PropertyProfile_PricingPosture_Vacant"].Value, property.MonthlyRevenueTarget.ToString("C"));
        if (monthlyRent > property.MonthlyRevenueTarget) return Localizer["PropertyProfile_PricingPosture_AboveTarget"];
        if (monthlyRent < property.MonthlyRevenueTarget) return Localizer["PropertyProfile_PricingPosture_BelowTarget"];
        return Localizer["PropertyProfile_PricingPosture_OnTarget"];
    }

    private string GetOperationsFocus(Property property, int vacantCount)
    {
        if (vacantCount > 0) return Localizer["PropertyProfile_OperationsFocus_Vacant"];
        if (string.IsNullOrWhiteSpace(property.OperationalNotes)) return Localizer["PropertyProfile_OperationsFocus_Default"];
        return property.OperationalNotes;
    }

    private List<string> GetRecommendedActions(Property property, List<Unit> propertyUnits, int vacantCount, int readinessScore, decimal monthlyRent)
    {
        var actions = new List<string>();
        if (propertyUnits.Count == 0) actions.Add(Localizer["PropertyProfile_Action_AddUnitMix"]);
        if (vacantCount > 0) actions.Add(Localizer["PropertyProfile_Action_VacancyRecovery"]);
        if (readinessScore < 80) actions.Add(Localizer["PropertyProfile_Action_CompletePlaybook"]);
        if (monthlyRent < property.MonthlyRevenueTarget) actions.Add(Localizer["PropertyProfile_Action_ReviewPricing"]);
        if (actions.Count == 0)
        {
            actions.Add(Localizer["PropertyProfile_Action_DocumentBenchmark"]);
            actions.Add(Localizer["PropertyProfile_Action_StayAhead"]);
        }
        return actions.Take(3).ToList();
    }

    private string GetUnitLabel(Guid unitId)
        => _units.FirstOrDefault(x => x.Id == unitId)?.UnitNumber ?? unitId.ToString()[..8];

    private string GetPostalCodeOrFallback(Property property)
        => string.IsNullOrWhiteSpace(property.PostalCode) ? Localizer["PropertyProfile_PostalPending"] : property.PostalCode;

    private string LocalizePropertyType(string propertyType)
        => propertyType switch
        {
            "Multi-family" => Localizer["Properties_PropertyType_MultiFamily"],
            "Urban mid-rise" => Localizer["Properties_PropertyType_UrbanMidRise"],
            "Low-rise apartment" => Localizer["Properties_PropertyType_LowRiseApartment"],
            "Condo building" => Localizer["Properties_PropertyType_CondoBuilding"],
            "Purpose-built rental" => Localizer["Properties_PropertyType_PurposeBuiltRental"],
            "Duplex / triplex" => Localizer["Properties_PropertyType_DuplexTriplex"],
            "Townhome cluster" => Localizer["Properties_PropertyType_TownhomeCluster"],
            "Single-family rental" => Localizer["Properties_PropertyType_SingleFamilyRental"],
            "Student housing" => Localizer["Properties_PropertyType_StudentHousing"],
            "Waterfront condo" => Localizer["Properties_PropertyType_WaterfrontCondo"],
            "Mixed-use asset" => Localizer["Properties_PropertyType_MixedUseAsset"],
            "Micro-suite building" => Localizer["Properties_PropertyType_MicroSuiteBuilding"],
            "Luxury rental" => Localizer["Properties_PropertyType_LuxuryRental"],
            "Suburban family asset" => Localizer["Properties_PropertyType_SuburbanFamilyAsset"],
            "Transit-oriented rental" => Localizer["Properties_PropertyType_TransitOrientedRental"],
            "Executive furnished rental" => Localizer["Properties_PropertyType_ExecutiveFurnishedRental"],
            _ => propertyType
        };

    private string LocalizeAssetStage(string stage)
        => stage switch
        {
            "Setup" => Localizer["Properties_AssetStage_Setup"],
            "Lease-up" => Localizer["Properties_AssetStage_LeaseUp"],
            "Stabilize playbook" => Localizer["Properties_AssetStage_StabilizePlaybook"],
            "Stabilized" => Localizer["Properties_AssetStage_Stabilized"],
            _ => stage
        };

    private static string GetTextOrFallback(string value, string fallback)
        => string.IsNullOrWhiteSpace(value) ? fallback : value;
}