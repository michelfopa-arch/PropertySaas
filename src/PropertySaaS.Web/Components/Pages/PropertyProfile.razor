@attribute [Authorize]
@page "/properties/{PropertyId:guid}"
@inject SaasDataService DataService

<PageTitle>Property Profile</PageTitle>

@if (_property is null)
{
    <MudAlert Severity="Severity.Warning">Property not found.</MudAlert>
}
else
{
    var occupiedCount = _units.Count(x => x.IsOccupied);
    var vacantCount = _units.Count - occupiedCount;
    var monthlyRent = _units.Sum(x => x.MonthlyRent);
    var readinessScore = GetMarketingReadinessScore(_property, _units, occupiedCount, monthlyRent);
    var performanceLabel = GetPerformanceLabel(_property, _units, occupiedCount, monthlyRent);
    var performanceColor = GetPerformanceColor(_property, _units, occupiedCount, monthlyRent);

    <MudStack Spacing="3">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudAvatar Size="Size.Large" Class="property-avatar">
                    <MudIcon Icon="@Icons.Material.Filled.Apartment" />
                </MudAvatar>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h4">@_property.Name</MudText>
                    <MudText Typo="Typo.body1" Class="property-address">@FormatAddress(_property)</MudText>
                </MudStack>
            </MudStack>

            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudChip T="string" Variant="Variant.Filled" Color="@performanceColor">@performanceLabel</MudChip>
                <MudButton Href="/properties" Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.ArrowBack">Back to properties</MudButton>
            </MudStack>
        </MudStack>

        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
            <MudChip T="string" Variant="Variant.Filled" Color="Color.Dark">@_property.PropertyType</MudChip>
            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary">@_property.City</MudChip>
            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">@GetPostalCodeOrFallback(_property)</MudChip>
            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Secondary">@($"{_units.Count} unit(s)")</MudChip>
            <MudChip T="string" Variant="Variant.Filled" Color="Color.Success">@($"{occupiedCount} occupied")</MudChip>
            <MudChip T="string" Variant="Variant.Filled" Color="Color.Warning">@($"{vacantCount} vacant")</MudChip>
        </MudStack>

        <MudGrid Spacing="2">
            <MudItem xs="12" md="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">Revenue target</MudText><MudText Typo="Typo.h6">@_property.MonthlyRevenueTarget.ToString("C")</MudText></MudPaper></MudItem>
            <MudItem xs="12" md="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">Actual rent roll</MudText><MudText Typo="Typo.h6">@monthlyRent.ToString("C")</MudText></MudPaper></MudItem>
            <MudItem xs="12" md="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">Occupancy</MudText><MudText Typo="Typo.h6">@GetOccupancyLabel(_units.Count, occupiedCount)</MudText></MudPaper></MudItem>
            <MudItem xs="12" md="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">Leasing readiness</MudText><MudText Typo="Typo.h6">@readinessScore/100</MudText></MudPaper></MudItem>
        </MudGrid>

        <MudTabs Rounded="true" PanelClass="pa-4">
            <MudTabPanel Text="Overview">
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="4"><MudPaper Class="pa-4 property-detail-panel h-100" Elevation="0"><MudText Typo="Typo.subtitle2">Ideal renter profile</MudText><MudText Typo="Typo.body2">@GetIdealRenterProfile(_property)</MudText></MudPaper></MudItem>
                    <MudItem xs="12" md="4"><MudPaper Class="pa-4 property-detail-panel h-100" Elevation="0"><MudText Typo="Typo.subtitle2">Suggested listing headline</MudText><MudText Typo="Typo.body2">@GetSuggestedHeadline(_property)</MudText></MudPaper></MudItem>
                    <MudItem xs="12" md="4"><MudPaper Class="pa-4 property-detail-panel h-100" Elevation="0"><MudText Typo="Typo.subtitle2">Asset stage</MudText><MudChip T="string" Variant="Variant.Filled" Color="@GetAssetStageColor(_units, vacantCount, readinessScore)">@GetAssetStage(_units, vacantCount, readinessScore)</MudChip><MudText Typo="Typo.body2" Class="mt-2">@GetAssetStageNarrative(_units, vacantCount, readinessScore)</MudText></MudPaper></MudItem>
                    <MudItem xs="12"><MudPaper Class="pa-4 property-score-panel" Elevation="0"><MudText Typo="Typo.h6">Leasing readiness score</MudText><MudText Typo="Typo.body2" Class="property-note">@GetReadinessSummary(readinessScore)</MudText><MudProgressLinear Class="mt-3" Rounded="true" Size="Size.Large" Color="@GetReadinessColor(readinessScore)" Value="@readinessScore" /></MudPaper></MudItem>
                </MudGrid>
            </MudTabPanel>
            <MudTabPanel Text="Units">
                @if (_units.Count == 0)
                {
                    <MudAlert Severity="Severity.Info">No units added yet for this property.</MudAlert>
                }
                else
                {
                    <MudTable Items="_units" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Class="property-units-table">
                        <HeaderContent>
                            <MudTh>Unit</MudTh>
                            <MudTh>Layout</MudTh>
                            <MudTh>Rent</MudTh>
                            <MudTh>Status</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Unit">@context.UnitNumber</MudTd>
                            <MudTd DataLabel="Layout">@($"{context.Bedrooms} bd / {context.Bathrooms} ba")</MudTd>
                            <MudTd DataLabel="Rent">@context.MonthlyRent.ToString("C")</MudTd>
                            <MudTd DataLabel="Status"><MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@(context.IsOccupied ? Color.Success : Color.Warning)">@(context.IsOccupied ? "Occupied" : "Vacant")</MudChip></MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudTabPanel>
            <MudTabPanel Text="Leasing">
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="6"><MudPaper Class="pa-4 property-detail-panel h-100" Elevation="0"><MudText Typo="Typo.subtitle2">Leasing playbook</MudText><MudText Typo="Typo.body2">@GetTextOrFallback(_property.LeasingNotes, "Record who rents here best, pricing cues and showing narrative.")</MudText></MudPaper></MudItem>
                    <MudItem xs="12" md="6"><MudPaper Class="pa-4 property-detail-panel h-100" Elevation="0"><MudText Typo="Typo.subtitle2">Pricing posture</MudText><MudText Typo="Typo.body2">@GetPricingPosture(_property, monthlyRent, vacantCount)</MudText></MudPaper></MudItem>
                    <MudItem xs="12"><MudPaper Class="pa-4 property-detail-panel" Elevation="0"><MudText Typo="Typo.subtitle2">Recommended actions</MudText><MudList T="string" Dense="true">@foreach (var action in GetRecommendedActions(_property, _units, vacantCount, readinessScore, monthlyRent)) { <MudListItem T="string">@action</MudListItem> }</MudList></MudPaper></MudItem>
                    <MudItem xs="12">
                        <MudPaper Class="pa-4 property-detail-panel" Elevation="0">
                            <MudText Typo="Typo.subtitle2">Live leases</MudText>
                            @if (_leases.Count == 0)
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">No leases currently linked to this property.</MudAlert>
                            }
                            else
                            {
                                <MudTable Items="_leases" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Class="mt-2">
                                    <HeaderContent>
                                        <MudTh>Unit</MudTh>
                                        <MudTh>Start</MudTh>
                                        <MudTh>End</MudTh>
                                        <MudTh>Rent</MudTh>
                                        <MudTh>Status</MudTh>
                                        <MudTh>Ontario lease</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="Unit">@GetUnitLabel(context.UnitId)</MudTd>
                                        <MudTd DataLabel="Start">@context.StartDate</MudTd>
                                        <MudTd DataLabel="End">@context.EndDate</MudTd>
                                        <MudTd DataLabel="Rent">@context.MonthlyRent.ToString("C")</MudTd>
                                        <MudTd DataLabel="Status">@context.Status</MudTd>
                                        <MudTd DataLabel="Ontario lease">@(context.StandardOntarioLeaseSigned ? "Signed" : "Missing")</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
            <MudTabPanel Text="Ops">
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="6"><MudPaper Class="pa-4 property-detail-panel h-100" Elevation="0"><MudText Typo="Typo.subtitle2">Operational notes</MudText><MudText Typo="Typo.body2">@GetTextOrFallback(_property.OperationalNotes, "Store turnover, vendor and operational watchouts for the team.")</MudText></MudPaper></MudItem>
                    <MudItem xs="12" md="6"><MudPaper Class="pa-4 property-detail-panel h-100" Elevation="0"><MudText Typo="Typo.subtitle2">Operations focus</MudText><MudText Typo="Typo.body2">@GetOperationsFocus(_property, vacantCount)</MudText></MudPaper></MudItem>
                    <MudItem xs="12"><MudPaper Class="pa-4 property-detail-panel" Elevation="0"><MudText Typo="Typo.subtitle2">Amenities</MudText><MudText Typo="Typo.body2">@GetTextOrFallback(_property.AmenitySummary, "Capture building amenities to arm leasing and showing conversations.")</MudText></MudPaper></MudItem>
                    <MudItem xs="12">
                        <MudPaper Class="pa-4 property-detail-panel" Elevation="0">
                            <MudText Typo="Typo.subtitle2">Maintenance pipeline</MudText>
                            @if (_maintenance.Count == 0)
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">No maintenance items currently linked to this property.</MudAlert>
                            }
                            else
                            {
                                <MudTable Items="_maintenance" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Class="mt-2">
                                    <HeaderContent>
                                        <MudTh>Title</MudTh>
                                        <MudTh>Priority</MudTh>
                                        <MudTh>Status</MudTh>
                                        <MudTh>Vendor</MudTh>
                                        <MudTh>Requested</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="Title">@context.Title</MudTd>
                                        <MudTd DataLabel="Priority">@context.Priority</MudTd>
                                        <MudTd DataLabel="Status">@context.Status</MudTd>
                                        <MudTd DataLabel="Vendor">@context.VendorName</MudTd>
                                        <MudTd DataLabel="Requested">@context.RequestedDate</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
            <MudTabPanel Text="Compliance">
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="6">
                        <MudPaper Class="pa-4 property-detail-panel h-100" Elevation="0">
                            <MudText Typo="Typo.subtitle2">Compliance reminder</MudText>
                            <MudText Typo="Typo.body2">Use this property profile to coordinate Ontario notices, unit turnover documentation and leasing readiness from one place.</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudPaper Class="pa-4 property-detail-panel h-100" Elevation="0">
                            <MudText Typo="Typo.subtitle2">Execution checklist</MudText>
                            <MudList T="string" Dense="true">
                                <MudListItem T="string">Verify Ontario lease package is current for new move-ins</MudListItem>
                                <MudListItem T="string">Track notice service dates and supporting audit trail</MudListItem>
                                <MudListItem T="string">Review turnover documentation before relisting any vacant unit</MudListItem>
                            </MudList>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12">
                        <MudPaper Class="pa-4 property-detail-panel" Elevation="0">
                            <MudText Typo="Typo.subtitle2">Upcoming Ontario reminders</MudText>
                            @if (_compliance.Count == 0)
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">No compliance reminders are currently available.</MudAlert>
                            }
                            else
                            {
                                <MudTable Items="_compliance" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Class="mt-2">
                                    <HeaderContent>
                                        <MudTh>Reminder</MudTh>
                                        <MudTh>Notice</MudTh>
                                        <MudTh>Due</MudTh>
                                        <MudTh>Reference</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="Reminder">@context.Title</MudTd>
                                        <MudTd DataLabel="Notice"><MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info">@context.NoticeType</MudChip></MudTd>
                                        <MudTd DataLabel="Due">@context.DueDate</MudTd>
                                        <MudTd DataLabel="Reference">@context.Reference</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
        </MudTabs>
    </MudStack>
}

@code {
    [Parameter] public Guid PropertyId { get; set; }

    private Property? _property;
    private List<Unit> _units = new();
    private List<Lease> _leases = new();
    private List<MaintenanceRequest> _maintenance = new();
    private List<ComplianceReminder> _compliance = new();

    protected override async Task OnParametersSetAsync()
    {
        var properties = await DataService.GetPropertiesAsync();
        _property = properties.FirstOrDefault(x => x.Id == PropertyId);

        _units = (await DataService.GetUnitsAsync())
            .Where(x => x.PropertyId == PropertyId)
            .OrderBy(x => x.UnitNumber)
            .ToList();

        var unitIds = _units.Select(x => x.Id).ToHashSet();
        _leases = (await DataService.GetLeasesAsync())
            .Where(x => unitIds.Contains(x.UnitId))
            .OrderByDescending(x => x.StartDate)
            .ToList();

        _maintenance = (await DataService.GetMaintenanceAsync())
            .Where(x => x.PropertyId == PropertyId || (x.UnitId.HasValue && unitIds.Contains(x.UnitId.Value)))
            .OrderByDescending(x => x.RequestedDate)
            .ToList();

        _compliance = (await DataService.GetComplianceAsync())
            .OrderBy(x => x.DueDate)
            .ToList();
    }

    private static string FormatAddress(Property property)
    {
        var parts = new[] { property.AddressLine1, property.City, property.Province, property.PostalCode }.Where(x => !string.IsNullOrWhiteSpace(x));
        return string.Join(", ", parts);
    }

    private static string GetOccupancyLabel(int totalUnits, int occupiedUnits)
        => totalUnits == 0 ? "No units" : $"{Math.Round((decimal)occupiedUnits / totalUnits * 100, 0)}%";

    private static int GetMarketingReadinessScore(Property property, List<Unit> propertyUnits, int occupiedCount, decimal monthlyRent)
    {
        var score = 0;
        if (!string.IsNullOrWhiteSpace(property.PropertyType)) score += 10;
        if (!string.IsNullOrWhiteSpace(property.PostalCode)) score += 10;
        if (!string.IsNullOrWhiteSpace(property.AmenitySummary)) score += 20;
        if (!string.IsNullOrWhiteSpace(property.NeighborhoodNotes)) score += 15;
        if (!string.IsNullOrWhiteSpace(property.LeasingNotes)) score += 20;
        if (!string.IsNullOrWhiteSpace(property.OperationalNotes)) score += 10;
        if (propertyUnits.Count > 0) score += 10;
        if (occupiedCount > 0 || monthlyRent > 0) score += 5;
        return Math.Min(score, 100);
    }

    private static string GetPerformanceLabel(Property property, List<Unit> propertyUnits, int occupiedCount, decimal monthlyRent)
    {
        if (propertyUnits.Count == 0) return "Setup needed";
        if (occupiedCount == propertyUnits.Count && monthlyRent >= property.MonthlyRevenueTarget) return "Performing";
        if (occupiedCount == 0) return "Needs leasing";
        return "Watchlist";
    }

    private static Color GetPerformanceColor(Property property, List<Unit> propertyUnits, int occupiedCount, decimal monthlyRent)
    {
        if (propertyUnits.Count == 0) return Color.Info;
        if (occupiedCount == propertyUnits.Count && monthlyRent >= property.MonthlyRevenueTarget) return Color.Success;
        if (occupiedCount == 0) return Color.Error;
        return Color.Warning;
    }

    private static Color GetReadinessColor(int score)
        => score >= 80 ? Color.Success : score >= 55 ? Color.Warning : Color.Error;

    private static string GetReadinessSummary(int score)
        => score >= 80 ? "This property is well documented and ready for consistent leasing execution."
            : score >= 55 ? "Good baseline, but more positioning detail would improve leasing consistency."
            : "High upside: complete the playbook fields to strengthen leasing quality and team execution.";

    private static string GetIdealRenterProfile(Property property)
    {
        if (property.PropertyType.Contains("student", StringComparison.OrdinalIgnoreCase)) return "Best positioned for students and parents prioritizing predictable operations, transit and nearby amenities.";
        if (property.PropertyType.Contains("single-family", StringComparison.OrdinalIgnoreCase) || property.PropertyType.Contains("townhome", StringComparison.OrdinalIgnoreCase)) return "Strong fit for longer-stay households looking for neighbourhood stability, storage and practical daily living.";
        return "Best suited for professionals and couples who value location quality, polished leasing presentation and smooth move-in execution.";
    }

    private static string GetSuggestedHeadline(Property property)
    {
        var city = string.IsNullOrWhiteSpace(property.City) ? "Toronto" : property.City;
        if (property.PropertyType.Contains("student", StringComparison.OrdinalIgnoreCase)) return $"Student-ready living in {city} with practical convenience and fast move-in support.";
        if (property.PropertyType.Contains("single-family", StringComparison.OrdinalIgnoreCase) || property.PropertyType.Contains("townhome", StringComparison.OrdinalIgnoreCase)) return $"Stable family-oriented rental in {city} with practical space and everyday convenience.";
        if (property.PropertyType.Contains("luxury", StringComparison.OrdinalIgnoreCase) || property.PropertyType.Contains("waterfront", StringComparison.OrdinalIgnoreCase) || property.PropertyType.Contains("executive", StringComparison.OrdinalIgnoreCase)) return $"Premium {property.PropertyType.ToLowerInvariant()} living in {city} with polished presentation and strong renter appeal.";
        return $"Well-positioned {property.PropertyType.ToLowerInvariant()} rental in {city} with commuter-friendly appeal and disciplined operations.";
    }

    private static string GetAssetStage(List<Unit> propertyUnits, int vacantCount, int readinessScore)
    {
        if (propertyUnits.Count == 0) return "Setup";
        if (vacantCount > 0) return "Lease-up";
        if (readinessScore < 80) return "Stabilize playbook";
        return "Stabilized";
    }

    private static Color GetAssetStageColor(List<Unit> propertyUnits, int vacantCount, int readinessScore)
    {
        var stage = GetAssetStage(propertyUnits, vacantCount, readinessScore);
        return stage switch
        {
            "Setup" => Color.Info,
            "Lease-up" => Color.Warning,
            "Stabilize playbook" => Color.Secondary,
            _ => Color.Success
        };
    }

    private static string GetAssetStageNarrative(List<Unit> propertyUnits, int vacantCount, int readinessScore)
    {
        var stage = GetAssetStage(propertyUnits, vacantCount, readinessScore);
        return stage switch
        {
            "Setup" => "The asset structure is not fully mapped yet. Finish the base setup before relying on portfolio insights.",
            "Lease-up" => "This address needs focused vacancy execution, pricing discipline and sharper listing follow-through.",
            "Stabilize playbook" => "Occupancy is workable, but the commercial playbook still needs stronger documentation for repeatable team execution.",
            _ => "The property is documented and operationally steady enough to serve as a benchmark asset in the portfolio."
        };
    }

    private static string GetPricingPosture(Property property, decimal monthlyRent, int vacantCount)
    {
        if (vacantCount > 0) return $"Protect revenue recovery first. Benchmark against the target of {property.MonthlyRevenueTarget:C}, tighten showing speed and avoid overpricing vacant suites.";
        if (monthlyRent > property.MonthlyRevenueTarget) return "This asset is outperforming target. Preserve pricing discipline and document why this positioning resonates with renters.";
        if (monthlyRent < property.MonthlyRevenueTarget) return "Revenue sits below target. Review unit mix, renewal strategy and whether the property story supports the desired price point.";
        return "Revenue is on target. Focus on keeping renewals smooth and protecting turnover quality rather than chasing avoidable concessions.";
    }

    private static string GetOperationsFocus(Property property, int vacantCount)
    {
        if (vacantCount > 0) return "Keep turnover speed high, align vendors early and remove friction between vacancy, maintenance and leasing handoff.";
        if (string.IsNullOrWhiteSpace(property.OperationalNotes)) return "Add repeatable operating notes so onsite staff and external vendors execute the asset the same way every time.";
        return property.OperationalNotes;
    }

    private static List<string> GetRecommendedActions(Property property, List<Unit> propertyUnits, int vacantCount, int readinessScore, decimal monthlyRent)
    {
        var actions = new List<string>();
        if (propertyUnits.Count == 0) actions.Add("Add the unit mix so occupancy, rent roll and leasing performance become measurable.");
        if (vacantCount > 0) actions.Add("Launch a vacancy recovery sprint with sharper pricing, faster showings and tighter follow-up.");
        if (readinessScore < 80) actions.Add("Complete the missing playbook inputs to improve consistency across listings, tours and renewals.");
        if (monthlyRent < property.MonthlyRevenueTarget) actions.Add("Review the pricing story and positioning against the revenue target before offering concessions.");
        if (actions.Count == 0)
        {
            actions.Add("Document what is working here and reuse this property as the benchmark playbook for similar assets.");
            actions.Add("Stay ahead of renewals and maintenance windows to protect the current stabilized performance.");
        }
        return actions.Take(3).ToList();
    }

    private string GetUnitLabel(Guid unitId)
        => _units.FirstOrDefault(x => x.Id == unitId)?.UnitNumber ?? unitId.ToString()[..8];

    private static string GetPostalCodeOrFallback(Property property)
        => string.IsNullOrWhiteSpace(property.PostalCode) ? "Postal pending" : property.PostalCode;

    private static string GetTextOrFallback(string value, string fallback)
        => string.IsNullOrWhiteSpace(value) ? fallback : value;
}