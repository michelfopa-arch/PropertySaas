@attribute [Authorize]
@page "/import-export"
@using PropertySaaS.Web.Localization

<PageTitle>@UiText.Get("ImportExport_PageTitle")</PageTitle>

<MudStack Spacing="3">
    <MudText Typo="Typo.h4">@UiText.Get("ImportExport_Title")</MudText>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4 h-100">
                <MudText Typo="Typo.h6" GutterBottom="true">@UiText.Get("ImportExport_ImportTitle")</MudText>
                <MudText Typo="Typo.body1">@UiText.Get("ImportExport_ImportBody")</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4 h-100">
                <MudText Typo="Typo.h6" GutterBottom="true">@UiText.Get("ImportExport_ExportTitle")</MudText>
                <MudText Typo="Typo.body1">@UiText.Get("ImportExport_ExportBody")</MudText>
                <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap" Class="mt-3">
                    <MudButton Href="/export/properties" Variant="Variant.Filled" Color="Color.Primary">@UiText.Get("ImportExport_ExportPropertiesCsv")</MudButton>
                    <MudButton Href="/export/tenants" Variant="Variant.Filled" Color="Color.Primary">@UiText.Get("ImportExport_ExportTenantsCsv")</MudButton>
                    <MudButton Href="/export/leases" Variant="Variant.Filled" Color="Color.Primary">@UiText.Get("ImportExport_ExportLeasesCsv")</MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>
