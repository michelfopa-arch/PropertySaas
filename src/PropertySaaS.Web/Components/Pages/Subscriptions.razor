@attribute [Authorize]
@page "/subscriptions"
@using PropertySaaS.Web.Localization

<PageTitle>@UiText.Get("Subscriptions_PageTitle")</PageTitle>

<MudStack Spacing="3">
    <MudText Typo="Typo.h4">@UiText.Get("Subscriptions_Title")</MudText>

    <MudPaper Class="pa-4">
        <MudText Typo="Typo.body1" Class="mb-3">@UiText.Get("Subscriptions_Intro")</MudText>
        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
            <MudButton Href="/billing/checkout/starter" Variant="Variant.Filled" Color="Color.Primary">@UiText.Get("Subscriptions_StartStarter")</MudButton>
            <MudButton Href="/billing/checkout/growth" Variant="Variant.Filled" Color="Color.Primary">@UiText.Get("Subscriptions_StartGrowth")</MudButton>
            <MudButton Href="/billing/checkout/pro" Variant="Variant.Filled" Color="Color.Primary">@UiText.Get("Subscriptions_StartPro")</MudButton>
            <MudButton Href="/billing/portal" Variant="Variant.Outlined" Color="Color.Default">@UiText.Get("Subscriptions_OpenPortal")</MudButton>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4">
        <MudText Typo="Typo.h6" GutterBottom="true">@UiText.Get("Subscriptions_AuthTitle")</MudText>
        <MudText Typo="Typo.body1" Class="mb-3">@UiText.Get("Subscriptions_AuthBody")</MudText>
        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
            <MudButton Href="/account/login" Variant="Variant.Filled" Color="Color.Secondary">@UiText.Get("Nav_SignIn")</MudButton>
            <MudButton Href="/account/logout" Variant="Variant.Outlined" Color="Color.Default">@UiText.Get("Nav_SignOut")</MudButton>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4">
        <MudText Typo="Typo.h6" GutterBottom="true">@UiText.Get("Subscriptions_ChecklistTitle")</MudText>
        <MudList T="string" Dense="true">
            <MudListItem T="string">@UiText.Get("Subscriptions_Checklist1")</MudListItem>
            <MudListItem T="string">@UiText.Get("Subscriptions_Checklist2")</MudListItem>
            <MudListItem T="string">@UiText.Get("Subscriptions_Checklist3")</MudListItem>
        </MudList>
    </MudPaper>
</MudStack>

