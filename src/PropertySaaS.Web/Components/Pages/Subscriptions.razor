@attribute [Authorize]
@page "/subscriptions"
@inject SaasDataService DataService
@inject NavigationManager NavigationManager
@using PropertySaaS.Web.Localization

<PageTitle>@UiText.Get("Subscriptions_PageTitle")</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="px-0">
    <MudStack Spacing="3">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h4">@UiText.Get("Subscriptions_Title")</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">@UiText.Get("Subscriptions_Intro")</MudText>
        </MudStack>

        @if (!string.IsNullOrWhiteSpace(_checkoutMessage))
        {
            <MudAlert Severity="@_checkoutSeverity" Variant="Variant.Filled">@_checkoutMessage</MudAlert>
        }

        @if (_entitlements is not null)
        {
            <MudPaper Class="pa-4 marketing-card" Elevation="0">
                <MudStack Spacing="2">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                        <div>
                            <MudText Typo="Typo.h6">@UiText.Format("Subscriptions_CurrentPlan", _entitlements.PlanName)</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@UiText.Get("Subscriptions_CurrentPlanHelp")</MudText>
                        </div>
                        <MudButton Href="/billing/portal" Variant="Variant.Outlined" Color="Color.Default">@UiText.Get("Subscriptions_OpenPortal")</MudButton>
                    </MudStack>

                    @if (!string.IsNullOrWhiteSpace(_entitlements.TrialBanner))
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">@UiText.Format("Dashboard_TrialBanner", _entitlements.TrialBanner, FormatUnits(_entitlements.MaxUnits), _entitlements.MaxUsers)</MudAlert>
                    }

                    <MudGrid Spacing="2">
                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-4" Elevation="0">
                                <MudText Typo="Typo.subtitle1">@UiText.Get("Subscriptions_LimitsTitle")</MudText>
                                <MudList T="string" Dense="true" Class="mt-2">
                                    <MudListItem T="string">@UiText.Format("Subscriptions_MaxUnits", FormatUnits(_entitlements.MaxUnits))</MudListItem>
                                    <MudListItem T="string">@UiText.Format("Subscriptions_MaxUsers", _entitlements.MaxUsers.ToString())</MudListItem>
                                </MudList>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-4" Elevation="0">
                                <MudText Typo="Typo.subtitle1">@UiText.Get("Subscriptions_FeaturesTitle")</MudText>
                                <MudList T="string" Dense="true" Class="mt-2">
                                    <MudListItem T="string">@UiText.Format("Subscriptions_Compliance", FormatFeature(_entitlements.IncludesCompliance))</MudListItem>
                                    <MudListItem T="string">@UiText.Format("Subscriptions_AuditLogs", FormatFeature(_entitlements.IncludesAuditLogs))</MudListItem>
                                    <MudListItem T="string">@UiText.Format("Subscriptions_PrioritySupport", FormatFeature(_entitlements.IncludesPrioritySupport))</MudListItem>
                                    <MudListItem T="string">@UiText.Format("Subscriptions_AdvancedExports", FormatFeature(_entitlements.IncludesAdvancedExports))</MudListItem>
                                </MudList>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudStack>
            </MudPaper>
        }

        <MudGrid Spacing="3">
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4 marketing-card h-100" Elevation="0">
                    <MudStack Spacing="2">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6">Starter</MudText>
                            @if (IsCurrentPlan("Starter"))
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small">@UiText.Get("Subscriptions_CurrentPlanChip")</MudChip>
                            }
                        </MudStack>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@UiText.Get("Subscriptions_StarterSummary")</MudText>
                        <MudList T="string" Dense="true">
                            <MudListItem T="string">@UiText.Get("Pricing_Starter1")</MudListItem>
                            <MudListItem T="string">@UiText.Get("Pricing_Starter2")</MudListItem>
                            <MudListItem T="string">@UiText.Get("Pricing_Starter5")</MudListItem>
                        </MudList>
                        <MudButton Href="/billing/checkout/starter" Variant="@(IsCurrentPlan("Starter") ? Variant.Outlined : Variant.Filled)" Color="Color.Primary">@UiText.Get("Subscriptions_StartStarter")</MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4 marketing-card h-100" Elevation="0">
                    <MudStack Spacing="2">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6">Growth</MudText>
                            @if (IsCurrentPlan("Growth"))
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small">@UiText.Get("Subscriptions_CurrentPlanChip")</MudChip>
                            }
                        </MudStack>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@UiText.Get("Subscriptions_GrowthSummary")</MudText>
                        <MudList T="string" Dense="true">
                            <MudListItem T="string">@UiText.Get("Pricing_Growth1")</MudListItem>
                            <MudListItem T="string">@UiText.Get("Pricing_Growth3")</MudListItem>
                            <MudListItem T="string">@UiText.Get("Pricing_Growth5")</MudListItem>
                        </MudList>
                        <MudButton Href="/billing/checkout/growth" Variant="@(IsCurrentPlan("Growth") ? Variant.Outlined : Variant.Filled)" Color="Color.Primary">@UiText.Get("Subscriptions_StartGrowth")</MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4 marketing-card h-100" Elevation="0">
                    <MudStack Spacing="2">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6">Pro</MudText>
                            @if (IsCurrentPlan("Pro"))
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small">@UiText.Get("Subscriptions_CurrentPlanChip")</MudChip>
                            }
                        </MudStack>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@UiText.Get("Subscriptions_ProSummary")</MudText>
                        <MudList T="string" Dense="true">
                            <MudListItem T="string">@UiText.Get("Pricing_Pro1")</MudListItem>
                            <MudListItem T="string">@UiText.Get("Pricing_Pro4")</MudListItem>
                            <MudListItem T="string">@UiText.Get("Pricing_Pro5")</MudListItem>
                        </MudList>
                        <MudButton Href="/billing/checkout/pro" Variant="@(IsCurrentPlan("Pro") ? Variant.Outlined : Variant.Filled)" Color="Color.Primary">@UiText.Get("Subscriptions_StartPro")</MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6" GutterBottom="true">@UiText.Get("Subscriptions_ChecklistTitle")</MudText>
            <MudList T="string" Dense="true">
                <MudListItem T="string">@UiText.Get("Subscriptions_Checklist1")</MudListItem>
                <MudListItem T="string">@UiText.Get("Subscriptions_Checklist2")</MudListItem>
                <MudListItem T="string">@UiText.Get("Subscriptions_Checklist3")</MudListItem>
            </MudList>
        </MudPaper>
    </MudStack>
</MudContainer>

@code {
    private SubscriptionEntitlementsDto? _entitlements;
    private string? _checkoutMessage;
    private Severity _checkoutSeverity = Severity.Info;

    protected override async Task OnInitializedAsync()
    {
        _entitlements = await DataService.GetSubscriptionEntitlementsAsync();
        ResolveCheckoutMessage();
    }

    private void ResolveCheckoutMessage()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (!query.TryGetValue("checkout", out var checkoutValue))
        {
            return;
        }

        switch (checkoutValue.ToString())
        {
            case "success":
                _checkoutSeverity = Severity.Success;
                _checkoutMessage = UiText.Get("Subscriptions_CheckoutSuccess");
                break;
            case "cancelled":
                _checkoutSeverity = Severity.Warning;
                _checkoutMessage = UiText.Get("Subscriptions_CheckoutCancelled");
                break;
            case "missing-organization":
                _checkoutSeverity = Severity.Error;
                _checkoutMessage = UiText.Get("Subscriptions_CheckoutMissingOrganization");
                break;
        }
    }

    private string FormatUnits(int units)
        => units == int.MaxValue ? UiText.Get("Dashboard_Unlimited") : units.ToString();

    private string FormatFeature(bool enabled)
        => enabled ? UiText.Get("Dashboard_Included") : UiText.Get("Dashboard_NotIncluded");

    private bool IsCurrentPlan(string planName)
        => _entitlements is not null && string.Equals(_entitlements.PlanName, planName, StringComparison.OrdinalIgnoreCase);
}

