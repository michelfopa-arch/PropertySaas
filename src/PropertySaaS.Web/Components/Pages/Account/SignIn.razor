@page "/sign-in"
@using PropertySaaS.Web.Localization

<PageTitle>@UiText.Get("Auth_SignInPageTitle")</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="py-8">
    <MudPaper Class="pa-6 marketing-card" Elevation="0">
        <MudStack Spacing="3">
            <MudText Typo="Typo.h4">@UiText.Get("Auth_SignInTitle")</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">@UiText.Get("Auth_SignInSubtitle")</MudText>
            <MudStack Spacing="2">
                <MudButton Href="/account/login" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true">@UiText.Get("Auth_ContinueWithClerk")</MudButton>
                <MudButton Href="/sign-up" Variant="Variant.Outlined" Color="Color.Default" FullWidth="true">@UiText.Get("Auth_CreateAccount")</MudButton>
                <MudButton Href="/forgot-password" Variant="Variant.Text" Color="Color.Secondary" FullWidth="true">@UiText.Get("Auth_ForgotPassword")</MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>
</MudContainer>
