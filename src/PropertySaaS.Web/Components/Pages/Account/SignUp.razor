@page "/sign-up"
@using PropertySaaS.Web.Localization

<PageTitle>@UiText.Get("Auth_SignUpPageTitle")</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="py-8">
    <MudPaper Class="pa-6 marketing-card" Elevation="0">
        <MudStack Spacing="3">
            <MudText Typo="Typo.h4">@UiText.Get("Auth_SignUpTitle")</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">@UiText.Get("Auth_SignUpSubtitle")</MudText>
            <MudStack Spacing="2">
                <MudButton Href="/account/sign-up" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true">@UiText.Get("Auth_StartFree")</MudButton>
                <MudButton Href="/sign-in" Variant="Variant.Outlined" Color="Color.Default" FullWidth="true">@UiText.Get("Auth_AlreadyHaveAccount")</MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>
</MudContainer>
