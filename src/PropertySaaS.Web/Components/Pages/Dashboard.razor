@attribute [Authorize]
@page "/dashboard"
@inject SaasDataService DataService
@inject NavigationManager NavigationManager
@inject PropertySaaS.Application.Common.CurrentOrganization CurrentOrganization
@using PropertySaaS.Web.Localization

<PageTitle>@UiText.Get("Dashboard_PageTitle")</PageTitle>

@if (_summary is null)
{
    <MudPaper Class="pa-6 d-flex justify-center">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    </MudPaper>
}
else
{
    <MudContainer MaxWidth="MaxWidth.False" Class="px-0">
        @if (!IsDemoCleanView && _entitlements is not null && !string.IsNullOrWhiteSpace(_entitlements.TrialBanner))
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Dense="true" Class="mb-4">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                    <MudText Typo="Typo.body2">@UiText.Format("Dashboard_TrialBanner", _entitlements.TrialBanner, _entitlements.MaxUnits, _entitlements.MaxUsers)</MudText>
                    <MudButton Href="/subscriptions" Variant="Variant.Text" Color="Color.Inherit">@UiText.Get("Dashboard_UpgradeCta")</MudButton>
                </MudStack>
            </MudAlert>
        }

        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4" Wrap="Wrap.Wrap">
            <MudStack Spacing="1">
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">@UiText.Get("Dashboard_PremiumBadge")</MudChip>
                <MudText Typo="Typo.h4">@UiText.Get("Dashboard_Title")</MudText>
            </MudStack>
            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenGuidedDemoStart">@UiText.Get("Dashboard_StartGuidedDemo")</MudButton>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled">@OccupancyCaption</MudChip>
            </MudStack>
        </MudStack>

        <DemoJourneyBanner CurrentStepKey="dashboard" ResidentRoute="@Resident360DemoRoute" />

        <MudPaper Class="pa-3 marketing-card mb-4" Elevation="0">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                <MudText Typo="Typo.subtitle2">@UiText.Get("Common_RecommendedNextStop")</MudText>
                <MudButton Variant="Variant.Text" Color="@RecommendedNextStopColor" OnClick="OpenRecommendedNextStop">@RecommendedNextStopLabel</MudButton>
            </MudStack>
        </MudPaper>

        <MudExpansionPanels Class="marketing-card mb-4" Elevation="0">
            <MudExpansionPanel Text="@UiText.Get("Dashboard_OperationalStoryTitle")">
                <MudText Typo="Typo.body2">@UiText.Get("Dashboard_OperationalStorySubtitle")</MudText>
                <MudList T="string" Dense="true" Class="mt-3">
                    <MudListItem T="string">@UiText.Get("Dashboard_OperationalStoryStep1")</MudListItem>
                    <MudListItem T="string">@UiText.Get("Dashboard_OperationalStoryStep2")</MudListItem>
                    <MudListItem T="string">@UiText.Get("Dashboard_OperationalStoryStep3")</MudListItem>
                </MudList>
            </MudExpansionPanel>
        </MudExpansionPanels>

        @if (!IsDemoCleanView)
        {
            <MudExpansionPanels Class="property-detail-panel mb-4" Elevation="0">
                <MudExpansionPanel Text="@UiText.Get("Dashboard_ManagerQueueTitle")">
                    <MudText Typo="Typo.body2">@UiText.Get("Dashboard_ManagerQueueSubtitle")</MudText>
                    <MudGrid Spacing="2" Class="mt-2">
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Class="pa-3 property-mini-stat" Elevation="0">
                                <MudText Typo="Typo.overline">@UiText.Get("Dashboard_ManagerQueueAwaitingReply")</MudText>
                                <MudButton Class="mt-2" Variant="Variant.Text" Color="Color.Warning" OnClick='() => OpenCommunicationQueue("awaiting-reply")'>@_summary.CommunicationAwaitingReply</MudButton>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Class="pa-3 property-mini-stat" Elevation="0">
                                <MudText Typo="Typo.overline">@UiText.Get("Dashboard_ManagerQueueRentAtRisk")</MudText>
                                <MudButton Class="mt-2" Variant="Variant.Text" Color="Color.Secondary" OnClick='() => OpenCommunicationQueue("rent")'>@_summary.CommunicationRentAtRisk</MudButton>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Class="pa-3 property-mini-stat" Elevation="0">
                                <MudText Typo="Typo.overline">@UiText.Get("Dashboard_ManagerQueueMoveInBlocked")</MudText>
                                <MudButton Class="mt-2" Variant="Variant.Text" Color="Color.Info" OnClick='() => OpenCommunicationQueue("move-in")'>@_summary.CommunicationMoveInBlocked</MudButton>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Class="pa-3 property-mini-stat" Elevation="0">
                                <MudText Typo="Typo.overline">@UiText.Get("Dashboard_ManagerQueueMaintenanceActive")</MudText>
                                <MudButton Class="mt-2" Variant="Variant.Text" Color="Color.Error" OnClick='() => OpenCommunicationQueue("maintenance")'>@_summary.CommunicationMaintenanceActive</MudButton>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudExpansionPanel>
            </MudExpansionPanels>
        }

        <MudPaper Class="pa-4 marketing-card mb-4" Elevation="0">
            <MudText Typo="Typo.h6">@UiText.Get("Dashboard_ManagerNextActionTitle")</MudText>
            <MudText Typo="Typo.body2" Class="mt-2">@ManagerNextActionMessage</MudText>
            <MudButton Class="mt-3" Variant="Variant.Filled" Color="@ManagerNextActionColor" OnClick="OpenManagerNextAction">@UiText.Get("Dashboard_ManagerNextActionOpen")</MudButton>
        </MudPaper>

        <MudExpansionPanels Class="marketing-card mb-4" Elevation="0">
            <MudExpansionPanel Text="@UiText.Get("Dashboard_DailyBriefTitle")">
                <MudText Typo="Typo.body2">@UiText.Get("Dashboard_DailyBriefSubtitle")</MudText>
                <MudText Typo="Typo.subtitle2" Class="mt-3">@DailyBriefHeadline</MudText>
                <MudList T="string" Dense="true" Class="mt-2">
                    @foreach (var item in DailyBriefItems)
                    {
                        <MudListItem T="string">@item</MudListItem>
                    }
                </MudList>
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="mt-3" Wrap="Wrap.Wrap">
                    <MudText Typo="Typo.overline">@UiText.Get("Dashboard_DailyBriefOpeningLane")</MudText>
                    <MudChip T="string" Variant="Variant.Outlined" Color="@ManagerNextActionColor">@NextOpeningLaneLabel</MudChip>
                </MudStack>
                <MudButton Class="mt-3" Variant="Variant.Filled" Color="@ManagerNextActionColor" OnClick="OpenManagerNextAction">@UiText.Get("Dashboard_DailyBriefStartDay")</MudButton>
            </MudExpansionPanel>
        </MudExpansionPanels>

        @if (!IsDemoCleanView)
        {
            <MudExpansionPanels Class="property-detail-panel mb-4" Elevation="0">
                <MudExpansionPanel Text="@UiText.Get("Dashboard_ChangesTitle")">
                    <MudStack Spacing="2">
                        @foreach (var item in ChangeHighlights)
                        {
                            <MudPaper Class="pa-3 property-detail-panel" Elevation="0">
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                                    <MudText Typo="Typo.body2">@item.Message</MudText>
                                    @if (item.Action is not null)
                                    {
                                        <MudButton Variant="Variant.Text" Color="@item.Color" OnClick="item.Action">@UiText.Get("Common_ReviewNow")</MudButton>
                                    }
                                </MudStack>
                            </MudPaper>
                        }
                    </MudStack>
                </MudExpansionPanel>
            </MudExpansionPanels>
        }

        <MudExpansionPanels Class="marketing-card mb-4" Elevation="0">
            <MudExpansionPanel Text="@UiText.Get("Dashboard_GuidedDemoTitle")">
                <MudText Typo="Typo.body2">@UiText.Get("Dashboard_GuidedDemoSubtitle")</MudText>
                <MudGrid Spacing="2" Class="mt-2">
                    <MudItem xs="12" md="6">
                        <MudPaper Class="pa-3 property-detail-panel h-100" Elevation="0">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                                <MudText Typo="Typo.subtitle2">@UiText.Get("Dashboard_GuidedDemoStep1")</MudText>
                                @if (string.Equals(RecommendedDemoStepKey, "portfolio", StringComparison.OrdinalIgnoreCase))
                                {
                                    <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary">@UiText.Get("Dashboard_GuidedDemoRecommended")</MudChip>
                                }
                            </MudStack>
                            <MudText Typo="Typo.body2" Class="mt-1">@UiText.Get("Dashboard_GuidedDemoStep1Body")</MudText>
                            <MudButton Class="mt-2" Variant="Variant.Text" Color="Color.Primary" Href="@WithDemoMode("/properties")">@UiText.Get("Common_ReviewNow")</MudButton>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudPaper Class="pa-3 property-detail-panel h-100" Elevation="0">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                                <MudText Typo="Typo.subtitle2">@UiText.Get("Dashboard_GuidedDemoStep2")</MudText>
                                @if (string.Equals(RecommendedDemoStepKey, "leasing", StringComparison.OrdinalIgnoreCase))
                                {
                                    <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary">@UiText.Get("Dashboard_GuidedDemoRecommended")</MudChip>
                                }
                            </MudStack>
                            <MudText Typo="Typo.body2" Class="mt-1">@UiText.Get("Dashboard_GuidedDemoStep2Body")</MudText>
                            <MudButton Class="mt-2" Variant="Variant.Text" Color="Color.Primary" Href="@WithDemoMode("/leasing")">@UiText.Get("Common_ReviewNow")</MudButton>
                        </MudPaper>
                    </MudItem>
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-3 property-detail-panel h-100" Elevation="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                            <MudText Typo="Typo.subtitle2">@UiText.Get("Dashboard_GuidedDemoStep3")</MudText>
                            @if (string.Equals(RecommendedDemoStepKey, "resident", StringComparison.OrdinalIgnoreCase))
                            {
                                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary">@UiText.Get("Dashboard_GuidedDemoRecommended")</MudChip>
                            }
                        </MudStack>
                        <MudText Typo="Typo.body2" Class="mt-1">@UiText.Get("Dashboard_GuidedDemoStep3Body")</MudText>
                        <MudButton Class="mt-2" Variant="Variant.Text" Color="Color.Primary" Href="@WithDemoMode(Resident360DemoRoute)">@UiText.Get("Common_ReviewNow")</MudButton>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-3 property-detail-panel h-100" Elevation="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                            <MudText Typo="Typo.subtitle2">@UiText.Get("Dashboard_GuidedDemoStep4")</MudText>
                            @if (string.Equals(RecommendedDemoStepKey, "maintenance", StringComparison.OrdinalIgnoreCase))
                            {
                                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary">@UiText.Get("Dashboard_GuidedDemoRecommended")</MudChip>
                            }
                        </MudStack>
                        <MudText Typo="Typo.body2" Class="mt-1">@UiText.Get("Dashboard_GuidedDemoStep4Body")</MudText>
                        <MudButton Class="mt-2" Variant="Variant.Text" Color="Color.Primary" Href="@WithDemoMode("/maintenance")">@UiText.Get("Common_ReviewNow")</MudButton>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-3 property-detail-panel h-100" Elevation="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                            <MudText Typo="Typo.subtitle2">@UiText.Get("Dashboard_GuidedDemoStep5")</MudText>
                            @if (string.Equals(RecommendedDemoStepKey, "evidence", StringComparison.OrdinalIgnoreCase))
                            {
                                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary">@UiText.Get("Dashboard_GuidedDemoRecommended")</MudChip>
                            }
                        </MudStack>
                        <MudText Typo="Typo.body2" Class="mt-1">@UiText.Get("Dashboard_GuidedDemoStep5Body")</MudText>
                        <MudButton Class="mt-2" Variant="Variant.Text" Color="Color.Primary" Href="@WithDemoMode("/documents-evidence")">@UiText.Get("Common_ReviewNow")</MudButton>
                    </MudPaper>
                </MudItem>
                </MudGrid>
            </MudExpansionPanel>
        </MudExpansionPanels>

        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6" md="3"><MetricCard Title="@UiText.Get("Nav_Properties")" Value="@_summary.Properties.ToString()" Caption="@UiText.Get("Dashboard_ManagedBuildings")" Icon="@Icons.Material.Filled.Apartment" /></MudItem>
            <MudItem xs="12" sm="6" md="3"><MetricCard Title="@UiText.Get("Nav_Units")" Value="@_summary.Units.ToString()" Caption="@OccupancyCaption" Icon="@Icons.Material.Filled.MeetingRoom" /></MudItem>
            <MudItem xs="12" sm="6" md="3"><MetricCard Title="@UiText.Get("Dashboard_ActiveLeases")" Value="@_summary.ActiveLeases.ToString()" Caption="@CurrentOrganization.Jurisdiction.LeasePackageLabel" Icon="@Icons.Material.Filled.Description" /></MudItem>
            <MudItem xs="12" sm="6" md="3"><MetricCard Title="@UiText.Get("Dashboard_RentRoll")" Value="@RentRollValue" Caption="@UiText.Get("Dashboard_MonthlyContractedRent")" Icon="@Icons.Material.Filled.Paid" /></MudItem>

            <MudItem xs="12" sm="6" md="4"><MetricCard Title="@UiText.Get("Dashboard_OpenMaintenance")" Value="@_summary.OpenMaintenance.ToString()" Caption="@UiText.Get("Dashboard_VendorCoordinationQueue")" Icon="@Icons.Material.Filled.BuildCircle" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MetricCard Title="@UiText.Get("Dashboard_ComplianceDueSoon")" Value="@_summary.ComplianceDueSoon.ToString()" Caption="@UiText.Format("Dashboard_WorkflowQueue", CurrentOrganization.Jurisdiction.ProvinceDisplayName)" Icon="@Icons.Material.Filled.EventNote" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MetricCard Title="@UiText.Get("Dashboard_Tenants")" Value="@_summary.Tenants.ToString()" Caption="@UiText.Get("Dashboard_ScreeningReadyContacts")" Icon="@Icons.Material.Filled.Groups2" /></MudItem>

            <MudItem xs="12" sm="6" md="4">
                <MudPaper Class="pa-4 marketing-card h-100" Elevation="0">
                    <MudText Typo="Typo.overline">@UiText.Get("Dashboard_DispatchAtRisk")</MudText>
                    <MudText Typo="Typo.h4">@_summary.DispatchAtRisk</MudText>
                    <MudText Typo="Typo.body2">@UiText.Get("Dashboard_DispatchAtRiskCaption")</MudText>
                    <MudButton Class="mt-3" Variant="Variant.Text" Color="Color.Warning" OnClick='() => OpenMaintenanceDispatch("AtRisk")'>@UiText.Get("Dashboard_OpenAtRiskDispatch")</MudButton>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Class="pa-4 marketing-card h-100" Elevation="0">
                    <MudText Typo="Typo.overline">@UiText.Get("Dashboard_DispatchBlocked")</MudText>
                    <MudText Typo="Typo.h4">@_summary.DispatchBlocked</MudText>
                    <MudText Typo="Typo.body2">@UiText.Get("Dashboard_DispatchBlockedCaption")</MudText>
                    <MudButton Class="mt-3" Variant="Variant.Text" Color="Color.Default" OnClick='() => OpenMaintenanceDispatch("Blocked")'>@UiText.Get("Dashboard_OpenBlockedDispatch")</MudButton>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Class="pa-4 marketing-card h-100" Elevation="0">
                    <MudText Typo="Typo.overline">@UiText.Get("Dashboard_VendorFollowUpTitle")</MudText>
                    @if (PriorityVendorSignal is null)
                    {
                        <MudText Typo="Typo.body2" Class="mt-2">@UiText.Get("Dashboard_VendorFollowUpEmpty")</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.h6" Class="mt-1">@PriorityVendorSignal.VendorName</MudText>
                        <MudText Typo="Typo.body2">@UiText.Format("Dashboard_VendorFollowUpSummary", PriorityVendorSignal.Title, PriorityVendorSignal.DispatchStatus, GetSignalRiskLabel(PriorityVendorSignal))</MudText>
                        <MudButton Class="mt-3" Variant="Variant.Text" Color="Color.Primary" OnClick='() => OpenVendorFollowUp(PriorityVendorSignal.VendorName)'>@UiText.Get("Dashboard_OpenVendorFollowUp")</MudButton>
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" md="4"><MetricCard Title="@UiText.Get("Dashboard_SubscriptionTier")" Value="@_summary.SubscriptionTier" Caption="@UiText.Get("Dashboard_StripeReadyPlanSnapshot")" Icon="@Icons.Material.Filled.Subscriptions" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MetricCard Title="@UiText.Format("Dashboard_NoticesTitle", CurrentOrganization.Jurisdiction.ProvinceDisplayName)" Value="@_summary.JurisdictionNoticesInWorkflow.ToString()" Caption="@UiText.Format("Dashboard_NoticesCaption", string.Join("/", CurrentOrganization.Jurisdiction.NoticeTypes))" Icon="@Icons.Material.Filled.Gavel" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MetricCard Title="@UiText.Get("Dashboard_ExportsReady")" Value="@_summary.ExportFeedsReady.ToString()" Caption="@UiText.Get("Dashboard_ExportsCaption")" Icon="@Icons.Material.Filled.ImportExport" /></MudItem>

            <MudItem xs="12" md="6"><MetricCard Title="@UiText.Get("Dashboard_OccupiedUnits")" Value="@_summary.OccupiedUnits.ToString()" Caption="@UiText.Get("Dashboard_IncomeProducingInventory")" Icon="@Icons.Material.Filled.DomainVerification" /></MudItem>
            <MudItem xs="12" md="6"><MetricCard Title="@UiText.Get("Dashboard_VacantUnits")" Value="@_summary.VacantUnits.ToString()" Caption="@UiText.Get("Dashboard_LeasingOpportunities")" Icon="@Icons.Material.Filled.HomeWork" /></MudItem>
        </MudGrid>

        @if (!IsDemoCleanView && _entitlements is not null)
        {
            <MudGrid Spacing="3" Class="mt-1">
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4 marketing-card h-100" Elevation="0">
                        <MudText Typo="Typo.h6">@UiText.Get("Dashboard_TrialReadinessTitle")</MudText>
                        <MudList T="string" Dense="true" Class="mt-3">
                            <MudListItem T="string">@UiText.Format("Dashboard_TrialUnits", _entitlements.MaxUnits == int.MaxValue ? UiText.Get("Dashboard_Unlimited") : _entitlements.MaxUnits.ToString())</MudListItem>
                            <MudListItem T="string">@UiText.Format("Dashboard_TrialUsers", _entitlements.MaxUsers.ToString())</MudListItem>
                            <MudListItem T="string">@UiText.Format("Dashboard_TrialCompliance", _entitlements.IncludesCompliance ? UiText.Get("Dashboard_Included") : UiText.Get("Dashboard_NotIncluded"))</MudListItem>
                            <MudListItem T="string">@UiText.Format("Dashboard_TrialExports", _entitlements.IncludesAdvancedExports ? UiText.Get("Dashboard_Included") : UiText.Get("Dashboard_NotIncluded"))</MudListItem>
                        </MudList>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4 marketing-card h-100" Elevation="0">
                        <MudText Typo="Typo.h6">@UiText.Get("Dashboard_ActivationTitle")</MudText>
                        <MudList T="string" Dense="true" Class="mt-3">
                            <MudListItem T="string">@UiText.Get("Dashboard_Activation1")</MudListItem>
                            <MudListItem T="string">@UiText.Get("Dashboard_Activation2")</MudListItem>
                            <MudListItem T="string">@UiText.Get("Dashboard_Activation3")</MudListItem>
                            <MudListItem T="string">@UiText.Get("Dashboard_Activation4")</MudListItem>
                        </MudList>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }

        <MudPaper Class="pa-4 marketing-card h-100 mt-4" Elevation="0">
            <MudText Typo="Typo.h6">@UiText.Get("Dashboard_DispatchPriorityTitle")</MudText>
            @if (PriorityDispatchTicket is null)
            {
                <MudText Typo="Typo.body2" Class="mt-2">@UiText.Get("Dashboard_DispatchNoPriority")</MudText>
            }
            else
            {
                <MudText Typo="Typo.subtitle2" Class="mt-2">@PriorityDispatchTicket.Title</MudText>
                <MudText Typo="Typo.body2">@PriorityDispatchTicket.PropertyName - @PriorityDispatchTicket.DispatchStatus</MudText>
                <MudText Typo="Typo.body2">@(PriorityDispatchTicket.IsAtRisk ? UiText.Get("Maintenance_SlaAtRisk") : UiText.Get("Dashboard_DispatchBlocked"))</MudText>
                <MudButton Class="mt-3" Variant="Variant.Filled" Color="Color.Primary" OnClick='() => OpenMaintenanceTicket(PriorityDispatchTicket.MaintenanceRequestId)'>@UiText.Get("Common_OpenTicket")</MudButton>
            }
        </MudPaper>
    </MudContainer>
}

@code {
    [SupplyParameterFromQuery(Name = "demo")]
    public string? DemoMode { get; set; }

    private DashboardSummaryDto? _summary;
    private SubscriptionEntitlementsDto? _entitlements;
    private List<DispatchSignalDto> _dispatchSignals = new();
    private Guid? _residentDemoTenantId;
    private bool IsDemoCleanView => DemoModeRouteHelper.IsClean(DemoMode);
    private string OccupancyCaption => _summary is null ? string.Empty : UiText.Format("Dashboard_OccupancyCaption", _summary.OccupancyRate);
    private string RentRollValue => _summary is null ? string.Empty : _summary.MonthlyRentRoll.ToString("C");
    private string Resident360DemoRoute => _residentDemoTenantId.HasValue ? $"/resident-360?tenantId={_residentDemoTenantId.Value}" : "/resident-360";
    private DispatchSignalDto? PriorityDispatchTicket => _dispatchSignals.FirstOrDefault(x => x.IsAtRisk) ?? _dispatchSignals.FirstOrDefault(x => x.IsBlocked);
    private DispatchSignalDto? PriorityVendorSignal => _dispatchSignals.FirstOrDefault(x => !string.IsNullOrWhiteSpace(x.VendorName) && x.IsAtRisk)
        ?? _dispatchSignals.FirstOrDefault(x => !string.IsNullOrWhiteSpace(x.VendorName) && string.Equals(x.DispatchStatus, "Assigned", StringComparison.OrdinalIgnoreCase))
        ?? _dispatchSignals.FirstOrDefault(x => !string.IsNullOrWhiteSpace(x.VendorName));
    private sealed record ChangeHighlight(string Message, Func<Task>? Action, string ActionLabel, Color Color);
    private string ManagerNextActionMessage
        => _summary is null
            ? string.Empty
            : _summary.DispatchAtRisk > 0
                ? UiText.Get("Dashboard_ManagerNextActionDispatch")
                : _summary.CommunicationAwaitingReply > 0
                    ? UiText.Get("Dashboard_ManagerNextActionAwaitingReply")
                    : _summary.CommunicationRentAtRisk > 0
                        ? UiText.Get("Dashboard_ManagerNextActionRent")
                        : _summary.CommunicationMoveInBlocked > 0
                            ? UiText.Get("Dashboard_ManagerNextActionMoveIn")
                            : _summary.CommunicationMaintenanceActive > 0
                                ? UiText.Get("Dashboard_ManagerNextActionMaintenance")
                                : PriorityVendorSignal is not null
                                    ? UiText.Get("Dashboard_ManagerNextActionVendor")
                                    : UiText.Get("Dashboard_ManagerNextActionStable");

    private Color ManagerNextActionColor
        => _summary is null
            ? Color.Default
            : _summary.DispatchAtRisk > 0
                ? Color.Error
                : _summary.CommunicationAwaitingReply > 0
                    ? Color.Warning
                    : _summary.CommunicationRentAtRisk > 0
                        ? Color.Secondary
                        : _summary.CommunicationMoveInBlocked > 0
                            ? Color.Info
                            : _summary.CommunicationMaintenanceActive > 0
                                ? Color.Warning
                                : PriorityVendorSignal is not null
                                    ? Color.Primary
                                    : Color.Success;

    private string RecommendedNextStopLabel
        => _summary is null
            ? UiText.Get("Nav_Properties")
            : _summary.DispatchAtRisk > 0 || _summary.CommunicationMaintenanceActive > 0
                ? UiText.Get("Nav_Maintenance")
                : _summary.CommunicationRentAtRisk > 0 || _summary.CommunicationAwaitingReply > 0
                    ? UiText.Get("Nav_Resident360")
                    : _summary.CommunicationMoveInBlocked > 0 || _summary.VacantUnits > 0
                        ? UiText.Get("Nav_Leasing")
                        : _summary.ComplianceDueSoon > 0
                            ? UiText.Get("Nav_DocumentsEvidence")
                            : UiText.Get("Nav_Properties");

    private Color RecommendedNextStopColor
        => _summary is null
            ? Color.Primary
            : _summary.DispatchAtRisk > 0 || _summary.CommunicationMaintenanceActive > 0
                ? Color.Warning
                : _summary.CommunicationRentAtRisk > 0 || _summary.CommunicationAwaitingReply > 0
                    ? Color.Secondary
                    : _summary.CommunicationMoveInBlocked > 0 || _summary.VacantUnits > 0
                        ? Color.Info
                        : _summary.ComplianceDueSoon > 0
                            ? Color.Primary
                            : Color.Success;

    private int DailyUrgentLaneCount
        => _summary is null
            ? 0
            : (_summary.DispatchAtRisk > 0 ? 1 : 0)
            + (_summary.CommunicationAwaitingReply > 0 ? 1 : 0)
            + (_summary.CommunicationRentAtRisk > 0 ? 1 : 0)
            + (_summary.CommunicationMoveInBlocked > 0 ? 1 : 0)
            + (_summary.CommunicationMaintenanceActive > 0 ? 1 : 0);

    private string DailyBriefHeadline
        => _summary is null
            ? string.Empty
            : DailyUrgentLaneCount > 0
                ? UiText.Format("Dashboard_DailyBriefHeadlineAction", DailyUrgentLaneCount)
                : UiText.Get("Dashboard_DailyBriefHeadlineStable");

    private string NextOpeningLaneLabel
        => _summary is null
            ? string.Empty
            : _summary.DispatchAtRisk > 0
                ? UiText.Get("Dashboard_OpenAtRiskDispatch")
                : _summary.CommunicationAwaitingReply > 0
                    ? UiText.Get("Dashboard_ManagerQueueAwaitingReply")
                    : _summary.CommunicationRentAtRisk > 0
                        ? UiText.Get("Dashboard_ManagerQueueRentAtRisk")
                        : _summary.CommunicationMoveInBlocked > 0
                            ? UiText.Get("Dashboard_ManagerQueueMoveInBlocked")
                            : _summary.CommunicationMaintenanceActive > 0
                                ? UiText.Get("Dashboard_ManagerQueueMaintenanceActive")
                                : PriorityVendorSignal is not null
                                    ? UiText.Get("Dashboard_OpenVendorFollowUp")
                                    : UiText.Get("Dashboard_DailyBriefLaneStable");

    private string RecommendedDemoStepKey
        => _summary is null
            ? "portfolio"
            : _summary.DispatchAtRisk > 0 || _summary.CommunicationMaintenanceActive > 0
                ? "maintenance"
                : _summary.CommunicationRentAtRisk > 0 || _summary.CommunicationAwaitingReply > 0
                    ? "resident"
                    : _summary.CommunicationMoveInBlocked > 0 || _summary.VacantUnits > 0
                        ? "leasing"
                        : _summary.ComplianceDueSoon > 0
                            ? "evidence"
                            : "portfolio";

    private IReadOnlyList<string> DailyBriefItems
    {
        get
        {
            if (_summary is null)
            {
                return Array.Empty<string>();
            }

            var items = new List<string>();

            if (_summary.DispatchAtRisk > 0)
            {
                items.Add(UiText.Format("Dashboard_DailyBriefItemDispatch", _summary.DispatchAtRisk));
            }

            if (_summary.CommunicationAwaitingReply > 0)
            {
                items.Add(UiText.Format("Dashboard_DailyBriefItemAwaitingReply", _summary.CommunicationAwaitingReply));
            }

            if (_summary.CommunicationRentAtRisk > 0)
            {
                items.Add(UiText.Format("Dashboard_DailyBriefItemRent", _summary.CommunicationRentAtRisk));
            }

            if (_summary.CommunicationMoveInBlocked > 0)
            {
                items.Add(UiText.Format("Dashboard_DailyBriefItemMoveIn", _summary.CommunicationMoveInBlocked));
            }

            if (_summary.CommunicationMaintenanceActive > 0)
            {
                items.Add(UiText.Format("Dashboard_DailyBriefItemMaintenance", _summary.CommunicationMaintenanceActive));
            }

            if (items.Count == 0)
            {
                items.Add(UiText.Get("Dashboard_DailyBriefItemStable"));
            }

            return items;
        }
    }

    private IReadOnlyList<ChangeHighlight> ChangeHighlights
    {
        get
        {
            if (_summary is null)
            {
                return Array.Empty<ChangeHighlight>();
            }

            var items = new List<ChangeHighlight>();

            if (_summary.RecentConversationUpdates24h > 0)
            {
                items.Add(new ChangeHighlight(
                    UiText.Format("Dashboard_ChangesConversations", _summary.RecentConversationUpdates24h),
                    OpenAwaitingReplyQueueAsync,
                    UiText.Get("Dashboard_ManagerQueueAwaitingReply"),
                    Color.Warning));
            }

            if (_summary.NewMaintenanceToday > 0)
            {
                items.Add(new ChangeHighlight(
                    UiText.Format("Dashboard_ChangesMaintenance", _summary.NewMaintenanceToday),
                    OpenMaintenanceBoardAsync,
                    UiText.Get("Dashboard_OpenAtRiskDispatch"),
                    Color.Error));
            }

            if (_summary.ComplianceDueNext7Days > 0)
            {
                items.Add(new ChangeHighlight(
                    UiText.Format("Dashboard_ChangesCompliance", _summary.ComplianceDueNext7Days),
                    OpenComplianceBoardAsync,
                    UiText.Get("Nav_ComplianceWorkspace"),
                    Color.Info));
            }

            if (items.Count == 0)
            {
                items.Add(new ChangeHighlight(
                    UiText.Get("Dashboard_ChangesStable"),
                    OpenResident360ReviewAsync,
                    UiText.Get("Nav_Resident360"),
                    Color.Success));
            }

            return items;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await DataService.ImportSamplePortfolioAsync();
        _summary = await DataService.GetDashboardAsync();
        _entitlements = await DataService.GetSubscriptionEntitlementsAsync();
        _dispatchSignals = await DataService.GetDispatchSignalsAsync();
        _residentDemoTenantId = (await DataService.GetTenantsAsync())
            .OrderBy(x => x.CreditScore)
            .ThenBy(x => x.FullName)
            .Select(x => (Guid?)x.Id)
            .FirstOrDefault();
    }

    private string WithDemoMode(string route)
        => DemoModeRouteHelper.Apply(route, IsDemoCleanView);

    private void OpenMaintenanceDispatch(string filter)
        => NavigationManager.NavigateTo(WithDemoMode($"/maintenance?dispatch={Uri.EscapeDataString(filter)}"));

    private void OpenMaintenanceTicket(Guid maintenanceRequestId)
        => NavigationManager.NavigateTo(WithDemoMode($"/maintenance?ticket={maintenanceRequestId}#ticket-{maintenanceRequestId}"));

    private void OpenVendorFollowUp(string vendorName)
        => NavigationManager.NavigateTo(WithDemoMode($"/vendors?vendor={Uri.EscapeDataString(vendorName)}"));

    private void OpenCommunicationQueue(string filter)
        => NavigationManager.NavigateTo(WithDemoMode($"/tenant-communications?filter={Uri.EscapeDataString(filter)}"));

    private Task OpenAwaitingReplyQueueAsync()
    {
        OpenCommunicationQueue("awaiting-reply");
        return Task.CompletedTask;
    }

    private Task OpenMaintenanceBoardAsync()
    {
        NavigationManager.NavigateTo(WithDemoMode("/maintenance"));
        return Task.CompletedTask;
    }

    private Task OpenComplianceBoardAsync()
    {
        NavigationManager.NavigateTo(WithDemoMode("/compliance"));
        return Task.CompletedTask;
    }

    private Task OpenResident360ReviewAsync()
    {
        NavigationManager.NavigateTo(WithDemoMode(Resident360DemoRoute));
        return Task.CompletedTask;
    }

    private void OpenManagerNextAction()
    {
        if (_summary is null)
        {
            return;
        }

        if (_summary.DispatchAtRisk > 0)
        {
            OpenMaintenanceDispatch("AtRisk");
            return;
        }

        if (_summary.CommunicationAwaitingReply > 0)
        {
            OpenCommunicationQueue("awaiting-reply");
            return;
        }

        if (_summary.CommunicationRentAtRisk > 0)
        {
            OpenCommunicationQueue("rent");
            return;
        }

        if (_summary.CommunicationMoveInBlocked > 0)
        {
            OpenCommunicationQueue("move-in");
            return;
        }

        if (_summary.CommunicationMaintenanceActive > 0)
        {
            OpenCommunicationQueue("maintenance");
            return;
        }

        if (PriorityVendorSignal is not null)
        {
            OpenVendorFollowUp(PriorityVendorSignal.VendorName);
            return;
        }

        NavigationManager.NavigateTo(WithDemoMode(Resident360DemoRoute));
    }

    private void OpenRecommendedNextStop()
    {
        if (_summary is null)
        {
            NavigationManager.NavigateTo(WithDemoMode("/properties"));
            return;
        }

        if (_summary.DispatchAtRisk > 0 || _summary.CommunicationMaintenanceActive > 0)
        {
            NavigationManager.NavigateTo(WithDemoMode("/maintenance"));
            return;
        }

        if (_summary.CommunicationRentAtRisk > 0 || _summary.CommunicationAwaitingReply > 0)
        {
            NavigationManager.NavigateTo(WithDemoMode(Resident360DemoRoute));
            return;
        }

        if (_summary.CommunicationMoveInBlocked > 0 || _summary.VacantUnits > 0)
        {
            NavigationManager.NavigateTo(WithDemoMode("/leasing"));
            return;
        }

        if (_summary.ComplianceDueSoon > 0)
        {
            NavigationManager.NavigateTo(WithDemoMode("/documents-evidence"));
            return;
        }

        NavigationManager.NavigateTo(WithDemoMode("/properties"));
    }

    private void OpenGuidedDemoStart()
    {
        switch (RecommendedDemoStepKey)
        {
            case "leasing":
                NavigationManager.NavigateTo(WithDemoMode("/leasing"));
                break;
            case "resident":
                NavigationManager.NavigateTo(WithDemoMode(Resident360DemoRoute));
                break;
            case "maintenance":
                NavigationManager.NavigateTo(WithDemoMode("/maintenance"));
                break;
            case "evidence":
                NavigationManager.NavigateTo(WithDemoMode("/documents-evidence"));
                break;
            default:
                NavigationManager.NavigateTo(WithDemoMode("/properties"));
                break;
        }
    }

    private string GetSignalRiskLabel(DispatchSignalDto signal)
        => signal.IsAtRisk
            ? UiText.Get("Maintenance_SlaAtRisk")
            : signal.IsBlocked
                ? UiText.Get("Dashboard_DispatchBlocked")
                : UiText.Get("Maintenance_SlaOnTrack");
}
