@attribute [Authorize]
@page "/vendors"
@inject SaasDataService DataService
@inject NavigationManager NavigationManager
@using Microsoft.AspNetCore.Components
@using PropertySaaS.Web.Localization
@using PropertySaaS.Domain.Entities

<PageTitle>@UiText.Get("Nav_Vendors")</PageTitle>

<MudStack Spacing="3">
    <MudStack Spacing="0">
        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" Class="mb-2">@UiText.Get("Vendors_PremiumBadge")</MudChip>
        <MudText Typo="Typo.h4">@UiText.Get("Vendors_Title")</MudText>
        <MudText Typo="Typo.body2">@UiText.Get("Vendors_Subtitle")</MudText>
    </MudStack>

    @if (_vendors.Count == 0)
    {
        <MudPaper Class="pa-6 properties-empty-state" Elevation="0">
            <MudText Typo="Typo.subtitle1">@UiText.Get("Vendors_EmptyTitle")</MudText>
            <MudText Typo="Typo.body2">@UiText.Get("Vendors_EmptySubtitle")</MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Class="pa-4 property-detail-panel" Elevation="0">
            <MudText Typo="Typo.h6">@UiText.Get("Vendors_InsightTitle")</MudText>
            <MudGrid Spacing="2" Class="mt-2">
                <MudItem xs="12" md="4"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@UiText.Get("Vendors_InsightUrgency")</MudText><MudChip T="string" Variant="Variant.Outlined" Color="@InsightColor" Class="mt-2">@InsightUrgencyLabel</MudChip></MudPaper></MudItem>
                <MudItem xs="12" md="4"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@UiText.Get("Vendors_InsightFocus")</MudText><MudChip T="string" Variant="Variant.Outlined" Color="@InsightColor" Class="mt-2">@InsightFocusLabel</MudChip></MudPaper></MudItem>
                <MudItem xs="12" md="4"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@UiText.Get("Vendors_InsightNextAction")</MudText><MudButton Class="mt-2" Variant="Variant.Text" Color="@InsightColor" OnClick="OpenInsightNextActionAsync">@InsightActionLabel</MudButton></MudPaper></MudItem>
            </MudGrid>
            <MudText Typo="Typo.body2" Class="mt-3">@InsightMessage</MudText>
        </MudPaper>

        <MudGrid Spacing="3">
            <MudItem xs="12" md="4"><MetricCard Title="@UiText.Get("Vendors_PreferredTitle")" Value="@_vendors.Count(x => x.IsPreferred).ToString()" Caption="@UiText.Get("Vendors_PreferredCaption")" Icon="@Icons.Material.Filled.Star" /></MudItem>
            <MudItem xs="12" md="4"><MetricCard Title="@UiText.Get("Vendors_TradesTitle")" Value="@_vendors.Select(x => x.Trade).Distinct(StringComparer.OrdinalIgnoreCase).Count().ToString()" Caption="@UiText.Get("Vendors_TradesCaption")" Icon="@Icons.Material.Filled.Handyman" /></MudItem>
            <MudItem xs="12" md="4"><MetricCard Title="@UiText.Get("Vendors_ServiceAreaTitle")" Value="@_vendors.Select(x => x.ServiceArea).Distinct(StringComparer.OrdinalIgnoreCase).Count().ToString()" Caption="@UiText.Get("Vendors_ServiceAreaCaption")" Icon="@Icons.Material.Filled.Map" /></MudItem>
        </MudGrid>

        <MudPaper Class="pa-4 marketing-card" Elevation="0">
            <MudText Typo="Typo.h6">@UiText.Get("Maintenance_DispatchBoardTitle")</MudText>
            <MudGrid Spacing="2" Class="mt-1">
                <MudItem xs="12" sm="6" md="3"><MudChip T="string" Variant="Variant.Filled" Color="Color.Default">@UiText.Get("Maintenance_DispatchUnassigned"): @_maintenance.Count(x => string.Equals(x.DispatchStatus, "Unassigned", StringComparison.OrdinalIgnoreCase))</MudChip></MudItem>
                <MudItem xs="12" sm="6" md="3"><MudChip T="string" Variant="Variant.Filled" Color="Color.Info">@UiText.Get("Maintenance_DispatchRecommended"): @_maintenance.Count(x => string.Equals(x.DispatchStatus, "Recommended", StringComparison.OrdinalIgnoreCase))</MudChip></MudItem>
                <MudItem xs="12" sm="6" md="3"><MudChip T="string" Variant="Variant.Filled" Color="Color.Warning">@UiText.Get("Maintenance_DispatchAssigned"): @_maintenance.Count(x => string.Equals(x.DispatchStatus, "Assigned", StringComparison.OrdinalIgnoreCase) || string.Equals(x.DispatchStatus, "Acknowledged", StringComparison.OrdinalIgnoreCase))</MudChip></MudItem>
                <MudItem xs="12" sm="6" md="3"><MudChip T="string" Variant="Variant.Filled" Color="Color.Success">@UiText.Get("Maintenance_DispatchCompleted"): @_maintenance.Count(x => string.Equals(x.DispatchStatus, "Completed", StringComparison.OrdinalIgnoreCase))</MudChip></MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Class="pa-4 marketing-card" Elevation="0">
            <MudText Typo="Typo.h6">@UiText.Get("Vendors_RecommendationTitle")</MudText>
            @if (_recommendation is null)
            {
                <MudText Typo="Typo.body2" Class="mt-2">@UiText.Get("Vendors_RecommendationFallback")</MudText>
            }
            else
            {
                <MudText Typo="Typo.subtitle2" Class="mt-2">@_recommendation.VendorName</MudText>
                <MudText Typo="Typo.body2">@UiText.Get("Vendors_DispatchStatus"): @_recommendation.DispatchStatus</MudText>
                <MudText Typo="Typo.body2">@UiText.Get("Vendors_ResponseHours"): @_recommendation.TypicalResponseHours h</MudText>
                <MudText Typo="Typo.body2">@UiText.Get("Vendors_RecommendationReason"): @_recommendation.RecommendationReason</MudText>
            }
        </MudPaper>

        <MudPaper Class="pa-4 marketing-card" Elevation="0">
            <MudText Typo="Typo.h6">@UiText.Get("Vendors_PriorityActionTitle")</MudText>
            @if (PriorityVendorGroup is null)
            {
                <MudText Typo="Typo.body2" Class="mt-2">@UiText.Get("Vendors_PriorityActionEmpty")</MudText>
            }
            else
            {
                <MudText Typo="Typo.subtitle2" Class="mt-2">@PriorityVendorGroup.Key</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">@UiText.Get("Vendors_PriorityActionCaption")</MudText>
                <MudText Typo="Typo.body2">@UiText.Format("Vendors_PriorityActionSummary", PriorityVendorGroup.Key, PriorityVendorGroup.Count(), PriorityVendorGroup.Count(IsAtRisk))</MudText>
                <MudStack Row="true" Spacing="1" Class="mt-2" Wrap="Wrap.Wrap">
                    <MudChip T="string" Variant="Variant.Filled" Color="@GetPriorityVendorChipColor()">@GetPriorityVendorActionLabel()</MudChip>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" OnClick='() => SelectVendorGroup(PriorityVendorGroup.Key)'>@UiText.Get("Vendors_PriorityActionReview")</MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small" OnClick='() => OpenVendorDispatch(PriorityVendorGroup.Key)'>@UiText.Get("Vendors_OpenVendorDispatch")</MudButton>
                </MudStack>
            }
        </MudPaper>

        <MudPaper Class="pa-2 table-wrap properties-table-shell" Elevation="0">
            <MudTable Items="_vendors" Dense="true" Hover="true" Breakpoint="Breakpoint.Md">
                <HeaderContent>
                    <MudTh>@UiText.Get("Vendors_Name")</MudTh>
                    <MudTh>@UiText.Get("Vendors_Trade")</MudTh>
                    <MudTh>@UiText.Get("Vendors_ServiceArea")</MudTh>
                    <MudTh>@UiText.Get("Vendors_Email")</MudTh>
                    <MudTh>@UiText.Get("Vendors_Phone")</MudTh>
                    <MudTh>@UiText.Get("Vendors_Status")</MudTh>
                    <MudTh>@UiText.Get("Vendors_DispatchStatus")</MudTh>
                    <MudTh>@UiText.Get("Vendors_PreferredPriority")</MudTh>
                    <MudTh>@UiText.Get("Vendors_ResponseHours")</MudTh>
                    <MudTh>@UiText.Get("Vendors_LinkedOpenRequests")</MudTh>
                    <MudTh>@UiText.Get("Vendors_RiskColumn")</MudTh>
                    <MudTh>@UiText.Get("Vendors_NextAction")</MudTh>
                </HeaderContent>
                <RowTemplate>
                    @{ var vendorDispatch = GetVendorDispatchItems(context.Name); }
                    <MudTd DataLabel="@UiText.Get("Vendors_Name")">@context.Name</MudTd>
                    <MudTd DataLabel="@UiText.Get("Vendors_Trade")">@context.Trade</MudTd>
                    <MudTd DataLabel="@UiText.Get("Vendors_ServiceArea")">@context.ServiceArea</MudTd>
                    <MudTd DataLabel="@UiText.Get("Vendors_Email")">@context.Email</MudTd>
                    <MudTd DataLabel="@UiText.Get("Vendors_Phone")">@context.PhoneNumber</MudTd>
                    <MudTd DataLabel="@UiText.Get("Vendors_Status")">@(context.IsPreferred ? UiText.Get("Vendors_PreferredStatus") : UiText.Get("Vendors_StandardStatus"))</MudTd>
                    <MudTd DataLabel="@UiText.Get("Vendors_DispatchStatus")">@context.DispatchStatus</MudTd>
                    <MudTd DataLabel="@UiText.Get("Vendors_PreferredPriority")">@context.PreferredForPriority</MudTd>
                    <MudTd DataLabel="@UiText.Get("Vendors_ResponseHours")">@context.TypicalResponseHours h</MudTd>
                    <MudTd DataLabel="@UiText.Get("Vendors_LinkedOpenRequests")">@context.LinkedOpenRequests</MudTd>
                    <MudTd DataLabel="@UiText.Get("Vendors_RiskColumn")">
                        <MudChip T="string" Variant="Variant.Filled" Color="@GetVendorRiskColor(vendorDispatch)">@GetVendorRiskLabel(vendorDispatch)</MudChip>
                    </MudTd>
                    <MudTd DataLabel="@UiText.Get("Vendors_NextAction")">
                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                            <MudChip T="string" Variant="Variant.Outlined" Color="@GetVendorActionColor(vendorDispatch)">@GetVendorActionLabel(vendorDispatch)</MudChip>
                            @if (vendorDispatch.Count != 0)
                            {
                                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" OnClick='() => SelectVendorGroup(context.Name)'>@UiText.Get("Vendors_ReviewTickets")</MudButton>
                            }
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>

        <MudPaper Class="pa-4 marketing-card" Elevation="0">
            <MudText Typo="Typo.h6">@UiText.Get("Vendors_ActiveDispatchTitle")</MudText>
            @if (!ActiveVendorDispatch.Any())
            {
                <MudText Typo="Typo.body2" Class="mt-2">@UiText.Get("Vendors_ActiveDispatchEmpty")</MudText>
            }
            else
            {
                <MudList T="string" Dense="true" Class="mt-3">
                    @foreach (var group in ActiveVendorDispatch)
                    {
                        var firstTicket = group.FirstOrDefault();
                        <MudListItem T="string">
                            @group.Key - @group.Count() ticket(s) - @GetGroupEta(group.Key) - @UiText.Format("Vendors_AtRiskCount", group.Count(IsAtRisk)) - @string.Join(", ", group.Select(x => x.Title).Take(3))
                            <MudButton Class="ml-2" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" OnClick='() => OpenVendorDispatch(group.Key)'>@UiText.Get("Vendors_OpenVendorDispatch")</MudButton>
                            @if (firstTicket is not null)
                            {
                                <MudButton Class="ml-1" Variant="Variant.Text" Color="Color.Info" Size="Size.Small" OnClick='() => SelectVendorGroup(group.Key)'>@UiText.Get("Vendors_ReviewTickets")</MudButton>
                                <MudButton Class="ml-1" Variant="Variant.Text" Color="Color.Default" Size="Size.Small" OnClick='() => SelectVendorTicket(firstTicket.Id)'>@UiText.Get("Common_OpenTicket")</MudButton>
                                <MudButton Class="ml-1" Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small" OnClick='() => OpenVendorTicket(firstTicket.Id)'>@UiText.Get("Vendors_OpenTicket")</MudButton>
                                <MudButton Class="ml-1" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" OnClick='() => OpenVendorTenantThreadAsync(firstTicket.Id)'>@UiText.Get("Vendors_OpenTenantThread")</MudButton>
                                @if (string.Equals(firstTicket.DispatchStatus, "Assigned", StringComparison.OrdinalIgnoreCase))
                                {
                                    <MudButton Class="ml-1" Variant="Variant.Text" Color="Color.Warning" Size="Size.Small" OnClick='() => MarkVendorTicketAsync(firstTicket.Id, "Acknowledged")'>@UiText.Get("Vendors_MarkAcknowledged")</MudButton>
                                }
                                @if (!string.Equals(firstTicket.DispatchStatus, "Completed", StringComparison.OrdinalIgnoreCase))
                                {
                                    <MudButton Class="ml-1" Variant="Variant.Text" Color="Color.Success" Size="Size.Small" OnClick='() => MarkVendorTicketAsync(firstTicket.Id, "Completed")'>@UiText.Get("Vendors_MarkCompleted")</MudButton>
                                }
                            }
                        </MudListItem>
                    }
                </MudList>
            }
        </MudPaper>

        <MudPaper Class="pa-4 marketing-card" Elevation="0">
            <MudText Typo="Typo.h6">@UiText.Get("Vendors_TicketDetailTitle")</MudText>
            @if (_selectedTicket is null)
            {
                <MudText Typo="Typo.body2" Class="mt-2">@UiText.Get("Vendors_TicketDetailEmpty")</MudText>
            }
            else
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">@UiText.Format("Vendors_SelectedVendorSummary", SelectedVendorTickets.Count, _selectedTicket.VendorName)</MudText>
                <MudText Typo="Typo.subtitle2" Class="mt-2">@_selectedTicket.Title</MudText>
                <MudStack Row="true" Spacing="1" Class="mt-2" Wrap="Wrap.Wrap">
                    <MudChip T="string" Variant="Variant.Filled" Color="@GetDispatchColor(_selectedTicket)">@_selectedTicket.DispatchStatus</MudChip>
                    <MudChip T="string" Variant="Variant.Outlined" Color="@GetRiskColor(_selectedTicket)">@GetRiskLabel(_selectedTicket)</MudChip>
                    <MudChip T="string" Variant="Variant.Outlined" Color="Color.Default">@UiText.Get("Vendors_TicketPriority"): @_selectedTicket.Priority</MudChip>
                </MudStack>
                <MudText Typo="Typo.body2" Class="mt-2">@_selectedTicket.Status</MudText>
                <MudText Typo="Typo.body2">@_selectedTicket.VendorName</MudText>
                <MudText Typo="Typo.body2">@UiText.Get("Vendors_TicketRequested"): @_selectedTicket.RequestedDate</MudText>
                <MudText Typo="Typo.body2">@UiText.Get("Vendors_TicketCost"): @_selectedTicket.EstimatedCost.ToString("C")</MudText>
                <MudText Typo="Typo.body2">@UiText.Get("Vendors_TicketDescription"): @_selectedTicket.Description</MudText>

                @if (SelectedVendorTickets.Count > 1)
                {
                    <MudDivider Class="my-3" />
                    <MudText Typo="Typo.subtitle2">@UiText.Get("Vendors_ReviewTickets")</MudText>
                    <MudList T="string" Dense="true" Class="mt-2">
                        @foreach (var ticket in SelectedVendorTickets)
                        {
                            <MudListItem T="string" OnClick='() => SelectVendorTicket(ticket.Id)'>
                                @ticket.Title - @ticket.DispatchStatus - @GetRiskLabel(ticket)
                            </MudListItem>
                        }
                    </MudList>
                }
            }
        </MudPaper>
    }
</MudStack>

@code {
    [SupplyParameterFromQuery(Name = "vendor")]
    public string? VendorQuery { get; set; }

    private List<VendorSummaryDto> _vendors = new();
    private List<MaintenanceRequest> _maintenance = new();
    private VendorRecommendationDto? _recommendation;
    private MaintenanceRequest? _selectedTicket;
    private string? _selectedVendorName;
    private IEnumerable<IGrouping<string, MaintenanceRequest>> ActiveVendorDispatch => _maintenance
        .Where(x => !string.IsNullOrWhiteSpace(x.VendorName) && !string.Equals(x.DispatchStatus, "Completed", StringComparison.OrdinalIgnoreCase) && !string.Equals(x.Status, "Closed", StringComparison.OrdinalIgnoreCase))
        .GroupBy(x => x.VendorName)
        .OrderByDescending(x => x.Count())
        .ThenBy(x => x.Key);
    private IGrouping<string, MaintenanceRequest>? PriorityVendorGroup => ActiveVendorDispatch
        .OrderByDescending(x => x.Count(IsAtRisk))
        .ThenByDescending(x => x.Count(y => string.Equals(y.DispatchStatus, "Assigned", StringComparison.OrdinalIgnoreCase)))
        .ThenByDescending(x => x.Count())
        .FirstOrDefault();
    private string InsightUrgencyLabel
        => PriorityVendorGroup is not null && PriorityVendorGroup.Any(IsAtRisk)
            ? UiText.Get("Vendors_InsightUrgencyHigh")
            : PriorityVendorGroup is not null && PriorityVendorGroup.Any(x => string.Equals(x.DispatchStatus, "Assigned", StringComparison.OrdinalIgnoreCase))
                ? UiText.Get("Vendors_InsightUrgencyMedium")
                : UiText.Get("Vendors_InsightUrgencyStable");

    private string InsightFocusLabel
        => PriorityVendorGroup is not null && PriorityVendorGroup.Any(IsAtRisk)
            ? UiText.Get("Vendors_InsightFocusAtRisk")
            : PriorityVendorGroup is not null && PriorityVendorGroup.Any(x => string.Equals(x.DispatchStatus, "Assigned", StringComparison.OrdinalIgnoreCase))
                ? UiText.Get("Vendors_InsightFocusAcknowledgement")
                : UiText.Get("Vendors_InsightFocusStable");

    private string InsightMessage
        => PriorityVendorGroup is not null && PriorityVendorGroup.Any(IsAtRisk)
            ? UiText.Get("Vendors_InsightMessageAtRisk")
            : PriorityVendorGroup is not null && PriorityVendorGroup.Any(x => string.Equals(x.DispatchStatus, "Assigned", StringComparison.OrdinalIgnoreCase))
                ? UiText.Get("Vendors_InsightMessageAcknowledgement")
                : UiText.Get("Vendors_InsightMessageStable");

    private string InsightActionLabel
        => PriorityVendorGroup is not null
            ? UiText.Get("Vendors_InsightOpenPriority")
            : UiText.Get("Vendors_InsightOpenReview");

    private Color InsightColor
        => PriorityVendorGroup is not null && PriorityVendorGroup.Any(IsAtRisk)
            ? Color.Error
            : PriorityVendorGroup is not null && PriorityVendorGroup.Any(x => string.Equals(x.DispatchStatus, "Assigned", StringComparison.OrdinalIgnoreCase))
                ? Color.Warning
                : Color.Success;
    private List<MaintenanceRequest> SelectedVendorTickets => string.IsNullOrWhiteSpace(_selectedVendorName)
        ? (_selectedTicket is null ? new List<MaintenanceRequest>() : new List<MaintenanceRequest> { _selectedTicket })
        : _maintenance
            .Where(x => string.Equals(x.VendorName, _selectedVendorName, StringComparison.OrdinalIgnoreCase)
                        && !string.Equals(x.DispatchStatus, "Completed", StringComparison.OrdinalIgnoreCase)
                        && !string.Equals(x.Status, "Closed", StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(x => IsAtRisk(x))
            .ThenByDescending(x => x.Priority)
            .ThenBy(x => x.RequestedDate)
            .ToList();

    private string GetGroupEta(string vendorName)
    {
        var hours = _vendors.FirstOrDefault(x => string.Equals(x.Name, vendorName, StringComparison.OrdinalIgnoreCase))?.TypicalResponseHours;
        return hours.HasValue && hours.Value > 0
            ? $"ETA {hours.Value} h"
            : UiText.Get("Maintenance_TodayDispatchNoEta");
    }

    protected override async Task OnInitializedAsync()
    {
        _vendors = await DataService.GetVendorsAsync();
        _maintenance = await DataService.GetMaintenanceAsync();
        var firstOpenTicket = _maintenance.FirstOrDefault(x => !string.Equals(x.Status, "Closed", StringComparison.OrdinalIgnoreCase));
        if (firstOpenTicket is not null)
        {
            _recommendation = await DataService.RecommendVendorForMaintenanceAsync(firstOpenTicket.Id);
            _selectedTicket = firstOpenTicket;
            _selectedVendorName = firstOpenTicket.VendorName;
        }

        if (!string.IsNullOrWhiteSpace(VendorQuery))
        {
            SelectVendorGroup(VendorQuery);
        }
    }

    private void OpenVendorDispatch(string vendorName)
        => NavigationManager.NavigateTo($"/maintenance?vendor={Uri.EscapeDataString(vendorName)}");

    private void OpenVendorTicket(Guid maintenanceRequestId)
        => NavigationManager.NavigateTo($"/maintenance?ticket={maintenanceRequestId}#ticket-{maintenanceRequestId}");

    private Task OpenInsightNextActionAsync()
    {
        if (PriorityVendorGroup is not null)
        {
            SelectVendorGroup(PriorityVendorGroup.Key);
            return Task.CompletedTask;
        }

        NavigationManager.NavigateTo("/vendors");
        return Task.CompletedTask;
    }

    private async Task OpenVendorTenantThreadAsync(Guid maintenanceRequestId)
    {
        var conversationId = await DataService.EnsureMaintenanceConversationAsync(maintenanceRequestId);
        NavigationManager.NavigateTo(conversationId.HasValue
            ? $"/tenant-communications?conversationId={conversationId.Value}"
            : "/tenant-communications");
    }

    private async Task MarkVendorTicketAsync(Guid maintenanceRequestId, string dispatchStatus)
    {
        var updated = await DataService.UpdateMaintenanceDispatchStatusAsync(maintenanceRequestId, dispatchStatus);
        if (!updated)
        {
            return;
        }

        _maintenance = await DataService.GetMaintenanceAsync();
        _selectedTicket = _maintenance.FirstOrDefault(x => x.Id == maintenanceRequestId);
        _selectedVendorName = _selectedTicket?.VendorName;
    }

    private void SelectVendorTicket(Guid maintenanceRequestId)
    {
        _selectedTicket = _maintenance.FirstOrDefault(x => x.Id == maintenanceRequestId);
        _selectedVendorName = _selectedTicket?.VendorName;
    }

    private void SelectVendorGroup(string vendorName)
    {
        _selectedVendorName = vendorName;
        _selectedTicket = SelectedVendorTickets.FirstOrDefault();
    }

    private List<MaintenanceRequest> GetVendorDispatchItems(string vendorName)
        => _maintenance
            .Where(x => string.Equals(x.VendorName, vendorName, StringComparison.OrdinalIgnoreCase)
                        && !string.Equals(x.DispatchStatus, "Completed", StringComparison.OrdinalIgnoreCase)
                        && !string.Equals(x.Status, "Closed", StringComparison.OrdinalIgnoreCase))
            .ToList();

    private bool IsAtRisk(MaintenanceRequest request)
    {
        var responseHours = _vendors.FirstOrDefault(x => string.Equals(x.Name, request.VendorName, StringComparison.OrdinalIgnoreCase))?.TypicalResponseHours ?? int.MaxValue;
        return responseHours != int.MaxValue
            && responseHours > 0
            && request.RequestedDate <= DateOnly.FromDateTime(DateTime.Today.AddDays(-1))
            && !string.Equals(request.DispatchStatus, "Completed", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsBlocked(MaintenanceRequest request)
        => string.IsNullOrWhiteSpace(request.VendorName) || string.Equals(request.DispatchStatus, "Unassigned", StringComparison.OrdinalIgnoreCase);

    private string GetVendorRiskLabel(IReadOnlyCollection<MaintenanceRequest> vendorDispatch)
    {
        if (vendorDispatch.Count == 0)
        {
            return UiText.Get("Vendors_NoActiveDispatch");
        }

        if (vendorDispatch.Any(IsAtRisk))
        {
            return UiText.Get("Maintenance_SlaAtRisk");
        }

        return UiText.Get("Maintenance_SlaOnTrack");
    }

    private Color GetVendorRiskColor(IReadOnlyCollection<MaintenanceRequest> vendorDispatch)
    {
        if (vendorDispatch.Count == 0)
        {
            return Color.Default;
        }

        return vendorDispatch.Any(IsAtRisk)
            ? Color.Error
            : Color.Success;
    }

    private string GetVendorActionLabel(IReadOnlyCollection<MaintenanceRequest> vendorDispatch)
    {
        if (vendorDispatch.Count == 0)
        {
            return UiText.Get("Vendors_ActionAllOnTrack");
        }

        if (vendorDispatch.Any(IsAtRisk))
        {
            return UiText.Get("Vendors_ActionNeedsFollowUp");
        }

        if (vendorDispatch.Any(x => string.Equals(x.DispatchStatus, "Assigned", StringComparison.OrdinalIgnoreCase)))
        {
            return UiText.Get("Vendors_ActionConfirmAcknowledgement");
        }

        return UiText.Get("Vendors_ActionReviewDispatch");
    }

    private Color GetVendorActionColor(IReadOnlyCollection<MaintenanceRequest> vendorDispatch)
    {
        if (vendorDispatch.Count == 0)
        {
            return Color.Default;
        }

        if (vendorDispatch.Any(IsAtRisk))
        {
            return Color.Error;
        }

        if (vendorDispatch.Any(x => string.Equals(x.DispatchStatus, "Assigned", StringComparison.OrdinalIgnoreCase)))
        {
            return Color.Warning;
        }

        return Color.Info;
    }

    private string GetRiskLabel(MaintenanceRequest request)
        => IsAtRisk(request)
            ? UiText.Get("Maintenance_SlaAtRisk")
            : IsBlocked(request)
                ? UiText.Get("Vendors_DispatchBlocked")
                : UiText.Get("Maintenance_SlaOnTrack");

    private static Color GetRiskColor(MaintenanceRequest request)
        => IsBlocked(request)
            ? Color.Error
            : Color.Warning;

    private Color GetPriorityVendorChipColor()
    {
        if (PriorityVendorGroup is null)
        {
            return Color.Default;
        }

        return GetVendorActionColor(PriorityVendorGroup.ToList());
    }

    private string GetPriorityVendorActionLabel()
    {
        if (PriorityVendorGroup is null)
        {
            return UiText.Get("Vendors_ActionAllOnTrack");
        }

        return GetVendorActionLabel(PriorityVendorGroup.ToList());
    }

    private Color GetDispatchColor(MaintenanceRequest request)
        => IsAtRisk(request)
            ? Color.Error
            : request.DispatchStatus switch
            {
                "Completed" => Color.Success,
                "Acknowledged" => Color.Info,
                "Assigned" => Color.Warning,
                "Recommended" => Color.Secondary,
                _ => Color.Default
            };
}
