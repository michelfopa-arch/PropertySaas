    private string GetOccupancyLabel(int totalUnits, int occupiedUnits)
        => totalUnits == 0 ? Localizer["Properties_NoUnits"] : $"{Math.Round((decimal)occupiedUnits / totalUnits * 100, 0)}%";

    private static int GetMarketingReadinessScore(Property property, List<Unit> propertyUnits, int occupiedCount, decimal monthlyRent)
    {
        var score = 0;

        if (!string.IsNullOrWhiteSpace(property.PropertyType)) score += 10;
        if (!string.IsNullOrWhiteSpace(property.PostalCode)) score += 10;
        if (!string.IsNullOrWhiteSpace(property.AmenitySummary)) score += 20;
        if (!string.IsNullOrWhiteSpace(property.NeighborhoodNotes)) score += 15;
        if (!string.IsNullOrWhiteSpace(property.LeasingNotes)) score += 20;
        if (!string.IsNullOrWhiteSpace(property.OperationalNotes)) score += 10;
        if (propertyUnits.Count > 0) score += 10;
        if (occupiedCount > 0 || monthlyRent > 0) score += 5;

        return Math.Min(score, 100);
    }

    private static Color GetReadinessColor(int score)
        => score >= 80 ? Color.Success : score >= 55 ? Color.Warning : Color.Error;

    private static string GetAssetStage(List<Unit> propertyUnits, int vacantCount, int readinessScore)
    {
        if (propertyUnits.Count == 0) return "Setup";
        if (vacantCount > 0) return "Lease-up";
        if (readinessScore < 80) return "Stabilize playbook";
        return "Stabilized";
    }

    private static Color GetAssetStageColor(List<Unit> propertyUnits, int vacantCount, int readinessScore)
    {
        var stage = GetAssetStage(propertyUnits, vacantCount, readinessScore);
        return stage switch
        {
            "Setup" => Color.Info,
            "Lease-up" => Color.Warning,
            "Stabilize playbook" => Color.Secondary,
            _ => Color.Success
        };
    }

