    private string GetPortfolioActionLabel(Property property)
    {
        var propertyUnits = GetUnitsForProperty(property.Id);
        var vacantCount = propertyUnits.Count(x => !x.IsOccupied);
        var readinessScore = GetMarketingReadinessScore(property, propertyUnits, propertyUnits.Count(x => x.IsOccupied), propertyUnits.Sum(x => x.MonthlyRent));

        if (vacantCount > 0)
        {
            return UiText.Get("Properties_ActionLeaseUp");
        }

        if (readinessScore < 80)
        {
            return UiText.Get("Properties_ActionStabilize");
        }

        return UiText.Get("Properties_ActionReview");
    }

    private Color GetPortfolioActionColor(Property property)
    {
        var propertyUnits = GetUnitsForProperty(property.Id);
        var vacantCount = propertyUnits.Count(x => !x.IsOccupied);
        var readinessScore = GetMarketingReadinessScore(property, propertyUnits, propertyUnits.Count(x => x.IsOccupied), propertyUnits.Sum(x => x.MonthlyRent));

        if (vacantCount > 0)
        {
            return Color.Warning;
        }

        if (readinessScore < 80)
        {
            return Color.Info;
        }

        return Color.Success;
    }

    private static string FormatAddress(Property property)
    {
