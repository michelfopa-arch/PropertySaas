    private static Task<IEnumerable<string>> SearchOptionsAsync(IEnumerable<string> options, string? value, CancellationToken cancellationToken)
    {
        cancellationToken.ThrowIfCancellationRequested();
        var results = string.IsNullOrWhiteSpace(value)
            ? options
            : options.Where(option => option.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(results);
    }

    private string GetMarketSegment(Property property)
    {
        if (property.PropertyType.Contains("student", StringComparison.OrdinalIgnoreCase)) return Localizer["Properties_MarketSegment_Student"];
        if (property.PropertyType.Contains("single-family", StringComparison.OrdinalIgnoreCase) || property.PropertyType.Contains("townhome", StringComparison.OrdinalIgnoreCase)) return Localizer["Properties_MarketSegment_Family"];
        if (property.PropertyType.Contains("luxury", StringComparison.OrdinalIgnoreCase) || property.PropertyType.Contains("executive", StringComparison.OrdinalIgnoreCase) || property.PropertyType.Contains("waterfront", StringComparison.OrdinalIgnoreCase)) return Localizer["Properties_MarketSegment_Premium"];
        if (property.City.Contains("Toronto", StringComparison.OrdinalIgnoreCase) || property.City.Contains("Mississauga", StringComparison.OrdinalIgnoreCase) || property.City.Contains("Markham", StringComparison.OrdinalIgnoreCase)) return Localizer["Properties_MarketSegment_Urban"];
        return Localizer["Properties_MarketSegment_Core"];
    }

    private string GetRecommendedStrategyPack(Property property)
        => $"{LocalizeLeasingTemplate(GetRecommendedLeasingTemplate(property.PropertyType))} + {LocalizeOperationsTemplate(GetRecommendedOperationsTemplate(property.PropertyType))}";

    private string GetMarketNarrative(Property property)
    {
        var city = string.IsNullOrWhiteSpace(property.City) ? Localizer["Properties_MarketNarrative_DefaultCity"].Value : property.City;
        var segment = GetMarketSegment(property);

        if (segment == Localizer["Properties_MarketSegment_Student"])
        {
            return string.Format(Localizer["Properties_MarketNarrative_Student"].Value, city);
        }

        if (segment == Localizer["Properties_MarketSegment_Family"])
        {
            return string.Format(Localizer["Properties_MarketNarrative_Family"].Value, city);
        }

        if (segment == Localizer["Properties_MarketSegment_Premium"])
        {
            return string.Format(Localizer["Properties_MarketNarrative_Premium"].Value, city);
        }

        return string.Format(Localizer["Properties_MarketNarrative_Core"].Value, city);
    }

