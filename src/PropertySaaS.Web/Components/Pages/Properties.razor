    private async Task ImportCsvAsync()
    {
        var imported = 0;
        var skipped = 0;
        var lines = _csvInput.Split(new[] { "\r\n", "\n" }, StringSplitOptions.RemoveEmptyEntries);
        foreach (var line in lines)
        {
            var parts = line.Split(',');
            if (parts.Length < 4)
            {
                skipped++;
                continue;
            }

            var name = parts[0].Trim();
            var address = parts[1].Trim();
            var city = parts[2].Trim();
            if (string.IsNullOrWhiteSpace(name) || string.IsNullOrWhiteSpace(address) || string.IsNullOrWhiteSpace(city) || !decimal.TryParse(parts[3], out var revenue))
            {
                skipped++;
                continue;
            }

            if (_items.Any(x => string.Equals(x.Name, name, StringComparison.OrdinalIgnoreCase) && string.Equals(x.AddressLine1, address, StringComparison.OrdinalIgnoreCase)))
            {
                skipped++;
                continue;
            }

            await DataService.AddPropertyAsync(new Property
            {
                Name = name,
                AddressLine1 = address,
                City = city,
                Province = "ON",
                MonthlyRevenueTarget = revenue
            });
            imported++;
        }
        _csvInput = string.Empty;
        await ReloadAsync();
        _importResult = $"Imported {imported} row(s); skipped {skipped}.";
    }

    private int GetFilteredVacantUnits()
        => FilteredProperties.Sum(property => GetUnitsForProperty(property.Id).Count(x => !x.IsOccupied));

    private decimal GetFilteredRentRoll()
        => FilteredProperties.Sum(property => GetUnitsForProperty(property.Id).Sum(x => x.MonthlyRent));

    private string GetAverageReadinessLabel()
    {
        var properties = FilteredProperties.ToList();
        if (properties.Count == 0)
        {
            return "0/100";
        }

        var average = properties.Average(property =>
        {
            var propertyUnits = GetUnitsForProperty(property.Id);
            return GetMarketingReadinessScore(property, propertyUnits, propertyUnits.Count(x => x.IsOccupied), propertyUnits.Sum(x => x.MonthlyRent));
        });

        return $"{Math.Round(average, 0)}/100";
    }

    private List<Unit> GetUnitsForProperty(Guid propertyId) => _units.Where(x => x.PropertyId == propertyId).OrderBy(x => x.UnitNumber).ToList();

    private static string FormatAddress(Property property)
    {
        var parts = new[] { property.AddressLine1, property.City, property.Province, property.PostalCode }
            .Where(x => !string.IsNullOrWhiteSpace(x));
        return string.Join(", ", parts);
    }

    private static string GetOccupancyLabel(int totalUnits, int occupiedUnits)
        => totalUnits == 0 ? "No units" : $"{Math.Round((decimal)occupiedUnits / totalUnits * 100, 0)}%";

    private static string GetVarianceToTarget(Property property, decimal monthlyRent)
    {
        var variance = monthlyRent - property.MonthlyRevenueTarget;
        return variance == 0 ? "On target" : variance > 0 ? $"+{variance:C}" : $"{variance:C}";
    }

    private static int GetMarketingReadinessScore(Property property, List<Unit> propertyUnits, int occupiedCount, decimal monthlyRent)
    {
        var score = 0;

        if (!string.IsNullOrWhiteSpace(property.PropertyType)) score += 10;
        if (!string.IsNullOrWhiteSpace(property.PostalCode)) score += 10;
        if (!string.IsNullOrWhiteSpace(property.AmenitySummary)) score += 20;
        if (!string.IsNullOrWhiteSpace(property.NeighborhoodNotes)) score += 15;
        if (!string.IsNullOrWhiteSpace(property.LeasingNotes)) score += 20;
        if (!string.IsNullOrWhiteSpace(property.OperationalNotes)) score += 10;
        if (propertyUnits.Count > 0) score += 10;
        if (occupiedCount > 0 || monthlyRent > 0) score += 5;

        return Math.Min(score, 100);
    }

    private static Color GetReadinessColor(int score)
        => score >= 80 ? Color.Success : score >= 55 ? Color.Warning : Color.Error;

    private static string GetReadinessSummary(int score)
        => score >= 80
            ? "This property is well documented and ready for consistent leasing execution."
            : score >= 55
                ? "Good baseline, but more positioning detail would improve leasing consistency."
                : "High upside: complete the playbook fields to strengthen leasing quality and team execution.";

    private static string GetPerformanceLabel(Property property, List<Unit> propertyUnits, int occupiedCount, decimal monthlyRent)
    {
        if (propertyUnits.Count == 0)
        {
            return "Setup needed";
        }

        if (occupiedCount == propertyUnits.Count && monthlyRent >= property.MonthlyRevenueTarget)
        {
            return "Performing";
        }

        if (occupiedCount == 0)
        {
            return "Needs leasing";
        }

        return "Watchlist";
    }

    private static Color GetPerformanceColor(Property property, List<Unit> propertyUnits, int occupiedCount, decimal monthlyRent)
    {
        if (propertyUnits.Count == 0)
        {
            return Color.Info;
        }

        if (occupiedCount == propertyUnits.Count && monthlyRent >= property.MonthlyRevenueTarget)
        {
            return Color.Success;
        }

        if (occupiedCount == 0)
        {
            return Color.Error;
        }

        return Color.Warning;
    }

    private static string BuildPropertyNote(Property property, List<Unit> propertyUnits, int occupiedCount, int vacantCount)
    {
        if (propertyUnits.Count == 0)
        {
            return "No units configured yet. Add suites to start tracking occupancy, rent and leasing activity for this address.";
        }

        if (vacantCount > 0)
        {
            return $"{vacantCount} unit(s) are currently vacant. Focus next on leasing readiness, showing cadence and pricing alignment against the monthly target of {property.MonthlyRevenueTarget:C}.";
        }

        return $"This property is fully occupied across {occupiedCount} unit(s). Use it as a stable rent-roll asset and monitor renewals, maintenance timing and Ontario compliance deadlines.";
    }

    private static string GetIdealRenterProfile(Property property)
    {
        if (property.PropertyType.Contains("student", StringComparison.OrdinalIgnoreCase))
        {
            return "Best positioned for students and parents prioritizing predictable operations, transit and nearby amenities.";
        }

        if (property.PropertyType.Contains("single-family", StringComparison.OrdinalIgnoreCase) || property.PropertyType.Contains("townhome", StringComparison.OrdinalIgnoreCase))
        {
            return "Strong fit for longer-stay households looking for neighbourhood stability, storage and practical daily living.";
        }

        return "Best suited for professionals and couples who value location quality, polished leasing presentation and smooth move-in execution.";
    }

    private static string GetNextPortfolioAction(Property property, List<Unit> propertyUnits, int vacantCount, int readinessScore)
    {
        if (propertyUnits.Count == 0)
        {
            return "Add units first so occupancy, rent roll and leasing visibility become actionable inside the portfolio.";
        }

        if (vacantCount > 0)
        {
            return "Prioritize vacancy recovery: confirm pricing, refresh the showing story and tighten follow-up cadence on open suites.";
        }

        if (readinessScore < 80)
        {
            return "Complete the missing playbook fields to make renewals, turnovers and new listings more consistent for the team.";
        }

        return "Use this property as a benchmark asset and document what should be replicated across similar addresses in the portfolio.";
    }

    private static string GetOperationsFocus(Property property, int vacantCount)
    {
        if (vacantCount > 0)
        {
            return "Keep turnover speed high, align vendors early and remove friction between vacancy, maintenance and leasing handoff.";
        }

        if (string.IsNullOrWhiteSpace(property.OperationalNotes))
        {
            return "Add repeatable operating notes so onsite staff and external vendors execute the asset the same way every time.";
        }

        return property.OperationalNotes;
    }

    private static string GetPricingPosture(Property property, decimal monthlyRent, int vacantCount)
    {
        if (vacantCount > 0)
        {
            return $"Protect revenue recovery first. Benchmark against the target of {property.MonthlyRevenueTarget:C}, tighten showing speed and avoid overpricing vacant suites.";
        }

        if (monthlyRent > property.MonthlyRevenueTarget)
        {
            return "This asset is outperforming target. Preserve pricing discipline and document why this positioning resonates with renters.";
        }

        if (monthlyRent < property.MonthlyRevenueTarget)
        {
            return "Revenue sits below target. Review unit mix, renewal strategy and whether the property story supports the desired price point.";
        }

        return "Revenue is on target. Focus on keeping renewals smooth and protecting turnover quality rather than chasing avoidable concessions.";
    }

    private static string GetSuggestedHeadline(Property property)
    {
        var city = string.IsNullOrWhiteSpace(property.City) ? "Toronto" : property.City;

        if (property.PropertyType.Contains("student", StringComparison.OrdinalIgnoreCase))
        {
            return $"Student-ready living in {city} with practical convenience and fast move-in support.";
        }

        if (property.PropertyType.Contains("single-family", StringComparison.OrdinalIgnoreCase) || property.PropertyType.Contains("townhome", StringComparison.OrdinalIgnoreCase))
        {
            return $"Stable family-oriented rental in {city} with practical space and everyday convenience.";
        }

        if (property.PropertyType.Contains("luxury", StringComparison.OrdinalIgnoreCase) || property.PropertyType.Contains("waterfront", StringComparison.OrdinalIgnoreCase) || property.PropertyType.Contains("executive", StringComparison.OrdinalIgnoreCase))
        {
            return $"Premium {property.PropertyType.ToLowerInvariant()} living in {city} with polished presentation and strong renter appeal.";
