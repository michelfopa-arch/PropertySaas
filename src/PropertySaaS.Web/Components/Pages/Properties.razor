    private string GetAverageReadinessLabel()
    {
        var properties = FilteredProperties.ToList();
        if (properties.Count == 0)
        {
            return "0/100";
        }

        var average = properties.Average(property =>
        {
            var propertyUnits = GetUnitsForProperty(property.Id);
            return GetMarketingReadinessScore(property, propertyUnits, propertyUnits.Count(x => x.IsOccupied), propertyUnits.Sum(x => x.MonthlyRent));
        });

        return $"{Math.Round(average, 0)}/100";
    }

