    private async Task ImportCsvAsync()
    {
        var imported = 0;
        var skipped = 0;
        var lines = _csvInput.Split(new[] { "\r\n", "\n" }, StringSplitOptions.RemoveEmptyEntries);
        foreach (var line in lines)
        {
            var parts = line.Split(',');
            if (parts.Length < 4)
            {
                skipped++;
                continue;
            }

            var name = parts[0].Trim();
            var address = parts[1].Trim();
            var city = parts[2].Trim();
            if (string.IsNullOrWhiteSpace(name) || string.IsNullOrWhiteSpace(address) || string.IsNullOrWhiteSpace(city) || !decimal.TryParse(parts[3], out var revenue))
            {
                skipped++;
                continue;
            }

            if (_items.Any(x => string.Equals(x.Name, name, StringComparison.OrdinalIgnoreCase) && string.Equals(x.AddressLine1, address, StringComparison.OrdinalIgnoreCase)))
            {
                skipped++;
                continue;
            }

            await DataService.AddPropertyAsync(new Property
            {
                Name = name,
                AddressLine1 = address,
                City = city,
                Province = "ON",
                MonthlyRevenueTarget = revenue
            });
            imported++;
        }
        _csvInput = string.Empty;
        await ReloadAsync();
        _importResult = string.Format(Localizer["Properties_ImportResult"].Value, imported, skipped);
    }

