@attribute [Authorize]
@page "/properties"
@inject SaasDataService DataService
@inject NavigationManager NavigationManager
@inject PropertySaaS.Application.Common.CurrentOrganization CurrentOrganization
@inject IStringLocalizer<SharedResource> Localizer
@using PropertySaaS.Web.Localization

<PageTitle>@Localizer["Properties_Title"]</PageTitle>

<MudStack Spacing="3">
    <MudStack Spacing="0">
        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" Class="mb-2">@UiText.Get("Properties_PremiumBadge")</MudChip>
        <MudText Typo="Typo.h4">@Localizer["Properties_Title"]</MudText>
        <MudText Typo="Typo.body2">@Localizer["Properties_Subtitle"]</MudText>
    </MudStack>

    <DemoJourneyBanner CurrentStepKey="properties" UsePortfolioJourney="true" PropertiesRoute="@PropertiesRoute" PropertyProfileRoute="@PropertyProfileRoute" />

    @if (!IsDemoCleanView)
    {
        <MudGrid Spacing="2" Class="align-center-grid">
        <MudItem xs="12" lg="4">
            <MudTextField T="string"
                          Label="@Localizer["Properties_SearchLabel"]"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          @bind-Value="_searchText"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Placeholder="@Localizer["Properties_SearchPlaceholder"]" />
        </MudItem>
        <MudItem xs="12" sm="4" lg="2">
            <MudSelect T="string" Label="@Localizer["Properties_FilterType"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="_selectedTypeFilter">
                <MudSelectItem T="string" Value="@string.Empty">@Localizer["Properties_FilterAllTypes"]</MudSelectItem>
                @foreach (var propertyType in _propertyTypes)
                {
                    <MudSelectItem T="string" Value="@propertyType">@LocalizePropertyType(propertyType)</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="4" lg="2">
            <MudSelect T="string" Label="@Localizer["Properties_FilterCity"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="_selectedCityFilter">
                <MudSelectItem T="string" Value="@string.Empty">@Localizer["Properties_FilterAllCities"]</MudSelectItem>
                @foreach (var city in _cities)
                {
                    <MudSelectItem T="string" Value="@city">@city</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="4" lg="2">
            <MudSelect T="string" Label="@Localizer["Properties_FilterStage"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="_selectedStageFilter">
                <MudSelectItem T="string" Value="@string.Empty">@Localizer["Properties_FilterAllStages"]</MudSelectItem>
                @foreach (var stage in _assetStages)
                {
                    <MudSelectItem T="string" Value="@stage">@LocalizeAssetStage(stage)</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" lg="2">
            <MudStack Row="true" Spacing="1" Class="properties-toolbar-actions">
                @if (HasActiveFilters)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true" StartIcon="@Icons.Material.Filled.FilterAltOff" OnClick="ClearFilters">@Localizer["Common_Reset"]</MudButton>
                }
                @if (CurrentOrganization.CanManageData)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreatePanel">@Localizer["Properties_AddProperty"]</MudButton>
                }
            </MudStack>
        </MudItem>
        </MudGrid>
    }

    <MudGrid Spacing="2">
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["Properties_StatShown"]</MudText><MudText Typo="Typo.h6">@FilteredProperties.Count()</MudText></MudPaper></MudItem>
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["Properties_StatVacantUnits"]</MudText><MudText Typo="Typo.h6">@GetFilteredVacantUnits()</MudText></MudPaper></MudItem>
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["Properties_StatAverageReadiness"]</MudText><MudText Typo="Typo.h6">@GetAverageReadinessLabel()</MudText></MudPaper></MudItem>
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["Properties_StatRentRoll"]</MudText><MudText Typo="Typo.h6">@GetFilteredRentRoll().ToString("C")</MudText></MudPaper></MudItem>
    </MudGrid>

    <MudPaper Class="pa-4 property-detail-panel" Elevation="0">
        <MudText Typo="Typo.h6">@UiText.Get("Properties_InsightTitle")</MudText>
        <MudGrid Spacing="2" Class="mt-2">
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-3 property-mini-stat" Elevation="0">
                    <MudText Typo="Typo.overline">@UiText.Get("Properties_InsightUrgency")</MudText>
                    <MudChip T="string" Variant="Variant.Outlined" Color="@PortfolioInsightColor" Class="mt-2">@PortfolioInsightUrgencyLabel</MudChip>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-3 property-mini-stat" Elevation="0">
                    <MudText Typo="Typo.overline">@UiText.Get("Properties_InsightFocus")</MudText>
                    <MudChip T="string" Variant="Variant.Outlined" Color="@PortfolioInsightColor" Class="mt-2">@PortfolioInsightFocusLabel</MudChip>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-3 property-mini-stat" Elevation="0">
                    <MudText Typo="Typo.overline">@UiText.Get("Properties_InsightNextAction")</MudText>
                    <MudButton Class="mt-2" Variant="Variant.Text" Color="@PortfolioInsightColor" OnClick="OpenPortfolioInsightNextActionAsync">@PortfolioInsightActionLabel</MudButton>
                </MudPaper>
            </MudItem>
        </MudGrid>
        <MudText Typo="Typo.body2" Class="mt-3">@PortfolioInsightMessage</MudText>
    </MudPaper>

    @if (!IsDemoCleanView)
    {
        <MudExpansionPanels>
            <MudExpansionPanel Text="@Localizer["Common_BulkImport"]">
                <MudPaper Class="pa-4" Elevation="0">
                    <MudText Typo="Typo.h6">@Localizer["Common_QuickCsvImport"]</MudText>
                    <MudText Typo="Typo.body2" Class="mb-2">@Localizer["Properties_CsvFormatHint"]</MudText>
                    <MudTextField Lines="5" Variant="Variant.Outlined" @bind-Value="_csvInput" FullWidth="true" />
                    @if (CurrentOrganization.CanManageData)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary" Class="mt-3" OnClick="ImportCsvAsync">@Localizer["Common_ImportCsvText"]</MudButton>
                    }
                    @if (!string.IsNullOrWhiteSpace(_importResult))
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3 mb-0">@_importResult</MudAlert>
                    }
                </MudPaper>
            </MudExpansionPanel>
        </MudExpansionPanels>
    }

    <MudPaper Class="pa-2 table-wrap properties-table-shell">
        <MudTable Items="FilteredProperties.ToList()" Dense="true" Hover="true" Breakpoint="Breakpoint.Md" RowsPerPage="10">
            <HeaderContent>
                <MudTh>@Localizer["Properties_ColumnProperty"]</MudTh>
                <MudTh>@Localizer["Properties_ColumnType"]</MudTh>
                <MudTh>@Localizer["Properties_ColumnCity"]</MudTh>
                <MudTh>@Localizer["Properties_ColumnUnits"]</MudTh>
                <MudTh>@Localizer["Properties_ColumnOccupancy"]</MudTh>
                <MudTh>@Localizer["Properties_ColumnRentRoll"]</MudTh>
                <MudTh>@Localizer["Properties_ColumnReadiness"]</MudTh>
                <MudTh>@Localizer["Properties_ColumnStage"]</MudTh>
                <MudTh>@UiText.Get("Properties_ColumnNextAction")</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                @{ var propertyUnits = GetUnitsForProperty(context.Id); }
                @{ var occupiedCount = propertyUnits.Count(x => x.IsOccupied); }
                @{ var vacantCount = propertyUnits.Count - occupiedCount; }
                @{ var monthlyRent = propertyUnits.Sum(x => x.MonthlyRent); }
                @{ var readinessScore = GetMarketingReadinessScore(context, propertyUnits, occupiedCount, monthlyRent); }
                <MudTd DataLabel="@Localizer["Properties_ColumnProperty"]">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2">@context.Name</MudText>
                        <MudText Typo="Typo.caption" Class="property-address">@FormatAddress(context)</MudText>
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="@Localizer["Properties_ColumnType"]">@LocalizePropertyType(context.PropertyType)</MudTd>
                <MudTd DataLabel="@Localizer["Properties_ColumnCity"]">@context.City</MudTd>
                <MudTd DataLabel="@Localizer["Properties_ColumnUnits"]">@propertyUnits.Count</MudTd>
                <MudTd DataLabel="@Localizer["Properties_ColumnOccupancy"]">@GetOccupancyLabel(propertyUnits.Count, occupiedCount)</MudTd>
                <MudTd DataLabel="@Localizer["Properties_ColumnRentRoll"]">@monthlyRent.ToString("C")</MudTd>
                <MudTd DataLabel="@Localizer["Properties_ColumnReadiness"]"><MudChip T="string" Variant="Variant.Filled" Color="@GetReadinessColor(readinessScore)">@readinessScore/100</MudChip></MudTd>
                <MudTd DataLabel="@Localizer["Properties_ColumnStage"]"><MudChip T="string" Variant="Variant.Outlined" Color="@GetAssetStageColor(propertyUnits, vacantCount, readinessScore)">@LocalizeAssetStage(GetAssetStage(propertyUnits, vacantCount, readinessScore))</MudChip></MudTd>
                <MudTd DataLabel="@UiText.Get("Properties_ColumnNextAction")"><MudChip T="string" Variant="Variant.Outlined" Color="@GetPortfolioActionColor(context)">@GetPortfolioActionLabel(context)</MudChip></MudTd>
                <MudTd DataLabel="@Localizer["Properties_ColumnActions"]">
                    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                        <MudButton Href="@GetPropertyProfileHref(context.Id)" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small">@Localizer["Properties_ViewDetails"]</MudButton>
                        @if (CurrentOrganization.CanManageData)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small" OnClick="() => OpenEditPanel(context)">@Localizer["Common_Edit"]</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteAsync(context.Id)">@Localizer["Common_Delete"]</MudButton>
                        }
                    </MudStack>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudStack Class="pa-6 properties-empty-state" Spacing="1" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Apartment" Size="Size.Large" Color="Color.Default" />
                    <MudText Typo="Typo.subtitle1">@Localizer["Properties_NoRecordsTitle"]</MudText>
                    <MudText Typo="Typo.body2">@Localizer["Properties_NoRecordsSubtitle"]</MudText>
                    @if (HasActiveFilters)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ClearFilters">@Localizer["Common_ResetFilters"]</MudButton>
                    }
                </MudStack>
            </NoRecordsContent>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>

    @if (_isFormPanelOpen)
    {
        <div class="property-form-backdrop" @onclick="CloseFormPanel">
            <MudPaper Class="pa-5 property-form-drawer" Elevation="0" @onclick:stopPropagation="true">
                <MudStack Spacing="3">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h5">@(_isCreateMode ? Localizer["Properties_DrawerAddTitle"] : Localizer["Properties_DrawerEditTitle"])</MudText>
                            <MudText Typo="Typo.body2">@Localizer["Properties_DrawerSubtitle"]</MudText>
                        </MudStack>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="CloseFormPanel" />
                    </MudStack>

                    <EditForm Model="ActiveProperty" OnValidSubmit="SaveFormAsync">
                        <MudGrid Spacing="2">
                            <MudItem xs="12"><MudText Typo="Typo.subtitle2">@Localizer["Properties_SectionIdentityLocation"]</MudText></MudItem>
                            <MudItem xs="12" md="6"><MudTextField Label="@Localizer["Properties_FormName"]" Variant="Variant.Outlined" @bind-Value="ActiveProperty.Name" /></MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="string" Label="@Localizer["Properties_FormType"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="ActiveProperty.PropertyType">
                                    @foreach (var propertyType in _propertyTypes)
                                    {
                                        <MudSelectItem T="string" Value="@propertyType">@LocalizePropertyType(propertyType)</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="8"><MudTextField Label="@Localizer["Properties_FormAddress"]" Variant="Variant.Outlined" @bind-Value="ActiveProperty.AddressLine1" /></MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect T="string" Label="@Localizer["Properties_FormCity"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="ActiveProperty.City">
                                    @foreach (var city in _cities)
                                    {
                                        <MudSelectItem T="string" Value="@city">@city</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect T="string" Label="@Localizer["Properties_FormProvince"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="ActiveProperty.Province">
                                    @foreach (var province in _provinces)
                                    {
                                        <MudSelectItem T="string" Value="@province">@province</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="4"><MudTextField Label="@Localizer["Properties_FormPostalCode"]" Variant="Variant.Outlined" @bind-Value="ActiveProperty.PostalCode" /></MudItem>
                            <MudItem xs="12" md="4"><MudNumericField T="int?" Label="@Localizer["Properties_FormYearBuilt"]" Variant="Variant.Outlined" Placeholder="@Localizer["Properties_FormOptional"]" @bind-Value="FormYearBuiltValue" /></MudItem>
                            <MudItem xs="12" md="4"><MudNumericField T="decimal" Label="@Localizer["Properties_FormRevenueTarget"]" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentText="$" @bind-Value="ActiveProperty.MonthlyRevenueTarget" /></MudItem>
                            <MudItem xs="12"><MudDivider Class="my-2" /></MudItem>
                            <MudItem xs="12"><MudText Typo="Typo.subtitle2">@Localizer["Properties_SectionPlaybook"]</MudText></MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="string" Label="@Localizer["Properties_FormAmenityTemplate"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="FormAmenityTemplate">
                                    @foreach (var option in _amenityTemplates)
                                    {
                                        <MudSelectItem T="string" Value="@option">@LocalizeAmenityTemplate(option)</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="string" Label="@Localizer["Properties_FormNeighborhoodTemplate"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="FormNeighborhoodTemplate">
                                    @foreach (var option in _neighborhoodTemplates)
                                    {
                                        <MudSelectItem T="string" Value="@option">@LocalizeNeighborhoodTemplate(option)</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="string" Label="@Localizer["Properties_FormLeasingStrategy"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="FormLeasingTemplate">
                                    @foreach (var option in _leasingTemplates)
                                    {
                                        <MudSelectItem T="string" Value="@option">@LocalizeLeasingTemplate(option)</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="string" Label="@Localizer["Properties_FormOperationsFocus"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="FormOperationsTemplate">
                                    @foreach (var option in _operationsTemplates)
                                    {
                                        <MudSelectItem T="string" Value="@option">@LocalizeOperationsTemplate(option)</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12">
                                <MudPaper Class="pa-3 property-detail-panel" Elevation="0">
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.subtitle2">@Localizer["Properties_RecommendedMarketPack"]</MudText>
                                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                            <MudChip T="string" Variant="Variant.Filled" Color="Color.Primary">@GetMarketSegment(ActiveProperty)</MudChip>
                                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Secondary">@GetRecommendedStrategyPack(ActiveProperty)</MudChip>
                                        </MudStack>
                                        <MudText Typo="Typo.body2">@GetMarketNarrative(ActiveProperty)</MudText>
                                        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                                            <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AutoAwesome" OnClick="ApplyFormRecommendedPack">@Localizer["Properties_UseRecommendedPack"]</MudButton>
                                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.AutoFixHigh" OnClick="ApplyFormPlaybookTemplates">@Localizer["Properties_ApplyGuidedPresets"]</MudButton>
                                        </MudStack>
                                    </MudStack>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="12" md="6"><MudTextField Label="@Localizer["Properties_FormAmenities"]" Variant="Variant.Outlined" @bind-Value="ActiveProperty.AmenitySummary" /></MudItem>
                            <MudItem xs="12" md="6"><MudTextField Label="@Localizer["Properties_FormNeighborhoodNotes"]" Variant="Variant.Outlined" Lines="2" @bind-Value="ActiveProperty.NeighborhoodNotes" /></MudItem>
                            <MudItem xs="12" md="6"><MudTextField Label="@Localizer["Properties_FormLeasingNotes"]" Variant="Variant.Outlined" Lines="3" @bind-Value="ActiveProperty.LeasingNotes" /></MudItem>
                            <MudItem xs="12" md="6"><MudTextField Label="@Localizer["Properties_FormOperationalNotes"]" Variant="Variant.Outlined" Lines="3" @bind-Value="ActiveProperty.OperationalNotes" /></MudItem>
                        </MudGrid>

                        <MudStack Row="true" Spacing="2" Class="mt-4" Justify="Justify.FlexEnd">
                            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CloseFormPanel">@Localizer["Common_Cancel"]</MudButton>
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">@(_isCreateMode ? Localizer["Properties_Create"] : Localizer["Common_SaveChanges"])</MudButton>
                        </MudStack>
                    </EditForm>
                </MudStack>
            </MudPaper>
        </div>
    }

</MudStack>

@code {
    [SupplyParameterFromQuery(Name = "demo")]
    public string? DemoMode { get; set; }

    private static readonly string[] _propertyTypes =
    {
        "Multi-family",
        "Urban mid-rise",
        "Low-rise apartment",
        "Condo building",
        "Purpose-built rental",
        "Duplex / triplex",
        "Townhome cluster",
        "Single-family rental",
        "Student housing",
        "Waterfront condo",
        "Mixed-use asset",
        "Micro-suite building",
        "Luxury rental",
        "Suburban family asset",
        "Transit-oriented rental",
        "Executive furnished rental"
    };

    private static readonly string[] _provinces =
    {
        "ON",
        "QC",
        "BC",
        "AB",
        "MB",
        "SK",
        "NS",
        "NB",
        "PE",
        "NL"
    };

    private static readonly string[] _cities =
    {
        "Toronto",
        "Mississauga",
        "Brampton",
        "Hamilton",
        "Ottawa",
        "London",
        "Kitchener",
        "Waterloo",
        "Cambridge",
        "Oakville",
        "Burlington",
        "Milton",
        "Vaughan",
        "Markham",
        "Richmond Hill",
        "Pickering",
        "Ajax",
        "Whitby",
        "Oshawa",
        "Kingston"
    };

    private static readonly string[] _amenityTemplates =
    {
        "Essential urban living",
        "Lifestyle-driven premium",
        "Family convenience",
        "Student practical needs",
        "Transit convenience",
        "Executive furnished living",
        "Pet-friendly positioning",
        "Renovated value story"
    };

    private static readonly string[] _neighborhoodTemplates =
    {
        "Transit-led urban appeal",
        "Family-oriented neighbourhood",
        "Student convenience corridor",
        "Waterfront lifestyle",
        "Value repositioning pocket",
        "Downtown convenience hub",
        "Suburban stability corridor",
        "Executive relocation pocket"
    };

    private static readonly string[] _leasingTemplates =
    {
        "Premium professional positioning",
        "Fast vacancy recovery",
        "Long-stay household retention",
        "Student turnover cadence",
        "Renovation-led rent lift",
        "Transit commuter positioning",
        "Executive furnished demand",
        "Pet-friendly demand capture"
    };

    private static readonly string[] _operationsTemplates =
    {
        "Turnover speed",
        "Vendor coordination",
        "Preventive maintenance",
        "Resident experience",
        "Compliance-heavy operations",
        "Listing readiness",
        "Concierge-style service",
        "Seasonal turnover control"
    };

    private static readonly string[] _assetStages =
    {
        "Setup",
        "Lease-up",
        "Stabilize playbook",
        "Stabilized"
    };

    private List<Property> _items = new();
    private List<Unit> _units = new();
    private Property _newProperty = new() { Province = "ON", City = "Toronto", PropertyType = "Multi-family" };
    private Property _editProperty = new() { Province = "ON", City = "Toronto", PropertyType = "Multi-family" };
    private string _newAmenityTemplate = string.Empty;
    private string _newNeighborhoodTemplate = string.Empty;
    private string _newLeasingTemplate = string.Empty;
    private string _newOperationsTemplate = string.Empty;
    private string _editAmenityTemplate = string.Empty;
    private string _editNeighborhoodTemplate = string.Empty;
    private string _editLeasingTemplate = string.Empty;
    private string _editOperationsTemplate = string.Empty;
    private string _csvInput = string.Empty;
    private string? _importResult;
    private string _searchText = string.Empty;
    private string _selectedTypeFilter = string.Empty;
    private string _selectedCityFilter = string.Empty;
    private string _selectedStageFilter = string.Empty;
    private bool _isFormPanelOpen;
    private bool _isCreateMode = true;
    private bool IsDemoCleanView => DemoModeRouteHelper.IsClean(DemoMode);
    private Property? PriorityPortfolioProperty => FilteredProperties
        .OrderByDescending(property => GetUnitsForProperty(property.Id).Count(x => !x.IsOccupied) > 0)
        .ThenBy(property => GetMarketingReadinessScore(property, GetUnitsForProperty(property.Id), GetUnitsForProperty(property.Id).Count(x => x.IsOccupied), GetUnitsForProperty(property.Id).Sum(x => x.MonthlyRent)))
        .FirstOrDefault();
    private bool HasActiveFilters => !string.IsNullOrWhiteSpace(_searchText) || !string.IsNullOrWhiteSpace(_selectedTypeFilter) || !string.IsNullOrWhiteSpace(_selectedCityFilter) || !string.IsNullOrWhiteSpace(_selectedStageFilter);
    private IEnumerable<Property> FilteredProperties => _items.Where(property =>
        string.IsNullOrWhiteSpace(_searchText)
        || property.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
        || (property.AddressLine1?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
        || (property.City?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
        || (property.PostalCode?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
        || (property.PropertyType?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(property => string.IsNullOrWhiteSpace(_selectedTypeFilter) || string.Equals(property.PropertyType, _selectedTypeFilter, StringComparison.OrdinalIgnoreCase))
        .Where(property => string.IsNullOrWhiteSpace(_selectedCityFilter) || string.Equals(property.City, _selectedCityFilter, StringComparison.OrdinalIgnoreCase))
