    private static string GetAssetStage(List<Unit> propertyUnits, int vacantCount, int readinessScore)
    {
        if (propertyUnits.Count == 0) return "Setup";
        if (vacantCount > 0) return "Lease-up";
        if (readinessScore < 80) return "Stabilize playbook";
        return "Stabilized";
    }

    private static Color GetAssetStageColor(List<Unit> propertyUnits, int vacantCount, int readinessScore)
    {
        var stage = GetAssetStage(propertyUnits, vacantCount, readinessScore);
        return stage switch
        {
            "Setup" => Color.Info,
            "Lease-up" => Color.Warning,
            "Stabilize playbook" => Color.Secondary,
            _ => Color.Success
        };
    }

    private static string GetAssetStageNarrative(List<Unit> propertyUnits, int vacantCount, int readinessScore)
    {
        var stage = GetAssetStage(propertyUnits, vacantCount, readinessScore);
        return stage switch
        {
            "Setup" => "The asset structure is not fully mapped yet. Finish the base setup before relying on portfolio insights.",
            "Lease-up" => "This address needs focused vacancy execution, pricing discipline and sharper listing follow-through.",
            "Stabilize playbook" => "Occupancy is workable, but the commercial playbook still needs stronger documentation for repeatable team execution.",
            _ => "The property is documented and operationally steady enough to serve as a benchmark asset in the portfolio."
        };
    }

    private static List<string> GetMissingPlaybookItems(Property property, List<Unit> propertyUnits)
    {
        var gaps = new List<string>();

        if (string.IsNullOrWhiteSpace(property.AmenitySummary)) gaps.Add("Amenities summary");
        if (string.IsNullOrWhiteSpace(property.NeighborhoodNotes)) gaps.Add("Neighborhood positioning");
        if (string.IsNullOrWhiteSpace(property.LeasingNotes)) gaps.Add("Leasing strategy");
        if (string.IsNullOrWhiteSpace(property.OperationalNotes)) gaps.Add("Operations notes");
        if (propertyUnits.Count == 0) gaps.Add("Units mapping");

        return gaps;
    }

    private static List<string> GetRecommendedActions(Property property, List<Unit> propertyUnits, int vacantCount, int readinessScore, decimal monthlyRent)
    {
        var actions = new List<string>();

        if (propertyUnits.Count == 0)
        {
            actions.Add("Add the unit mix so occupancy, rent roll and leasing performance become measurable.");
        }

        if (vacantCount > 0)
        {
            actions.Add("Launch a vacancy recovery sprint with sharper pricing, faster showings and tighter follow-up.");
        }

        if (readinessScore < 80)
        {
            actions.Add("Complete the missing playbook inputs to improve consistency across listings, tours and renewals.");
        }

        if (monthlyRent < property.MonthlyRevenueTarget)
        {
            actions.Add("Review the pricing story and positioning against the revenue target before offering concessions.");
        }

        if (actions.Count == 0)
        {
            actions.Add("Document what is working here and reuse this property as the benchmark playbook for similar assets.");
            actions.Add("Stay ahead of renewals and maintenance windows to protect the current stabilized performance.");
        }

        return actions.Take(3).ToList();
    }

    private static void ApplyTemplatesToProperty(Property property, string amenityTemplate, string neighborhoodTemplate, string leasingTemplate, string operationsTemplate)
    {
        if (!string.IsNullOrWhiteSpace(amenityTemplate))
        {
            property.AmenitySummary = amenityTemplate switch
            {
                "Essential urban living" => "Laundry access, secure entry, practical storage and daily convenience features that support reliable city living.",
                "Lifestyle-driven premium" => "Fitness, outdoor amenity space, upgraded finishes and convenience features that justify a stronger rent story.",
                "Family convenience" => "Parking, storage, durable layouts and practical amenities that make longer-stay household living easier.",
                "Student practical needs" => "Transit access, shared study-friendly layouts, durable finishes and simple move-in convenience for recurring turnovers.",
                _ => property.AmenitySummary
            };
        }

        if (!string.IsNullOrWhiteSpace(neighborhoodTemplate))
        {
            property.NeighborhoodNotes = neighborhoodTemplate switch
            {
                "Transit-led urban appeal" => $"Strong appeal for renters seeking quick access to transit, daily retail and a smooth commute around {property.City}.",
                "Family-oriented neighbourhood" => $"Position around stability, schools, parks and daily convenience for households evaluating longer stays in {property.City}.",
                "Student convenience corridor" => $"Best marketed around campus access, transit simplicity and predictable day-to-day convenience for students and guarantors.",
                "Waterfront lifestyle" => "Lead with walkability, views, recreation access and lifestyle differentiation that strengthens emotional renter interest.",
                "Value repositioning pocket" => $"Useful for renters trading a prime core address for more space, better value and practical commuting from this {property.City} pocket.",
                _ => property.NeighborhoodNotes
            };
        }

        if (!string.IsNullOrWhiteSpace(leasingTemplate))
        {
            property.LeasingNotes = leasingTemplate switch
            {
                "Premium professional positioning" => "Lead with finish quality, low-friction commuting and a polished move-in experience for professionals and couples.",
                "Fast vacancy recovery" => "Simplify the story, keep pricing sharp and run a tighter follow-up cadence to compress vacancy days without diluting quality.",
                "Long-stay household retention" => "Emphasize stability, practical layout value and resident experience to attract lower-turnover households.",
                "Student turnover cadence" => "Prepare for seasonal peaks, standardize showings and keep documentation and move-in workflows fast for recurring cycles.",
                "Renovation-led rent lift" => "Use upgraded finishes and clearer before/after positioning to support pricing confidence and stronger listing conversion.",
                _ => property.LeasingNotes
            };
        }

        if (!string.IsNullOrWhiteSpace(operationsTemplate))
        {
            property.OperationalNotes = operationsTemplate switch
            {
                "Turnover speed" => "Pre-book vendors, standardize refresh scope and reduce idle time between notice, maintenance and marketing launch.",
                "Vendor coordination" => "Keep vendor expectations, access steps and closeout communication tight so the team can move from issue to completion faster.",
                "Preventive maintenance" => "Prioritize recurring checks and small interventions early to prevent avoidable resident disruption and revenue leakage.",
                "Resident experience" => "Maintain clear communication, dependable service timing and cleaner handoffs to strengthen renewals and referrals.",
                "Compliance-heavy operations" => "Track Ontario notice windows, safety checks and documentation discipline so compliance work stays visible and repeatable.",
                _ => property.OperationalNotes
            };
        }
    }

