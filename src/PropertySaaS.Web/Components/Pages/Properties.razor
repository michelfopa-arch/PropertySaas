    private Task<IEnumerable<string>> SearchPropertyTypesAsync(string? value, CancellationToken cancellationToken)
        => SearchOptionsAsync(_propertyTypes, value, cancellationToken);

    private Task<IEnumerable<string>> SearchCitiesAsync(string? value, CancellationToken cancellationToken)
        => SearchOptionsAsync(_cities, value, cancellationToken);

    private Task<IEnumerable<string>> SearchAmenityTemplatesAsync(string? value, CancellationToken cancellationToken)
        => SearchOptionsAsync(_amenityTemplates, value, cancellationToken);

    private Task<IEnumerable<string>> SearchNeighborhoodTemplatesAsync(string? value, CancellationToken cancellationToken)
        => SearchOptionsAsync(_neighborhoodTemplates, value, cancellationToken);

    private Task<IEnumerable<string>> SearchLeasingTemplatesAsync(string? value, CancellationToken cancellationToken)
        => SearchOptionsAsync(_leasingTemplates, value, cancellationToken);

    private Task<IEnumerable<string>> SearchOperationsTemplatesAsync(string? value, CancellationToken cancellationToken)
        => SearchOptionsAsync(_operationsTemplates, value, cancellationToken);

    private static Task<IEnumerable<string>> SearchOptionsAsync(IEnumerable<string> options, string? value, CancellationToken cancellationToken)
    {
        cancellationToken.ThrowIfCancellationRequested();
        var results = string.IsNullOrWhiteSpace(value)
            ? options
            : options.Where(option => option.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(results);
    }

    private static string GetMarketSegment(Property property)
    {
        if (property.PropertyType.Contains("student", StringComparison.OrdinalIgnoreCase)) return "Student market";
        if (property.PropertyType.Contains("single-family", StringComparison.OrdinalIgnoreCase) || property.PropertyType.Contains("townhome", StringComparison.OrdinalIgnoreCase)) return "Family rental market";
        if (property.PropertyType.Contains("luxury", StringComparison.OrdinalIgnoreCase) || property.PropertyType.Contains("executive", StringComparison.OrdinalIgnoreCase) || property.PropertyType.Contains("waterfront", StringComparison.OrdinalIgnoreCase)) return "Premium renter market";
        if (property.City.Contains("Toronto", StringComparison.OrdinalIgnoreCase) || property.City.Contains("Mississauga", StringComparison.OrdinalIgnoreCase) || property.City.Contains("Markham", StringComparison.OrdinalIgnoreCase)) return "Urban commuter market";
        return "Core rental market";
    }

    private static string GetRecommendedStrategyPack(Property property)
        => $"{GetRecommendedLeasingTemplate(property.PropertyType)} + {GetRecommendedOperationsTemplate(property.PropertyType)}";

    private static string GetMarketNarrative(Property property)
    {
        var city = string.IsNullOrWhiteSpace(property.City) ? "this market" : property.City;
        var segment = GetMarketSegment(property);

        if (segment == "Student market")
        {
            return $"In {city}, emphasize speed, predictability and recurring seasonal readiness to win in the student segment.";
        }

        if (segment == "Family rental market")
        {
            return $"In {city}, stability, storage, schools and resident experience should anchor the property story for family-oriented renters.";
        }

        if (segment == "Premium renter market")
        {
            return $"In {city}, lead with finish quality, convenience and a polished leasing journey to support stronger pricing confidence.";
        }

        return $"In {city}, combine practical amenities, commuter convenience and disciplined follow-up to strengthen leasing conversion.";
    }

