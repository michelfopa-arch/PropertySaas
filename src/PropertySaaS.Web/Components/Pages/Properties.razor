@attribute [Authorize]
@page "/properties"
@inject SaasDataService DataService
@inject PropertySaaS.Application.Common.CurrentOrganization CurrentOrganization

<PageTitle>Properties</PageTitle>

<MudStack Spacing="3">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h4">Properties</MudText>
        <MudText Typo="Typo.body2">Portfolio view first, execution detail second. Open each property profile only when the team needs the full operating context.</MudText>
    </MudStack>

    <MudGrid Spacing="2" Class="align-center-grid">
        <MudItem xs="12" lg="4">
            <MudTextField T="string"
                          Label="Search properties"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          @bind-Value="_searchText"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Placeholder="Search by name, address, city, postal code or type" />
        </MudItem>
        <MudItem xs="12" sm="4" lg="2">
            <MudSelect T="string" Label="Type" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="_selectedTypeFilter">
                <MudSelectItem T="string" Value="@string.Empty">All types</MudSelectItem>
                @foreach (var propertyType in _propertyTypes)
                {
                    <MudSelectItem T="string" Value="@propertyType">@propertyType</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="4" lg="2">
            <MudSelect T="string" Label="City" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="_selectedCityFilter">
                <MudSelectItem T="string" Value="@string.Empty">All cities</MudSelectItem>
                @foreach (var city in _cities)
                {
                    <MudSelectItem T="string" Value="@city">@city</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="4" lg="2">
            <MudSelect T="string" Label="Stage" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="_selectedStageFilter">
                <MudSelectItem T="string" Value="@string.Empty">All stages</MudSelectItem>
                @foreach (var stage in _assetStages)
                {
                    <MudSelectItem T="string" Value="@stage">@stage</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" lg="2">
            <MudStack Row="true" Spacing="1" Class="properties-toolbar-actions">
                @if (HasActiveFilters)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true" StartIcon="@Icons.Material.Filled.FilterAltOff" OnClick="ClearFilters">Reset</MudButton>
                }
                @if (CurrentOrganization.CanManageData)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreatePanel">Add property</MudButton>
                }
            </MudStack>
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="2">
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">Properties shown</MudText><MudText Typo="Typo.h6">@FilteredProperties.Count()</MudText></MudPaper></MudItem>
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">Vacant units</MudText><MudText Typo="Typo.h6">@GetFilteredVacantUnits()</MudText></MudPaper></MudItem>
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">Average readiness</MudText><MudText Typo="Typo.h6">@GetAverageReadinessLabel()</MudText></MudPaper></MudItem>
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">Rent roll</MudText><MudText Typo="Typo.h6">@GetFilteredRentRoll().ToString("C")</MudText></MudPaper></MudItem>
    </MudGrid>

    <MudExpansionPanels>
        <MudExpansionPanel Text="Bulk import">
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.h6">Quick CSV Import</MudText>
                <MudText Typo="Typo.body2" Class="mb-2">Format: Name,AddressLine1,City,MonthlyRevenueTarget</MudText>
                <MudTextField Lines="5" Variant="Variant.Outlined" @bind-Value="_csvInput" FullWidth="true" />
                @if (CurrentOrganization.CanManageData)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" Class="mt-3" OnClick="ImportCsvAsync">Import CSV Text</MudButton>
                }
                @if (!string.IsNullOrWhiteSpace(_importResult))
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3 mb-0">@_importResult</MudAlert>
                }
            </MudPaper>
        </MudExpansionPanel>
    </MudExpansionPanels>

    <MudPaper Class="pa-2 table-wrap properties-table-shell">
        <MudTable Items="FilteredProperties.ToList()" Dense="true" Hover="true" Breakpoint="Breakpoint.Md" RowsPerPage="10">
            <HeaderContent>
                <MudTh>Property</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>City</MudTh>
                <MudTh>Units</MudTh>
                <MudTh>Occupancy</MudTh>
                <MudTh>Rent roll</MudTh>
                <MudTh>Readiness</MudTh>
                <MudTh>Stage</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                @{ var propertyUnits = GetUnitsForProperty(context.Id); }
                @{ var occupiedCount = propertyUnits.Count(x => x.IsOccupied); }
                @{ var vacantCount = propertyUnits.Count - occupiedCount; }
                @{ var monthlyRent = propertyUnits.Sum(x => x.MonthlyRent); }
                @{ var readinessScore = GetMarketingReadinessScore(context, propertyUnits, occupiedCount, monthlyRent); }
                <MudTd DataLabel="Property">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2">@context.Name</MudText>
                        <MudText Typo="Typo.caption" Class="property-address">@FormatAddress(context)</MudText>
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="Type">@context.PropertyType</MudTd>
                <MudTd DataLabel="City">@context.City</MudTd>
                <MudTd DataLabel="Units">@propertyUnits.Count</MudTd>
                <MudTd DataLabel="Occupancy">@GetOccupancyLabel(propertyUnits.Count, occupiedCount)</MudTd>
                <MudTd DataLabel="Rent roll">@monthlyRent.ToString("C")</MudTd>
                <MudTd DataLabel="Readiness"><MudChip T="string" Variant="Variant.Filled" Color="@GetReadinessColor(readinessScore)">@readinessScore/100</MudChip></MudTd>
                <MudTd DataLabel="Stage"><MudChip T="string" Variant="Variant.Outlined" Color="@GetAssetStageColor(propertyUnits, vacantCount, readinessScore)">@GetAssetStage(propertyUnits, vacantCount, readinessScore)</MudChip></MudTd>
                <MudTd DataLabel="Actions">
                    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                        <MudButton Href="@($"/properties/{context.Id}")" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small">View details</MudButton>
                        @if (CurrentOrganization.CanManageData)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small" OnClick="() => OpenEditPanel(context)">Edit</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteAsync(context.Id)">Delete</MudButton>
                        }
                    </MudStack>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudStack Class="pa-6 properties-empty-state" Spacing="1" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Apartment" Size="Size.Large" Color="Color.Default" />
                    <MudText Typo="Typo.subtitle1">No properties match the current filters.</MudText>
                    <MudText Typo="Typo.body2">Reset the filters or add a new address to keep growing the portfolio.</MudText>
                    @if (HasActiveFilters)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ClearFilters">Reset filters</MudButton>
                    }
                </MudStack>
            </NoRecordsContent>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>

    @if (_isFormPanelOpen)
    {
        <div class="property-form-backdrop" @onclick="CloseFormPanel">
            <MudPaper Class="pa-5 property-form-drawer" Elevation="0" @onclick:stopPropagation="true">
                <MudStack Spacing="3">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h5">@(_isCreateMode ? "Add property" : "Edit property")</MudText>
                            <MudText Typo="Typo.body2">Capture only what the team needs now. Full execution lives in the property profile.</MudText>
                        </MudStack>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="CloseFormPanel" />
                    </MudStack>

                    <EditForm Model="ActiveProperty" OnValidSubmit="SaveFormAsync">
                        <MudGrid Spacing="2">
                            <MudItem xs="12"><MudText Typo="Typo.subtitle2">Identity and location</MudText></MudItem>
                            <MudItem xs="12" md="6"><MudTextField Label="Property name" Variant="Variant.Outlined" @bind-Value="ActiveProperty.Name" /></MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="string" Label="Property type" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="ActiveProperty.PropertyType">
                                    @foreach (var propertyType in _propertyTypes)
                                    {
                                        <MudSelectItem T="string" Value="@propertyType">@propertyType</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="8"><MudTextField Label="Address" Variant="Variant.Outlined" @bind-Value="ActiveProperty.AddressLine1" /></MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect T="string" Label="City" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="ActiveProperty.City">
                                    @foreach (var city in _cities)
                                    {
                                        <MudSelectItem T="string" Value="@city">@city</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect T="string" Label="Province" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="ActiveProperty.Province">
                                    @foreach (var province in _provinces)
                                    {
                                        <MudSelectItem T="string" Value="@province">@province</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="4"><MudTextField Label="Postal code" Variant="Variant.Outlined" @bind-Value="ActiveProperty.PostalCode" /></MudItem>
                            <MudItem xs="12" md="4"><MudNumericField T="int?" Label="Year built" Variant="Variant.Outlined" Placeholder="Optional" @bind-Value="FormYearBuiltValue" /></MudItem>
                            <MudItem xs="12" md="4"><MudNumericField T="decimal" Label="Revenue target" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentText="$" @bind-Value="ActiveProperty.MonthlyRevenueTarget" /></MudItem>
                            <MudItem xs="12"><MudDivider Class="my-2" /></MudItem>
                            <MudItem xs="12"><MudText Typo="Typo.subtitle2">Commercialization playbook</MudText></MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="string" Label="Amenity template" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="FormAmenityTemplate">
                                    @foreach (var option in _amenityTemplates)
                                    {
                                        <MudSelectItem T="string" Value="@option">@option</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="string" Label="Neighborhood template" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="FormNeighborhoodTemplate">
                                    @foreach (var option in _neighborhoodTemplates)
                                    {
                                        <MudSelectItem T="string" Value="@option">@option</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="string" Label="Leasing strategy" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="FormLeasingTemplate">
                                    @foreach (var option in _leasingTemplates)
                                    {
                                        <MudSelectItem T="string" Value="@option">@option</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="string" Label="Operations focus" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="FormOperationsTemplate">
                                    @foreach (var option in _operationsTemplates)
                                    {
                                        <MudSelectItem T="string" Value="@option">@option</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12">
                                <MudPaper Class="pa-3 property-detail-panel" Elevation="0">
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.subtitle2">Recommended market pack</MudText>
                                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                            <MudChip T="string" Variant="Variant.Filled" Color="Color.Primary">@GetMarketSegment(ActiveProperty)</MudChip>
                                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Secondary">@GetRecommendedStrategyPack(ActiveProperty)</MudChip>
                                        </MudStack>
                                        <MudText Typo="Typo.body2">@GetMarketNarrative(ActiveProperty)</MudText>
                                        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                                            <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AutoAwesome" OnClick="ApplyFormRecommendedPack">Use recommended pack</MudButton>
                                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.AutoFixHigh" OnClick="ApplyFormPlaybookTemplates">Apply guided presets</MudButton>
                                        </MudStack>
                                    </MudStack>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="12" md="6"><MudTextField Label="Amenities" Variant="Variant.Outlined" @bind-Value="ActiveProperty.AmenitySummary" /></MudItem>
                            <MudItem xs="12" md="6"><MudTextField Label="Neighborhood notes" Variant="Variant.Outlined" Lines="2" @bind-Value="ActiveProperty.NeighborhoodNotes" /></MudItem>
                            <MudItem xs="12" md="6"><MudTextField Label="Leasing notes" Variant="Variant.Outlined" Lines="3" @bind-Value="ActiveProperty.LeasingNotes" /></MudItem>
                            <MudItem xs="12" md="6"><MudTextField Label="Operational notes" Variant="Variant.Outlined" Lines="3" @bind-Value="ActiveProperty.OperationalNotes" /></MudItem>
                        </MudGrid>

                        <MudStack Row="true" Spacing="2" Class="mt-4" Justify="Justify.FlexEnd">
                            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CloseFormPanel">Cancel</MudButton>
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">@(_isCreateMode ? "Create property" : "Save changes")</MudButton>
                        </MudStack>
                    </EditForm>
                </MudStack>
            </MudPaper>
        </div>
    }

</MudStack>

@code {
    private static readonly string[] _propertyTypes =
    {
        "Multi-family",
        "Urban mid-rise",
        "Low-rise apartment",
        "Condo building",
        "Purpose-built rental",
        "Duplex / triplex",
        "Townhome cluster",
        "Single-family rental",
        "Student housing",
        "Waterfront condo",
        "Mixed-use asset",
        "Micro-suite building",
        "Luxury rental",
        "Suburban family asset",
        "Transit-oriented rental",
        "Executive furnished rental"
    };

    private static readonly string[] _provinces =
    {
        "ON",
        "QC",
        "BC",
        "AB",
        "MB",
        "SK",
        "NS",
        "NB",
        "PE",
        "NL"
    };

    private static readonly string[] _cities =
    {
        "Toronto",
        "Mississauga",
        "Brampton",
        "Hamilton",
        "Ottawa",
        "London",
        "Kitchener",
        "Waterloo",
        "Cambridge",
        "Oakville",
        "Burlington",
        "Milton",
        "Vaughan",
        "Markham",
        "Richmond Hill",
        "Pickering",
        "Ajax",
        "Whitby",
        "Oshawa",
        "Kingston"
    };

    private static readonly string[] _amenityTemplates =
    {
        "Essential urban living",
        "Lifestyle-driven premium",
        "Family convenience",
        "Student practical needs",
        "Transit convenience",
        "Executive furnished living",
        "Pet-friendly positioning",
        "Renovated value story"
    };

    private static readonly string[] _neighborhoodTemplates =
    {
        "Transit-led urban appeal",
        "Family-oriented neighbourhood",
        "Student convenience corridor",
        "Waterfront lifestyle",
        "Value repositioning pocket",
        "Downtown convenience hub",
        "Suburban stability corridor",
        "Executive relocation pocket"
    };

    private static readonly string[] _leasingTemplates =
    {
        "Premium professional positioning",
        "Fast vacancy recovery",
        "Long-stay household retention",
        "Student turnover cadence",
        "Renovation-led rent lift",
        "Transit commuter positioning",
        "Executive furnished demand",
        "Pet-friendly demand capture"
    };

    private static readonly string[] _operationsTemplates =
    {
        "Turnover speed",
        "Vendor coordination",
        "Preventive maintenance",
        "Resident experience",
        "Compliance-heavy operations",
        "Listing readiness",
        "Concierge-style service",
        "Seasonal turnover control"
    };

    private static readonly string[] _assetStages =
    {
        "Setup",
        "Lease-up",
        "Stabilize playbook",
        "Stabilized"
    };

    private List<Property> _items = new();
    private List<Unit> _units = new();
    private Property _newProperty = new() { Province = "ON", City = "Toronto", PropertyType = "Multi-family" };
    private Property _editProperty = new() { Province = "ON", City = "Toronto", PropertyType = "Multi-family" };
    private string _newAmenityTemplate = string.Empty;
    private string _newNeighborhoodTemplate = string.Empty;
    private string _newLeasingTemplate = string.Empty;
    private string _newOperationsTemplate = string.Empty;
    private string _editAmenityTemplate = string.Empty;
    private string _editNeighborhoodTemplate = string.Empty;
    private string _editLeasingTemplate = string.Empty;
    private string _editOperationsTemplate = string.Empty;
    private string _csvInput = string.Empty;
    private string? _importResult;
    private string _searchText = string.Empty;
    private string _selectedTypeFilter = string.Empty;
    private string _selectedCityFilter = string.Empty;
    private string _selectedStageFilter = string.Empty;
    private bool _isFormPanelOpen;
    private bool _isCreateMode = true;
    private bool HasActiveFilters => !string.IsNullOrWhiteSpace(_searchText) || !string.IsNullOrWhiteSpace(_selectedTypeFilter) || !string.IsNullOrWhiteSpace(_selectedCityFilter) || !string.IsNullOrWhiteSpace(_selectedStageFilter);
    private IEnumerable<Property> FilteredProperties => _items.Where(property =>
        string.IsNullOrWhiteSpace(_searchText)
        || property.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
        || (property.AddressLine1?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
        || (property.City?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
        || (property.PostalCode?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
        || (property.PropertyType?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(property => string.IsNullOrWhiteSpace(_selectedTypeFilter) || string.Equals(property.PropertyType, _selectedTypeFilter, StringComparison.OrdinalIgnoreCase))
        .Where(property => string.IsNullOrWhiteSpace(_selectedCityFilter) || string.Equals(property.City, _selectedCityFilter, StringComparison.OrdinalIgnoreCase))
        .Where(property => string.IsNullOrWhiteSpace(_selectedStageFilter) || string.Equals(GetAssetStage(GetUnitsForProperty(property.Id), GetUnitsForProperty(property.Id).Count(x => !x.IsOccupied), GetMarketingReadinessScore(property, GetUnitsForProperty(property.Id), GetUnitsForProperty(property.Id).Count(x => x.IsOccupied), GetUnitsForProperty(property.Id).Sum(x => x.MonthlyRent))), _selectedStageFilter, StringComparison.OrdinalIgnoreCase));

    private Property ActiveProperty => _isCreateMode ? _newProperty : _editProperty;

    private int? FormYearBuiltValue
    {
        get => ActiveProperty.YearBuilt == 0 ? null : ActiveProperty.YearBuilt;
        set => ActiveProperty.YearBuilt = value ?? 0;
    }

    private string FormAmenityTemplate { get => _isCreateMode ? _newAmenityTemplate : _editAmenityTemplate; set { if (_isCreateMode) _newAmenityTemplate = value; else _editAmenityTemplate = value; } }
    private string FormNeighborhoodTemplate { get => _isCreateMode ? _newNeighborhoodTemplate : _editNeighborhoodTemplate; set { if (_isCreateMode) _newNeighborhoodTemplate = value; else _editNeighborhoodTemplate = value; } }
    private string FormLeasingTemplate { get => _isCreateMode ? _newLeasingTemplate : _editLeasingTemplate; set { if (_isCreateMode) _newLeasingTemplate = value; else _editLeasingTemplate = value; } }
    private string FormOperationsTemplate { get => _isCreateMode ? _newOperationsTemplate : _editOperationsTemplate; set { if (_isCreateMode) _newOperationsTemplate = value; else _editOperationsTemplate = value; } }

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
        ResetNewTemplates();
        ResetEditTemplates();
    }
    private async Task ReloadAsync()
    {
        _items = await DataService.GetPropertiesAsync();
        _units = await DataService.GetUnitsAsync();
    }
    private async Task CreateAsync()
    {
        await DataService.AddPropertyAsync(_newProperty);
        _newProperty = new Property { Province = "ON", City = "Toronto", PropertyType = "Multi-family" };
        ResetNewTemplates();
        await ReloadAsync();
    }

    private async Task SaveFormAsync()
    {
        if (_isCreateMode)
        {
            await CreateAsync();
        }
        else
        {
            await SaveEditAsync();
        }

        CloseFormPanel();
    }

    private async Task DeleteAsync(Guid id)
    {
        await DataService.DeletePropertyAsync(id);
        await ReloadAsync();
    }

    private void ClearFilters()
    {
        _searchText = string.Empty;
        _selectedTypeFilter = string.Empty;
        _selectedCityFilter = string.Empty;
        _selectedStageFilter = string.Empty;
    }

    private void OpenCreatePanel()
    {
        _isCreateMode = true;
        _newProperty = new Property { Province = "ON", City = "Toronto", PropertyType = "Multi-family" };
        ResetNewTemplates();
        _isFormPanelOpen = true;
    }

    private void OpenEditPanel(Property property)
    {
        _isCreateMode = false;
        ResetEditTemplates();
        _editProperty = new Property
        {
            Id = property.Id,
            Name = property.Name,
            PropertyType = property.PropertyType,
            AddressLine1 = property.AddressLine1,
            City = property.City,
            Province = property.Province,
            PostalCode = property.PostalCode,
            YearBuilt = property.YearBuilt,
            MonthlyRevenueTarget = property.MonthlyRevenueTarget,
            AmenitySummary = property.AmenitySummary,
            NeighborhoodNotes = property.NeighborhoodNotes,
            LeasingNotes = property.LeasingNotes,
            OperationalNotes = property.OperationalNotes
        };
        SetEditTemplateDefaults(_editProperty.PropertyType);
        _isFormPanelOpen = true;
    }

    private void StartEdit(Property property) => OpenEditPanel(property);

    private void CloseFormPanel()
    {
        _isFormPanelOpen = false;
        _isCreateMode = true;
    }

    private async Task SaveEditAsync()
    {
        await DataService.UpdatePropertyAsync(_editProperty);
        await ReloadAsync();
        _editProperty = new Property { Province = "ON", City = "Toronto", PropertyType = "Multi-family" };
        ResetEditTemplates();
    }

    private void ApplyNewPlaybookTemplates()
        => ApplyTemplatesToProperty(_newProperty, _newAmenityTemplate, _newNeighborhoodTemplate, _newLeasingTemplate, _newOperationsTemplate);

    private void ApplyEditPlaybookTemplates()
        => ApplyTemplatesToProperty(_editProperty, _editAmenityTemplate, _editNeighborhoodTemplate, _editLeasingTemplate, _editOperationsTemplate);

    private void ApplyFormPlaybookTemplates()
    {
        if (_isCreateMode)
        {
            ApplyNewPlaybookTemplates();
            return;
        }

        ApplyEditPlaybookTemplates();
    }

    private void ApplyRecommendedNewPack()
    {
        SetNewTemplateDefaults(_newProperty.PropertyType);
        ApplyNewPlaybookTemplates();
    }

    private void ApplyRecommendedEditPack()
    {
        SetEditTemplateDefaults(_editProperty.PropertyType);
        ApplyEditPlaybookTemplates();
    }

    private void ApplyFormRecommendedPack()
    {
        if (_isCreateMode)
        {
            ApplyRecommendedNewPack();
            return;
        }

        ApplyRecommendedEditPack();
    }

    private Task OnNewPropertyTypeChanged(string propertyType)
    {
        _newProperty.PropertyType = string.IsNullOrWhiteSpace(propertyType) ? "Multi-family" : propertyType;
