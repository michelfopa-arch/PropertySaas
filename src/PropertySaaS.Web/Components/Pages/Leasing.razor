@attribute [Authorize]
@page "/leasing"
@inject SaasDataService DataService
@inject PropertySaaS.Application.Common.CurrentOrganization CurrentOrganization
@using PropertySaaS.Web.Localization
@using PropertySaaS.Domain.Entities
@using PropertySaaS.Domain.Enums

<PageTitle>@UiText.Get("Nav_Leasing")</PageTitle>

<MudStack Spacing="3">
    <MudStack Spacing="0">
        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" Class="mb-2">@UiText.Get("Leasing_PremiumBadge")</MudChip>
        <MudText Typo="Typo.h4">@UiText.Get("Leasing_Title")</MudText>
        <MudText Typo="Typo.body2">@UiText.Get("Leasing_Subtitle")</MudText>
    </MudStack>

    @if (_listings.Count == 0)
    {
        <MudPaper Class="pa-6 properties-empty-state" Elevation="0">
            <MudText Typo="Typo.subtitle1">@UiText.Get("Leasing_NoListingsTitle")</MudText>
            <MudText Typo="Typo.body2">@UiText.Get("Leasing_NoListingsSubtitle")</MudText>
        </MudPaper>
    }
    else
    {
        <MudGrid Spacing="3">
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4 marketing-card h-100" Elevation="0">
                    <MudText Typo="Typo.h6">@UiText.Get("Leasing_ReadyListingsTitle")</MudText>
                    <MudList T="string" Dense="true" Class="mt-3">
                        @foreach (var listing in _listings.Take(6))
                        {
                            <MudListItem T="string">
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="w-100">
                                    <MudStack Spacing="0">
                                        <MudText>@listing.Title - @listing.PropertyName @FormatUnitLabel(listing.UnitLabel) - @listing.AskingRent.ToString("C")</MudText>
                                        <MudText Typo="Typo.caption">@UiText.Get("Leasing_PublishReadiness"): @listing.PublishReadinessSummary</MudText>
                                        <MudText Typo="Typo.caption">@UiText.Get("Leasing_PublishChannels"): @listing.PublishChannelsLabel</MudText>
                                    </MudStack>
                                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" OnClick="() => SelectListingPreviewAsync(listing.ListingId)">@UiText.Get("Leasing_PublicationPreviewTitle")</MudButton>
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4 marketing-card h-100" Elevation="0">
                    <MudText Typo="Typo.h6">@UiText.Get("Leasing_AIListingTitle")</MudText>
                    <MudText Typo="Typo.body2" Class="mb-3">@UiText.Get("Leasing_AIListingSubtitle")</MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string">@UiText.Get("Leasing_AIListing1")</MudListItem>
                        <MudListItem T="string">@UiText.Get("Leasing_AIListing2")</MudListItem>
                        <MudListItem T="string">@UiText.Get("Leasing_AIListing3")</MudListItem>
                    </MudList>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @if (_selectedListingPreview is not null)
        {
            <MudGrid Spacing="3">
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4 marketing-card h-100" Elevation="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6">@UiText.Get("Leasing_PublicationPreviewTitle")</MudText>
                            <MudButton Href="@($"/export/listings/{_selectedListingPreview.ListingId}/copy")" Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small">@UiText.Get("Leasing_ExportCopy")</MudButton>
                        </MudStack>
                        <MudText Class="mt-3"><strong>@_selectedListingPreview.Title</strong></MudText>
                        <MudText Typo="Typo.body2">@UiText.Get("Leasing_PublishReadiness"): @_selectedListingPreview.PublishReadinessSummary</MudText>
                        <MudText Typo="Typo.body2">@UiText.Get("Leasing_PublishChannels"): @_selectedListingPreview.PublishChannelsLabel</MudText>
                        <MudText Typo="Typo.subtitle2" Class="mt-3">@UiText.Get("Leasing_ShortCopy")</MudText>
                        <MudText Typo="Typo.body2">@_selectedListingPreview.ShortCopy</MudText>
                        <MudText Typo="Typo.subtitle2" Class="mt-3">@UiText.Get("Leasing_LongCopy")</MudText>
                        <MudText Typo="Typo.body2">@_selectedListingPreview.LongCopy</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4 marketing-card h-100" Elevation="0">
                        <MudText Typo="Typo.h6">@UiText.Get("Leasing_PublicationChecklistTitle")</MudText>
                        <MudList T="string" Dense="true" Class="mt-3">
                            <MudListItem T="string">@UiText.Get("Leasing_PublicationChecklist1")</MudListItem>
                            <MudListItem T="string">@UiText.Get("Leasing_PublicationChecklist2")</MudListItem>
                            <MudListItem T="string">@UiText.Get("Leasing_PublicationChecklist3")</MudListItem>
                        </MudList>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }

        <MudGrid Spacing="3">
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4 marketing-card h-100" Elevation="0">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">@UiText.Get("Leasing_LeadsTitle")</MudText>
                        @if (CurrentOrganization.CanManageData)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateLeadPanel">@UiText.Get("Common_Add")</MudButton>
                        }
                    </MudStack>
                    <MudList T="string" Dense="true" Class="mt-3">
                        @foreach (var lead in _leads.Take(6))
                        {
                            <MudListItem T="string">
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="w-100">
                                    <MudText>@lead.FullName - @lead.ListingTitle - @lead.Status</MudText>
                                    @if (CurrentOrganization.CanManageData)
                                    {
                                        <MudStack Row="true" Spacing="1">
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Secondary" OnClick="() => OpenEditLeadPanel(lead)" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => DeleteLeadAsync(lead.LeadId)" />
                                        </MudStack>
                                    }
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4 marketing-card h-100" Elevation="0">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">@UiText.Get("Leasing_ShowingsTitle")</MudText>
                        @if (CurrentOrganization.CanManageData)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateShowingPanel">@UiText.Get("Common_Add")</MudButton>
                        }
                    </MudStack>
                    <MudList T="string" Dense="true" Class="mt-3">
                        @foreach (var showing in _showings.Take(6))
                        {
                            <MudListItem T="string">
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="w-100">
                                    <MudText>@showing.ScheduledUtc.ToLocalTime().ToString("g") - @showing.ListingTitle - @showing.LeadName</MudText>
                                    @if (CurrentOrganization.CanManageData)
                                    {
                                        <MudStack Row="true" Spacing="1">
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Secondary" OnClick="() => OpenEditShowingPanel(showing)" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => DeleteShowingAsync(showing.ShowingId)" />
                                        </MudStack>
                                    }
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @if (_isLeadPanelOpen)
        {
            <div class="property-form-backdrop" @onclick="CloseLeadPanel">
                <MudPaper Class="pa-5 property-form-drawer" Elevation="0" @onclick:stopPropagation="true">
                    <MudStack Spacing="3">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h5">@(_isLeadCreateMode ? UiText.Get("Leasing_AddLead") : UiText.Get("Leasing_EditLead"))</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="CloseLeadPanel" />
                        </MudStack>

                        <EditForm Model="ActiveLead" OnValidSubmit="SaveLeadAsync">
                            <MudGrid Spacing="2">
                                <MudItem xs="12" md="6"><MudTextField Label="@UiText.Get("Leasing_LeadName")" Variant="Variant.Outlined" @bind-Value="ActiveLead.FullName" /></MudItem>
                                <MudItem xs="12" md="6"><MudTextField Label="@UiText.Get("Leasing_LeadEmail")" Variant="Variant.Outlined" @bind-Value="ActiveLead.Email" /></MudItem>
                                <MudItem xs="12" md="6"><MudTextField Label="@UiText.Get("Leasing_LeadPhone")" Variant="Variant.Outlined" @bind-Value="ActiveLead.PhoneNumber" /></MudItem>
                                <MudItem xs="12" md="6"><MudTextField Label="@UiText.Get("Leasing_LeadSource")" Variant="Variant.Outlined" @bind-Value="ActiveLead.Source" /></MudItem>
                                <MudItem xs="12" md="6">
                                    <MudSelect T="Guid?" Label="@UiText.Get("Leasing_LeadListing")" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="FormLeadListingId">
                                        <MudSelectItem T="Guid?" Value="@((Guid?)null)">@UiText.Get("Leasing_SelectListing")</MudSelectItem>
                                        @foreach (var listing in _listings)
                                        {
                                            <MudSelectItem T="Guid?" Value="@((Guid?)listing.ListingId)">@listing.Title</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudSelect T="LeadStatus" Label="@UiText.Get("Leasing_LeadStatus")" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="ActiveLead.Status">
                                        @foreach (var status in Enum.GetValues<LeadStatus>())
                                        {
                                            <MudSelectItem T="LeadStatus" Value="@status">@status</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12"><MudTextField Label="@UiText.Get("Leasing_LeadNotes")" Variant="Variant.Outlined" Lines="3" @bind-Value="ActiveLead.Notes" /></MudItem>
                            </MudGrid>

                            <MudStack Row="true" Spacing="2" Class="mt-4" Justify="Justify.FlexEnd">
                                <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CloseLeadPanel">@UiText.Get("Common_Cancel")</MudButton>
                                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">@(_isLeadCreateMode ? UiText.Get("Common_Create") : UiText.Get("Common_SaveChanges"))</MudButton>
                            </MudStack>
                        </EditForm>
                    </MudStack>
                </MudPaper>
            </div>
        }

        @if (_isShowingPanelOpen)
        {
            <div class="property-form-backdrop" @onclick="CloseShowingPanel">
                <MudPaper Class="pa-5 property-form-drawer" Elevation="0" @onclick:stopPropagation="true">
                    <MudStack Spacing="3">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h5">@(_isShowingCreateMode ? UiText.Get("Leasing_AddShowing") : UiText.Get("Leasing_EditShowing"))</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="CloseShowingPanel" />
                        </MudStack>

                        <EditForm Model="ActiveShowing" OnValidSubmit="SaveShowingAsync">
                            <MudGrid Spacing="2">
                                <MudItem xs="12" md="6">
                                    <MudSelect T="Guid?" Label="@UiText.Get("Leasing_LeadListing")" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="FormShowingListingId">
                                        <MudSelectItem T="Guid?" Value="@((Guid?)null)">@UiText.Get("Leasing_SelectListing")</MudSelectItem>
                                        @foreach (var listing in _listings)
                                        {
                                            <MudSelectItem T="Guid?" Value="@((Guid?)listing.ListingId)">@listing.Title</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudSelect T="Guid?" Label="@UiText.Get("Leasing_ShowingLead")" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="FormShowingLeadId">
                                        <MudSelectItem T="Guid?" Value="@((Guid?)null)">@UiText.Get("Leasing_OptionalLead")</MudSelectItem>
                                        @foreach (var lead in AvailableLeads)
                                        {
                                            <MudSelectItem T="Guid?" Value="@((Guid?)lead.LeadId)">@lead.FullName</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="6"><MudDatePicker Label="@UiText.Get("Leasing_ShowingDate")" Variant="Variant.Outlined" @bind-Date="_showingScheduledDate" Editable="true" /></MudItem>
                                <MudItem xs="12" md="6"><MudTextField Label="@UiText.Get("Leasing_ShowingStatus")" Variant="Variant.Outlined" @bind-Value="ActiveShowing.Status" /></MudItem>
                                <MudItem xs="12"><MudTextField Label="@UiText.Get("Leasing_LeadNotes")" Variant="Variant.Outlined" Lines="3" @bind-Value="ActiveShowing.Notes" /></MudItem>
                            </MudGrid>

                            <MudStack Row="true" Spacing="2" Class="mt-4" Justify="Justify.FlexEnd">
                                <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CloseShowingPanel">@UiText.Get("Common_Cancel")</MudButton>
                                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">@(_isShowingCreateMode ? UiText.Get("Common_Create") : UiText.Get("Common_SaveChanges"))</MudButton>
                            </MudStack>
                        </EditForm>
                    </MudStack>
                </MudPaper>
            </div>
        }
    }
</MudStack>

@code {
    private List<ListingSummaryDto> _listings = new();
    private List<LeadSummaryDto> _leads = new();
    private List<ShowingSummaryDto> _showings = new();
    private ListingSummaryDto? _selectedListingPreview;
    private Lead _newLead = new() { Status = LeadStatus.New };
    private Lead _editLead = new() { Status = LeadStatus.New };
    private Showing _newShowing = new() { Status = "Scheduled" };
    private Showing _editShowing = new() { Status = "Scheduled" };
    private bool _isLeadPanelOpen;
    private bool _isLeadCreateMode = true;
    private bool _isShowingPanelOpen;
    private bool _isShowingCreateMode = true;
    private DateTime? _showingScheduledDate = DateTime.Now.AddDays(1);

    private Lead ActiveLead => _isLeadCreateMode ? _newLead : _editLead;
    private Showing ActiveShowing => _isShowingCreateMode ? _newShowing : _editShowing;
    private IEnumerable<LeadSummaryDto> AvailableLeads => FormShowingListingId is null || FormShowingListingId == Guid.Empty ? _leads : _leads.Where(x => x.ListingId == FormShowingListingId.Value);

    private Guid? FormLeadListingId
    {
        get => ActiveLead.ListingId == Guid.Empty ? null : ActiveLead.ListingId;
        set => ActiveLead.ListingId = value ?? Guid.Empty;
    }

    private Guid? FormShowingListingId
    {
        get => ActiveShowing.ListingId == Guid.Empty ? null : ActiveShowing.ListingId;
        set
        {
            ActiveShowing.ListingId = value ?? Guid.Empty;
            if (ActiveShowing.LeadId.HasValue && !AvailableLeads.Any(x => x.LeadId == ActiveShowing.LeadId.Value))
            {
                ActiveShowing.LeadId = null;
            }
        }
    }

    private Guid? FormShowingLeadId
    {
        get => ActiveShowing.LeadId;
        set => ActiveShowing.LeadId = value;
    }

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private static string FormatUnitLabel(string unitLabel)
        => string.IsNullOrWhiteSpace(unitLabel) ? string.Empty : $"- Unit {unitLabel}";

    private async Task ReloadAsync()
    {
        _listings = await DataService.GetListingsAsync();
        _leads = await DataService.GetLeadsAsync();
        _showings = await DataService.GetShowingsAsync();
        _selectedListingPreview ??= _listings.FirstOrDefault();
    }

    private async Task SelectListingPreviewAsync(Guid listingId)
    {
        _selectedListingPreview = await DataService.GetListingPublicationPreviewAsync(listingId);
    }

    private void OpenCreateLeadPanel()
    {
        _isLeadCreateMode = true;
        _newLead = new Lead { Status = LeadStatus.New };
        _isLeadPanelOpen = true;
    }

    private void OpenEditLeadPanel(LeadSummaryDto lead)
    {
        _isLeadCreateMode = false;
        _editLead = new Lead
        {
            Id = lead.LeadId,
            ListingId = lead.ListingId,
            FullName = lead.FullName,
            Email = lead.Email,
            Source = lead.Source,
            Status = Enum.TryParse<LeadStatus>(lead.Status, out var status) ? status : LeadStatus.New
        };
        _isLeadPanelOpen = true;
    }

    private void CloseLeadPanel()
    {
        _isLeadPanelOpen = false;
        _isLeadCreateMode = true;
    }

    private async Task SaveLeadAsync()
    {
        if (ActiveLead.ListingId == Guid.Empty || string.IsNullOrWhiteSpace(ActiveLead.FullName))
        {
            return;
        }

        if (_isLeadCreateMode)
        {
            await DataService.AddLeadAsync(_newLead);
        }
        else
        {
            await DataService.UpdateLeadAsync(_editLead);
        }

        await ReloadAsync();
        CloseLeadPanel();
    }

    private async Task DeleteLeadAsync(Guid id)
    {
        await DataService.DeleteLeadAsync(id);
        await ReloadAsync();
    }

    private void OpenCreateShowingPanel()
    {
        _isShowingCreateMode = true;
        _newShowing = new Showing { Status = "Scheduled" };
        _showingScheduledDate = DateTime.Now.AddDays(1);
        _isShowingPanelOpen = true;
    }

    private void OpenEditShowingPanel(ShowingSummaryDto showing)
    {
        _isShowingCreateMode = false;
        _editShowing = new Showing
        {
            Id = showing.ShowingId,
            ListingId = showing.ListingId,
            LeadId = showing.LeadId,
            ScheduledUtc = showing.ScheduledUtc,
            Status = showing.Status
        };
        _showingScheduledDate = showing.ScheduledUtc.ToLocalTime();
        _isShowingPanelOpen = true;
    }

    private void CloseShowingPanel()
    {
        _isShowingPanelOpen = false;
        _isShowingCreateMode = true;
    }

    private async Task SaveShowingAsync()
    {
        if (ActiveShowing.ListingId == Guid.Empty)
        {
            return;
        }

        ActiveShowing.ScheduledUtc = (_showingScheduledDate ?? DateTime.Now).ToUniversalTime();

        if (_isShowingCreateMode)
        {
            await DataService.AddShowingAsync(_newShowing);
        }
        else
        {
            await DataService.UpdateShowingAsync(_editShowing);
        }

        await ReloadAsync();
        CloseShowingPanel();
    }

    private async Task DeleteShowingAsync(Guid id)
    {
        await DataService.DeleteShowingAsync(id);
        await ReloadAsync();
    }
}
