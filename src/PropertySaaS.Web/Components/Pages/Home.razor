@page "/"
@inject CurrentOrganization CurrentOrganization
@using PropertySaaS.Web.Localization

<PageTitle>@UiText.Get("Home_PageTitle")</PageTitle>

<MudStack Spacing="4">
    <MudPaper Class="hero pa-8">
        <MudGrid Spacing="4" Class="align-center-grid">
            <MudItem xs="12" lg="7">
                <MudText Typo="Typo.h3">@UiText.Get("Home_HeroTitle")</MudText>
                <MudText Typo="Typo.h6" Class="mt-4 hero-copy">@UiText.Get("Home_HeroCopy")</MudText>
                <MudStack Row="true" Spacing="2" Class="mt-6" Wrap="Wrap.Wrap">
                    <MudButton Href="/sign-up" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large">@UiText.Get("Home_StartFreeTrial")</MudButton>
                    <MudButton Href="/sign-in" Variant="Variant.Outlined" Color="Color.Inherit" Size="Size.Large">@UiText.Get("Home_SignInCta")</MudButton>
                    <MudButton Href="/account" Variant="Variant.Text" Color="Color.Inherit" Size="Size.Large">@UiText.Get("Home_ManageAccountCta")</MudButton>
                    <MudButton Href="/dashboard" Variant="Variant.Filled" Color="Color.Inherit" Size="Size.Large" Class="hero-primary-action">@UiText.Get("Home_OpenDemo")</MudButton>
                    <MudButton Href="/pricing" Variant="Variant.Outlined" Color="Color.Inherit" Size="Size.Large">@UiText.Get("Home_SeePricing")</MudButton>
                    <MudButton Href="/properties" Variant="Variant.Filled" Color="Color.Warning" Size="Size.Large">@UiText.Get("Home_SeeProductFlow")</MudButton>
                </MudStack>
            </MudItem>

            <MudItem xs="12" lg="5">
                <MudPaper Class="pa-4 marketing-panel" Elevation="0">
                    <MudText Typo="Typo.h5">@UiText.Get("Home_ProspectsTitle")</MudText>
                    <MudList T="string" Dense="true" Class="mt-3">
                        <MudListItem T="string">@UiText.Get("Home_ProspectsItem1")</MudListItem>
                        <MudListItem T="string">@UiText.Get("Home_ProspectsItem2")</MudListItem>
                        <MudListItem T="string">@UiText.Format("Home_ProspectsItem3", CurrentOrganization.Jurisdiction.ProvinceDisplayName)</MudListItem>
                        <MudListItem T="string">@UiText.Get("Home_ProspectsItem4")</MudListItem>
                        <MudListItem T="string">@UiText.Get("Home_ProspectsItem5")</MudListItem>
                        <MudListItem T="string">@UiText.Get("Home_ProspectsItem6")</MudListItem>
                    </MudList>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudStack Spacing="2">
        <MudText Typo="Typo.h4">@UiText.Get("Home_PositioningTitle")</MudText>
        <MudGrid Spacing="3">
            <MudItem xs="12" md="4"><MudPaper Class="pa-4 marketing-card h-100" Elevation="0"><MudText Typo="Typo.h6">@UiText.Get("Home_PositioningCard1Title")</MudText><MudText Typo="Typo.body1">@UiText.Get("Home_PositioningCard1Body")</MudText></MudPaper></MudItem>
            <MudItem xs="12" md="4"><MudPaper Class="pa-4 marketing-card h-100" Elevation="0"><MudText Typo="Typo.h6">@UiText.Get("Home_PositioningCard2Title")</MudText><MudText Typo="Typo.body1">@UiText.Get("Home_PositioningCard2Body")</MudText></MudPaper></MudItem>
            <MudItem xs="12" md="4"><MudPaper Class="pa-4 marketing-card h-100" Elevation="0"><MudText Typo="Typo.h6">@UiText.Get("Home_PositioningCard3Title")</MudText><MudText Typo="Typo.body1">@UiText.Get("Home_PositioningCard3Body")</MudText></MudPaper></MudItem>
        </MudGrid>
    </MudStack>

    <MudStack Spacing="2">
        <MudText Typo="Typo.h4">@UiText.Get("Home_SwitchTitle")</MudText>
        <MudGrid Spacing="3">
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4 marketing-card h-100" Elevation="0">
                    <MudText Typo="Typo.h6">@UiText.Get("Home_TypicalTitle")</MudText>
                    <MudList T="string" Dense="true" Class="mt-3">
                        <MudListItem T="string">@UiText.Get("Home_Typical1")</MudListItem>
                        <MudListItem T="string">@UiText.Get("Home_Typical2")</MudListItem>
                        <MudListItem T="string">@UiText.Get("Home_Typical3")</MudListItem>
                        <MudListItem T="string">@UiText.Get("Home_Typical4")</MudListItem>
                    </MudList>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4 marketing-card h-100" Elevation="0">
                    <MudText Typo="Typo.h6">@UiText.Get("Home_AdvantageTitle")</MudText>
                    <MudList T="string" Dense="true" Class="mt-3">
                        <MudListItem T="string">@UiText.Get("Home_Advantage1")</MudListItem>
                        <MudListItem T="string">@UiText.Get("Home_Advantage2")</MudListItem>
                        <MudListItem T="string">@UiText.Get("Home_Advantage3")</MudListItem>
                        <MudListItem T="string">@UiText.Get("Home_Advantage4")</MudListItem>
                    </MudList>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudStack>

    <MudStack Spacing="2">
        <MudText Typo="Typo.h4">@UiText.Get("Home_DemoTitle")</MudText>
        <MudGrid Spacing="3">
            <MudItem xs="12" md="3"><MudPaper Class="pa-4 marketing-card h-100" Elevation="0"><MudText Typo="Typo.h6">@UiText.Get("Home_DemoPropertiesTitle")</MudText><MudText Typo="Typo.body2">@UiText.Get("Home_DemoPropertiesBody")</MudText></MudPaper></MudItem>
            <MudItem xs="12" md="3"><MudPaper Class="pa-4 marketing-card h-100" Elevation="0"><MudText Typo="Typo.h6">@UiText.Get("Home_DemoUnitsLeasesTitle")</MudText><MudText Typo="Typo.body2">@UiText.Get("Home_DemoUnitsLeasesBody")</MudText></MudPaper></MudItem>
            <MudItem xs="12" md="3"><MudPaper Class="pa-4 marketing-card h-100" Elevation="0"><MudText Typo="Typo.h6">@UiText.Get("Home_DemoTenantsMaintenanceTitle")</MudText><MudText Typo="Typo.body2">@UiText.Get("Home_DemoTenantsMaintenanceBody")</MudText></MudPaper></MudItem>
            <MudItem xs="12" md="3"><MudPaper Class="pa-4 marketing-card h-100" Elevation="0"><MudText Typo="Typo.h6">@UiText.Get("Home_DemoComplianceTitle")</MudText><MudText Typo="Typo.body2">@UiText.Get("Home_DemoComplianceBody")</MudText></MudPaper></MudItem>
        </MudGrid>
    </MudStack>

    <MudPaper Class="pa-6 marketing-panel" Elevation="0">
        <MudStack Spacing="2" AlignItems="AlignItems.Start">
            <MudText Typo="Typo.h4">@UiText.Get("Home_FinalCtaTitle")</MudText>
            <MudText Typo="Typo.body1">@UiText.Get("Home_FinalCtaBody")</MudText>
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudButton Href="/sign-up" Variant="Variant.Filled" Color="Color.Primary">@UiText.Get("Home_StartFreeTrial")</MudButton>
                <MudButton Href="/sign-in" Variant="Variant.Outlined" Color="Color.Primary">@UiText.Get("Home_SignInCta")</MudButton>
                <MudButton Href="/account" Variant="Variant.Text" Color="Color.Primary">@UiText.Get("Home_ManageAccountCta")</MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>
</MudStack>
