@attribute [Authorize]
@page "/tenants"
@inject SaasDataService DataService
@inject PropertySaaS.Application.Common.CurrentOrganization CurrentOrganization
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@Localizer["Tenants_Title"]</PageTitle>

<MudStack Spacing="3">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h4">@Localizer["Tenants_Title"]</MudText>
        <MudText Typo="Typo.body2">@Localizer["Tenants_Subtitle"]</MudText>
    </MudStack>

    <MudGrid Spacing="2" Class="align-center-grid">
        <MudItem xs="12" lg="4">
            <MudTextField T="string"
                          Label="@Localizer["Tenants_SearchLabel"]"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          @bind-Value="_searchText"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Placeholder="@Localizer["Tenants_SearchPlaceholder"]" />
        </MudItem>
        <MudItem xs="12" sm="4" lg="2">
            <MudSelect T="string" Label="@Localizer["Tenants_FilterScreening"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="_selectedProviderFilter">
                <MudSelectItem T="string" Value="@string.Empty">@Localizer["Tenants_FilterAllProviders"]</MudSelectItem>
                @foreach (var provider in ProviderOptions)
                {
                    <MudSelectItem T="string" Value="@provider">@provider</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="4" lg="2">
            <MudSelect T="string" Label="@Localizer["Tenants_FilterScoreBand"]" Variant="Variant.Outlined" ShrinkLabel="true" @bind-Value="_selectedScoreBand">
                <MudSelectItem T="string" Value="@string.Empty">@Localizer["Tenants_FilterAllScores"]</MudSelectItem>
                <MudSelectItem T="string" Value='@("750+")'>750+</MudSelectItem>
                <MudSelectItem T="string" Value='@("700-749")'>700-749</MudSelectItem>
                <MudSelectItem T="string" Value='@Localizer["Tenants_ScoreBandUnder700"].Value'>@Localizer["Tenants_ScoreBandUnder700"]</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="4" lg="2">
            <MudStack Row="true" Spacing="1" Class="properties-toolbar-actions">
                @if (HasActiveFilters)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true" StartIcon="@Icons.Material.Filled.FilterAltOff" OnClick="ClearFilters">@Localizer["Common_Reset"]</MudButton>
                }
            </MudStack>
        </MudItem>
        <MudItem xs="12" lg="2">
            <MudStack Row="true" Spacing="1" Class="properties-toolbar-actions">
                @if (CurrentOrganization.CanManageData)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreatePanel">@Localizer["Tenants_AddTenant"]</MudButton>
                }
            </MudStack>
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="2">
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["Tenants_StatShown"]</MudText><MudText Typo="Typo.h6">@FilteredTenants.Count()</MudText></MudPaper></MudItem>
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["Tenants_StatAverageScore"]</MudText><MudText Typo="Typo.h6">@GetAverageScoreLabel()</MudText></MudPaper></MudItem>
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["Tenants_StatProvidersUsed"]</MudText><MudText Typo="Typo.h6">@FilteredTenants.Select(x => x.ScreeningProvider).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).Count()</MudText></MudPaper></MudItem>
        <MudItem xs="12" sm="6" lg="3"><MudPaper Class="pa-3 property-mini-stat" Elevation="0"><MudText Typo="Typo.overline">@Localizer["Tenants_StatHighScoreResidents"]</MudText><MudText Typo="Typo.h6">@FilteredTenants.Count(x => x.CreditScore >= 750)</MudText></MudPaper></MudItem>
    </MudGrid>

    <MudExpansionPanels>
        <MudExpansionPanel Text="@Localizer["Common_BulkImport"]">
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.h6">@Localizer["Common_QuickCsvImport"]</MudText>
                <MudText Typo="Typo.body2" Class="mb-2">@Localizer["Tenants_CsvFormatHint"]</MudText>
                <MudTextField Lines="6" Variant="Variant.Outlined" @bind-Value="_csvInput" FullWidth="true" />
                @if (CurrentOrganization.CanManageData)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" Class="mt-3" OnClick="ImportCsvAsync">@Localizer["Common_ImportCsvText"]</MudButton>
                }
                @if (!string.IsNullOrWhiteSpace(_importResult))
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3 mb-0">@_importResult</MudAlert>
                }
            </MudPaper>
        </MudExpansionPanel>
    </MudExpansionPanels>

    <MudPaper Class="pa-2 table-wrap properties-table-shell">
        <MudTable Items="FilteredTenants.ToList()" Dense="true" Hover="true" Breakpoint="Breakpoint.Md" RowsPerPage="10">
            <HeaderContent>
                <MudTh>@Localizer["Tenants_ColumnName"]</MudTh>
                <MudTh>@Localizer["Tenants_ColumnEmail"]</MudTh>
                <MudTh>@Localizer["Tenants_ColumnPhone"]</MudTh>
                <MudTh>@Localizer["Tenants_ColumnScreening"]</MudTh>
                <MudTh>@Localizer["Tenants_ColumnScore"]</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="@Localizer["Tenants_ColumnName"]">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2">@context.FullName</MudText>
                        <MudText Typo="Typo.caption" Class="property-address">@GetTenantScoreNarrative(context)</MudText>
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="@Localizer["Tenants_ColumnEmail"]">@context.Email</MudTd>
                <MudTd DataLabel="@Localizer["Tenants_ColumnPhone"]">@context.PhoneNumber</MudTd>
                <MudTd DataLabel="@Localizer["Tenants_ColumnScreening"]"><MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">@GetProviderLabel(context.ScreeningProvider)</MudChip></MudTd>
                <MudTd DataLabel="@Localizer["Tenants_ColumnScore"]"><MudChip T="string" Variant="Variant.Filled" Color="@GetScoreColor(context.CreditScore)">@context.CreditScore</MudChip></MudTd>
                <MudTd DataLabel="@Localizer["Tenants_ColumnActions"]">
                    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                        <MudButton Href="/leases" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small">@Localizer["Tenants_OpenLeases"]</MudButton>
                        @if (CurrentOrganization.CanManageData)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small" OnClick="() => OpenEditPanel(context)">@Localizer["Common_Edit"]</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteAsync(context.Id)">@Localizer["Common_Delete"]</MudButton>
                        }
                    </MudStack>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudStack Class="pa-6 properties-empty-state" Spacing="1" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Color="Color.Default" />
                    <MudText Typo="Typo.subtitle1">@Localizer["Tenants_NoRecordsTitle"]</MudText>
                    <MudText Typo="Typo.body2">@Localizer["Tenants_NoRecordsSubtitle"]</MudText>
                    @if (HasActiveFilters)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ClearFilters">@Localizer["Common_ResetFilters"]</MudButton>
                    }
                </MudStack>
            </NoRecordsContent>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>

    <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
        <MudButton Href="/import-export" Variant="Variant.Outlined" Color="Color.Default">@Localizer["Tenants_OpenImportExport"]</MudButton>
        <MudButton Href="/export/tenants" Variant="Variant.Outlined" Color="Color.Primary">@Localizer["Tenants_ExportCsv"]</MudButton>
    </MudStack>

    @if (_isFormPanelOpen)
    {
        <div class="property-form-backdrop" @onclick="CloseFormPanel">
            <MudPaper Class="pa-5 property-form-drawer" Elevation="0" @onclick:stopPropagation="true">
                <MudStack Spacing="3">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h5">@(_isCreateMode ? Localizer["Tenants_AddTenant"] : Localizer["Tenants_DrawerEditTitle"])</MudText>
                            <MudText Typo="Typo.body2">@Localizer["Tenants_DrawerSubtitle"]</MudText>
                        </MudStack>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="CloseFormPanel" />
                    </MudStack>

                    <EditForm Model="ActiveTenant" OnValidSubmit="SaveFormAsync">
                        <MudGrid Spacing="2">
                            <MudItem xs="12" md="6"><MudTextField Label="@Localizer["Tenants_FormFullName"]" Variant="Variant.Outlined" @bind-Value="ActiveTenant.FullName" /></MudItem>
                            <MudItem xs="12" md="6"><MudTextField Label="@Localizer["Tenants_ColumnEmail"]" Variant="Variant.Outlined" @bind-Value="ActiveTenant.Email" /></MudItem>
                            <MudItem xs="12" md="4"><MudTextField Label="@Localizer["Tenants_ColumnPhone"]" Variant="Variant.Outlined" @bind-Value="ActiveTenant.PhoneNumber" /></MudItem>
                            <MudItem xs="12" md="4"><MudNumericField T="int" Label="@Localizer["Tenants_FormCreditScore"]" Variant="Variant.Outlined" @bind-Value="ActiveTenant.CreditScore" /></MudItem>
                            <MudItem xs="12" md="4"><MudTextField Label="@Localizer["Tenants_FormScreeningProvider"]" Variant="Variant.Outlined" @bind-Value="ActiveTenant.ScreeningProvider" /></MudItem>
                            <MudItem xs="12"><MudSwitch T="bool" Color="Color.Primary" Label="@Localizer["Tenants_FormScreeningCompleted"]" @bind-Value="ActiveTenant.ScreeningCompleted" /></MudItem>
                            <MudItem xs="12"><MudPaper Class="pa-3 property-detail-panel" Elevation="0"><MudText Typo="Typo.subtitle2">@Localizer["Tenants_FormResidentNote"]</MudText><MudText Typo="Typo.body2">@GetFormGuidance()</MudText></MudPaper></MudItem>
                        </MudGrid>

                        <MudStack Row="true" Spacing="2" Class="mt-4" Justify="Justify.FlexEnd">
                            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CloseFormPanel">@Localizer["Common_Cancel"]</MudButton>
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">@(_isCreateMode ? Localizer["Tenants_Create"] : Localizer["Common_SaveChanges"])</MudButton>
                        </MudStack>
                    </EditForm>
                </MudStack>
            </MudPaper>
        </div>
    }
</MudStack>

@code {
    private List<Tenant> _items = new();
    private Tenant _newTenant = new() { ScreeningCompleted = true, ScreeningProvider = "SingleKey" };
    private Tenant _editTenant = new() { ScreeningCompleted = true, ScreeningProvider = "SingleKey" };
    private string _csvInput = string.Empty;
    private string? _importResult;
    private string _searchText = string.Empty;
    private string _selectedProviderFilter = string.Empty;
    private string _selectedScoreBand = string.Empty;
    private bool _isFormPanelOpen;
    private bool _isCreateMode = true;

    private bool HasActiveFilters => !string.IsNullOrWhiteSpace(_searchText) || !string.IsNullOrWhiteSpace(_selectedProviderFilter) || !string.IsNullOrWhiteSpace(_selectedScoreBand);
    private Tenant ActiveTenant => _isCreateMode ? _newTenant : _editTenant;
    private IEnumerable<string> ProviderOptions => _items.Select(x => GetProviderLabel(x.ScreeningProvider)).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(x => x);

    private IEnumerable<Tenant> FilteredTenants => _items
        .Where(tenant => string.IsNullOrWhiteSpace(_searchText)
            || tenant.FullName.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || tenant.Email.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || tenant.PhoneNumber.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || GetProviderLabel(tenant.ScreeningProvider).Contains(_searchText, StringComparison.OrdinalIgnoreCase))
        .Where(tenant => string.IsNullOrWhiteSpace(_selectedProviderFilter) || string.Equals(GetProviderLabel(tenant.ScreeningProvider), _selectedProviderFilter, StringComparison.OrdinalIgnoreCase))
        .Where(tenant => string.IsNullOrWhiteSpace(_selectedScoreBand) || IsInScoreBand(tenant.CreditScore, _selectedScoreBand));

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync() => _items = await DataService.GetTenantsAsync();

    private void OpenCreatePanel()
    {
        _isCreateMode = true;
        _newTenant = new Tenant { ScreeningCompleted = true, ScreeningProvider = "SingleKey" };
        _isFormPanelOpen = true;
    }

    private void OpenEditPanel(Tenant tenant)
    {
        _isCreateMode = false;
        _editTenant = new Tenant
        {
            Id = tenant.Id,
            FullName = tenant.FullName,
            Email = tenant.Email,
            PhoneNumber = tenant.PhoneNumber,
            CreditScore = tenant.CreditScore,
            ScreeningCompleted = tenant.ScreeningCompleted,
            ScreeningProvider = tenant.ScreeningProvider
        };
        _isFormPanelOpen = true;
    }

    private void CloseFormPanel()
    {
        _isFormPanelOpen = false;
        _isCreateMode = true;
    }

    private async Task SaveFormAsync()
    {
        if (_isCreateMode)
        {
            await DataService.AddTenantAsync(_newTenant);
            _newTenant = new Tenant { ScreeningCompleted = true, ScreeningProvider = "SingleKey" };
        }
        else
        {
            await DataService.UpdateTenantAsync(_editTenant);
            _editTenant = new Tenant { ScreeningCompleted = true, ScreeningProvider = "SingleKey" };
        }

        await ReloadAsync();
        CloseFormPanel();
    }

    private async Task DeleteAsync(Guid id)
    {
        await DataService.DeleteTenantAsync(id);
        await ReloadAsync();
    }

    private void ClearFilters()
    {
        _searchText = string.Empty;
        _selectedProviderFilter = string.Empty;
        _selectedScoreBand = string.Empty;
    }

    private async Task ImportCsvAsync()
    {
        var imported = 0;
        var skipped = 0;
        var lines = _csvInput.Split(new[] { "\r\n", "\n" }, StringSplitOptions.RemoveEmptyEntries);
        foreach (var line in lines)
        {
            var parts = line.Split(',');
            if (parts.Length < 5)
            {
                skipped++;
                continue;
            }

            var fullName = parts[0].Trim();
            var email = parts[1].Trim();
            var phone = parts[2].Trim();
            var provider = parts[4].Trim();
            if (string.IsNullOrWhiteSpace(fullName) || string.IsNullOrWhiteSpace(email) || !int.TryParse(parts[3], out var score))
            {
                skipped++;
                continue;
            }

            if (_items.Any(x => string.Equals(x.Email, email, StringComparison.OrdinalIgnoreCase)))
            {
                skipped++;
                continue;
            }

            await DataService.AddTenantAsync(new Tenant
            {
                FullName = fullName,
                Email = email,
                PhoneNumber = phone,
                CreditScore = score,
                ScreeningCompleted = true,
                ScreeningProvider = string.IsNullOrWhiteSpace(provider) ? "SingleKey" : provider
            });
            imported++;
        }

        _csvInput = string.Empty;
        await ReloadAsync();
        _importResult = string.Format(Localizer["Tenants_ImportResult"].Value, imported, skipped);
    }

    private string GetAverageScoreLabel()
    {
        var tenants = FilteredTenants.ToList();
        return tenants.Count == 0 ? "0" : Math.Round(tenants.Average(x => x.CreditScore), 0).ToString();
    }

    private string GetProviderLabel(string provider)
        => string.IsNullOrWhiteSpace(provider) ? Localizer["Tenants_Unspecified"].Value : provider;

    private static Color GetScoreColor(int creditScore)
        => creditScore switch
        {
            >= 750 => Color.Success,
            >= 700 => Color.Warning,
            _ => Color.Error
        };

    private bool IsInScoreBand(int creditScore, string scoreBand)
        => scoreBand switch
        {
            "750+" => creditScore >= 750,
            "700-749" => creditScore >= 700 && creditScore < 750,
            var under700 when string.Equals(under700, Localizer["Tenants_ScoreBandUnder700"].Value, StringComparison.OrdinalIgnoreCase) => creditScore < 700,
            _ => true
        };

    private string GetTenantScoreNarrative(Tenant tenant)
        => tenant.CreditScore switch
        {
            >= 750 => Localizer["Tenants_NarrativeStrong"].Value,
            >= 700 => Localizer["Tenants_NarrativeSolid"].Value,
            _ => Localizer["Tenants_NarrativeNeedsReview"].Value
        };

    private string GetFormGuidance()
    {
        if (!ActiveTenant.ScreeningCompleted)
        {
            return Localizer["Tenants_GuidanceScreeningIncomplete"].Value;
        }

        return ActiveTenant.CreditScore >= 750
            ? Localizer["Tenants_GuidanceStrongProfile"].Value
            : Localizer["Tenants_GuidanceCoordinateLeaseSteps"].Value;
    }
}
