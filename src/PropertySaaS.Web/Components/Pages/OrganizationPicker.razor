@attribute [Authorize]
@page "/onboarding/organization-picker"
@page "/superadmin/select-organization"
@inject SaasDataService DataService
@inject CurrentOrganization CurrentOrganization
@inject NavigationManager NavigationManager
@using PropertySaaS.Web.Localization

<PageTitle>@UiText.Get("OrganizationPicker_PageTitle")</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="px-0">
    <MudStack Spacing="3">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h4">@(CurrentOrganization.IsSuperAdmin ? UiText.Get("SuperAdmin_SelectOrganizationTitle") : UiText.Get("OrganizationPicker_Title"))</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">@(CurrentOrganization.IsSuperAdmin ? UiText.Get("SuperAdmin_SelectOrganizationHelp") : UiText.Get("OrganizationPicker_Subtitle"))</MudText>
        </MudStack>

        @foreach (var option in _options)
        {
            <MudPaper Class="pa-4 marketing-card" Elevation="0">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                    <div>
                        <MudText Typo="Typo.h6">@option.OrganizationName</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@option.Role</MudText>
                    </div>
                    <form method="get" action="/organizations/select">
                        <input type="hidden" name="organizationId" value="@option.OrganizationId" />
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">@UiText.Get("OrganizationPicker_Continue")</MudButton>
                    </form>
                </MudStack>
            </MudPaper>
        }

        @if (!CurrentOrganization.IsSuperAdmin)
        {
        <MudPaper Class="pa-4 marketing-card" Elevation="0">
            <MudText Typo="Typo.h6">@UiText.Get("OrganizationPicker_CreateNewTitle")</MudText>
            <MudText Typo="Typo.body2" Class="mb-4">@UiText.Get("OrganizationPicker_CreateNewHelp")</MudText>
            <MudButton Href="/onboarding" Variant="Variant.Outlined" Color="Color.Primary">@UiText.Get("OrganizationPicker_CreateNewCta")</MudButton>
        </MudPaper>
        }
    </MudStack>
</MudContainer>

@code {
    private List<OrganizationAccessOptionDto> _options = new();

    protected override async Task OnInitializedAsync()
    {
        if (CurrentOrganization.HasOrganizationAccess && !CurrentOrganization.IsSuperAdmin)
        {
            NavigationManager.NavigateTo("/dashboard");
            return;
        }

        if (CurrentOrganization.IsSuperAdmin)
        {
            _options = (await DataService.GetSuperAdminOrganizationsAsync())
                .Select(option => new OrganizationAccessOptionDto
                {
                    OrganizationId = option.OrganizationId,
                    OrganizationName = option.OrganizationName,
                    IsDemo = option.IsDemo,
                    Role = "SuperAdmin",
                    Status = "Active"
                })
                .ToList();
        }
        else
        {
            _options = await DataService.GetAccessibleOrganizationsAsync();
        }

        if (_options.Count <= 1 && !CurrentOrganization.IsSuperAdmin)
        {
            NavigationManager.NavigateTo("/onboarding");
        }
    }
}
