@inherits LayoutComponentBase
@using Runtira.Application.Common
@inject CurrentOrganization CurrentOrganization

<div class="page">
    <main>
        <div class="top-row px-4">
            <a class="brand-block brand-link" href="@GetWorkspaceHomeHref()">
                <span class="brand-mark">R</span>
                <div>
                    <strong>Runtira</strong>
                    <div class="brand-subtitle">@RuntiraText.Get("Brand_Subtitle", CurrentOrganization.PreferredLanguage)</div>
                </div>
            </a>

            <div class="top-row-actions">
                <NavMenu />
                <AuthorizeView>
                    <Authorized>
                        <a class="top-nav-link provider-link" href="/account">Account</a>
                    </Authorized>
                    <NotAuthorized>
                        <a class="top-nav-link provider-link" href="/sign-in">Sign in</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>

        <article class="content-shell px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    @RuntiraText.Get("Error_Subtitle", CurrentOrganization.PreferredLanguage)
    <a href="." class="reload">@RuntiraText.Get("Reconnect_Retry", CurrentOrganization.PreferredLanguage)</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private string GetWorkspaceHomeHref()
        => string.IsNullOrWhiteSpace(CurrentOrganization.OrganizationSlug)
            ? "/"
            : string.IsNullOrWhiteSpace(CurrentOrganization.PropertySlug)
                ? $"/{CurrentOrganization.OrganizationSlug}"
                : $"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}";
}
