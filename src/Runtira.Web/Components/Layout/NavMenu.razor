@using Runtira.Application.Common
@inject CurrentOrganization CurrentOrganization

<nav class="top-nav">
    @if (!CurrentOrganization.IsAuthenticated)
    {
        <NavLink class="top-nav-link" href="/demo">Demo</NavLink>
        <NavLink class="top-nav-link nav-priority-link" href="/sign-up">Créer un compte</NavLink>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(CurrentOrganization.OrganizationSlug))
        {
            <NavLink class="top-nav-link nav-priority-link" href="@BuildWorkspaceHref("dashboard")">Espace</NavLink>
            <NavLink class="top-nav-link" href="@BuildWorkspaceHref("billing")">Facturation</NavLink>
        }

        @if (CurrentOrganization.IsSuperAdmin)
        {
            <NavLink class="top-nav-link" href="/organizations">Espaces</NavLink>
        }
    }
</nav>

@code {
    private string BuildWorkspaceHref(string leaf)
    {
        if (string.IsNullOrWhiteSpace(CurrentOrganization.OrganizationSlug))
        {
            return "/";
        }

        return string.IsNullOrWhiteSpace(CurrentOrganization.PropertySlug)
            ? $"/{CurrentOrganization.OrganizationSlug}/{leaf}"
            : $"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/{leaf}";
    }
}

