@page "/{tenantSlug}/exports"
@page "/{tenantSlug}/{propertySlug}/exports"
@using Runtira.Application.Common
@using Runtira.Application.Features
@inject CurrentOrganization CurrentOrganization
@inject RuntiraWorkspaceService WorkspaceService

<PageTitle>@RuntiraText.Get("Nav_Exports", CurrentOrganization.PreferredLanguage)</PageTitle>

<div class="hero-shell">
    <section class="hero-card">
        <div class="hero-badge">@RuntiraText.Get("Exports_Badge", CurrentOrganization.PreferredLanguage)</div>
        <h1>@RuntiraText.Get("Exports_Title", CurrentOrganization.PreferredLanguage)</h1>
        <p class="hero-copy">@RuntiraText.Get("Exports_Subtitle", CurrentOrganization.PreferredLanguage)</p>

        @if (_isLoading)
        {
            <PageLoadingState />
        }
        else if (_workspace is not null)
        {
            <div class="tenant-summary">
                <div>
                    <span class="summary-label">@RuntiraText.Get("Imports_Summary_Region", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_workspace.ActiveRegion</strong>
                </div>
                <div>
                    <span class="summary-label">@RuntiraText.Get("Imports_Summary_Language", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_workspace.ActiveLanguage</strong>
                </div>
                <div>
                    <span class="summary-label">@RuntiraText.Get("Exports_Summary_Formats", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_workspace.Options.Count</strong>
                </div>
                <div>
                    <span class="summary-label">@RuntiraText.Get("Exports_Summary_Destinations", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@string.Join(" · ", _workspace.SupportedDestinations)</strong>
                </div>
            </div>

            <SectionToolbar Hint="@RuntiraText.Get("Exports_ResultsHint", CurrentOrganization.PreferredLanguage)">
                <Actions>
                    <a class="ghost-button" href="@($"/{CurrentOrganization.OrganizationSlug}")">@RuntiraText.Get("Exports_BackHome", CurrentOrganization.PreferredLanguage)</a>
                </Actions>
            </SectionToolbar>

            <ExplorerSection Title="@RuntiraText.Get("Exports_WorkspaceTitle", CurrentOrganization.PreferredLanguage)"
                             Hint="@RuntiraText.Get("Exports_ListHint", CurrentOrganization.PreferredLanguage)"
                             HasItems="@(_workspace.Options.Count > 0)"
                             EmptyTitle="@RuntiraText.Get("Exports_DetailEmptyTitle", CurrentOrganization.PreferredLanguage)"
                             EmptyMessage="@RuntiraText.Get("Exports_DetailEmptyBody", CurrentOrganization.PreferredLanguage)"
                             DetailEmptyTitle="@RuntiraText.Get("Exports_DetailEmptyTitle", CurrentOrganization.PreferredLanguage)"
                             DetailEmptyMessage="@RuntiraText.Get("Exports_DetailEmptyBody", CurrentOrganization.PreferredLanguage)">
                <ListContent>
                    @foreach (var option in _workspace.Options)
                    {
                        <button type="button"
                                class="@(IsSelectedExport(option.Format) ? "explorer-list-item selected" : "explorer-list-item")"
                                @onclick="() => SelectExport(option.Format)">
                            <strong>@option.Format</strong>
                            <span>@option.Audience</span>
                            <small>@option.Status</small>
                        </button>
                    }
                </ListContent>
                <DetailContent>
                    @if (SelectedExport is not null)
                    {
                        <div class="explorer-detail-stack">
                            <div class="stat-card unit-detail-card">
                                <div class="card-header-inline">
                                    <div>
                                        <span>@RuntiraText.Get("Exports_DetailTitle", CurrentOrganization.PreferredLanguage)</span>
                                        <strong>@SelectedExport.Format</strong>
                                        <p class="detail-helper-copy">@RuntiraText.Get("Assets_DetailPanelHint", CurrentOrganization.PreferredLanguage)</p>
                                    </div>
                                </div>

                                <div class="tenant-summary unit-detail-summary">
                                    <div>
                                        <span class="summary-label">@RuntiraText.Get("Exports_Audience", CurrentOrganization.PreferredLanguage)</span>
                                        <strong>@SelectedExport.Audience</strong>
                                    </div>
                                    <div>
                                        <span class="summary-label">@RuntiraText.Get("Exports_Status", CurrentOrganization.PreferredLanguage)</span>
                                        <strong>@SelectedExport.Status</strong>
                                    </div>
                                    <div>
                                        <span class="summary-label">@RuntiraText.Get("Imports_Summary_Region", CurrentOrganization.PreferredLanguage)</span>
                                        <strong>@_workspace.ActiveRegion</strong>
                                    </div>
                                    <div>
                                        <span class="summary-label">@RuntiraText.Get("Imports_Summary_Language", CurrentOrganization.PreferredLanguage)</span>
                                        <strong>@_workspace.ActiveLanguage</strong>
                                    </div>
                                </div>

                                <div class="draft-box">
                                    <strong>@RuntiraText.Get("Exports_DetailDeliveryTitle", CurrentOrganization.PreferredLanguage)</strong>
                                    <p class="detail-summary-copy">@SelectedExport.Summary</p>
                                    <div class="option-list">
                                        @foreach (var destination in _workspace.SupportedDestinations)
                                        {
                                            <span class="option-pill">@destination</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </DetailContent>
            </ExplorerSection>
        }
    </section>

    <section class="workspace-card">
        <div class="workspace-header">
            <h2>@RuntiraText.Get("Exports_WorkspaceTitle", CurrentOrganization.PreferredLanguage)</h2>
            <span class="workspace-state">@RuntiraText.Get("Common_Preview", CurrentOrganization.PreferredLanguage)</span>
        </div>

        <div class="workspace-grid">
            <div class="workspace-panel">
                <h3>@RuntiraText.Get("Exports_Panel_Standard", CurrentOrganization.PreferredLanguage)</h3>
                <div class="option-list">
                    <span class="option-pill option-pill-accent">Excel</span>
                    <span class="option-pill option-pill-accent">PDF</span>
                    <span class="option-pill">CSV</span>
                    <span class="option-pill">Word</span>
                </div>
            </div>
            <div class="workspace-panel">
                <h3>@RuntiraText.Get("Exports_Panel_Delivery", CurrentOrganization.PreferredLanguage)</h3>
                <div class="option-list">
                    @foreach (var destination in _workspace?.SupportedDestinations ?? Array.Empty<string>())
                    {
                        <span class="option-pill">@destination</span>
                    }
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(CurrentOrganization.OrganizationSlug))
            {
                <div class="localized-section">
                    <div class="prompt-title">@RuntiraText.Get("Exports_DownloadsTitle", CurrentOrganization.PreferredLanguage)</div>
                    <div class="prompt-box">
                        <a class="prompt-chip prompt-link" href="@($"/{CurrentOrganization.OrganizationSlug}/exports/leads.csv")">@RuntiraText.Get("Exports_DownloadLeadsCsv", CurrentOrganization.PreferredLanguage)</a>
                    </div>
                </div>
            }
        </div>
    </section>
</div>

@code {
    [Parameter]
    public string? TenantSlug { get; set; }

    [Parameter]
    public string? PropertySlug { get; set; }

    private RuntiraExportWorkspaceDto? _workspace;
    private bool _isLoading = true;
    private bool _hasInitialized;
    private string? _selectedExportFormat;

    private RuntiraExportOptionDto? SelectedExport => _workspace?.Options.FirstOrDefault(x => string.Equals(x.Format, _selectedExportFormat, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        if (_hasInitialized)
        {
            return;
        }

        _hasInitialized = true;

        try
        {
            _workspace = await WorkspaceService.GetExportWorkspaceAsync();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void SelectExport(string format)
        => _selectedExportFormat = format;

    private bool IsSelectedExport(string format)
        => string.Equals(_selectedExportFormat, format, StringComparison.OrdinalIgnoreCase);
}
