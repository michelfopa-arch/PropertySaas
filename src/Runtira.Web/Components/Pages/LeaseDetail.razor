@page "/{tenantSlug}/{propertySlug}/leases/{leaseId:guid}"
@using Runtira.Application.Common
@using Runtira.Application.Features
@using Runtira.Web.Components.Shared
@inject CurrentOrganization CurrentOrganization
@inject RuntiraWorkspaceService WorkspaceService

<PageTitle>@(_lease is null ? "Lease" : GetLeaseTitle(_lease)) · @CurrentOrganization.PropertyName</PageTitle>

<div class="hero-shell">
    <section class="hero-card">
        <div class="hero-badge">Lease</div>

        <BusyOverlay IsVisible="@_isSubmittingAction" Label="Mise à jour" Message="Application de l’action sur le bail." />

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <PageEmptyState Title="@_statusMessage" CssClass="inline-status" />
        }

        @if (_isLoading)
        {
            <PageLoadingState />
        }
        else if (_lease is not null)
        {
            <div class="card-header-inline">
                <div>
                    <h1>@GetLeaseTitle(_lease)</h1>
                    <p class="hero-copy">@_lease.ResidentName · @_workspace?.AssetName</p>
                </div>
                <span class="@EntityStatusPresenter.LeasePaymentCss(_lease.Status)">@EntityStatusPresenter.LeasePaymentLabel(_lease.Status)</span>
            </div>

            <SectionToolbar Hint="Fiche complète du bail, avec le résident lié et ses actions.">
                <Actions>
                    <a class="ghost-button" href="@GetBackToLeasesHref()">Back to leases</a>
                </Actions>
            </SectionToolbar>

            <div class="tenant-summary unit-detail-summary">
                <div>
                    <span class="summary-label">Loyer mensuel</span>
                    <strong>@_lease.MonthlyRent.ToString("C")</strong>
                </div>
                <div>
                    <span class="summary-label">Période</span>
                    <strong>@_lease.BillingPeriod</strong>
                </div>
                <div>
                    <span class="summary-label">Résident</span>
                    <strong>@_lease.ResidentName</strong>
                </div>
                <div>
                    <span class="summary-label">Unité</span>
                    <strong>@(string.IsNullOrWhiteSpace(_lease.UnitCode) ? "Propriété entière" : _lease.UnitCode)</strong>
                </div>
            </div>

            @if (CurrentOrganization.CanManageData)
            {
                <StandardActionMenu MenuLabel="Actions"
                                     Title="Gérer le bail"
                                     Items="@GetLeaseActionItems()"
                                     IsBusy="@_isSubmittingAction"
                                     OnAction="@(action => HandleLeaseActionAsync(action))" />
            }

            @if (_ledger is not null)
            {
                <div class="localized-section">
                    <div class="prompt-title">Historique de paiement (Rent Ledger)</div>
                    <div class="tenant-summary unit-detail-summary">
                        <div>
                            <span class="summary-label">Payés</span>
                            <strong class="ledger-count-paid">@_ledger.PaidCount</strong>
                        </div>
                        <div>
                            <span class="summary-label">En retard</span>
                            <strong class="ledger-count-late">@_ledger.LateCount</strong>
                        </div>
                        <div>
                            <span class="summary-label">À venir</span>
                            <strong>@_ledger.PendingCount</strong>
                        </div>
                        <div>
                            <span class="summary-label">Solde impayé</span>
                            <strong>@_ledger.OutstandingBalance.ToString("C")</strong>
                        </div>
                    </div>

                    <div class="ledger-list">
                        @foreach (var entry in _ledger.Entries)
                        {
                            <div class="ledger-row">
                                <span class="ledger-month">@entry.PeriodMonthUtc.ToString("MMMM yyyy")</span>
                                <span class="ledger-amount">@entry.AmountDue.ToString("C")</span>
                                <span class="@GetLedgerStatusCss(entry.Status)">@GetLedgerStatusLabel(entry.Status)</span>
                                @if (CurrentOrganization.CanManageData)
                                {
                                    @if (string.Equals(entry.Status, "Paid", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <button type="button" class="ghost-button ledger-action" disabled="@_isSubmittingLedgerAction" @onclick='() => ToggleRentPaymentAsync(entry.PeriodMonthUtc, "markUnpaid")'>Annuler</button>
                                    }
                                    else
                                    {
                                        <button type="button" class="ghost-button ledger-action ledger-action-accent" disabled="@_isSubmittingLedgerAction" @onclick='() => ToggleRentPaymentAsync(entry.PeriodMonthUtc, "markPaid")'>Marquer payé</button>
                                    }
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            @if (_resident is not null)
            {
                <div class="draft-box">
                    <strong>Résident lié</strong>
                    <div>@_resident.FullName</div>
                    <div>@_resident.Email</div>
                    <div>Langue préférée · @_resident.PreferredLanguage</div>
                    <div>Statut · @EntityStatusPresenter.ResidentStatusLabel(_resident.Status)</div>
                </div>
            }

            @if (_lease.ComplianceData?.Fields is { Count: > 0 } fields)
            {
                <FlexibleContextCard Title="Détails du bail" Fields="@fields" />
            }
        }
        else
        {
            <PageEmptyState Title="Bail introuvable" Message="Ce bail n’existe plus ou a été supprimé.">
                <a class="ghost-button" href="@GetBackToLeasesHref()">Back to leases</a>
            </PageEmptyState>
        }
    </section>

    <QuickLinksPanel Actions="@GetQuickActions()" AiPrompts="@GetAiPrompts()" />
</div>

@code {
    [Parameter]
    public string? TenantSlug { get; set; }

    [Parameter]
    public string? PropertySlug { get; set; }

    [Parameter]
    public Guid LeaseId { get; set; }

    private RuntiraAssetWorkspaceDto? _workspace;
    private RuntiraLeaseSummaryDto? _lease;
    private RuntiraResidentSummaryDto? _resident;
    private RuntiraRentLedgerDto? _ledger;
    private bool _isLoading = true;
    private string? _loadedPropertySlug;
    private bool _isSubmittingAction;
    private bool _isSubmittingLedgerAction;
    private string? _statusMessage;

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrWhiteSpace(TenantSlug))
        {
            CurrentOrganization.OrganizationSlug = TenantSlug;
        }

        if (!string.IsNullOrWhiteSpace(PropertySlug))
        {
            CurrentOrganization.PropertySlug = PropertySlug;
        }

        if (_workspace is not null && string.Equals(_loadedPropertySlug, CurrentOrganization.PropertySlug, StringComparison.OrdinalIgnoreCase))
        {
            await RefreshSelectedLeaseAsync();
            return;
        }

        _isLoading = true;
        try
        {
            _workspace = await WorkspaceService.GetAssetWorkspaceAsync();
            if (_workspace is not null)
            {
                CurrentOrganization.PropertyName = _workspace.AssetName;
            }

            _loadedPropertySlug = CurrentOrganization.PropertySlug;
            await RefreshSelectedLeaseAsync();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task RefreshSelectedLeaseAsync()
    {
        _lease = _workspace?.Leases.FirstOrDefault(x => x.Id == LeaseId);
        _resident = _lease is null ? null : _workspace?.Residents.FirstOrDefault(x => string.Equals(x.FullName, _lease.ResidentName, StringComparison.OrdinalIgnoreCase));
        _ledger = _lease is null ? null : await WorkspaceService.GetRentLedgerAsync(_lease.Id);
    }

    private string GetBackToLeasesHref()
        => $"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/leases";

    private string GetPropertyLeafHref(string leaf)
        => $"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/{leaf}";

    private string GetInvoiceHref(int monthOffset)
        => $"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/leases/{LeaseId}/invoice.pdf?monthOffset={monthOffset}";

    private static string GetLeaseTitle(RuntiraLeaseSummaryDto lease)
        => string.IsNullOrWhiteSpace(lease.UnitCode) ? lease.ResidentName : $"Unit {lease.UnitCode}";

    private List<QuickLinkAction> GetQuickActions()
    {
        var actions = new List<QuickLinkAction>();
        if (_lease is null)
        {
            return actions;
        }

        actions.Add(new QuickLinkAction("Imprimer la facture du mois précédent", GetInvoiceHref(-1), Target: "_blank"));
        actions.Add(new QuickLinkAction("Imprimer la facture du mois courant", GetInvoiceHref(0), IsAccent: true, Target: "_blank"));
        actions.Add(new QuickLinkAction("Imprimer la facture du mois suivant", GetInvoiceHref(1), Target: "_blank"));
        actions.Add(new QuickLinkAction("Composer une facture avancée", GetPropertyLeafHref("invoice-composer")));

        if (!string.IsNullOrWhiteSpace(_lease.UnitCode))
        {
            actions.Add(new QuickLinkAction("Voir l’unité de ce bail", GetPropertyLeafHref("units")));
        }

        if (_resident is not null)
        {
            actions.Add(new QuickLinkAction("Voir la fiche du résident", $"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/residents/{_resident.Id}"));
        }

        actions.Add(new QuickLinkAction("Voir les leads de cette propriété", GetPropertyLeafHref("leads")));
        actions.Add(new QuickLinkAction("Voir tous les baux", GetPropertyLeafHref("leases")));
        return actions;
    }

    private List<AiPromptSuggestion> GetAiPrompts()
    {
        var prompts = new List<AiPromptSuggestion>();
        if (_lease is null)
        {
            return prompts;
        }

        prompts.Add(new AiPromptSuggestion(
            "Résumer ce bail pour le propriétaire",
            $"Résume en 3 phrases ce bail pour le propriétaire : résident {_lease.ResidentName}, {(string.IsNullOrWhiteSpace(_lease.UnitCode) ? "propriété entière" : $"unité {_lease.UnitCode}")}, loyer {_lease.MonthlyRent:C} ({_lease.BillingPeriod}), statut {_lease.Status}, du {_lease.LeaseStartUtc:MMM d, yyyy} au {(_lease.LeaseEndUtc.HasValue ? _lease.LeaseEndUtc.Value.ToString("MMM d, yyyy") : "indéterminé")}."));

        if (string.Equals(_lease.Status, "Review", StringComparison.OrdinalIgnoreCase))
        {
            prompts.Add(new AiPromptSuggestion(
                "Rédiger un message de suivi",
                $"Rédige un message professionnel à {_lease.ResidentName} pour clarifier le statut « à vérifier » de son bail (loyer {_lease.MonthlyRent:C}), en demandant les informations manquantes."));
        }

        if (_lease.LeaseEndUtc.HasValue && _lease.LeaseEndUtc.Value <= DateTime.UtcNow.AddDays(60))
        {
            prompts.Add(new AiPromptSuggestion(
                "Préparer un avis de renouvellement",
                $"Rédige un avis de renouvellement de bail pour {_lease.ResidentName}, échéance le {_lease.LeaseEndUtc.Value:MMM d, yyyy}, loyer actuel {_lease.MonthlyRent:C}."));
        }

        return prompts;
    }

    private IReadOnlyList<StandardActionMenuItem> GetLeaseActionItems()
        =>
        [
            new StandardActionMenuItem(
                "markReview",
                "Marquer à vérifier",
                _lease is null || string.Equals(_lease.Status, "Review", StringComparison.OrdinalIgnoreCase),
                "Le bail passe en statut à vérifier."),
            new StandardActionMenuItem(
                "markActive",
                "Marquer actif",
                _lease is null || string.Equals(_lease.Status, "Active", StringComparison.OrdinalIgnoreCase),
                "Le bail redevient actif (loyer à jour.)")
        ];

    private async Task HandleLeaseActionAsync(string action)
    {
        if (_isSubmittingAction || _lease is null)
        {
            return;
        }

        _isSubmittingAction = true;
        _statusMessage = null;

        try
        {
            var result = await WorkspaceService.ManageLeaseAsync(_lease.Id, action);
            _statusMessage = result.ResultCode switch
            {
                "Updated" => $"Bail {result.UnitCode} mis à jour · {result.LeaseStatus}.",
                "LeaseNotFound" => "Bail introuvable.",
                _ => "Action indisponible."
            };

            _workspace = await WorkspaceService.GetAssetWorkspaceAsync();
            await RefreshSelectedLeaseAsync();
        }
        finally
        {
            _isSubmittingAction = false;
        }
    }

    private async Task ToggleRentPaymentAsync(DateTime periodMonthUtc, string action)
    {
        if (_isSubmittingLedgerAction || _lease is null)
        {
            return;
        }

        _isSubmittingLedgerAction = true;

        try
        {
            await WorkspaceService.MarkRentPaymentAsync(_lease.Id, periodMonthUtc, action);
            _ledger = await WorkspaceService.GetRentLedgerAsync(_lease.Id);
        }
        finally
        {
            _isSubmittingLedgerAction = false;
        }
    }

    private static string GetLedgerStatusLabel(string status)
        => status switch
        {
            "Paid" => "Payé",
            "Late" => "En retard",
            _ => "À venir"
        };

    private static string GetLedgerStatusCss(string status)
        => status switch
        {
            "Paid" => "status-pill status-pill-success",
            "Late" => "status-pill status-pill-danger",
            _ => "status-pill status-pill-muted"
        };
}
