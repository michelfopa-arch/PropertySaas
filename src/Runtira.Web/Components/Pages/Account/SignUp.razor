@page "/sign-up"
@inject NavigationManager NavigationManager

<PageTitle>@RuntiraText.Get("Nav_SignUp")</PageTitle>

<div class="hero-shell auth-shell">
    <section class="hero-card">
        <div class="hero-badge">@RuntiraText.Get("Badge_Clerk")</div>
        <h1>Créer mon compte</h1>
        <p class="hero-copy">
            Commence simplement avec un compte, puis ajoute ta première propriété au moment opportun.
        </p>

        <div class="prompt-box">
            <a class="prompt-chip prompt-link" href="@SignUpHref">Créer mon compte</a>
            <a class="prompt-chip prompt-link" href="/demo">Jouer la démo</a>
        </div>
    </section>

    <section class="workspace-card">
        <div class="workspace-header">
            <h2>Essai simple</h2>
            <span class="workspace-state">Prêt</span>
        </div>

        <div class="option-list">
            <span class="option-pill option-pill-accent">14 days free</span>
            <span class="option-pill">Créer un compte</span>
            <span class="option-pill">Ajouter une propriété</span>
        </div>
    </section>
</div>

@code {
    private string SignUpHref => BuildHref("/account/sign-up");
    private string BuildHref(string basePath)
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (!query.TryGetValue("invitation", out var invitation) || string.IsNullOrWhiteSpace(invitation))
        {
            return basePath;
        }

        return $"{basePath}?invitation={Uri.EscapeDataString(invitation!)}";
    }
}
