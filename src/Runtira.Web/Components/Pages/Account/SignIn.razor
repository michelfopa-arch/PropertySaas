@page "/sign-in"
@inject NavigationManager NavigationManager

<PageTitle>@RuntiraText.Get("Nav_SignIn")</PageTitle>

<div class="hero-shell auth-shell">
    <section class="hero-card">
        <div class="hero-badge">@RuntiraText.Get("Badge_Clerk")</div>
        <h1>@RuntiraText.Get("SignIn_Title")</h1>
        <p class="hero-copy">
            @RuntiraText.Get("SignIn_Subtitle")
        </p>

        <div class="prompt-box">
            <a class="prompt-chip prompt-link" href="@LoginHref">@RuntiraText.Get("SignIn_Action")</a>
            <a class="prompt-chip prompt-link" href="/demo">Play the demo</a>
        </div>

        <div class="prompt-box prompt-box-soft mt-3">
            <div class="prompt-title">Mock access</div>
            <a class="prompt-chip prompt-link" href="/mock-login?mockRole=superadmin">Enter as super admin</a>
            <a class="prompt-chip prompt-link" href="/mock-login?mockRole=owner">Enter as owner</a>
            <a class="prompt-chip prompt-link" href="/mock-login?mockRole=manager">Enter as manager</a>
            <a class="prompt-chip prompt-link" href="/mock-login?mockRole=viewer">Enter as viewer</a>
        </div>
    </section>

    <section class="workspace-card">
        <div class="workspace-header">
            <h2>@RuntiraText.Get("SignIn_ProvidersTitle")</h2>
            <span class="workspace-state">@RuntiraText.Get("Common_Ready")</span>
        </div>

        <div class="option-list">
            <span class="option-pill option-pill-accent">Super admin</span>
            <span class="option-pill">Owner</span>
            <span class="option-pill">Manager</span>
            <span class="option-pill">Viewer</span>
        </div>
    </section>
</div>

@code {
    private string LoginHref => BuildHref("/account/login");
    private string BuildHref(string basePath)
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (!query.TryGetValue("invitation", out var invitation) || string.IsNullOrWhiteSpace(invitation))
        {
            return basePath;
        }

        return $"{basePath}?invitation={Uri.EscapeDataString(invitation!)}";
    }
}
