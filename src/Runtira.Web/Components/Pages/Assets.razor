@page "/{tenantSlug}/assets"
@using Runtira.Application.Common
@using Runtira.Application.Features
@inject CurrentOrganization CurrentOrganization
@inject RuntiraWorkspaceService WorkspaceService

<PageTitle>@RuntiraText.Get("Nav_Assets", CurrentOrganization.PreferredLanguage)</PageTitle>

<div class="hero-shell">
    <section class="hero-card">
        <div class="hero-badge">@RuntiraText.Get("Assets_Badge", CurrentOrganization.PreferredLanguage)</div>
        <h1>@RuntiraText.Get("Assets_Title", CurrentOrganization.PreferredLanguage)</h1>
        <p class="hero-copy">@RuntiraText.Get("Assets_Subtitle", CurrentOrganization.PreferredLanguage)</p>

        <BusyOverlay IsVisible="@IsBusy"
                     Label="@RuntiraText.Get("Common_BusyTitle", CurrentOrganization.PreferredLanguage)"
                     Message="@RuntiraText.Get("Common_BusyMessage", CurrentOrganization.PreferredLanguage)" />

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <PageEmptyState Title="@_statusMessage" CssClass="inline-status" />
        }

        @if (_isLoading)
        {
            <PageLoadingState />
        }
        else if (_workspace is not null)
        {
            <div class="tenant-summary">
                <div>
                    <span class="summary-label">@RuntiraText.Get("Assets_Summary_Asset", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_workspace.AssetName</strong>
                </div>
                <div>
                    <span class="summary-label">@RuntiraText.Get("Assets_Summary_Address", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_workspace.AssetAddress</strong>
                </div>
                <div>
                    <span class="summary-label">@RuntiraText.Get("Assets_Summary_Units", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_workspace.Units.Count</strong>
                </div>
                <div>
                    <span class="summary-label">@RuntiraText.Get("Assets_Summary_Residents", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_workspace.TotalResidentCount</strong>
                </div>
                <div>
                    <span class="summary-label">@RuntiraText.Get("Assets_Summary_Leases", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_workspace.TotalLeaseCount</strong>
                </div>
            </div>

            <SectionToolbar Hint="@RuntiraText.Get("Assets_ResultsHint", CurrentOrganization.PreferredLanguage)">
                <Actions>
                    <a class="ghost-button" href="@($"/{CurrentOrganization.OrganizationSlug}")">@RuntiraText.Get("Assets_BackHome", CurrentOrganization.PreferredLanguage)</a>
                </Actions>
            </SectionToolbar>

            <ExplorerSection Title="@RuntiraText.Get("Assets_UnitsTitle", CurrentOrganization.PreferredLanguage)"
                             ShowSearch="true"
                             SearchLabel="@RuntiraText.Get("Assets_UnitSearchLabel", CurrentOrganization.PreferredLanguage)"
                             SearchPlaceholder="@RuntiraText.Get("Assets_UnitSearchPlaceholder", CurrentOrganization.PreferredLanguage)"
                             SearchValue="@_unitSearchTerm"
                             OnSearchInput="OnUnitSearchChanged"
                             OnSearchKeyDown="OnUnitSearchKeyDown"
                             ShowAutocomplete="@ShouldShowUnitAutocomplete()"
                             AutocompleteTitle="@RuntiraText.Get("Assets_UnitAutocompleteTitle", CurrentOrganization.PreferredLanguage)"
                             Hint="@RuntiraText.Get("Assets_ExplorerCompactHint", CurrentOrganization.PreferredLanguage)"
                             HasItems="@(GetFilteredUnits().Count > 0)"
                             EmptyTitle="@RuntiraText.Get("Assets_UnitNoMatchTitle", CurrentOrganization.PreferredLanguage)"
                             EmptyMessage="@RuntiraText.Get("Assets_UnitNoMatchBody", CurrentOrganization.PreferredLanguage)"
                             DetailEmptyTitle="@RuntiraText.Get("Explorer_SelectItemTitle", CurrentOrganization.PreferredLanguage)"
                             DetailEmptyMessage="@RuntiraText.Get("Explorer_SelectItemBody", CurrentOrganization.PreferredLanguage)">
                <MetaContent>
                    <span>@RuntiraText.Format("Assets_UnitShowing", CurrentOrganization.PreferredLanguage, GetFilteredUnits().Count, _workspace.Units.Count)</span>
                </MetaContent>
                <AutocompleteContent>
                    @foreach (var suggestion in GetUnitAutocompleteSuggestions().Select((unit, index) => new { Unit = unit, Index = index }))
                    {
                        <button type="button"
                                class="@(suggestion.Index == _unitAutocompleteIndex ? "explorer-autocomplete-item active" : "explorer-autocomplete-item")"
                                @onclick="() => SelectUnitFromAutocomplete(suggestion.Unit)">
                            <strong>@suggestion.Unit.UnitCode</strong>
                            <span>@suggestion.Unit.UnitType</span>
                            <small>@suggestion.Unit.Status</small>
                        </button>
                    }
                </AutocompleteContent>
                <ListContent>
                    @foreach (var unit in GetFilteredUnits())
                    {
                        <button type="button"
                                class="@(IsSelectedUnit(unit.Id) ? "explorer-list-item selected" : "explorer-list-item")"
                                @onclick="() => SelectUnit(unit.Id)">
                            <strong>@unit.UnitCode</strong>
                            <span>@unit.UnitType</span>
                            <small>@unit.Status</small>
                        </button>
                    }
                </ListContent>
                <DetailContent>
                    @if (HasSelectedUnit)
                    {
                        @RenderSelectedUnitDetail()
                    }
                </DetailContent>
            </ExplorerSection>

            @if (_workspace.ContextData is not null)
            {
                <FlexibleContextCard Title="@RuntiraText.Get("Assets_ContextTitle", CurrentOrganization.PreferredLanguage)"
                                     SummaryItems="@GetAssetContextSummaryItems()" />
            }

            <ExplorerSection Title="@RuntiraText.Get("Assets_LeasesTitle", CurrentOrganization.PreferredLanguage)"
                             ShowSearch="true"
                             SearchLabel="@RuntiraText.Get("Assets_LeaseSearchLabel", CurrentOrganization.PreferredLanguage)"
                             SearchPlaceholder="@RuntiraText.Get("Assets_LeaseSearchPlaceholder", CurrentOrganization.PreferredLanguage)"
                             SearchValue="@_leaseSearchTerm"
                             OnSearchInput="OnLeaseSearchChanged"
                             OnSearchKeyDown="OnLeaseSearchKeyDown"
                             ShowAutocomplete="@ShouldShowLeaseAutocomplete()"
                             AutocompleteTitle="@RuntiraText.Get("Assets_LeaseAutocompleteTitle", CurrentOrganization.PreferredLanguage)"
                             Hint="@RuntiraText.Get("Assets_ExplorerCompactHint", CurrentOrganization.PreferredLanguage)"
                             HasItems="@(GetFilteredLeases().Count > 0)"
                             EmptyTitle="@RuntiraText.Get("Assets_LeaseNoMatchTitle", CurrentOrganization.PreferredLanguage)"
                             EmptyMessage="@RuntiraText.Get("Assets_LeaseNoMatchBody", CurrentOrganization.PreferredLanguage)"
                             DetailEmptyTitle="@RuntiraText.Get("Explorer_SelectItemTitle", CurrentOrganization.PreferredLanguage)"
                             DetailEmptyMessage="@RuntiraText.Get("Explorer_SelectItemBody", CurrentOrganization.PreferredLanguage)">
                <MetaContent>
                    <span>@RuntiraText.Format("Assets_LeaseShowing", CurrentOrganization.PreferredLanguage, GetFilteredLeases().Count, _workspace.Leases.Count)</span>
                </MetaContent>
                <AutocompleteContent>
                    @foreach (var suggestion in GetLeaseAutocompleteSuggestions().Select((lease, index) => new { Lease = lease, Index = index }))
                    {
                        <button type="button"
                                class="@(suggestion.Index == _leaseAutocompleteIndex ? "explorer-autocomplete-item active" : "explorer-autocomplete-item")"
                                @onclick="() => SelectLeaseFromAutocomplete(suggestion.Lease)">
                            <strong>@suggestion.Lease.UnitCode</strong>
                            <span>@suggestion.Lease.ResidentName</span>
                            <small>@suggestion.Lease.Status</small>
                        </button>
                    }
                </AutocompleteContent>
                <ListContent>
                    @foreach (var lease in GetFilteredLeases())
                    {
                        <button type="button"
                                class="@(IsSelectedLease(lease.Id) ? "explorer-list-item selected" : "explorer-list-item")"
                                @onclick="() => SelectLease(lease.Id)">
                            <strong>@lease.UnitCode</strong>
                            <span>@lease.ResidentName</span>
                            <small>@lease.Status</small>
                        </button>
                    }
                </ListContent>
                <DetailContent>
                    @if (HasSelectedLease)
                    {
                        @RenderSelectedLeaseDetail()
                    }
                </DetailContent>
            </ExplorerSection>

            <ExplorerSection Title="@RuntiraText.Get("Assets_ResidentsTitle", CurrentOrganization.PreferredLanguage)"
                             ShowSearch="true"
                             SearchLabel="@RuntiraText.Get("Assets_ResidentSearchLabel", CurrentOrganization.PreferredLanguage)"
                             SearchPlaceholder="@RuntiraText.Get("Assets_ResidentSearchPlaceholder", CurrentOrganization.PreferredLanguage)"
                             SearchValue="@_residentSearchTerm"
                             OnSearchInput="OnResidentSearchChanged"
                             OnSearchKeyDown="OnResidentSearchKeyDown"
                             ShowAutocomplete="@ShouldShowResidentAutocomplete()"
                             AutocompleteTitle="@RuntiraText.Get("Assets_ResidentAutocompleteTitle", CurrentOrganization.PreferredLanguage)"
                             Hint="@RuntiraText.Get("Assets_ExplorerCompactHint", CurrentOrganization.PreferredLanguage)"
                             HasItems="@(GetFilteredResidents().Count > 0)"
                             EmptyTitle="@RuntiraText.Get("Assets_ResidentNoMatchTitle", CurrentOrganization.PreferredLanguage)"
                             EmptyMessage="@RuntiraText.Get("Assets_ResidentNoMatchBody", CurrentOrganization.PreferredLanguage)"
                             DetailEmptyTitle="@RuntiraText.Get("Explorer_SelectItemTitle", CurrentOrganization.PreferredLanguage)"
                             DetailEmptyMessage="@RuntiraText.Get("Explorer_SelectItemBody", CurrentOrganization.PreferredLanguage)">
                <MetaContent>
                    <span>@RuntiraText.Format("Assets_ResidentShowing", CurrentOrganization.PreferredLanguage, GetFilteredResidents().Count, _workspace.Residents.Count)</span>
                </MetaContent>
                <AutocompleteContent>
                    @foreach (var suggestion in GetResidentAutocompleteSuggestions().Select((resident, index) => new { Resident = resident, Index = index }))
                    {
                        <button type="button"
                                class="@(suggestion.Index == _residentAutocompleteIndex ? "explorer-autocomplete-item active" : "explorer-autocomplete-item")"
                                @onclick="() => SelectResidentFromAutocomplete(suggestion.Resident)">
                            <strong>@suggestion.Resident.FullName</strong>
                            <span>@suggestion.Resident.Email</span>
                            <small>@suggestion.Resident.Status</small>
                        </button>
                    }
                </AutocompleteContent>
                <ListContent>
                    @foreach (var resident in GetFilteredResidents())
                    {
                        <button type="button"
                                class="@(IsSelectedResident(resident.Id) ? "explorer-list-item selected" : "explorer-list-item")"
                                @onclick="() => SelectResident(resident.Id)">
                            <strong>@resident.FullName</strong>
                            <span>@resident.Email</span>
                            <small>@resident.Status</small>
                        </button>
                    }
                </ListContent>
                <DetailContent>
                    @if (HasSelectedResident)
                    {
                        @RenderSelectedResidentDetail()
                    }
                </DetailContent>
            </ExplorerSection>
        }
        else
        {
            <PageEmptyState Title="@RuntiraText.Get("Assets_EmptyTitle", CurrentOrganization.PreferredLanguage)"
                            Message="@RuntiraText.Get("Assets_EmptyBody", CurrentOrganization.PreferredLanguage)" />
        }
    </section>

    <section class="workspace-card">
        <div class="workspace-header">
            <h2>@RuntiraText.Get("Assets_WorkspaceTitle", CurrentOrganization.PreferredLanguage)</h2>
            <span class="workspace-state">@RuntiraText.Get("Common_Mvp", CurrentOrganization.PreferredLanguage)</span>
        </div>

        <div class="prompt-box prompt-box-soft">
            <button type="button" class="prompt-chip">@RuntiraText.Get("Assets_Action_LinkLeads", CurrentOrganization.PreferredLanguage)</button>
            <button type="button" class="prompt-chip">@RuntiraText.Get("Assets_Action_PrepareLease", CurrentOrganization.PreferredLanguage)</button>
            <button type="button" class="prompt-chip">@RuntiraText.Get("Assets_Action_SendInvoice", CurrentOrganization.PreferredLanguage)</button>
            <button type="button" class="prompt-chip">@RuntiraText.Get("Assets_Action_Archive", CurrentOrganization.PreferredLanguage)</button>
        </div>
    </section>
</div>

@code {
    [Parameter]
    public string? TenantSlug { get; set; }

    private RuntiraAssetWorkspaceDto? _workspace;
    private bool _isLoading = true;
    private bool _hasInitialized;
    private string? _statusMessage;
    private bool _isSubmittingUnitAction;
    private bool _isSubmittingResidentAction;
    private bool _isSubmittingLeaseAction;
    private string _unitSearchTerm = string.Empty;
    private Guid? _selectedUnitId;
    private int _unitAutocompleteIndex = -1;
    private string _leaseSearchTerm = string.Empty;
    private Guid? _selectedLeaseId;
    private int _leaseAutocompleteIndex = -1;
    private string _residentSearchTerm = string.Empty;
    private Guid? _selectedResidentId;
    private int _residentAutocompleteIndex = -1;

    private bool IsBusy => _isLoading || _isSubmittingUnitAction || _isSubmittingResidentAction || _isSubmittingLeaseAction;
    private RuntiraUnitSummaryDto? SelectedUnit => GetSelectedUnit();
    private RuntiraLeaseSummaryDto? SelectedUnitLinkedLease => SelectedUnit is null ? null : GetLeaseForUnit(SelectedUnit);
    private RuntiraLeaseSummaryDto? SelectedLeaseItem => GetSelectedLease();
    private RuntiraResidentSummaryDto? SelectedLeaseResident => SelectedLeaseItem is null ? null : GetResidentForLease(SelectedLeaseItem);
    private RuntiraResidentSummaryDto? SelectedResidentItem => GetSelectedResident();
    private IReadOnlyList<RuntiraLeaseSummaryDto> SelectedResidentLeases => SelectedResidentItem is null ? new List<RuntiraLeaseSummaryDto>() : GetLeasesForResident(SelectedResidentItem);
    private bool HasSelectedUnit => SelectedUnit is not null;
    private Guid SelectedUnitIdValue => SelectedUnit?.Id ?? Guid.Empty;
    private string SelectedUnitCode => SelectedUnit?.UnitCode ?? string.Empty;
    private string SelectedUnitType => SelectedUnit?.UnitType ?? string.Empty;
    private string SelectedUnitStatus => SelectedUnit?.Status ?? string.Empty;
    private decimal SelectedUnitMarketRent => SelectedUnit?.MarketRent ?? 0m;
    private bool HasSelectedUnitLinkedLease => SelectedUnitLinkedLease is not null;
    private string SelectedUnitLinkedLeaseResidentName => SelectedUnitLinkedLease?.ResidentName ?? string.Empty;
    private string SelectedUnitLinkedLeaseStatus => SelectedUnitLinkedLease?.Status ?? string.Empty;
    private string SelectedUnitLinkedLeaseBillingPeriod => SelectedUnitLinkedLease?.BillingPeriod ?? string.Empty;
    private bool HasSelectedLease => SelectedLeaseItem is not null;
    private Guid SelectedLeaseIdValue => SelectedLeaseItem?.Id ?? Guid.Empty;
    private string SelectedLeaseUnitCode => SelectedLeaseItem?.UnitCode ?? string.Empty;
    private string SelectedLeaseResidentName => SelectedLeaseItem?.ResidentName ?? string.Empty;
    private string SelectedLeaseStatus => SelectedLeaseItem?.Status ?? string.Empty;
    private string SelectedLeaseBillingPeriod => SelectedLeaseItem?.BillingPeriod ?? string.Empty;
    private decimal SelectedLeaseMonthlyRent => SelectedLeaseItem?.MonthlyRent ?? 0m;
    private IReadOnlyDictionary<string, string>? SelectedLeaseComplianceFields => SelectedLeaseItem?.ComplianceData?.Fields;
    private bool HasSelectedLeaseResident => SelectedLeaseResident is not null;
    private string SelectedLeaseResidentFullName => SelectedLeaseResident?.FullName ?? string.Empty;
    private string SelectedLeaseResidentEmail => SelectedLeaseResident?.Email ?? string.Empty;
    private string SelectedLeaseResidentPreferredLanguage => SelectedLeaseResident?.PreferredLanguage ?? string.Empty;
    private bool HasSelectedResident => SelectedResidentItem is not null;
    private Guid SelectedResidentIdValue => SelectedResidentItem?.Id ?? Guid.Empty;
    private string SelectedResidentFullName => SelectedResidentItem?.FullName ?? string.Empty;
    private string SelectedResidentEmail => SelectedResidentItem?.Email ?? string.Empty;
    private string SelectedResidentPreferredLanguage => SelectedResidentItem?.PreferredLanguage ?? string.Empty;
    private string SelectedResidentStatus => SelectedResidentItem?.Status ?? string.Empty;
    private IReadOnlyDictionary<string, string>? SelectedResidentProfileFields => SelectedResidentItem?.ProfileData?.Fields;

    private IReadOnlyList<FlexibleContextSummaryItem> GetAssetContextSummaryItems()
        => _workspace?.ContextData is null
            ? Array.Empty<FlexibleContextSummaryItem>()
            : new[]
            {
                new FlexibleContextSummaryItem(RuntiraText.Get("Assets_ContextMarket", CurrentOrganization.PreferredLanguage), _workspace.ContextData.Market),
                new FlexibleContextSummaryItem(RuntiraText.Get("Assets_ContextSource", CurrentOrganization.PreferredLanguage), _workspace.ContextData.Source),
                new FlexibleContextSummaryItem(RuntiraText.Get("Assets_ContextMultiUnit", CurrentOrganization.PreferredLanguage), _workspace.ContextData.SupportsMultiUnit.ToString())
            };

    private RenderFragment RenderSelectedUnitDetail() => __builder =>
    {
        if (SelectedUnit is null)
        {
            return;
        }

        var unit = SelectedUnit;
        var linkedLease = SelectedUnitLinkedLease;
        var sequence = 0;

        __builder.OpenElement(sequence++, "div");
        __builder.AddAttribute(sequence++, "class", "stat-card unit-detail-card");
        __builder.AddMarkupContent(sequence++, $@"
<div class=""card-header-inline"">
    <div>
        <span>{RuntiraText.Get("Assets_UnitDetailsTitle", CurrentOrganization.PreferredLanguage)}</span>
        <strong>{unit.UnitCode}</strong>
        <p class=""detail-helper-copy"">{RuntiraText.Get("Assets_DetailPanelHint", CurrentOrganization.PreferredLanguage)}</p>
    </div>
</div>
<div class=""tenant-summary unit-detail-summary"">
    <div><span class=""summary-label"">{RuntiraText.Get("Assets_UnitType", CurrentOrganization.PreferredLanguage)}</span><strong>{unit.UnitType}</strong></div>
    <div><span class=""summary-label"">{RuntiraText.Get("Assets_UnitStatus", CurrentOrganization.PreferredLanguage)}</span><strong>{unit.Status}</strong></div>
    <div><span class=""summary-label"">{RuntiraText.Get("Assets_UnitRent", CurrentOrganization.PreferredLanguage)}</span><strong>{unit.MarketRent}</strong></div>
    <div><span class=""summary-label"">{RuntiraText.Get("Assets_UnitNavigatorTitle", CurrentOrganization.PreferredLanguage)}</span><strong>{RuntiraText.Format("Assets_UnitNavigatorPosition", CurrentOrganization.PreferredLanguage, GetSelectedUnitIndex(unit.Id), _workspace?.Units.Count ?? 0)}</strong></div>
</div>");

        if (CurrentOrganization.CanManageData)
        {
            __builder.OpenComponent<StandardActionMenu>(sequence++);
            __builder.AddAttribute(sequence++, "MenuLabel", RuntiraText.Get("Common_Actions", CurrentOrganization.PreferredLanguage));
            __builder.AddAttribute(sequence++, "Title", RuntiraText.Get("Assets_UnitManageTitle", CurrentOrganization.PreferredLanguage));
            __builder.AddAttribute(sequence++, "Items", GetUnitActionItems(unit));
            __builder.AddAttribute(sequence++, "IsBusy", IsBusy);
            __builder.AddAttribute(sequence++, "OnAction", EventCallback.Factory.Create<string>(this, action => HandleUnitActionAsync(unit.Id, action)));
            __builder.CloseComponent();
        }

        if (linkedLease is not null)
        {
            __builder.AddMarkupContent(sequence++, $@"<div class=""draft-box""><strong>{RuntiraText.Get("Assets_UnitCurrentLeaseTitle", CurrentOrganization.PreferredLanguage)}</strong><div>{RuntiraText.Get("Assets_LeaseResident", CurrentOrganization.PreferredLanguage)} · {linkedLease.ResidentName}</div><div>{RuntiraText.Get("Assets_LeaseStatus", CurrentOrganization.PreferredLanguage)} · {linkedLease.Status}</div><div>{RuntiraText.Get("Assets_LeaseBilling", CurrentOrganization.PreferredLanguage)} · {linkedLease.BillingPeriod}</div></div>");
        }
        else
        {
            __builder.OpenComponent<PageEmptyState>(sequence++);
            __builder.AddAttribute(sequence++, "Title", RuntiraText.Get("Assets_UnitNoLeaseTitle", CurrentOrganization.PreferredLanguage));
            __builder.AddAttribute(sequence++, "Message", RuntiraText.Get("Assets_UnitNoLeaseBody", CurrentOrganization.PreferredLanguage));
            __builder.CloseComponent();
        }

        __builder.CloseElement();
    };

    private RenderFragment RenderSelectedLeaseDetail() => __builder =>
    {
        if (SelectedLeaseItem is null)
        {
            return;
        }

        var lease = SelectedLeaseItem;
        var linkedResident = SelectedLeaseResident;
        var sequence = 0;

        __builder.OpenElement(sequence++, "div");
        __builder.AddAttribute(sequence++, "class", "stat-card unit-detail-card");
        __builder.AddMarkupContent(sequence++, $@"
<div class=""card-header-inline"">
    <div>
        <span>{RuntiraText.Get("Assets_LeaseDetailsTitle", CurrentOrganization.PreferredLanguage)}</span>
        <strong>{lease.UnitCode}</strong>
        <p class=""detail-helper-copy"">{RuntiraText.Get("Assets_DetailPanelHint", CurrentOrganization.PreferredLanguage)}</p>
    </div>
</div>
<div class=""tenant-summary unit-detail-summary"">
    <div><span class=""summary-label"">{RuntiraText.Get("Assets_LeaseResident", CurrentOrganization.PreferredLanguage)}</span><strong>{lease.ResidentName}</strong></div>
    <div><span class=""summary-label"">{RuntiraText.Get("Assets_LeaseStatus", CurrentOrganization.PreferredLanguage)}</span><strong>{lease.Status}</strong></div>
    <div><span class=""summary-label"">{RuntiraText.Get("Assets_LeaseBilling", CurrentOrganization.PreferredLanguage)}</span><strong>{lease.BillingPeriod}</strong></div>
    <div><span class=""summary-label"">{RuntiraText.Get("Assets_UnitRent", CurrentOrganization.PreferredLanguage)}</span><strong>{lease.MonthlyRent}</strong></div>
    <div><span class=""summary-label"">{RuntiraText.Get("Assets_LeaseNavigatorTitle", CurrentOrganization.PreferredLanguage)}</span><strong>{RuntiraText.Format("Assets_LeaseNavigatorPosition", CurrentOrganization.PreferredLanguage, GetSelectedLeaseIndex(lease.Id), _workspace?.Leases.Count ?? 0)}</strong></div>
</div>");

        if (CurrentOrganization.CanManageData)
        {
            __builder.OpenComponent<StandardActionMenu>(sequence++);
            __builder.AddAttribute(sequence++, "MenuLabel", RuntiraText.Get("Common_Actions", CurrentOrganization.PreferredLanguage));
            __builder.AddAttribute(sequence++, "Title", RuntiraText.Get("Assets_LeaseManageTitle", CurrentOrganization.PreferredLanguage));
            __builder.AddAttribute(sequence++, "Items", GetLeaseActionItems(lease));
            __builder.AddAttribute(sequence++, "IsBusy", IsBusy);
            __builder.AddAttribute(sequence++, "OnAction", EventCallback.Factory.Create<string>(this, action => HandleLeaseActionAsync(lease.Id, action)));
            __builder.CloseComponent();
        }

        if (linkedResident is not null)
        {
            __builder.AddMarkupContent(sequence++, $@"<div class=""draft-box""><strong>{RuntiraText.Get("Assets_LeaseLinkedResidentTitle", CurrentOrganization.PreferredLanguage)}</strong><div>{linkedResident.FullName}</div><div>{linkedResident.Email}</div><div>{RuntiraText.Get("Assets_ResidentLanguage", CurrentOrganization.PreferredLanguage)} · {linkedResident.PreferredLanguage}</div></div>");
        }

        __builder.OpenComponent<FlexibleContextCard>(sequence++);
        __builder.AddAttribute(sequence++, "Fields", lease.ComplianceData?.Fields);
        __builder.CloseComponent();
        __builder.CloseElement();
    };

    private RenderFragment RenderSelectedResidentDetail() => __builder =>
    {
        if (SelectedResidentItem is null)
        {
            return;
        }

        var resident = SelectedResidentItem;
        var sequence = 0;

        __builder.OpenElement(sequence++, "div");
        __builder.AddAttribute(sequence++, "class", "stat-card unit-detail-card");
        __builder.AddMarkupContent(sequence++, $@"
<div class=""card-header-inline"">
    <div>
        <span>{RuntiraText.Get("Assets_ResidentDetailsTitle", CurrentOrganization.PreferredLanguage)}</span>
        <strong>{resident.FullName}</strong>
        <p class=""detail-helper-copy"">{RuntiraText.Get("Assets_DetailPanelHint", CurrentOrganization.PreferredLanguage)}</p>
    </div>
</div>
<div class=""tenant-summary unit-detail-summary"">
    <div><span class=""summary-label"">{RuntiraText.Get("Assets_ResidentEmail", CurrentOrganization.PreferredLanguage)}</span><strong>{resident.Email}</strong></div>
    <div><span class=""summary-label"">{RuntiraText.Get("Assets_ResidentLanguage", CurrentOrganization.PreferredLanguage)}</span><strong>{resident.PreferredLanguage}</strong></div>
    <div><span class=""summary-label"">{RuntiraText.Get("Assets_UnitStatus", CurrentOrganization.PreferredLanguage)}</span><strong>{resident.Status}</strong></div>
    <div><span class=""summary-label"">{RuntiraText.Get("Assets_ResidentNavigatorTitle", CurrentOrganization.PreferredLanguage)}</span><strong>{RuntiraText.Format("Assets_ResidentNavigatorPosition", CurrentOrganization.PreferredLanguage, GetSelectedResidentIndex(resident.Id), _workspace?.Residents.Count ?? 0)}</strong></div>
</div>");

        if (CurrentOrganization.CanManageData)
        {
            __builder.OpenComponent<StandardActionMenu>(sequence++);
            __builder.AddAttribute(sequence++, "MenuLabel", RuntiraText.Get("Common_Actions", CurrentOrganization.PreferredLanguage));
            __builder.AddAttribute(sequence++, "Title", RuntiraText.Get("Assets_ResidentManageTitle", CurrentOrganization.PreferredLanguage));
            __builder.AddAttribute(sequence++, "Items", GetResidentActionItems(resident));
            __builder.AddAttribute(sequence++, "IsBusy", IsBusy);
            __builder.AddAttribute(sequence++, "OnAction", EventCallback.Factory.Create<string>(this, action => HandleResidentActionAsync(resident.Id, action)));
            __builder.CloseComponent();
        }

        if (SelectedResidentLeases.Count > 0)
        {
            __builder.OpenElement(sequence++, "div");
            __builder.AddAttribute(sequence++, "class", "draft-box");
            __builder.AddMarkupContent(sequence++, $"<strong>{RuntiraText.Get("Assets_ResidentLinkedLeasesTitle", CurrentOrganization.PreferredLanguage)}</strong>");
            foreach (var lease in SelectedResidentLeases)
            {
                __builder.AddMarkupContent(sequence++, $"<div>{lease.UnitCode} · {lease.Status} · {lease.BillingPeriod}</div>");
            }
            __builder.CloseElement();
        }
        else
        {
            __builder.OpenComponent<PageEmptyState>(sequence++);
            __builder.AddAttribute(sequence++, "Title", RuntiraText.Get("Assets_ResidentNoLeaseTitle", CurrentOrganization.PreferredLanguage));
            __builder.AddAttribute(sequence++, "Message", RuntiraText.Get("Assets_ResidentNoLeaseBody", CurrentOrganization.PreferredLanguage));
            __builder.CloseComponent();
        }

        __builder.OpenComponent<FlexibleContextCard>(sequence++);
        __builder.AddAttribute(sequence++, "Fields", resident.ProfileData?.Fields);
        __builder.CloseComponent();
        __builder.CloseElement();
    };

    protected override async Task OnInitializedAsync()
    {
        if (_hasInitialized)
        {
            return;
        }

        _hasInitialized = true;

        try
        {
            _workspace = await WorkspaceService.GetAssetWorkspaceAsync();
            _selectedUnitId = null;
            _selectedLeaseId = null;
            _selectedResidentId = null;
        }
        finally
        {
            _isLoading = false;
        }
    }

