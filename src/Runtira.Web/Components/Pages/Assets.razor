    private async Task HandleUnitActionAsync(Guid unitId, string action)
    {
        if (_isSubmittingUnitAction)
        {
            return;
        }

        _isSubmittingUnitAction = true;
        _statusMessage = string.Empty;

        try
        {
            var result = await WorkspaceService.ManageUnitAsync(unitId, action);
            _statusMessage = result.ResultCode switch
            {
                "Updated" => RuntiraText.Format("Assets_UnitUpdated", CurrentOrganization.PreferredLanguage, result.UnitCode, result.Status),
                "Deleted" => RuntiraText.Format("Assets_UnitDeleted", CurrentOrganization.PreferredLanguage, result.UnitCode),
                "UnitHasActiveLease" => RuntiraText.Format("Assets_UnitHasActiveLease", CurrentOrganization.PreferredLanguage, result.UnitCode),
                "UnitNotFound" => RuntiraText.Get("Leads_ConvertUnitNotFound", CurrentOrganization.PreferredLanguage),
                _ => RuntiraText.Get("Assets_UnitActionUnavailable", CurrentOrganization.PreferredLanguage)
            };

            _workspace = await WorkspaceService.GetAssetWorkspaceAsync();
            if (_workspace?.Units.All(x => x.Id != _selectedUnitId) != false)
            {
                _selectedUnitId = null;
            }

            if (_workspace?.Leases.All(x => x.Id != _selectedLeaseId) != false)
            {
                _selectedLeaseId = null;
            }

            if (_workspace?.Residents.All(x => x.Id != _selectedResidentId) != false)
            {
                _selectedResidentId = null;
            }
        }
        finally
        {
            _isSubmittingUnitAction = false;
        }
    }

