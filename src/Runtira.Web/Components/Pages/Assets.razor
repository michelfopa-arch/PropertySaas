    private void OnUnitSearchChanged(ChangeEventArgs args)
    {
        _unitSearchTerm = args.Value?.ToString()?.Trim() ?? string.Empty;
            _selectedUnitId = null;
        _unitAutocompleteIndex = GetUnitAutocompleteSuggestions().Count > 0 ? 0 : -1;
    }

    private void OnUnitSearchKeyDown(KeyboardEventArgs args)
    {
        var suggestions = GetUnitAutocompleteSuggestions();
        if (suggestions.Count == 0)
        {
            _unitAutocompleteIndex = -1;
            return;
        }

        if (string.Equals(args.Key, "ArrowDown", StringComparison.OrdinalIgnoreCase))
        {
            _unitAutocompleteIndex = _unitAutocompleteIndex < suggestions.Count - 1 ? _unitAutocompleteIndex + 1 : 0;
        }
        else if (string.Equals(args.Key, "ArrowUp", StringComparison.OrdinalIgnoreCase))
        {
            _unitAutocompleteIndex = _unitAutocompleteIndex > 0 ? _unitAutocompleteIndex - 1 : suggestions.Count - 1;
        }
        else if (string.Equals(args.Key, "Enter", StringComparison.OrdinalIgnoreCase))
        {
            var targetIndex = _unitAutocompleteIndex >= 0 ? _unitAutocompleteIndex : 0;
            SelectUnitFromAutocomplete(suggestions[targetIndex]);
        }
        else if (string.Equals(args.Key, "Escape", StringComparison.OrdinalIgnoreCase))
        {
            _unitAutocompleteIndex = -1;
        }
    }

