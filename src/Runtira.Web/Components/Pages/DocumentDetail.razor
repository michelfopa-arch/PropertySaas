@page "/{tenantSlug}/{propertySlug}/documents/{documentId:guid}"
@using Runtira.Application.Common
@using Runtira.Application.Features
@using Runtira.Web.Components.Shared
@inject CurrentOrganization CurrentOrganization
@inject RuntiraWorkspaceService WorkspaceService

<PageTitle>@(_document is null ? "Document" : _document.FileName) · @CurrentOrganization.PropertyName</PageTitle>

<div class="hero-shell">
    <section class="hero-card">
        <div class="hero-badge">@RuntiraText.Get("Documents_Badge", CurrentOrganization.PreferredLanguage)</div>

        @if (_isLoading)
        {
            <PageLoadingState />
        }
        else if (_document is not null)
        {
            <BusyOverlay IsVisible="@_isSubmittingAction" Label="Mise à jour" Message="Application de l’action sur le document." />

            @if (!string.IsNullOrWhiteSpace(_statusMessage))
            {
                <PageEmptyState Title="@_statusMessage" CssClass="inline-status" />
            }

            <div class="card-header-inline">
                <div>
                    <h1>@_document.FileName</h1>
                    <p class="hero-copy">@_document.Category</p>
                </div>
                <span class="@GetStatusCss(_document.Status)">@_document.Status</span>
            </div>

            <SectionToolbar Hint="@RuntiraText.Get("Documents_ListHint", CurrentOrganization.PreferredLanguage)">
                <Actions>
                    <a class="ghost-button" href="@GetBackToDocumentsHref()">Back to documents</a>
                </Actions>
            </SectionToolbar>

            <div class="tenant-summary unit-detail-summary">
                <div>
                    <span class="summary-label">@RuntiraText.Get("Documents_Table_Category", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_document.Category</strong>
                </div>
                <div>
                    <span class="summary-label">@RuntiraText.Get("Documents_Table_Status", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_document.Status</strong>
                </div>
                <div>
                    <span class="summary-label">@RuntiraText.Get("Documents_Table_Uploaded", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_document.UploadedUtc.ToString("yyyy-MM-dd HH:mm")</strong>
                </div>
                <div>
                    <span class="summary-label">@RuntiraText.Get("Documents_Table_Size", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@($"{_document.SizeBytes / 1024.0:0.#} Ko")</strong>
                </div>
            </div>

            @if (CurrentOrganization.CanManageData)
            {
                <StandardActionMenu MenuLabel="Actions"
                                     Title="Gérer le document"
                                     Items="@GetDocumentActionItems()"
                                     IsBusy="@_isSubmittingAction"
                                     OnAction="@(action => HandleDocumentActionAsync(action))" />
            }
        }
        else
        {
            <PageEmptyState Title="Document introuvable" Message="Ce document n’existe plus ou a été supprimé.">
                <a class="ghost-button" href="@GetBackToDocumentsHref()">Back to documents</a>
            </PageEmptyState>
        }
    </section>

    <QuickLinksPanel Actions="@GetQuickActions()" AiPrompts="@GetAiPrompts()" />
</div>

@code {
    [Parameter]
    public string? TenantSlug { get; set; }

    [Parameter]
    public string? PropertySlug { get; set; }

    [Parameter]
    public Guid DocumentId { get; set; }

    private RuntiraDocumentDto? _document;
    private bool _isLoading = true;
    private bool _hasInitialized;
    private bool _isSubmittingAction;
    private string? _statusMessage;

    protected override async Task OnInitializedAsync()
    {
        if (_hasInitialized)
        {
            return;
        }

        _hasInitialized = true;

        try
        {
            var documents = await WorkspaceService.GetDocumentsAsync();
            _document = documents.FirstOrDefault(x => x.Id == DocumentId);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private IReadOnlyList<StandardActionMenuItem> GetDocumentActionItems()
        =>
        [
            new StandardActionMenuItem(
                "markArchived",
                "Marquer archivé",
                _document is null || string.Equals(_document.Status, "Archived", StringComparison.OrdinalIgnoreCase),
                "Le document passe en statut Archivé."),
            new StandardActionMenuItem(
                "markPendingReview",
                "Marquer en revue",
                _document is null || string.Equals(_document.Status, "PendingReview", StringComparison.OrdinalIgnoreCase),
                "Le document est mis en attente de revue par le super admin.")
        ];

    private async Task HandleDocumentActionAsync(string action)
    {
        if (_isSubmittingAction || _document is null)
        {
            return;
        }

        _isSubmittingAction = true;
        _statusMessage = null;

        try
        {
            var result = await WorkspaceService.ManageDocumentAsync(_document.Id, action);
            _statusMessage = result.ResultCode switch
            {
                "Updated" => $"Document mis à jour · {result.Status}.",
                "DocumentNotFound" => "Document introuvable.",
                _ => "Action indisponible."
            };

            var documents = await WorkspaceService.GetDocumentsAsync();
            _document = documents.FirstOrDefault(x => x.Id == DocumentId);
        }
        finally
        {
            _isSubmittingAction = false;
        }
    }

    private static string GetStatusCss(string status)
        => status switch
        {
            "Archived" => "status-pill status-pill-success",
            "PendingReview" => "status-pill status-pill-warning",
            _ => "status-pill status-pill-muted"
        };

    private string GetBackToDocumentsHref()
        => $"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/documents";

    private string GetPropertyLeafHref(string leaf)
        => $"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/{leaf}";

    private List<QuickLinkAction> GetQuickActions()
    {
        var actions = new List<QuickLinkAction>();
        if (_document is null)
        {
            return actions;
        }

        actions.Add(new QuickLinkAction("Voir les baux liés", GetPropertyLeafHref("leases")));
        actions.Add(new QuickLinkAction("Voir les unités", GetPropertyLeafHref("units")));
        actions.Add(new QuickLinkAction("Voir tous les documents", GetPropertyLeafHref("documents")));
        return actions;
    }

    private List<AiPromptSuggestion> GetAiPrompts()
    {
        var prompts = new List<AiPromptSuggestion>();
        if (_document is null)
        {
            return prompts;
        }

        prompts.Add(new AiPromptSuggestion(
            "Résumer ce document",
            $"Résume en 3 phrases le contenu probable du document « {_document.FileName} » (catégorie {_document.Category}, déposé le {_document.UploadedUtc:yyyy-MM-dd}) pour le propriétaire."));

        if (string.Equals(_document.Status, "PendingReview", StringComparison.OrdinalIgnoreCase))
        {
            prompts.Add(new AiPromptSuggestion(
                "Rédiger une demande de revue",
                $"Rédige un message court demandant au super admin de réviser le document « {_document.FileName} » en attente de validation."));
        }

        return prompts;
    }
}
