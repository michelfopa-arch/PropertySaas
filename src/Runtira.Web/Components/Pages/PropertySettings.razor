@page "/{tenantSlug}/{propertySlug}/settings"
@using Runtira.Application.Common
@inject CurrentOrganization CurrentOrganization

<PageTitle>Property settings · @CurrentOrganization.PropertyName</PageTitle>

<div class="hero-shell">
    <section class="hero-card">
        <div class="hero-badge">Property settings</div>
        <h1>Property settings</h1>
        <p class="hero-copy">Configuration simple de la propriété pour un petit propriétaire : identité, règles locales, options de facturation et préférences d’exploitation.</p>

        <div class="tenant-summary">
            <div>
                <span class="summary-label">Organization</span>
                <strong>@CurrentOrganization.OrganizationName</strong>
            </div>
            <div>
                <span class="summary-label">Property</span>
                <strong>@CurrentOrganization.PropertyName</strong>
            </div>
            <div>
                <span class="summary-label">Routing</span>
                <strong>@($"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/settings")</strong>
            </div>
            <div>
                <span class="summary-label">Mode</span>
                <strong>Mock</strong>
            </div>
        </div>

        <div class="localized-section">
            <div class="prompt-title">Local rules</div>
            <div class="option-list">
                <span class="option-pill option-pill-accent">JSON legislation profile</span>
                <span class="option-pill">Monthly invoicing</span>
                <span class="option-pill">PDF invoice required</span>
                <span class="option-pill">Manual Excel review</span>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <span>Billing mode</span>
                <strong>Monthly</strong>
                <span>Simple recurring invoices</span>
            </div>
            <div class="stat-card">
                <span>Document retention</span>
                <strong>Blob + Cosmos</strong>
                <span>Fast restore ready</span>
            </div>
            <div class="stat-card">
                <span>Resident intake</span>
                <strong>Manual + Excel</strong>
                <span>Queue reviewed by super admin</span>
            </div>
            <div class="stat-card">
                <span>Visibility</span>
                <strong>Owner / Manager / Viewer</strong>
                <span>Mock access profile by role</span>
            </div>
        </div>
    </section>

    <section class="workspace-card">
        <div class="workspace-header">
            <h2>Settings actions</h2>
            <span class="workspace-state">Mock</span>
        </div>

        <div class="prompt-box prompt-box-soft">
            <button type="button" class="prompt-chip">Edit property identity</button>
            <button type="button" class="prompt-chip">Adjust local rules JSON</button>
            <button type="button" class="prompt-chip">Configure invoice defaults</button>
            <button type="button" class="prompt-chip">Archive settings snapshot</button>
            <a class="prompt-chip prompt-link" href="@($"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/dashboard")">Back to property</a>
        </div>
    </section>
</div>

@code {
    [Parameter]
    public string? TenantSlug { get; set; }

    [Parameter]
    public string? PropertySlug { get; set; }
}
