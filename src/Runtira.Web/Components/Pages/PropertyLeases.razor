@page "/{tenantSlug}/{propertySlug}/leases"
@using Runtira.Application.Common
@using Runtira.Application.Features
@using Runtira.Web.Components.Shared
@inject CurrentOrganization CurrentOrganization
@inject RuntiraWorkspaceService WorkspaceService

<PageTitle>Leases · @CurrentOrganization.PropertyName</PageTitle>

<div class="hero-shell hero-shell-single">
    <section class="hero-card">
        <div class="hero-badge">Leases</div>
        <h1>Leases</h1>
        <p class="hero-copy">Chaque bail affiche son statut, son loyer et son résident en un coup d’œil. Cliquez sur un bail pour ouvrir sa page dédiée.</p>

        @if (_isLoading)
        {
            <PageLoadingState />
        }
        else if (_workspace is not null)
        {
            <div class="tenant-summary">
                <div>
                    <span class="summary-label">Leases</span>
                    <strong>@_workspace.Leases.Count</strong>
                </div>
                <div>
                    <span class="summary-label">Monthly revenue</span>
                    <strong>@_workspace.Leases.Sum(x => x.MonthlyRent).ToString("C")</strong>
                </div>
                <div>
                    <span class="summary-label">Review needed</span>
                    <strong>@_workspace.Leases.Count(x => string.Equals(x.Status, "Review", StringComparison.OrdinalIgnoreCase))</strong>
                </div>
                <div>
                    <span class="summary-label">Property</span>
                    <strong>@(_workspace.AssetName)</strong>
                </div>
            </div>

            <SectionToolbar Hint="Cliquez sur un bail pour ouvrir sa fiche complète.">
                <Actions>
                    <a class="ghost-button" href="@($"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/dashboard")">Back to property</a>
                </Actions>
            </SectionToolbar>

            @if (_workspace.Leases.Count > 0)
            {
                <div class="unit-explorer-list">
                    @foreach (var lease in _workspace.Leases)
                    {
                        <a class="explorer-list-item" href="@GetLeaseDetailHref(lease.Id)">
                            <div class="unit-item-header">
                                <strong>@GetLeaseTitle(lease)</strong>
                                <span class="@EntityStatusPresenter.LeasePaymentCss(lease.Status)">@EntityStatusPresenter.LeasePaymentLabel(lease.Status)</span>
                            </div>
                            <span>@lease.MonthlyRent.ToString("C") · @lease.BillingPeriod</span>
                            <div class="unit-item-footer">
                                <small>@lease.ResidentName</small>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <PageEmptyState Title="Aucun bail" Message="Aucun bail mock disponible pour cette propriété." />
            }
        }
        else
        {
            <PageEmptyState Title="No lease data" Message="Aucun bail mock disponible pour cette propriété." />
        }
    </section>
</div>

@code {
    [Parameter]
    public string? TenantSlug { get; set; }

    [Parameter]
    public string? PropertySlug { get; set; }

    private RuntiraAssetWorkspaceDto? _workspace;
    private bool _isLoading = true;
    private string? _loadedPropertySlug;

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrWhiteSpace(TenantSlug))
        {
            CurrentOrganization.OrganizationSlug = TenantSlug;
        }

        if (!string.IsNullOrWhiteSpace(PropertySlug))
        {
            CurrentOrganization.PropertySlug = PropertySlug;
        }

        if (_workspace is not null && string.Equals(_loadedPropertySlug, CurrentOrganization.PropertySlug, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        _isLoading = true;
        try
        {
            _workspace = await WorkspaceService.GetAssetWorkspaceAsync();
            if (_workspace is not null)
            {
                CurrentOrganization.PropertyName = _workspace.AssetName;
            }

            _loadedPropertySlug = CurrentOrganization.PropertySlug;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetLeaseDetailHref(Guid leaseId)
        => $"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/leases/{leaseId}";

    private static string GetLeaseTitle(RuntiraLeaseSummaryDto lease)
        => string.IsNullOrWhiteSpace(lease.UnitCode) ? lease.ResidentName : $"Unit {lease.UnitCode}";
}
