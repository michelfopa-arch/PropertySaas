@page "/{tenantSlug}/{propertySlug}/dashboard"
@using Runtira.Application.Common
@inject CurrentOrganization CurrentOrganization

<PageTitle>@(string.IsNullOrWhiteSpace(CurrentOrganization.PropertyName) ? "Property" : CurrentOrganization.PropertyName)</PageTitle>

<div class="hero-shell">
    <section class="hero-card">
        <div class="hero-badge">Property workspace</div>
        <h1>@(string.IsNullOrWhiteSpace(CurrentOrganization.PropertyName) ? "Your property" : CurrentOrganization.PropertyName)</h1>
        <p class="hero-copy">Vue simple de la propriété. Choisis ensuite l’entité à gérer : unités, résidents, baux, documents, maintenance ou facturation.</p>

        <div class="option-list">
            <a class="option-pill option-pill-accent" href="@($"/{CurrentOrganization.OrganizationSlug}/properties")">Toutes les propriétés</a>
        </div>

        <div class="tenant-summary">
            <div>
                <span class="summary-label">Property</span>
                <strong>@(string.IsNullOrWhiteSpace(CurrentOrganization.PropertyName) ? CurrentOrganization.PropertySlug : CurrentOrganization.PropertyName)</strong>
            </div>
            <div>
                <span class="summary-label">Market</span>
                <strong>@CurrentOrganization.CountryCode-@CurrentOrganization.Province</strong>
            </div>
            <div>
                <span class="summary-label">Mode</span>
                <strong>Mock default</strong>
            </div>
            <div>
                <span class="summary-label">Plan</span>
                <strong>Free trial</strong>
            </div>
        </div>

        <div class="focus-strip">
            <a class="action-card action-card-primary" href="@($"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/units")">
                <strong>Units</strong>
                <span>Voir les unités, statuts et loyers marché de la propriété.</span>
            </a>
            <a class="action-card" href="@($"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/residents")">
                <strong>Residents</strong>
                <span>Consulter les résidents actifs et leurs informations essentielles.</span>
            </a>
        </div>

        <div class="option-list mt-3">
            <a class="option-pill option-pill-accent" href="@($"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/leases")">Leases</a>
            <a class="option-pill option-pill-accent" href="@($"/{CurrentOrganization.OrganizationSlug}/invoices")">Invoices</a>
            <a class="option-pill option-pill-accent" href="@($"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/invoice-composer")">Basic invoicing</a>
            <a class="option-pill" href="@($"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/imports")">Excel intake</a>
            <a class="option-pill" href="@($"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/documents")">Documents</a>
            <a class="option-pill" href="@($"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/maintenance")">Maintenance</a>
            <a class="option-pill" href="@($"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/settings")">Settings</a>
        </div>
    </section>

    <QuickLinksPanel Actions="@GetQuickActions()" AiPrompts="@GetAiPrompts()" />
</div>

@code {
    [Parameter]
    public string? TenantSlug { get; set; }

    [Parameter]
    public string? PropertySlug { get; set; }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(TenantSlug))
        {
            CurrentOrganization.OrganizationSlug = TenantSlug;
        }

        if (!string.IsNullOrWhiteSpace(PropertySlug))
        {
            CurrentOrganization.PropertySlug = PropertySlug;
        }
    }

    private List<QuickLinkAction> GetQuickActions()
        =>
        [
            new QuickLinkAction("Voir les leads", $"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/leads", IsAccent: true),
            new QuickLinkAction("Voir l'inbox", $"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/inbox"),
            new QuickLinkAction("Voir la facturation", $"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/billing"),
            new QuickLinkAction("Voir les exports", $"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/exports"),
            new QuickLinkAction("Voir toutes les factures", $"/{CurrentOrganization.OrganizationSlug}/invoices")
        ];

    private List<AiPromptSuggestion> GetAiPrompts()
        =>
        [
            new AiPromptSuggestion(
                "Résumer la propriété",
                $"Résume en 3 phrases l'état actuel de la propriété {(string.IsNullOrWhiteSpace(CurrentOrganization.PropertyName) ? CurrentOrganization.PropertySlug : CurrentOrganization.PropertyName)} pour le propriétaire : occupation, revenus et points d'attention."),
            new AiPromptSuggestion(
                "Préparer un rapport mensuel",
                $"Prépare un rapport mensuel court (occupation, loyers, baux à renouveler) pour la propriété {(string.IsNullOrWhiteSpace(CurrentOrganization.PropertyName) ? CurrentOrganization.PropertySlug : CurrentOrganization.PropertyName)}.")
        ];
}
