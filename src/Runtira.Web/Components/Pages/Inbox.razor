@page "/{tenantSlug}/inbox"
@using Runtira.Application.Common
@using Runtira.Application.Features
@inject CurrentOrganization CurrentOrganization
@inject RuntiraWorkspaceService WorkspaceService

<PageTitle>@RuntiraText.Get("Nav_Inbox", CurrentOrganization.PreferredLanguage)</PageTitle>

<div class="hero-shell">
    <section class="hero-card">
        <div class="hero-badge">@RuntiraText.Get("Inbox_Badge", CurrentOrganization.PreferredLanguage)</div>
        <h1>@RuntiraText.Get("Inbox_Title", CurrentOrganization.PreferredLanguage)</h1>
        <p class="hero-copy">@RuntiraText.Get("Inbox_Subtitle", CurrentOrganization.PreferredLanguage)</p>

        @if (_messages.Count > 0)
        {
            <div class="tenant-summary">
                <div>
                    <span class="summary-label">@RuntiraText.Get("Inbox_Summary_Total", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_messages.Count</strong>
                </div>
                <div>
                    <span class="summary-label">@RuntiraText.Get("Inbox_Summary_Classified", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_messages.Count(x => string.Equals(x.Status, "Classified", StringComparison.OrdinalIgnoreCase))</strong>
                </div>
                <div>
                    <span class="summary-label">@RuntiraText.Get("Inbox_Summary_Attachments", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_messages.Count(x => x.HasAttachments)</strong>
                </div>
                <div>
                    <span class="summary-label">@RuntiraText.Get("Inbox_Summary_Provider", CurrentOrganization.PreferredLanguage)</span>
                    <strong>MockMicrosoft365</strong>
                </div>
            </div>

            <ExplorerSection Title="@RuntiraText.Get("Inbox_WorkspaceTitle", CurrentOrganization.PreferredLanguage)"
                             Hint="@RuntiraText.Get("Inbox_ListHint", CurrentOrganization.PreferredLanguage)"
                             HasItems="@(_messages.Count > 0)"
                             EmptyTitle="@RuntiraText.Get("Inbox_EmptyTitle", CurrentOrganization.PreferredLanguage)"
                             EmptyMessage="@RuntiraText.Get("Inbox_EmptyBody", CurrentOrganization.PreferredLanguage)"
                             DetailEmptyTitle="@RuntiraText.Get("Inbox_DetailEmptyTitle", CurrentOrganization.PreferredLanguage)"
                             DetailEmptyMessage="@RuntiraText.Get("Inbox_DetailEmptyBody", CurrentOrganization.PreferredLanguage)">
                <ListContent>
                    @foreach (var message in _messages)
                    {
                        <button type="button"
                                class="@(IsSelectedMessage(message.Id) ? "explorer-list-item selected" : "explorer-list-item")"
                                @onclick="() => SelectMessage(message.Id)">
                            <strong>@message.FromEmail</strong>
                            <span>@message.Subject</span>
                            <small>@message.Status</small>
                        </button>
                    }
                </ListContent>
                <DetailContent>
                    @if (SelectedMessage is not null)
                    {
                        <div class="explorer-detail-stack">
                            <div class="stat-card unit-detail-card">
                                <div class="card-header-inline">
                                    <div>
                                        <span>@RuntiraText.Get("Inbox_DetailTitle", CurrentOrganization.PreferredLanguage)</span>
                                        <strong>@SelectedMessage.Subject</strong>
                                        <p class="detail-helper-copy">@RuntiraText.Get("Assets_DetailPanelHint", CurrentOrganization.PreferredLanguage)</p>
                                    </div>
                                </div>

                                <div class="tenant-summary unit-detail-summary">
                                    <div>
                                        <span class="summary-label">@RuntiraText.Get("Inbox_Table_From", CurrentOrganization.PreferredLanguage)</span>
                                        <strong>@SelectedMessage.FromEmail</strong>
                                    </div>
                                    <div>
                                        <span class="summary-label">@RuntiraText.Get("Inbox_Table_Category", CurrentOrganization.PreferredLanguage)</span>
                                        <strong>@SelectedMessage.Category</strong>
                                    </div>
                                    <div>
                                        <span class="summary-label">@RuntiraText.Get("Inbox_Table_Status", CurrentOrganization.PreferredLanguage)</span>
                                        <strong>@SelectedMessage.Status</strong>
                                    </div>
                                    <div>
                                        <span class="summary-label">@RuntiraText.Get("Inbox_Table_Received", CurrentOrganization.PreferredLanguage)</span>
                                        <strong>@SelectedMessage.ReceivedUtc.ToString("yyyy-MM-dd HH:mm")</strong>
                                    </div>
                                </div>

                                @if (SelectedMessage.HasAttachments)
                                {
                                    <div class="detail-kpi">@RuntiraText.Get("Inbox_Summary_Attachments", CurrentOrganization.PreferredLanguage)</div>
                                }

                                <div class="draft-box">
                                    <strong>@RuntiraText.Get("Inbox_DetailPreviewTitle", CurrentOrganization.PreferredLanguage)</strong>
                                    <p class="detail-summary-copy">@SelectedMessage.PreviewText</p>
                                </div>
                            </div>
                        </div>
                    }
                </DetailContent>
            </ExplorerSection>
        }
        else
        {
            <PageEmptyState Title="@RuntiraText.Get("Inbox_EmptyTitle", CurrentOrganization.PreferredLanguage)"
                            Message="@RuntiraText.Get("Inbox_EmptyBody", CurrentOrganization.PreferredLanguage)" />
        }
    </section>

    <section class="workspace-card">
        <div class="workspace-header">
            <h2>@RuntiraText.Get("Inbox_WorkspaceTitle", CurrentOrganization.PreferredLanguage)</h2>
            <span class="workspace-state">@RuntiraText.Get("Common_Preview", CurrentOrganization.PreferredLanguage)</span>
        </div>

        <div class="prompt-box">
            <button type="button" class="prompt-chip">@RuntiraText.Get("Inbox_Action_Seed", CurrentOrganization.PreferredLanguage)</button>
            <button type="button" class="prompt-chip">@RuntiraText.Get("Inbox_Action_Classify", CurrentOrganization.PreferredLanguage)</button>
            <button type="button" class="prompt-chip">@RuntiraText.Get("Inbox_Action_Attachments", CurrentOrganization.PreferredLanguage)</button>
            <button type="button" class="prompt-chip">@RuntiraText.Get("Inbox_Action_Link", CurrentOrganization.PreferredLanguage)</button>
        </div>
    </section>
</div>

@code {
    [Parameter]
    public string? TenantSlug { get; set; }

    private IReadOnlyList<RuntiraInboxMessageDto> _messages = Array.Empty<RuntiraInboxMessageDto>();
    private bool _hasInitialized;
    private Guid? _selectedMessageId;

    private RuntiraInboxMessageDto? SelectedMessage => _messages.FirstOrDefault(x => x.Id == _selectedMessageId);

    protected override async Task OnInitializedAsync()
    {
        if (_hasInitialized)
        {
            return;
        }

        _hasInitialized = true;

        _messages = await WorkspaceService.GetInboxAsync();
    }

    private void SelectMessage(Guid messageId)
        => _selectedMessageId = messageId;

    private bool IsSelectedMessage(Guid messageId)
        => _selectedMessageId == messageId;
}
