@page "/{tenantSlug}/{propertySlug}/units/{unitId:guid}"
@using Runtira.Application.Common
@using Runtira.Application.Features
@using Runtira.Web.Components.Shared
@inject CurrentOrganization CurrentOrganization
@inject RuntiraWorkspaceService WorkspaceService

<PageTitle>@(_unit is null ? "Unit" : _unit.UnitCode) · @CurrentOrganization.PropertyName</PageTitle>

<div class="hero-shell">
    <section class="hero-card">
        <div class="hero-badge">Unit</div>

        <BusyOverlay IsVisible="@_isSubmittingAction" Label="Mise à jour" Message="Application de l’action sur l’unité." />

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <PageEmptyState Title="@_statusMessage" CssClass="inline-status" />
        }

        @if (_isLoading)
        {
            <PageLoadingState />
        }
        else if (_unit is not null)
        {
            <div class="card-header-inline">
                <div>
                    <h1>@_unit.UnitCode</h1>
                    <p class="hero-copy">@_unit.UnitType · @_workspace?.AssetName</p>
                </div>
                <span class="@EntityStatusPresenter.UnitOccupancyCss(_unit.Status)">@EntityStatusPresenter.UnitOccupancyLabel(_unit.Status)</span>
            </div>

            <SectionToolbar Hint="Fiche complète de l’unité, avec son bail, son résident et ses actions.">
                <Actions>
                    <a class="ghost-button" href="@GetBackToUnitsHref()">Back to units</a>
                </Actions>
            </SectionToolbar>

            <div class="tenant-summary unit-detail-summary">
                <div>
                    <span class="summary-label">Type</span>
                    <strong>@_unit.UnitType</strong>
                </div>
                <div>
                    <span class="summary-label">Loyer marché</span>
                    <strong>@_unit.MarketRent.ToString("C")</strong>
                </div>
                <div>
                    <span class="summary-label">Statut bail</span>
                    <strong>@(_lease is null ? "Aucun" : EntityStatusPresenter.LeasePaymentLabel(_lease.Status))</strong>
                </div>
                <div>
                    <span class="summary-label">Résident</span>
                    <strong>@(_resident?.FullName ?? "Aucun")</strong>
                </div>
            </div>

            @if (CurrentOrganization.CanManageData)
            {
                <StandardActionMenu MenuLabel="Actions"
                                     Title="Gérer l’unité"
                                     Items="@GetUnitActionItems()"
                                     IsBusy="@_isSubmittingAction"
                                     OnAction="@(action => HandleUnitActionAsync(action))" />
            }

            @if (_lease is not null && _resident is not null)
            {
                <div class="draft-box">
                    <strong>Bail en cours</strong>
                    <div>Résident · @_resident.FullName</div>
                    <div>Email · @_resident.Email</div>
                    <div>Langue préférée · @_resident.PreferredLanguage</div>
                    <div>Loyer mensuel · @_lease.MonthlyRent.ToString("C") (@_lease.BillingPeriod)</div>
                    <div>Statut · @EntityStatusPresenter.LeasePaymentLabel(_lease.Status)</div>
                </div>

                <RentLedgerSummary Ledger="@_ledger" LeaseDetailHref="@GetLeaseDetailHref()" />

                @if (_lease.ComplianceData?.Fields is { Count: > 0 } fields)
                {
                    <FlexibleContextCard Title="Détails du bail" Fields="@fields" />
                }
            }
            else
            {
                <PageEmptyState Title="Aucun bail actif" Message="Cette unité n’a pas de bail rattaché pour le moment." />
            }
        }
        else
        {
            <PageEmptyState Title="Unité introuvable" Message="Cette unité n’existe plus ou a été supprimée.">
                <a class="ghost-button" href="@GetBackToUnitsHref()">Back to units</a>
            </PageEmptyState>
        }
    </section>

    <QuickLinksPanel Actions="@GetQuickActions()" AiPrompts="@GetAiPrompts()" />
</div>

@code {
    [Parameter]
    public string? TenantSlug { get; set; }

    [Parameter]
    public string? PropertySlug { get; set; }

    [Parameter]
    public Guid UnitId { get; set; }

    private RuntiraAssetWorkspaceDto? _workspace;
    private RuntiraUnitSummaryDto? _unit;
    private RuntiraLeaseSummaryDto? _lease;
    private RuntiraResidentSummaryDto? _resident;
    private RuntiraRentLedgerDto? _ledger;
    private bool _isLoading = true;
    private string? _loadedPropertySlug;
    private bool _isSubmittingAction;
    private string? _statusMessage;

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrWhiteSpace(TenantSlug))
        {
            CurrentOrganization.OrganizationSlug = TenantSlug;
        }

        if (!string.IsNullOrWhiteSpace(PropertySlug))
        {
            CurrentOrganization.PropertySlug = PropertySlug;
        }

        if (_workspace is not null && string.Equals(_loadedPropertySlug, CurrentOrganization.PropertySlug, StringComparison.OrdinalIgnoreCase))
        {
            await RefreshSelectedUnitAsync();
            return;
        }

        _isLoading = true;
        try
        {
            _workspace = await WorkspaceService.GetAssetWorkspaceAsync();
            if (_workspace is not null)
            {
                CurrentOrganization.PropertyName = _workspace.AssetName;
            }

            _loadedPropertySlug = CurrentOrganization.PropertySlug;
            await RefreshSelectedUnitAsync();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task RefreshSelectedUnitAsync()
    {
        _unit = _workspace?.Units.FirstOrDefault(x => x.Id == UnitId);
        _lease = _unit is null ? null : _workspace?.Leases.FirstOrDefault(x => string.Equals(x.UnitCode, _unit.UnitCode, StringComparison.OrdinalIgnoreCase));
        _resident = _lease is null ? null : _workspace?.Residents.FirstOrDefault(x => string.Equals(x.FullName, _lease.ResidentName, StringComparison.OrdinalIgnoreCase));
        _ledger = _lease is null ? null : await WorkspaceService.GetRentLedgerAsync(_lease.Id);
    }

    private string GetLeaseDetailHref()
        => _lease is null ? "#" : $"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/leases/{_lease.Id}";

    private string GetBackToUnitsHref()
        => $"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/units";

    private string GetPropertyLeafHref(string leaf)
        => $"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/{leaf}";

    private string GetInvoiceHref(int monthOffset)
        => _lease is null ? "#" : $"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/leases/{_lease.Id}/invoice.pdf?monthOffset={monthOffset}";

    private List<QuickLinkAction> GetQuickActions()
    {
        var actions = new List<QuickLinkAction>();
        if (_unit is null)
        {
            return actions;
        }

        if (_lease is not null)
        {
            actions.Add(new QuickLinkAction("Imprimer la facture du mois précédent", GetInvoiceHref(-1), Target: "_blank"));
            actions.Add(new QuickLinkAction("Imprimer la facture du mois courant", GetInvoiceHref(0), IsAccent: true, Target: "_blank"));
            actions.Add(new QuickLinkAction("Imprimer la facture du mois suivant", GetInvoiceHref(1), Target: "_blank"));
            actions.Add(new QuickLinkAction("Voir le bail complet", $"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/leases/{_lease.Id}"));
        }

        if (_resident is not null)
        {
            actions.Add(new QuickLinkAction("Voir la fiche du résident", $"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/residents/{_resident.Id}"));
        }

        actions.Add(new QuickLinkAction("Voir les leads de cette propriété", GetPropertyLeafHref("leads")));
        actions.Add(new QuickLinkAction("Voir toutes les unités", GetPropertyLeafHref("units")));
        actions.Add(new QuickLinkAction("Voir tous les baux", GetPropertyLeafHref("leases")));
        return actions;
    }

    private List<AiPromptSuggestion> GetAiPrompts()
    {
        var prompts = new List<AiPromptSuggestion>();
        if (_unit is null)
        {
            return prompts;
        }

        if (_lease is not null && _resident is not null)
        {
            prompts.Add(new AiPromptSuggestion(
                "Rédiger un rappel de paiement",
                $"Rédige un email de rappel de paiement de loyer, poli et professionnel, pour {_resident.FullName}, unité {_unit.UnitCode}, loyer {_lease.MonthlyRent:C} ({_lease.BillingPeriod})."));
        }

        if (string.Equals(_unit.Status, "Available", StringComparison.OrdinalIgnoreCase))
        {
            prompts.Add(new AiPromptSuggestion(
                "Rédiger une annonce de disponibilité",
                $"Rédige une annonce immobilière attrayante pour l'unité {_unit.UnitCode} ({_unit.UnitType}), disponible à {_unit.MarketRent:C}/mois, à {_workspace?.AssetAddress}."));
        }

        prompts.Add(new AiPromptSuggestion(
            "Résumer l'état de cette unité",
            $"Résume en 3 phrases l'état actuel de l'unité {_unit.UnitCode} pour le propriétaire : statut {_unit.Status}, loyer marché {_unit.MarketRent:C}{(_lease is null ? ", aucun bail actif" : $", bail actif avec {_lease.ResidentName}")}."));

        return prompts;
    }

    private IReadOnlyList<StandardActionMenuItem> GetUnitActionItems()
        =>
        [
            new StandardActionMenuItem(
                "markMaintenance",
                "Marquer en maintenance",
                _unit is null || string.Equals(_unit.Status, "Maintenance", StringComparison.OrdinalIgnoreCase),
                "L’unité passe en statut Maintenance."),
            new StandardActionMenuItem(
                "markAvailable",
                "Marquer disponible",
                _unit is null || string.Equals(_unit.Status, "Available", StringComparison.OrdinalIgnoreCase),
                "L’unité redevient disponible à la location."),
            new StandardActionMenuItem(
                "delete",
                "Supprimer l’unité",
                _unit is null || !_unit.CanDelete,
                _unit is not null && _unit.CanDelete ? "Supprime définitivement cette unité." : "Impossible : un bail actif y est rattaché.",
                isDestructive: true)
        ];

    private async Task HandleUnitActionAsync(string action)
    {
        if (_isSubmittingAction || _unit is null)
        {
            return;
        }

        _isSubmittingAction = true;
        _statusMessage = null;

        try
        {
            var result = await WorkspaceService.ManageUnitAsync(_unit.Id, action);
            _statusMessage = result.ResultCode switch
            {
                "Updated" => $"Unité {result.UnitCode} mise à jour · {result.Status}.",
                "Deleted" => $"Unité {result.UnitCode} supprimée.",
                "UnitHasActiveLease" => $"Impossible de supprimer {result.UnitCode} : un bail actif y est rattaché.",
                "UnitNotFound" => "Unité introuvable.",
                _ => "Action indisponible."
            };

            _workspace = await WorkspaceService.GetAssetWorkspaceAsync();
            await RefreshSelectedUnitAsync();
        }
        finally
        {
            _isSubmittingAction = false;
        }
    }
}
