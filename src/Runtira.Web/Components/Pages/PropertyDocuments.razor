@page "/{tenantSlug}/{propertySlug}/documents"
@using Runtira.Application.Common
@using Runtira.Application.Features
@inject CurrentOrganization CurrentOrganization
@inject RuntiraWorkspaceService WorkspaceService

<PageTitle>@RuntiraText.Get("Documents_Badge", CurrentOrganization.PreferredLanguage) · @CurrentOrganization.PropertyName</PageTitle>

<div class="hero-shell hero-shell-single">
    <section class="hero-card">
        <div class="hero-badge">@RuntiraText.Get("Documents_Badge", CurrentOrganization.PreferredLanguage)</div>
        <h1>@RuntiraText.Get("Documents_Title", CurrentOrganization.PreferredLanguage)</h1>
        <p class="hero-copy">@RuntiraText.Get("Documents_Subtitle", CurrentOrganization.PreferredLanguage)</p>

        @if (_isLoading)
        {
            <PageLoadingState />
        }
        else if (_documents.Count > 0)
        {
            <div class="tenant-summary">
                <div>
                    <span class="summary-label">@RuntiraText.Get("Documents_Summary_Total", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_documents.Count</strong>
                </div>
                <div>
                    <span class="summary-label">@RuntiraText.Get("Documents_Summary_Archived", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_documents.Count(x => string.Equals(x.Status, "Archived", StringComparison.OrdinalIgnoreCase))</strong>
                </div>
                <div>
                    <span class="summary-label">@RuntiraText.Get("Documents_Summary_Categories", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@string.Join(" · ", _documents.Select(x => x.Category).Distinct(StringComparer.OrdinalIgnoreCase))</strong>
                </div>
                <div>
                    <span class="summary-label">@RuntiraText.Get("Documents_Summary_Property", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@CurrentOrganization.PropertyName</strong>
                </div>
            </div>

            <SectionToolbar Hint="@RuntiraText.Get("Documents_ListHint", CurrentOrganization.PreferredLanguage)">
                <Actions>
                    <a class="ghost-button" href="@($"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/dashboard")">@RuntiraText.Get("Documents_BackToProperty", CurrentOrganization.PreferredLanguage)</a>
                </Actions>
            </SectionToolbar>

            <div class="unit-explorer-list">
                @foreach (var document in _documents)
                {
                    <a class="explorer-list-item" href="@GetDocumentDetailHref(document.Id)">
                        <div class="unit-item-header">
                            <strong>@document.FileName</strong>
                            <span class="@GetStatusCss(document.Status)">@document.Status</span>
                        </div>
                        <span>@document.Category</span>
                        <div class="unit-item-footer">
                            <small>@document.UploadedUtc.ToString("yyyy-MM-dd")</small>
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <PageEmptyState Title="@RuntiraText.Get("Documents_EmptyTitle", CurrentOrganization.PreferredLanguage)"
                            Message="@RuntiraText.Get("Documents_EmptyBody", CurrentOrganization.PreferredLanguage)" />
        }
    </section>
</div>

@code {
    [Parameter]
    public string? TenantSlug { get; set; }

    [Parameter]
    public string? PropertySlug { get; set; }

    private IReadOnlyList<RuntiraDocumentDto> _documents = Array.Empty<RuntiraDocumentDto>();
    private bool _isLoading = true;
    private bool _hasInitialized;

    protected override async Task OnInitializedAsync()
    {
        if (_hasInitialized)
        {
            return;
        }

        _hasInitialized = true;

        try
        {
            _documents = await WorkspaceService.GetDocumentsAsync();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string GetStatusCss(string status)
        => status switch
        {
            "Archived" => "status-pill status-pill-success",
            "PendingReview" => "status-pill status-pill-warning",
            _ => "status-pill status-pill-muted"
        };

    private string GetDocumentDetailHref(Guid documentId)
        => $"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/documents/{documentId}";
}
