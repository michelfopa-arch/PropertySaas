@page "/{tenantSlug}/{propertySlug}/documents"
@using Runtira.Application.Common
@using Runtira.Application.Features
@inject CurrentOrganization CurrentOrganization
@inject RuntiraWorkspaceService WorkspaceService

<PageTitle>@RuntiraText.Get("Documents_Badge", CurrentOrganization.PreferredLanguage) · @CurrentOrganization.PropertyName</PageTitle>

<div class="hero-shell">
    <section class="hero-card">
        <div class="hero-badge">@RuntiraText.Get("Documents_Badge", CurrentOrganization.PreferredLanguage)</div>
        <h1>@RuntiraText.Get("Documents_Title", CurrentOrganization.PreferredLanguage)</h1>
        <p class="hero-copy">@RuntiraText.Get("Documents_Subtitle", CurrentOrganization.PreferredLanguage)</p>

        @if (_isLoading)
        {
            <PageLoadingState />
        }
        else if (_documents.Count > 0)
        {
            <div class="tenant-summary">
                <div>
                    <span class="summary-label">@RuntiraText.Get("Documents_Summary_Total", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_documents.Count</strong>
                </div>
                <div>
                    <span class="summary-label">@RuntiraText.Get("Documents_Summary_Archived", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_documents.Count(x => string.Equals(x.Status, "Archived", StringComparison.OrdinalIgnoreCase))</strong>
                </div>
                <div>
                    <span class="summary-label">@RuntiraText.Get("Documents_Summary_Categories", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@string.Join(" · ", _documents.Select(x => x.Category).Distinct(StringComparer.OrdinalIgnoreCase))</strong>
                </div>
                <div>
                    <span class="summary-label">@RuntiraText.Get("Documents_Summary_Property", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@CurrentOrganization.PropertyName</strong>
                </div>
            </div>

            <SectionToolbar Hint="@RuntiraText.Get("Documents_ListHint", CurrentOrganization.PreferredLanguage)">
                <Actions>
                    <a class="ghost-button" href="@($"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/dashboard")">@RuntiraText.Get("Documents_BackToProperty", CurrentOrganization.PreferredLanguage)</a>
                </Actions>
            </SectionToolbar>

            <ExplorerSection HasItems="@(_documents.Count > 0)"
                             EmptyTitle="@RuntiraText.Get("Documents_EmptyTitle", CurrentOrganization.PreferredLanguage)"
                             EmptyMessage="@RuntiraText.Get("Documents_EmptyBody", CurrentOrganization.PreferredLanguage)"
                             DetailEmptyTitle="@RuntiraText.Get("Documents_DetailEmptyTitle", CurrentOrganization.PreferredLanguage)"
                             DetailEmptyMessage="@RuntiraText.Get("Documents_DetailEmptyBody", CurrentOrganization.PreferredLanguage)">
                <ListContent>
                    @foreach (var document in _documents)
                    {
                        <button type="button"
                                class="@(IsSelectedDocument(document.Id) ? "explorer-list-item selected" : "explorer-list-item")"
                                @onclick="() => SelectDocument(document.Id)">
                            <strong>@document.FileName</strong>
                            <span>@document.Category</span>
                            <small>@document.Status</small>
                        </button>
                    }
                </ListContent>
                <DetailContent>
                    @if (SelectedDocument is not null)
                    {
                        <div class="explorer-detail-stack">
                            <div class="stat-card unit-detail-card">
                                <div class="card-header-inline">
                                    <div>
                                        <span>@RuntiraText.Get("Documents_DetailTitle", CurrentOrganization.PreferredLanguage)</span>
                                        <strong>@SelectedDocument.FileName</strong>
                                    </div>
                                </div>

                                <div class="tenant-summary unit-detail-summary">
                                    <div>
                                        <span class="summary-label">@RuntiraText.Get("Documents_Table_Category", CurrentOrganization.PreferredLanguage)</span>
                                        <strong>@SelectedDocument.Category</strong>
                                    </div>
                                    <div>
                                        <span class="summary-label">@RuntiraText.Get("Documents_Table_Status", CurrentOrganization.PreferredLanguage)</span>
                                        <strong>@SelectedDocument.Status</strong>
                                    </div>
                                    <div>
                                        <span class="summary-label">@RuntiraText.Get("Documents_Table_Uploaded", CurrentOrganization.PreferredLanguage)</span>
                                        <strong>@SelectedDocument.UploadedUtc.ToString("yyyy-MM-dd HH:mm")</strong>
                                    </div>
                                    <div>
                                        <span class="summary-label">@RuntiraText.Get("Documents_Table_Size", CurrentOrganization.PreferredLanguage)</span>
                                        <strong>@($"{SelectedDocument.SizeBytes / 1024.0:0.#} Ko")</strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </DetailContent>
            </ExplorerSection>
        }
        else
        {
            <PageEmptyState Title="@RuntiraText.Get("Documents_EmptyTitle", CurrentOrganization.PreferredLanguage)"
                            Message="@RuntiraText.Get("Documents_EmptyBody", CurrentOrganization.PreferredLanguage)" />
        }
    </section>

    <section class="workspace-card">
        <div class="workspace-header">
            <h2>@RuntiraText.Get("Documents_WorkspaceTitle", CurrentOrganization.PreferredLanguage)</h2>
            <span class="workspace-state">@RuntiraText.Get("Common_Preview", CurrentOrganization.PreferredLanguage)</span>
        </div>

        <div class="prompt-box prompt-box-soft">
            <button type="button" class="prompt-chip">@RuntiraText.Get("Documents_Action_Upload", CurrentOrganization.PreferredLanguage)</button>
            <button type="button" class="prompt-chip">@RuntiraText.Get("Documents_Action_SendReview", CurrentOrganization.PreferredLanguage)</button>
        </div>
    </section>
</div>

@code {
    [Parameter]
    public string? TenantSlug { get; set; }

    [Parameter]
    public string? PropertySlug { get; set; }

    private IReadOnlyList<RuntiraDocumentDto> _documents = Array.Empty<RuntiraDocumentDto>();
    private bool _isLoading = true;
    private bool _hasInitialized;
    private Guid? _selectedDocumentId;

    private RuntiraDocumentDto? SelectedDocument => _documents.FirstOrDefault(x => x.Id == _selectedDocumentId);

    protected override async Task OnInitializedAsync()
    {
        if (_hasInitialized)
        {
            return;
        }

        _hasInitialized = true;

        try
        {
            _documents = await WorkspaceService.GetDocumentsAsync();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void SelectDocument(Guid documentId)
        => _selectedDocumentId = documentId;

    private bool IsSelectedDocument(Guid documentId)
        => _selectedDocumentId == documentId;
}
