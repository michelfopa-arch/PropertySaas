@page "/"
@page "/{tenantSlug}"
@page "/{tenantSlug}/{propertySlug}"
@using Runtira.Application.Common
@using Runtira.Application.Features
@inject CurrentOrganization CurrentOrganization
@inject NavigationManager Navigation
@inject RuntiraWorkspaceService WorkspaceService

<PageTitle>Runtira</PageTitle>

<div class="hero-shell">
    <section class="hero-card">
        <div class="hero-badge">@RuntiraText.Get("Home_Badge", CurrentOrganization.PreferredLanguage)</div>
        <h1>@GetHeroTitle()</h1>
        <p class="hero-copy">
            @GetHeroCopy()
        </p>

        <div class="prompt-box">
            <div class="prompt-title">@RuntiraText.Get("Home_TodayTitle", CurrentOrganization.PreferredLanguage)</div>
            <div class="focus-strip">
                <div class="focus-card focus-card-primary">
                    <span class="summary-label">Public demo</span>
                    <strong>Try the landlord workspace</strong>
                    <p>Explore the mock workflow before creating an account.</p>
                </div>
                <div class="focus-card">
                    <span class="summary-label">14-day trial</span>
                    <strong>Create your account online</strong>
                    <p>Start free with one organization and one property.</p>
                </div>
            </div>
            @if (CurrentOrganization.IsSuperAdmin && CurrentOrganization.OrganizationOptions.Count > 0)
            {
                <div class="prompt-title">Maintenance</div>
                <div class="option-list">
                    <a class="option-pill option-pill-accent" href="/organizations">Open admin view</a>
                    <a class="option-pill" href="/super-admin/imports">Review import queue</a>
                </div>
            }
            <div class="tenant-links">
                <a class="prompt-chip prompt-link" href="/sign-in">@RuntiraText.Get("Home_SignIn", CurrentOrganization.PreferredLanguage)</a>
                <a class="prompt-chip prompt-link" href="/sign-up">Créer mon compte</a>
                <a class="prompt-chip prompt-link" href="/demo">Public demo</a>
            </div>
                </div>
            </section>

    <section class="workspace-card">
        <div class="workspace-header">
            <h2>@RuntiraText.Get("Home_WorkspaceTitle", CurrentOrganization.PreferredLanguage)</h2>
            <span class="workspace-state">@RuntiraText.Get("Common_Mvp", CurrentOrganization.PreferredLanguage)</span>
        </div>

        @if (!string.IsNullOrWhiteSpace(CurrentOrganization.OrganizationSlug) && !string.IsNullOrWhiteSpace(CurrentOrganization.PropertySlug))
        {
            <div class="localized-section">
                <div class="prompt-title">Property</div>
                <div class="home-actions-grid">
                    <a class="action-card action-card-primary" href="@BuildWorkspaceHref("dashboard")">
                        <strong>@(string.IsNullOrWhiteSpace(CurrentOrganization.PropertyName) ? "Open property" : CurrentOrganization.PropertyName)</strong>
                        <span>Continue with the selected property.</span>
                    </a>
                    <a class="action-card" href="@BuildWorkspaceHref("units")">
                        <strong>Units</strong>
                        <span>Open unit list and unit actions.</span>
                    </a>
                    <a class="action-card" href="@BuildWorkspaceHref("billing")">
                        <strong>Billing</strong>
                        <span>Open invoicing for this property.</span>
                    </a>
                </div>
            </div>
        }

        @if (_isLoading)
        {
            <PageLoadingState />
        }
        else if (_properties.Count > 0 && string.IsNullOrWhiteSpace(CurrentOrganization.PropertySlug))
        {
            <div class="section-toolbar">
                <span class="results-hint">@_properties.Count propriété@(_properties.Count > 1 ? "s" : "") disponible@(_properties.Count > 1 ? "s" : "")</span>
                @if (_properties.Count > 1)
                {
                    <a class="ghost-button" href="@($"/{CurrentOrganization.OrganizationSlug}/properties")">Voir toutes les propriétés</a>
                }
            </div>

            <div class="property-grid">
                @foreach (var property in _properties.Take(3))
                {
                    <a class="property-card" href="@GetPropertyHref(property)">
                        <div class="property-card-header">
                            <strong>@property.AssetName</strong>
                            <span class="@GetOccupancyBadgeCss(property)">@GetOccupancyLabel(property)</span>
                        </div>
                        <span class="property-card-address">@property.AssetAddress</span>
                        <div class="property-card-metrics">
                            <div class="property-card-metric">
                                <span>Units</span>
                                <strong>@property.OccupiedUnitCount / @property.UnitCount</strong>
                            </div>
                            <div class="property-card-metric">
                                <span>Active leases</span>
                                <strong>@property.ActiveLeaseCount</strong>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <PageEmptyState Title="@RuntiraText.Get("Home_InitializedTitle", CurrentOrganization.PreferredLanguage)"
                            Message="@RuntiraText.Get("Home_InitializedBody", CurrentOrganization.PreferredLanguage)" />
        }
    </section>
</div>

@code {
    [Parameter]
    public string? TenantSlug { get; set; }

    [Parameter]
    public string? PropertySlug { get; set; }

    private RuntiraWorkspaceSummaryDto? _summary;
    private IReadOnlyList<RuntiraAssetSummaryDto> _properties = Array.Empty<RuntiraAssetSummaryDto>();
    private bool _isLoading = true;
    private bool _hasInitialized;

    protected override async Task OnInitializedAsync()
    {
        if (_hasInitialized)
        {
            return;
        }

        _hasInitialized = true;

        if (ShouldAutoOpenOrganization())
        {
            Navigation.NavigateTo($"/{CurrentOrganization.OrganizationSlug}", replace: true);
            return;
        }

        try
        {
            _summary = await WorkspaceService.GetWorkspaceSummaryAsync();

            if (!string.IsNullOrWhiteSpace(CurrentOrganization.OrganizationSlug) && string.IsNullOrWhiteSpace(CurrentOrganization.PropertySlug))
            {
                _properties = await WorkspaceService.GetAssetsAsync();
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private bool ShouldAutoOpenOrganization()
        => string.IsNullOrWhiteSpace(TenantSlug)
           && !string.IsNullOrWhiteSpace(CurrentOrganization.OrganizationSlug)
           && CurrentOrganization.HasOrganizationAccess
           && CurrentOrganization.AccessibleOrganizationCount <= 1;

    private string BuildWorkspaceHref(string leaf)
    {
        if (string.IsNullOrWhiteSpace(CurrentOrganization.OrganizationSlug))
        {
            return "/";
        }

        return string.IsNullOrWhiteSpace(CurrentOrganization.PropertySlug)
            ? $"/{CurrentOrganization.OrganizationSlug}/{leaf}"
            : $"/{CurrentOrganization.OrganizationSlug}/{CurrentOrganization.PropertySlug}/{leaf}";
    }

    private string GetHeroTitle()
        => CurrentOrganization.CountryCode switch
        {
            "US" => RuntiraText.Get("Home_HeroTitle_US", CurrentOrganization.PreferredLanguage),
            "CA" => RuntiraText.Get("Home_HeroTitle_Canada", CurrentOrganization.PreferredLanguage),
            _ => RuntiraText.Get("Home_HeroTitle_Default", CurrentOrganization.PreferredLanguage)
        };

    private string GetPropertyHref(RuntiraAssetSummaryDto property)
    {
        if (string.IsNullOrWhiteSpace(CurrentOrganization.OrganizationSlug))
        {
            return "/";
        }

        return string.IsNullOrWhiteSpace(property.PropertySlug)
            ? $"/{CurrentOrganization.OrganizationSlug}"
            : $"/{CurrentOrganization.OrganizationSlug}/{property.PropertySlug}/dashboard";
    }

    private static int GetOccupancyPercent(RuntiraAssetSummaryDto property)
        => property.UnitCount <= 0 ? 0 : (int)Math.Round(property.OccupiedUnitCount * 100m / property.UnitCount);

    private static string GetOccupancyLabel(RuntiraAssetSummaryDto property)
        => $"{GetOccupancyPercent(property)}% occupied";

    private static string GetOccupancyBadgeCss(RuntiraAssetSummaryDto property)
    {
        var percent = GetOccupancyPercent(property);
        return percent switch
        {
            >= 90 => "status-pill status-pill-success",
            >= 60 => "status-pill status-pill-info",
            > 0 => "status-pill status-pill-warning",
            _ => "status-pill status-pill-muted"
        };
    }

    private string GetHeroCopy()
        => CurrentOrganization.CountryCode switch
        {
            "US" => RuntiraText.Get("Home_HeroCopy_US", CurrentOrganization.PreferredLanguage),
            "CA" => RuntiraText.Get("Home_HeroCopy_Canada", CurrentOrganization.PreferredLanguage),
            _ => RuntiraText.Get("Home_HeroCopy_Default", CurrentOrganization.PreferredLanguage)
        };

    private string GetMarketLabel() => $"{CurrentOrganization.CountryCode}-{CurrentOrganization.Province} · {CurrentOrganization.PreferredLanguage}";

}
