@page "/"
@page "/{tenantSlug}"
@using Runtira.Application.Common
@using Runtira.Application.Features
@inject CurrentOrganization CurrentOrganization
@inject NavigationManager Navigation
@inject RuntiraWorkspaceService WorkspaceService

<PageTitle>@CurrentOrganization.OrganizationName</PageTitle>

<div class="hero-shell">
    <section class="hero-card">
        <div class="hero-badge">@RuntiraText.Get("Home_Badge", CurrentOrganization.PreferredLanguage)</div>
        <h1>@GetHeroTitle()</h1>
        <p class="hero-copy">
            @GetHeroCopy()
        </p>

        <div class="tenant-summary">
            <div>
                <span class="summary-label">@RuntiraText.Get("Home_Summary_Organization", CurrentOrganization.PreferredLanguage)</span>
                <strong>@CurrentOrganization.OrganizationName</strong>
            </div>
            <div>
                <span class="summary-label">@RuntiraText.Get("Home_Summary_Route", CurrentOrganization.PreferredLanguage)</span>
                <strong>@(string.IsNullOrWhiteSpace(CurrentOrganization.OrganizationSlug) ? "/" : $"/{CurrentOrganization.OrganizationSlug}")</strong>
            </div>
            <div>
                <span class="summary-label">@RuntiraText.Get("Home_Summary_Language", CurrentOrganization.PreferredLanguage)</span>
                <strong>@CurrentOrganization.PreferredLanguage</strong>
            </div>
            <div>
                <span class="summary-label">@RuntiraText.Get("Home_Summary_Jurisdiction", CurrentOrganization.PreferredLanguage)</span>
                <strong>@CurrentOrganization.CountryCode-@CurrentOrganization.Province</strong>
            </div>
            <div>
                <span class="summary-label">@RuntiraText.Get("Home_Summary_Experience", CurrentOrganization.PreferredLanguage)</span>
                <strong>@RuntiraText.Get("Home_Optimized", CurrentOrganization.PreferredLanguage)</strong>
            </div>
        </div>

        <div class="prompt-box">
            <div class="prompt-title">@RuntiraText.Get("Home_TodayTitle", CurrentOrganization.PreferredLanguage)</div>
            @foreach (var prompt in GetLocalizedPrompts())
            {
                <button type="button" class="prompt-chip">@prompt</button>
            }
            <div class="prompt-title">@RuntiraText.Get("Home_ProvidersTitle", CurrentOrganization.PreferredLanguage)</div>
            <div class="option-list">
                <span class="option-pill option-pill-accent">@RuntiraText.Get("Provider_Clerk", CurrentOrganization.PreferredLanguage)</span>
                <span class="option-pill option-pill-accent">@RuntiraText.Get("Provider_Stripe", CurrentOrganization.PreferredLanguage)</span>
                <span class="option-pill option-pill-accent">@RuntiraText.Get("Provider_Resend", CurrentOrganization.PreferredLanguage)</span>
            </div>
            <div class="tenant-links">
                <a class="prompt-chip prompt-link" href="/sign-in">@RuntiraText.Get("Home_SignIn", CurrentOrganization.PreferredLanguage)</a>
                <a class="prompt-chip prompt-link" href="/sign-up">@RuntiraText.Get("Home_SignUp", CurrentOrganization.PreferredLanguage)</a>
                <a class="prompt-chip prompt-link" href="/account">@RuntiraText.Get("Home_ManageAccount", CurrentOrganization.PreferredLanguage)</a>
            </div>
            @if (!string.IsNullOrWhiteSpace(CurrentOrganization.OrganizationSlug))
            {
                <a class="prompt-chip prompt-link" href="@($"/{CurrentOrganization.OrganizationSlug}/assets")">@RuntiraText.Get("Home_OpenAssets", CurrentOrganization.PreferredLanguage)</a>
                <a class="prompt-chip prompt-link" href="@($"/{CurrentOrganization.OrganizationSlug}/imports")">@RuntiraText.Get("Home_OpenImports", CurrentOrganization.PreferredLanguage)</a>
                <a class="prompt-chip prompt-link" href="@($"/{CurrentOrganization.OrganizationSlug}/leads")">@RuntiraText.Get("Home_OpenLeads", CurrentOrganization.PreferredLanguage)</a>
                <a class="prompt-chip prompt-link" href="@($"/{CurrentOrganization.OrganizationSlug}/inbox")">@RuntiraText.Get("Home_OpenInbox", CurrentOrganization.PreferredLanguage)</a>
                <a class="prompt-chip prompt-link" href="@($"/{CurrentOrganization.OrganizationSlug}/invoice-composer")">@RuntiraText.Get("Home_OpenInvoiceComposer", CurrentOrganization.PreferredLanguage)</a>
                <a class="prompt-chip prompt-link" href="@($"/{CurrentOrganization.OrganizationSlug}/billing")">@RuntiraText.Get("Home_OpenBilling", CurrentOrganization.PreferredLanguage)</a>
                <a class="prompt-chip prompt-link" href="@($"/{CurrentOrganization.OrganizationSlug}/legislation")">@RuntiraText.Get("Home_OpenLegislation", CurrentOrganization.PreferredLanguage)</a>
            }
            <div class="tenant-links">
                <span class="option-pill">@RuntiraText.Get("Home_MultiJurisdiction", CurrentOrganization.PreferredLanguage)</span>
            </div>
        </div>
    </section>

    <section class="workspace-card">
        <div class="workspace-header">
            <h2>@RuntiraText.Get("Home_WorkspaceTitle", CurrentOrganization.PreferredLanguage)</h2>
            <span class="workspace-state">@RuntiraText.Get("Common_Mvp", CurrentOrganization.PreferredLanguage)</span>
        </div>

        @if (!string.IsNullOrWhiteSpace(CurrentOrganization.OrganizationSlug))
        {
            <div class="localized-section">
                <div class="prompt-title">@RuntiraText.Get("Home_ActionHubTitle", CurrentOrganization.PreferredLanguage)</div>
                <p class="hero-copy">@RuntiraText.Get("Home_ActionHubCopy", CurrentOrganization.PreferredLanguage)</p>
                <div class="focus-strip">
                    <div class="focus-card focus-card-primary">
                        <span class="summary-label">@RuntiraText.Get("Home_Focus_Primary", CurrentOrganization.PreferredLanguage)</span>
                        <strong>@RuntiraText.Get("Home_Focus_Revenue_Title", CurrentOrganization.PreferredLanguage)</strong>
                        <p>@RuntiraText.Get("Home_Focus_Revenue_Copy", CurrentOrganization.PreferredLanguage)</p>
                    </div>
                    <div class="focus-card">
                        <span class="summary-label">@RuntiraText.Get("Home_Focus_Secondary", CurrentOrganization.PreferredLanguage)</span>
                        <strong>@RuntiraText.Get("Home_Focus_Support_Title", CurrentOrganization.PreferredLanguage)</strong>
                        <p>@RuntiraText.Get("Home_Focus_Support_Copy", CurrentOrganization.PreferredLanguage)</p>
                    </div>
                </div>
                <div class="home-actions-grid">
                    <a class="action-card action-card-primary" href="@($"/{CurrentOrganization.OrganizationSlug}/invoice-composer")">
                        <strong>@RuntiraText.Get("Home_Action_Billing_Title", CurrentOrganization.PreferredLanguage)</strong>
                        <span>@RuntiraText.Get("Home_Action_Billing_Copy", CurrentOrganization.PreferredLanguage)</span>
                    </a>
                    <a class="action-card" href="@($"/{CurrentOrganization.OrganizationSlug}/assets")">
                        <strong>@RuntiraText.Get("Home_Action_Assets_Title", CurrentOrganization.PreferredLanguage)</strong>
                        <span>@RuntiraText.Get("Home_Action_Assets_Copy", CurrentOrganization.PreferredLanguage)</span>
                    </a>
                    <a class="action-card" href="@($"/{CurrentOrganization.OrganizationSlug}/inbox")">
                        <strong>@RuntiraText.Get("Home_Action_Inbox_Title", CurrentOrganization.PreferredLanguage)</strong>
                        <span>@RuntiraText.Get("Home_Action_Inbox_Copy", CurrentOrganization.PreferredLanguage)</span>
                    </a>
                    <a class="action-card" href="@($"/{CurrentOrganization.OrganizationSlug}/imports")">
                        <strong>@RuntiraText.Get("Home_Action_Imports_Title", CurrentOrganization.PreferredLanguage)</strong>
                        <span>@RuntiraText.Get("Home_Action_Imports_Copy", CurrentOrganization.PreferredLanguage)</span>
                    </a>
                    <a class="action-card" href="@($"/{CurrentOrganization.OrganizationSlug}/exports")">
                        <strong>@RuntiraText.Get("Home_Action_Exports_Title", CurrentOrganization.PreferredLanguage)</strong>
                        <span>@RuntiraText.Get("Home_Action_Exports_Copy", CurrentOrganization.PreferredLanguage)</span>
                    </a>
                    <a class="action-card action-card-secondary" href="@($"/{CurrentOrganization.OrganizationSlug}/leads")">
                        <strong>@RuntiraText.Get("Home_Action_Leads_Title", CurrentOrganization.PreferredLanguage)</strong>
                        <span>@RuntiraText.Get("Home_Action_Leads_Copy", CurrentOrganization.PreferredLanguage)</span>
                    </a>
                </div>
            </div>
        }

        @if (_isLoading)
        {
            <PageLoadingState />
        }
        else if (_summary is not null)
        {
            <div class="stats-grid">
                <div class="stat-card">
                    <span>@RuntiraText.Get("Home_Stat_Assets", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_summary.AssetCount / @_summary.AssetLimit</strong>
                </div>
                <div class="stat-card">
                    <span>@RuntiraText.Get("Home_Stat_Conversations", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_summary.ConversationCount</strong>
                </div>
                <div class="stat-card">
                    <span>@RuntiraText.Get("Home_Stat_Templates", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_summary.WorkflowTemplateCount</strong>
                </div>
                <div class="stat-card">
                    <span>@RuntiraText.Get("Home_Stat_Archives", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@_summary.ArchiveCount</strong>
                </div>
                <div class="stat-card">
                    <span>@RuntiraText.Get("Home_Stat_Providers", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@string.Join(" · ", new[]
                    {
                        RuntiraText.Get("Provider_Clerk", CurrentOrganization.PreferredLanguage),
                        RuntiraText.Get("Provider_Stripe", CurrentOrganization.PreferredLanguage),
                        RuntiraText.Get("Provider_Resend", CurrentOrganization.PreferredLanguage)
                    })</strong>
                </div>
                <div class="stat-card">
                    <span>@RuntiraText.Get("Home_Stat_ActiveMarket", CurrentOrganization.PreferredLanguage)</span>
                    <strong>@GetMarketLabel()</strong>
                </div>
            </div>
        }
        else
        {
            <PageEmptyState Title="@RuntiraText.Get("Home_InitializedTitle", CurrentOrganization.PreferredLanguage)"
                            Message="@RuntiraText.Get("Home_InitializedBody", CurrentOrganization.PreferredLanguage)" />
        }
    </section>
</div>

@code {
    [Parameter]
    public string? TenantSlug { get; set; }

    private RuntiraWorkspaceSummaryDto? _summary;
    private bool _isLoading = true;
    private bool _hasInitialized;

    protected override async Task OnInitializedAsync()
    {
        if (_hasInitialized)
        {
            return;
        }

        _hasInitialized = true;

        if (ShouldAutoOpenOrganization())
        {
            Navigation.NavigateTo($"/{CurrentOrganization.OrganizationSlug}", replace: true);
            return;
        }

        try
        {
            _summary = await WorkspaceService.GetWorkspaceSummaryAsync();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private bool ShouldAutoOpenOrganization()
        => string.IsNullOrWhiteSpace(TenantSlug)
           && !string.IsNullOrWhiteSpace(CurrentOrganization.OrganizationSlug)
           && CurrentOrganization.HasOrganizationAccess
           && CurrentOrganization.AccessibleOrganizationCount <= 1;

    private string GetHeroTitle()
        => CurrentOrganization.CountryCode switch
        {
            "US" => RuntiraText.Get("Home_HeroTitle_US", CurrentOrganization.PreferredLanguage),
            "CA" => RuntiraText.Get("Home_HeroTitle_Canada", CurrentOrganization.PreferredLanguage),
            _ => RuntiraText.Get("Home_HeroTitle_Default", CurrentOrganization.PreferredLanguage)
        };

    private string GetHeroCopy()
        => CurrentOrganization.CountryCode switch
        {
            "US" => RuntiraText.Get("Home_HeroCopy_US", CurrentOrganization.PreferredLanguage),
            "CA" => RuntiraText.Get("Home_HeroCopy_Canada", CurrentOrganization.PreferredLanguage),
            _ => RuntiraText.Get("Home_HeroCopy_Default", CurrentOrganization.PreferredLanguage)
        };

    private string GetMarketLabel() => $"{CurrentOrganization.CountryCode}-{CurrentOrganization.Province} · {CurrentOrganization.PreferredLanguage}";

    private IReadOnlyList<string> GetLocalizedPrompts()
        => CurrentOrganization.CountryCode switch
        {
            "US" =>
            [
                RuntiraText.Get("Home_Prompt_1_US", CurrentOrganization.PreferredLanguage),
                RuntiraText.Get("Home_Prompt_2_US", CurrentOrganization.PreferredLanguage),
                RuntiraText.Get("Home_Prompt_3_US", CurrentOrganization.PreferredLanguage)
            ],
            "CA" =>
            [
                RuntiraText.Get("Home_Prompt_1_Canada", CurrentOrganization.PreferredLanguage),
                RuntiraText.Get("Home_Prompt_2_Canada", CurrentOrganization.PreferredLanguage),
                RuntiraText.Get("Home_Prompt_3_Canada", CurrentOrganization.PreferredLanguage)
            ],
            _ =>
            [
                RuntiraText.Get("Home_Prompt_1_Default", CurrentOrganization.PreferredLanguage),
                RuntiraText.Get("Home_Prompt_2_Default", CurrentOrganization.PreferredLanguage),
                RuntiraText.Get("Home_Prompt_3_Default", CurrentOrganization.PreferredLanguage)
            ]
        };
}
